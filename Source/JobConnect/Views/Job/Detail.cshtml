@using JobConnect.Models
@model JobPost
@{
    ViewData["Title"] = Model.Title;
    Layout = "_Layout";
}

<style>
    .prose ul { list-style: disc; padding-left: 1.25rem; }
    .prose ol { list-style: decimal; padding-left: 1.25rem; }
    .prose li { margin-bottom: 0.35rem; }
    .prose p { margin-bottom: 0.75rem; color: #94a3b8; }
    .prose h2, .prose h3 { color: #f1f5f9; }
    .prose strong { color: #f1f5f9; }
    .prose a { color: #60a5fa; text-decoration: underline; }
    .prose blockquote { border-left: 4px solid #3b82f6; padding-left: 1rem; font-style: italic; color: #94a3b8; margin: 1.5rem 0; }
    .prose code { background: #1e293b; color: #60a5fa; padding: 0.15rem 0.4rem; border-radius: 4px; font-size: 0.8rem; }

    .section-card {
        background: rgba(255,255,255,0.03);
        border-radius: 1rem;
        border: 1px solid #1e293b;
        padding: 1.5rem;
        backdrop-filter: blur(4px);
    }
    .section-card:hover {
        border-color: #334155;
        transition: border-color 0.2s;
    }
</style>

<div class="max-w-6xl mx-auto px-6 py-8">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        <!-- MAIN CONTENT -->
        <div class="lg:col-span-2 space-y-5">

            <!-- Job Header Card -->
            <div class="section-card">
                <div class="flex items-start gap-4 mb-5">
                    <div class="w-16 h-16 rounded-xl border border-slate-700 flex items-center justify-center bg-slate-900 shrink-0 overflow-hidden">
                        @if (!string.IsNullOrEmpty(Model.Employer?.LogoURL))
                        {
                            <img src="@Model.Employer.LogoURL" class="w-full h-full object-contain" />
                        }
                        else
                        {
                            <span class="material-symbols-outlined text-slate-500 text-3xl">business</span>
                        }
                    </div>
                    <div class="flex-1 min-w-0">
                        <div class="flex flex-wrap gap-1.5 mb-2">
                            @if (!string.IsNullOrEmpty(Model.JobType))
                            {
                                <span class="px-2.5 py-0.5 bg-blue-500/10 text-blue-400 border border-blue-500/20 rounded-full text-xs font-semibold">@Model.JobType</span>
                            }
                            @if (!string.IsNullOrEmpty(Model.ExperienceLevel))
                            {
                                <span class="px-2.5 py-0.5 bg-slate-800 text-slate-300 border border-slate-700 rounded-full text-xs font-semibold">@Model.ExperienceLevel</span>
                            }
                            @if (Model.IsFeatured)
                            {
                                <span class="px-2.5 py-0.5 bg-yellow-500/10 text-yellow-400 border border-yellow-500/20 rounded-full text-xs font-semibold">⭐ Nổi bật</span>
                            }
                        </div>
                        <h1 class="text-xl font-bold text-white leading-snug">@Model.Title</h1>
                        <a asp-controller="Company" asp-action="Detail" asp-route-id="@Model.Employer?.EmployerID"
                           class="text-blue-400 font-semibold text-sm hover:underline">
                            @Model.Employer?.CompanyName
                        </a>
                    </div>

                    <!-- Action buttons (desktop) -->
                    <div class="hidden md:flex flex-col gap-2 shrink-0">
                        @if (User.IsInRole("Candidate"))
                        {
                            if ((bool)(ViewBag.HasApplied ?? false))
                            {
                                <span class="px-6 py-3 bg-green-500/10 text-green-400 border border-green-500/20 rounded-xl text-sm font-bold text-center flex items-center gap-2">
                                    <span class="material-symbols-outlined text-sm">check_circle</span> Đã ứng tuyển
                                </span>
                            }
                            else
                            {
                                <button onclick="document.getElementById('applyModal').classList.remove('hidden')"
                                        class="px-6 py-3 bg-gradient-to-r from-blue-600 to-indigo-600 text-white rounded-xl text-sm font-bold hover:from-blue-700 hover:to-indigo-700 transition-all shadow-lg shadow-blue-500/20">
                                    Ứng tuyển ngay
                                </button>
                            }
                            <form asp-controller="Job" asp-action="ToggleSave" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="jobId" value="@Model.JobID" />
                                <button type="submit"
                                        class="w-full px-6 py-3 border border-slate-700 rounded-xl text-sm font-bold text-slate-300 hover:bg-slate-800 hover:border-slate-600 transition-colors flex items-center justify-center gap-2">
                                    <span class="material-symbols-outlined text-sm @((bool)(ViewBag.IsSaved ?? false) ? "text-blue-400" : "")">bookmark</span>
                                    @((bool)(ViewBag.IsSaved ?? false) ? "Đã lưu" : "Lưu việc làm")
                                </button>
                            </form>
                        }
                        else if (!User.Identity!.IsAuthenticated)
                        {
                            <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="/Job/Detail/@Model.JobID"
                               class="px-6 py-3 bg-gradient-to-r from-blue-600 to-indigo-600 text-white rounded-xl text-sm font-bold hover:from-blue-700 hover:to-indigo-700 text-center transition-all">
                                Ứng tuyển ngay
                            </a>
                        }
                        <a asp-controller="Report" asp-action="Create" asp-route-jobPostId="@Model.JobID"
                           class="w-full px-6 py-3 bg-red-600/20 hover:bg-red-600/30 text-red-400 border border-red-500/30 rounded-xl text-sm font-bold transition-colors flex items-center justify-center gap-2">
                            <span class="material-symbols-outlined text-sm">report</span>
                            Báo cáo
                        </a>
                    </div>
                </div>

                <!-- Meta info grid -->
                <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 p-4 bg-slate-900/60 rounded-xl border border-slate-800">
                    <div class="flex items-center gap-2 text-sm">
                        <span class="material-symbols-outlined text-blue-400 text-lg">payments</span>
                        <div>
                            <div class="text-xs text-slate-500">Mức lương</div>
                            <div class="font-bold text-blue-400">@Model.SalaryDisplay</div>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Location))
                    {
                        <div class="flex items-center gap-2 text-sm">
                            <span class="material-symbols-outlined text-slate-400 text-lg">location_on</span>
                            <div>
                                <div class="text-xs text-slate-500">Địa điểm</div>
                                <div class="font-semibold text-slate-200">@Model.Location</div>
                            </div>
                        </div>
                    }
                    <div class="flex items-center gap-2 text-sm">
                        <span class="material-symbols-outlined text-slate-400 text-lg">event</span>
                        <div>
                            <div class="text-xs text-slate-500">Hạn nộp</div>
                            <div class="font-semibold text-slate-200">@(Model.Deadline?.ToString("dd/MM/yyyy") ?? "Không giới hạn")</div>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Employer?.CompanySize))
                    {
                        <div class="flex items-center gap-2 text-sm">
                            <span class="material-symbols-outlined text-slate-400 text-lg">group</span>
                            <div>
                                <div class="text-xs text-slate-500">Quy mô</div>
                                <div class="font-semibold text-slate-200">@Model.Employer.CompanySize nhân viên</div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Mobile action buttons -->
                <div class="flex gap-2 mt-4 md:hidden">
                    @if (User.IsInRole("Candidate"))
                    {
                        if ((bool)(ViewBag.HasApplied ?? false))
                        {
                            <span class="flex-1 py-2.5 bg-green-500/10 text-green-400 border border-green-500/20 rounded-xl text-sm font-bold text-center">✓ Đã ứng tuyển</span>
                        }
                        else
                        {
                            <button onclick="document.getElementById('applyModal').classList.remove('hidden')"
                                    class="flex-1 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 text-white rounded-xl text-sm font-bold">
                                Ứng tuyển ngay
                            </button>
                        }
                        <form asp-controller="Job" asp-action="ToggleSave" method="post" class="inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="jobId" value="@Model.JobID" />
                            <button type="submit" class="px-4 py-2.5 border border-slate-700 rounded-xl text-sm text-slate-400 hover:bg-slate-800">
                                <span class="material-symbols-outlined text-sm">bookmark</span>
                            </button>
                        </form>
                    }
                    else if (!User.Identity!.IsAuthenticated)
                    {
                        <a asp-controller="Account" asp-action="Login"
                           class="flex-1 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 text-white rounded-xl text-sm font-bold text-center">
                            Ứng tuyển ngay
                        </a>
                    }
                </div>
            </div>

            <!-- Description -->
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <div class="section-card">
                    <h2 class="font-bold text-white mb-4 flex items-center gap-2">
                        <span class="w-1 h-5 bg-blue-500 rounded-full inline-block"></span>
                        Mô tả công việc
                    </h2>
                    <div class="prose text-sm text-slate-400 leading-relaxed">@Html.Raw(Model.Description)</div>
                </div>
            }

            <!-- Requirements + Benefits side by side -->
            @if (!string.IsNullOrEmpty(Model.Requirements) || !string.IsNullOrEmpty(Model.Benefits))
            {
                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                    @if (!string.IsNullOrEmpty(Model.Requirements))
                    {
                        <div class="section-card">
                            <h2 class="font-bold text-white mb-4 flex items-center gap-2">
                                <span class="w-1 h-5 bg-blue-500 rounded-full inline-block"></span>
                                Yêu cầu công việc
                            </h2>
                            <div class="prose text-sm text-slate-400 leading-relaxed">@Html.Raw(Model.Requirements)</div>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Benefits))
                    {
                        <div class="section-card">
                            <h2 class="font-bold text-white mb-4 flex items-center gap-2">
                                <span class="w-1 h-5 bg-green-500 rounded-full inline-block"></span>
                                Quyền lợi
                            </h2>
                            <div class="prose text-sm text-slate-400 leading-relaxed">@Html.Raw(Model.Benefits)</div>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- SIDEBAR -->
        <aside class="space-y-4">

            <!-- Company Info -->
            <div class="section-card">
                <h3 class="font-bold text-white mb-3">Về @Model.Employer?.CompanyName</h3>
                @if (!string.IsNullOrEmpty(Model.Employer?.Description))
                {
                    <p class="text-sm text-slate-400 leading-relaxed mb-3 line-clamp-4">@Model.Employer.Description</p>
                }
                <div class="space-y-2 text-sm text-slate-400 mb-4">
                    @if (!string.IsNullOrEmpty(Model.Employer?.Website))
                    {
                        <div class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-base text-blue-400">public</span>
                            <a href="@Model.Employer.Website" target="_blank" class="text-blue-400 hover:underline truncate">@Model.Employer.Website</a>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Employer?.Address))
                    {
                        <div class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-base text-slate-500">apartment</span>
                            <span>@Model.Employer.Address</span>
                        </div>
                    }
                </div>
                <a asp-controller="Company" asp-action="Detail" asp-route-id="@Model.Employer?.EmployerID"
                   class="block w-full text-center py-2.5 border border-blue-500/40 text-blue-400 rounded-xl text-sm font-bold hover:bg-blue-500/10 transition-all">
                    Xem trang công ty
                </a>
            </div>

            <!-- Job Stats -->
            <div class="section-card">
                <h3 class="font-bold text-white mb-3">Thông tin chung</h3>
                <dl class="space-y-3">
                    @foreach (var (icon, label, value) in new[]{
                        ("event", "Hạn nộp hồ sơ", Model.Deadline?.ToString("dd/MM/yyyy") ?? "Không giới hạn"),
                        ("work", "Hình thức", Model.JobType ?? "–"),
                        ("stairs", "Cấp bậc", Model.ExperienceLevel ?? "–"),
                        ("visibility", "Lượt xem", Model.ViewCount.ToString("N0")),
                        ("send", "Đã ứng tuyển", Model.Applications.Count.ToString())
                    })
                    {
                        <div class="flex items-center justify-between text-sm">
                            <span class="flex items-center gap-2 text-slate-400">
                                <span class="material-symbols-outlined text-base text-slate-500">@icon</span>
                                @label
                            </span>
                            <span class="font-semibold text-slate-200">@value</span>
                        </div>
                    }
                </dl>
            </div>

            <!-- Similar Jobs -->
            @if (ViewBag.SimilarJobs is List<JobPost> similar && similar.Any())
            {
                <div class="section-card">
                    <h3 class="font-bold text-white mb-3">Việc làm tương tự</h3>
                    <div class="space-y-3">
                        @foreach (var sj in similar.Take(3))
                        {
                            <a asp-controller="Job" asp-action="Detail" asp-route-id="@sj.JobID"
                               class="block hover:bg-slate-800/60 rounded-lg p-2 -mx-2 transition-colors">
                                <div class="font-semibold text-sm text-slate-200 hover:text-blue-400 transition-colors">@sj.Title</div>
                                <div class="text-xs text-slate-500 mt-0.5">@sj.Employer?.CompanyName</div>
                                <div class="flex justify-between items-center mt-1">
                                    <span class="text-xs font-bold text-blue-400">@sj.SalaryDisplay</span>
                                    <span class="text-xs text-slate-500">
                                        @((DateTime.Now - sj.CreatedAt).TotalDays < 1 ? "Hôm nay" : $"{(int)(DateTime.Now - sj.CreatedAt).TotalDays} ngày trước")
                                    </span>
                                </div>
                            </a>
                            @if (sj != similar.Take(3).Last())
                            {
                                <div class="border-t border-slate-800"></div>
                            }
                        }
                    </div>
                </div>
            }
        </aside>
    </div>
</div>

<!-- MODAL ỨNG TUYỂN -->
<div id="applyModal" class="hidden fixed inset-0 bg-black/70 backdrop-blur-sm z-50 flex items-center justify-center p-4">
    <div class="bg-slate-900 border border-slate-700 rounded-2xl p-6 w-full max-w-lg shadow-2xl">
        <div class="flex justify-between items-center mb-5">
            <div>
                <h3 class="font-bold text-lg text-white">Ứng tuyển vị trí</h3>
                <p class="text-blue-400 font-semibold">@Model.Title</p>
            </div>
            <button onclick="document.getElementById('applyModal').classList.add('hidden')"
                    class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-slate-800 text-slate-400 hover:text-white transition-colors">
                ✕
            </button>
        </div>

        <form asp-controller="Job" asp-action="Apply" method="post" class="space-y-5">
            @Html.AntiForgeryToken()
            <input type="hidden" name="jobId" value="@Model.JobID" />

            <div>
                <label class="block text-sm font-semibold mb-1.5 text-slate-300">Chọn CV <span class="text-red-400">*</span></label>
                <select name="cvId" class="w-full px-4 py-3 bg-slate-800 border border-slate-700 text-slate-200 rounded-xl focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none" required>
                    <option value="">-- Chọn CV --</option>
                    @if (ViewBag.CVs != null)
                    {
                        foreach (var cv in ViewBag.CVs)
                        {
                            <option value="@cv.CvID">@cv.FileName @(cv.IsDefault ? "(Mặc định)" : "")</option>
                        }
                    }
                </select>
            </div>

            <div>
                <label class="block text-sm font-semibold mb-1.5 text-slate-300">Thư xin việc</label>
                <textarea name="coverLetter" rows="6"
                          class="w-full px-4 py-3 bg-slate-800 border border-slate-700 text-slate-200 rounded-xl focus:border-blue-500 focus:ring-1 focus:ring-blue-500 resize-none outline-none placeholder-slate-500"
                          placeholder="Giới thiệu ngắn gọn về bản thân, kinh nghiệm và lý do bạn phù hợp..."></textarea>
            </div>

            <div class="flex gap-3 pt-2">
                <button type="button" onclick="document.getElementById('applyModal').classList.add('hidden')"
                        class="flex-1 py-3 border border-slate-700 text-slate-300 rounded-xl font-semibold hover:bg-slate-800 transition-colors">
                    Hủy
                </button>
                <button type="submit"
                        class="flex-1 py-3 bg-gradient-to-r from-blue-600 to-indigo-600 text-white font-bold rounded-xl hover:from-blue-700 hover:to-indigo-700 transition-all">
                    Gửi đơn ứng tuyển
                </button>
            </div>
        </form>
    </div>
</div>
