@using JobConnect.Models
@model List<JobPost>
@{
    ViewData["Title"] = "Tìm việc làm";
    Layout = "_Layout";
}

<style>
    .job-card {
        transition: all 0.22s cubic-bezier(0.4,0,0.2,1);
    }

        .job-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(0,61,155,0.10);
        }

    .filter-chip {
        transition: all 0.15s;
        cursor: pointer;
    }

        .filter-chip:hover {
            background: #dae2ff;
            color: #003d9b;
        }

        .filter-chip.active {
            background: #003d9b;
            color: #fff;
        }
</style>

<div class="max-w-6xl mx-auto px-6 py-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">

        <!-- SIDEBAR FILTERS -->
        <aside class="lg:col-span-3">
            <form method="get" id="filterForm">
                <div class="bg-white rounded-2xl border border-outline-variant p-5 shadow-sm">
                    <div class="flex items-center justify-between mb-5">
                        <h2 class="font-bold text-on-surface text-base">Bộ lọc</h2>
                        <a asp-action="Index" class="text-primary text-xs font-bold hover:underline">Xoá tất cả</a>
                    </div>

                    <!-- Location -->
                    <div class="mb-5">
                        <label class="block text-xs font-bold uppercase text-secondary tracking-wider mb-2">Địa điểm</label>
                        <select name="Location"
                                class="w-full px-3 py-2.5 border border-outline-variant rounded-lg bg-surface text-sm focus:border-primary focus:ring-1 focus:ring-primary outline-none">
                            <option value="">Tất cả địa điểm</option>
                            @foreach (var loc in (ViewBag.Locations as List<Category> ?? new()))
                            {
                                <option value="@loc.Name" selected="@(ViewBag.Filter?.Location == loc.Name ? "selected" : null)">@loc.Name</option>
                            }
                        </select>
                    </div>

                    <!-- Salary -->
                    <div class="mb-5">
                        <label class="block text-xs font-bold uppercase text-secondary tracking-wider mb-2">Mức lương</label>
                        <div class="space-y-2">
                            @foreach (var (label, val) in new[] { ("Dưới 10 triệu", "<10"), ("10 - 20 triệu", "10-20"), ("20 - 50 triệu", "20-50"), ("Trên 50 triệu", ">50") })
                            {
                                <label class="flex items-center gap-2.5 cursor-pointer group">
                                    <input type="checkbox" name="Salary" value="@val"
                                           class="w-4 h-4 rounded border-outline-variant text-primary focus:ring-primary" />
                                    <span class="text-sm text-on-surface group-hover:text-primary transition-colors">@label</span>
                                </label>
                            }
                        </div>
                    </div>

                    <!-- Experience -->
                    <div class="mb-5">
                        <label class="block text-xs font-bold uppercase text-secondary tracking-wider mb-2">Kinh nghiệm</label>
                        <div class="space-y-2">
                            @foreach (var (label, val) in new[] { ("Chưa có kinh nghiệm", "none"), ("Dưới 1 năm", "<1"), ("1 - 3 năm", "1-3"), ("Trên 3 năm", ">3") })
                            {
                                <label class="flex items-center gap-2.5 cursor-pointer group">
                                    <input type="radio" name="ExperienceLevel" value="@val"
                                           checked="@(ViewBag.Filter?.ExperienceLevel == val ? "checked" : null)"
                                           class="w-4 h-4 border-outline-variant text-primary focus:ring-primary" />
                                    <span class="text-sm text-on-surface group-hover:text-primary transition-colors">@label</span>
                                </label>
                            }
                        </div>
                    </div>

                    <!-- Job Type -->
                    <div>
                        <label class="block text-xs font-bold uppercase text-secondary tracking-wider mb-2">Loại hình</label>
                        <div class="flex flex-wrap gap-2">
                            @foreach (var (label, val) in new[] { ("Toàn thời gian", "FullTime"), ("Bán thời gian", "PartTime"), ("Remote", "Remote"), ("Thực tập", "Intern") })
                            {
                                bool active = ViewBag.Filter?.JobType == val;
                                <button type="submit" name="JobType" value="@val"
                                        class="px-3 py-1 rounded-full text-xs font-bold border transition-all
                                    @(active ? "bg-primary text-white border-primary" : "bg-surface-container text-primary border-transparent hover:border-primary")">
                                    @label
                                </button>
                            }
                        </div>
                    </div>

                    <!-- Industry -->
                    @if ((ViewBag.Industries as List<Category> ?? new()).Count > 0)
                    {
                        <div class="mt-5 pt-5 border-t border-outline-variant">
                            <label class="block text-xs font-bold uppercase text-secondary tracking-wider mb-2">Ngành nghề</label>
                            <div class="space-y-2 max-h-48 overflow-y-auto pr-1">
                                @foreach (var cat in (ViewBag.Industries as List<Category> ?? new()))
                                {
                                    <label class="flex items-center gap-2.5 cursor-pointer group">
                                        <input type="checkbox" name="Category" value="@cat.CategoryID"
                                               class="w-4 h-4 rounded border-outline-variant text-primary focus:ring-primary" />
                                        <span class="text-sm text-on-surface group-hover:text-primary transition-colors">@cat.Name</span>
                                    </label>
                                }
                            </div>
                        </div>
                    }
                </div>
            </form>
        </aside>

        <!-- MAIN CONTENT -->
        <section class="lg:col-span-9">
            <!-- Search + Sort bar -->
            <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3 mb-5">
                <form method="get" class="flex-1 flex gap-2">
                    <div class="relative flex-1">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-secondary text-xl">search</span>
                        <input name="Keyword" value="@ViewBag.Filter?.Keyword" type="text"
                               placeholder="Tìm kiếm chức danh, công ty..."
                               class="w-full pl-10 pr-4 py-2.5 border border-outline-variant rounded-lg bg-white text-sm focus:border-primary outline-none" />
                    </div>
                    <button type="submit" class="bg-primary text-white px-4 py-2.5 rounded-lg text-sm font-bold hover:opacity-90 transition-opacity whitespace-nowrap">
                        Tìm
                    </button>
                </form>
                <div class="flex items-center gap-2 bg-white border border-outline-variant rounded-lg px-3 py-2">
                    <span class="text-xs text-secondary whitespace-nowrap">Sắp xếp:</span>
                    <select name="SortBy" class="border-none bg-transparent text-primary text-sm font-bold focus:ring-0 outline-none cursor-pointer">
                        <option>Mới nhất</option>
                        <option>Lương cao nhất</option>
                        <option>Phổ biến nhất</option>
                    </select>
                </div>
            </div>

            <!-- Result count -->
            <p class="text-sm text-secondary mb-4">
                Tìm thấy <strong class="text-on-surface">@ViewBag.TotalCount</strong> việc làm phù hợp
                @if (!string.IsNullOrEmpty(ViewBag.Filter?.Keyword as string))
                {
                    <span> cho "<strong class="text-primary">@ViewBag.Filter.Keyword</strong>"</span>
                }
            </p>

            <!-- Job List -->
            @if (!Model.Any())
            {
                <div class="bg-white rounded-2xl border border-outline-variant p-16 text-center">
                    <span class="material-symbols-outlined text-5xl text-secondary block mb-3">search_off</span>
                    <p class="text-secondary font-medium">Không tìm thấy việc làm phù hợp.</p>
                    <a asp-action="Index" class="text-primary text-sm mt-3 inline-block hover:underline">← Xóa bộ lọc</a>
                </div>
            }

            <div class="space-y-3">
                @foreach (var job in Model)
                {
                    <div class="bg-white rounded-2xl border border-outline-variant p-5 job-card flex flex-col md:flex-row gap-4">
                        <!-- Logo -->
                        <div class="w-12 h-12 rounded-xl bg-surface-container border border-outline-variant flex items-center justify-center shrink-0 overflow-hidden">
                            @if (!string.IsNullOrEmpty(job.Employer?.LogoURL))
                            {
                                <img src="@job.Employer.LogoURL" class="w-full h-full object-contain" />
                            }
                            else
                            {
                                <span class="material-symbols-outlined text-secondary">business</span>
                            }
                        </div>

                        <!-- Info -->
                        <div class="flex-1 min-w-0">
                            <div class="flex justify-between items-start gap-2">
                                <div>
                                    <a asp-controller="Job" asp-action="Detail" asp-route-id="@job.JobID"
                                       class="font-bold text-on-surface hover:text-primary transition-colors text-base block leading-snug">
                                        @job.Title
                                    </a>
                                    <a asp-controller="Company" asp-action="Detail" asp-route-id="@job.Employer?.EmployerID"
                                       class="text-primary text-sm font-semibold hover:underline">
                                        @job.Employer?.CompanyName
                                    </a>
                                </div>
                                <a asp-controller="Job" asp-action="Detail" asp-route-id="@job.JobID"
                                   class="text-secondary hover:text-error transition-colors shrink-0">
                                    <span class="material-symbols-outlined">favorite</span>
                                </a>
                            </div>

                            <div class="flex flex-wrap gap-4 mt-2.5 text-sm text-secondary">
                                @if (!string.IsNullOrEmpty(job.Location))
                                {
                                    <span class="flex items-center gap-1">
                                        <span class="material-symbols-outlined text-base">location_on</span>
                                        @job.Location
                                    </span>
                                }
                                <span class="flex items-center gap-1">
                                    <span class="material-symbols-outlined text-base">payments</span>
                                    @job.SalaryDisplay
                                </span>
                                <span class="flex items-center gap-1">
                                    <span class="material-symbols-outlined text-base">schedule</span>
                                    @((DateTime.Now - job.CreatedAt).TotalHours < 1 ? "Vừa xong" :
                                      (DateTime.Now - job.CreatedAt).TotalHours < 24 ? $"{(int)(DateTime.Now - job.CreatedAt).TotalHours} giờ trước" :
                                      $"{(int)(DateTime.Now - job.CreatedAt).TotalDays} ngày trước")
                                </span>
                            </div>

                            <div class="flex flex-wrap gap-2 mt-3">
                                <span class="px-2.5 py-1 bg-surface-container-high text-on-surface-variant rounded text-xs font-semibold">@job.JobType</span>
                                @if (!string.IsNullOrEmpty(job.ExperienceLevel))
                                {
                                    <span class="px-2.5 py-1 bg-surface-container-high text-on-surface-variant rounded text-xs font-semibold">@job.ExperienceLevel</span>
                                }
                                @if (job.Deadline.HasValue && job.Deadline.Value < DateTime.Now.AddDays(7))
                                {
                                    <span class="px-2.5 py-1 bg-error-container text-on-error-container rounded text-xs font-semibold">
                                        Hết hạn: @job.Deadline.Value.ToString("dd/MM/yyyy")
                                    </span>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- PAGINATION -->
            @if ((int)(ViewBag.TotalPages ?? 1) > 1)
            {
                int currentPage = (int)(ViewBag.Filter?.Page ?? 1);
                int totalPages = (int)ViewBag.TotalPages;
                <div class="flex justify-center items-center gap-1.5 mt-8">
                    @if (currentPage > 1)
                    {
                        <a asp-action="Index" asp-route-Page="@(currentPage - 1)" asp-route-Keyword="@ViewBag.Filter?.Keyword"
                           class="w-10 h-10 flex items-center justify-center rounded-lg border border-outline-variant hover:bg-surface-container transition-colors text-secondary">
                            <span class="material-symbols-outlined">chevron_left</span>
                        </a>
                    }

                    @for (int i = 1; i <= totalPages; i++)
                    {
                        if (i == 1 || i == totalPages || (i >= currentPage - 1 && i <= currentPage + 1))
                        {
                            <a asp-action="Index" asp-route-Page="@i" asp-route-Keyword="@ViewBag.Filter?.Keyword"
                               class="w-10 h-10 flex items-center justify-center rounded-lg text-sm font-bold transition-colors
                                @(i == currentPage ? "bg-primary text-white" : "hover:bg-surface-container text-secondary border border-outline-variant")">
                                @i
                            </a>
                        }
                        else if (i == currentPage - 2 || i == currentPage + 2)
                        {
                            <span class="w-10 h-10 flex items-center justify-center text-secondary">…</span>
                        }
                    }

                    @if (currentPage < totalPages)
                    {
                        <a asp-action="Index" asp-route-Page="@(currentPage + 1)" asp-route-Keyword="@ViewBag.Filter?.Keyword"
                           class="w-10 h-10 flex items-center justify-center rounded-lg border border-outline-variant hover:bg-surface-container transition-colors text-secondary">
                            <span class="material-symbols-outlined">chevron_right</span>
                        </a>
                    }
                </div>
            }
        </section>
    </div>
</div>
