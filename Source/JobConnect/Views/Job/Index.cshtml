@using JobConnect.Models
@model List<JobPost>
@{
    ViewData["Title"] = "Tìm việc làm";
    Layout = "_Layout";
}

<!-- Google Fonts: Đảm bảo đồng bộ font chữ cao cấp -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<style>
    /* Áp dụng font chữ đồng bộ hệ thống hiện đại */
    #searchPageContainer {
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    /* Đổ bóng Ambient mềm mại */
    .modern-shadow-sm {
        box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.05), 0 1px 2px -1px rgba(0, 0, 0, 0.03);
    }

    .modern-shadow {
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.02), 0 2px 4px -1px rgba(0, 0, 0, 0.01);
    }

    /* Custom thiết kế trượt mượt cho Card */
    .job-card-premium {
        border: 1px solid #e2e8f0;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    }

        .job-card-premium:hover {
            transform: translateY(-3px);
            border-color: #3b82f6;
            box-shadow: 0 12px 25px -8px rgba(59, 130, 246, 0.12);
        }

    /* Ẩn thanh cuộn mặc định của trình duyệt nhưng vẫn giữ chức năng cuộn */
    .custom-scrollbar::-webkit-scrollbar {
        width: 5px;
    }

    .custom-scrollbar::-webkit-scrollbar-track {
        background: #f1f5f9;
        border-radius: 10px;
    }

    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: #cbd5e1;
        border-radius: 10px;
    }

        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }

    /* Loại bỏ giao diện select mặc định */
    .clean-select {
        -webkit-appearance: none;
        -moz-appearance: none;
        appearance: none;
    }
</style>

<div id="searchPageContainer" class="bg-slate-50/50 min-h-screen py-10">
    <div class="max-w-6xl mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">

            <!-- SIDEBAR FILTERS -->
            <aside class="lg:col-span-3">
                <form method="get" id="filterForm">
                    <div class="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm modern-shadow">
                        <div class="flex items-center justify-between mb-6 pb-4 border-b border-slate-100">
                            <div class="flex items-center gap-2">
                                <span class="material-symbols-outlined text-slate-700 text-lg">tune</span>
                                <h2 class="font-bold text-slate-800 text-base tracking-tight">Bộ lọc tìm kiếm</h2>
                            </div>
                            <a asp-action="Index" class="text-blue-600 text-xs font-bold hover:text-blue-700 hover:underline transition-colors">Xoá tất cả</a>
                        </div>

                        <!-- Location -->
                        <div class="mb-6">
                            <label class="block text-[11px] font-bold uppercase text-slate-400 tracking-wider mb-2.5">Địa điểm</label>
                            <div class="relative flex items-center group">
                                <span class="material-symbols-outlined text-slate-400 text-lg absolute left-3 pointer-events-none group-focus-within:text-blue-500 transition-colors">location_on</span>
                                <select name="Location"
                                        class="clean-select w-full pl-9 pr-8 py-2.5 border border-slate-200 rounded-xl bg-white text-sm font-semibold text-slate-700 focus:border-blue-500 focus:ring-2 focus:ring-blue-500/10 outline-none cursor-pointer transition-all">
                                    <option value="">Tất cả địa điểm</option>
                                    @foreach (var loc in (ViewBag.Locations as List<Category> ?? new()))
                                    {
                                        <option value="@loc.Name" selected="@(ViewBag.Filter?.Location == loc.Name ? "selected" : null)">@loc.Name</option>
                                    }
                                </select>
                                <span class="material-symbols-outlined text-slate-400 text-lg absolute right-3 pointer-events-none">keyboard_arrow_down</span>
                            </div>
                        </div>

                        <!-- Salary -->
                        <div class="mb-6">
                            <label class="block text-[11px] font-bold uppercase text-slate-400 tracking-wider mb-2.5">Mức lương</label>
                            <div class="space-y-2.5">
                                @foreach (var (label, val) in new[] { ("Dưới 10 triệu", "<10"), ("10 - 20 triệu", "10-20"), ("20 - 50 triệu", "20-50"), ("Trên 50 triệu", ">50") })
                                {
                                    <label class="flex items-center gap-3 cursor-pointer group select-none">
                                        <input type="checkbox" name="Salary" value="@val"
                                               class="w-4 h-4 rounded border-slate-300 text-blue-600 focus:ring-blue-500/20 focus:ring-offset-0 cursor-pointer transition-colors" />
                                        <span class="text-sm text-slate-600 font-medium group-hover:text-slate-900 transition-colors">@label</span>
                                    </label>
                                }
                            </div>
                        </div>

                        <!-- Experience -->
                        <div class="mb-6">
                            <label class="block text-[11px] font-bold uppercase text-slate-400 tracking-wider mb-2.5">Kinh nghiệm</label>
                            <div class="space-y-2.5">
                                @foreach (var (label, val) in new[] { ("Chưa có kinh nghiệm", "none"), ("Dưới 1 năm", "<1"), ("1 - 3 năm", "1-3"), ("Trên 3 năm", ">3") })
                                {
                                    <label class="flex items-center gap-3 cursor-pointer group select-none">
                                        <input type="radio" name="ExperienceLevel" value="@val"
                                               checked="@(ViewBag.Filter?.ExperienceLevel == val ? "checked" : null)"
                                               class="w-4 h-4 border-slate-300 text-blue-600 focus:ring-blue-500/20 focus:ring-offset-0 cursor-pointer transition-colors" />
                                        <span class="text-sm text-slate-600 font-medium group-hover:text-slate-900 transition-colors">@label</span>
                                    </label>
                                }
                            </div>
                        </div>

                        <!-- Job Type -->
                        <div class="mb-2">
                            <label class="block text-[11px] font-bold uppercase text-slate-400 tracking-wider mb-2.5">Loại hình làm việc</label>
                            <div class="flex flex-wrap gap-2">
                                @foreach (var (label, val) in new[] { ("Toàn thời gian", "FullTime"), ("Bán thời gian", "PartTime"), ("Remote", "Remote"), ("Thực tập", "Intern") })
                                {
                                    bool active = ViewBag.Filter?.JobType == val;
                                    <button type="submit" name="JobType" value="@val"
                                            class="px-3.5 py-1.5 rounded-xl text-xs font-bold border transition-all active:scale-95
                                        @(active ? "bg-blue-600 text-white border-blue-600 shadow-sm shadow-blue-500/10" : "bg-slate-50 text-slate-600 border-slate-200/60 hover:bg-slate-100 hover:text-slate-900")">
                                        @label
                                    </button>
                                }
                            </div>
                        </div>

                        <!-- Industry -->
                        @if ((ViewBag.Industries as List<Category> ?? new()).Count > 0)
                        {
                            <div class="mt-6 pt-5 border-t border-slate-100">
                                <label class="block text-[11px] font-bold uppercase text-slate-400 tracking-wider mb-2.5">Ngành nghề</label>
                                <div class="space-y-2.5 max-h-48 overflow-y-auto pr-1 custom-scrollbar">
                                    @foreach (var cat in (ViewBag.Industries as List<Category> ?? new()))
                                    {
                                        <label class="flex items-center gap-3 cursor-pointer group select-none">
                                            <input type="checkbox" name="Category" value="@cat.CategoryID"
                                                   class="w-4 h-4 rounded border-slate-300 text-blue-600 focus:ring-blue-500/20 focus:ring-offset-0 cursor-pointer transition-colors" />
                                            <span class="text-sm text-slate-600 font-medium group-hover:text-slate-900 transition-colors">@cat.Name</span>
                                        </label>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </form>
            </aside>

            <!-- MAIN CONTENT -->
            <section class="lg:col-span-9">
                <!-- Search + Sort bar -->
                <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3 mb-6">
                    <form method="get" class="flex-1 flex gap-2.5">
                        <div class="relative flex-1 group">
                            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-xl group-focus-within:text-blue-500 transition-colors">search</span>
                            <input name="Keyword" value="@ViewBag.Filter?.Keyword" type="text"
                                   placeholder="Tìm kiếm chức danh, vị trí, công ty..."
                                   class="w-full pl-10 pr-4 py-3 border border-slate-200 rounded-xl bg-white text-sm font-medium text-slate-800 placeholder-slate-400 focus:border-blue-500 focus:ring-2 focus:ring-blue-500/10 outline-none shadow-sm transition-all" />
                        </div>
                        <button type="submit" class="bg-blue-600 text-white px-6 py-3 rounded-xl text-sm font-bold hover:bg-blue-700 shadow-md shadow-blue-500/5 transition-all whitespace-nowrap active:scale-[0.97]">
                            Tìm kiếm
                        </button>
                    </form>

                    <div class="flex items-center gap-2 bg-white border border-slate-200 rounded-xl px-3.5 py-2.5 shadow-sm relative group">
                        <span class="text-xs text-slate-400 font-bold uppercase tracking-wider whitespace-nowrap">Sắp xếp:</span>
                        <div class="relative flex items-center">
                            <select name="SortBy" class="clean-select pr-5 bg-transparent border-none text-slate-700 text-sm font-bold focus:ring-0 outline-none cursor-pointer">
                                <option>Mới nhất</option>
                                <option>Lương cao nhất</option>
                                <option>Phổ biến nhất</option>
                            </select>
                            <span class="material-symbols-outlined text-slate-500 text-base absolute right-0 pointer-events-none">keyboard_arrow_down</span>
                        </div>
                    </div>
                </div>

                <!-- Result count -->
                <p class="text-sm text-slate-500 mb-5 font-medium">
                    Tìm thấy <span class="text-slate-900 font-bold">@ViewBag.TotalCount</span> việc làm phù hợp
                    @if (!string.IsNullOrEmpty(ViewBag.Filter?.Keyword as string))
                    {
                        <span>cho "<span class="text-blue-600 font-bold">@ViewBag.Filter.Keyword</span>"</span>
                    }
                </p>

                <!-- Job List -->
                @if (!Model.Any())
                {
                    <div class="bg-white rounded-2xl border border-slate-200 p-16 text-center shadow-sm modern-shadow">
                        <div class="w-16 h-16 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-4 border border-slate-100">
                            <span class="material-symbols-outlined text-3xl text-slate-400">search_off</span>
                        </div>
                        <p class="text-slate-600 font-semibold text-base">Không tìm thấy kết quả phù hợp</p>
                        <p class="text-slate-400 text-xs mt-1 max-w-xs mx-auto">Vui lòng thử thay đổi từ khóa hoặc xóa bớt các bộ lọc hiện tại.</p>
                        <a asp-action="Index" class="bg-slate-100 text-slate-700 px-4 py-2 rounded-xl text-xs font-bold mt-5 inline-block border border-slate-200/60 hover:bg-blue-600 hover:text-white hover:border-transparent transition-all">
                            ← Xóa bộ lọc
                        </a>
                    </div>
                }

                <div class="space-y-4">
                    @foreach (var job in Model)
                    {
                        <div class="bg-white rounded-2xl p-5 job-card-premium flex flex-col sm:flex-row gap-5 items-start sm:items-center">
                            <!-- Logo Công ty -->
                            <div class="w-14 h-14 rounded-xl bg-slate-50 border border-slate-100 flex items-center justify-center shrink-0 overflow-hidden p-2.5">
                                @if (!string.IsNullOrEmpty(job.Employer?.LogoURL))
                                {
                                    <img src="@job.Employer.LogoURL" alt="company logo" class="w-full h-full object-contain" />
                                }
                                else
                                {
                                    <span class="material-symbols-outlined text-slate-400 text-2xl">business</span>
                                }
                            </div>

                            <!-- Thông tin chính -->
                            <div class="flex-1 min-w-0">
                                <div class="flex justify-between items-start gap-3">
                                    <div>
                                        <a asp-controller="Job" asp-action="Detail" asp-route-id="@job.JobID"
                                           class="font-bold text-slate-800 hover:text-blue-600 transition-colors text-base block leading-snug line-clamp-1">
                                            @job.Title
                                        </a>
                                        <a asp-controller="Company" asp-action="Detail" asp-route-id="@job.Employer?.EmployerID"
                                           class="text-blue-600 text-xs font-bold hover:text-blue-700 hover:underline mt-0.5 inline-block">
                                            @job.Employer?.CompanyName
                                        </a>
                                    </div>
                                    <a asp-controller="Job" asp-action="Detail" asp-route-id="@job.JobID"
                                       class="text-slate-300 hover:text-rose-500 transition-colors shrink-0 p-1 bg-slate-50 rounded-lg hover:bg-rose-50 border border-transparent hover:border-rose-100">
                                        <span class="material-symbols-outlined text-xl block">favorite</span>
                                    </a>
                                </div>

                                <!-- Thuộc tính Meta ẩn dạng text tinh gọn -->
                                <div class="flex flex-wrap gap-x-4 gap-y-1.5 mt-3 text-xs font-medium text-slate-400">
                                    @if (!string.IsNullOrEmpty(job.Location))
                                    {
                                        <span class="flex items-center gap-1.5 text-slate-500">
                                            <span class="material-symbols-outlined text-slate-400 text-base">location_on</span>
                                            @job.Location
                                        </span>
                                    }
                                    <span class="flex items-center gap-1.5 text-emerald-600 font-bold">
                                        <span class="material-symbols-outlined text-emerald-500 text-base">payments</span>
                                        @job.SalaryDisplay
                                    </span>
                                    <span class="flex items-center gap-1.5">
                                        <span class="material-symbols-outlined text-slate-400 text-base">schedule</span>
                                        @{
                                            var timeSpan = DateTime.Now - job.CreatedAt;
                                            if (timeSpan.TotalHours < 1)
                                            {
                                                <span>Vừa xong</span>
                                            }
                                            else if (timeSpan.TotalHours < 24)
                                            {

                                                <span>@((int)timeSpan.TotalHours) giờ trước</span>
                                            }
                                            else
                                            {

                                                <span>@((int)timeSpan.TotalDays) ngày trước</span>
                                            }
                                        }
                                    </span>
                                </div>

                                <!-- Các Badge Tag phân loại công việc -->
                                <div class="flex flex-wrap gap-2 mt-3.5">
                                    <span class="px-2.5 py-1 bg-slate-50 text-slate-600 rounded-lg text-xs font-semibold border border-slate-100">@job.JobType</span>
                                    @if (!string.IsNullOrEmpty(job.ExperienceLevel))
                                    {
                                        <span class="px-2.5 py-1 bg-slate-50 text-slate-600 rounded-lg text-xs font-semibold border border-slate-100">@job.ExperienceLevel</span>
                                    }
                                    @if (job.Deadline.HasValue && job.Deadline.Value < DateTime.Now.AddDays(7))
                                    {
                                        <span class="px-2.5 py-1 bg-rose-50 text-rose-600 rounded-lg text-xs font-bold border border-rose-100 flex items-center gap-1 animate-pulse">
                                            <span class="w-1.5 h-1.5 rounded-full bg-rose-500"></span>
                                            Gấp: @job.Deadline.Value.ToString("dd/MM/yyyy")
                                        </span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- PAGINATION -->
                @if ((int)(ViewBag.TotalPages ?? 1) > 1)
                {
                    int currentPage = (int)(ViewBag.Filter?.Page ?? 1);
                    int totalPages = (int)ViewBag.TotalPages;

                    <div class="flex justify-center items-center gap-2 mt-10">
                        @if (currentPage > 1)
                        {
                            <a asp-action="Index" asp-route-Page="@(currentPage - 1)" asp-route-Keyword="@ViewBag.Filter?.Keyword"
                               class="w-10 h-10 flex items-center justify-center rounded-xl border border-slate-200 bg-white hover:bg-slate-50 transition-colors text-slate-600 shadow-sm active:scale-95">
                                <span class="material-symbols-outlined text-lg">chevron_left</span>
                            </a>
                        }

                        @for (int i = 1; i <= totalPages; i++)
                        {
                            if (i == 1 || i == totalPages || (i >= currentPage - 1 && i <= currentPage + 1))
                            {
                                <a asp-action="Index" asp-route-Page="@i" asp-route-Keyword="@ViewBag.Filter?.Keyword"
                                   class="w-10 h-10 flex items-center justify-center rounded-xl text-sm font-bold transition-all shadow-sm active:scale-95
                                    @(i == currentPage ? "bg-blue-600 text-white shadow-blue-500/10" : "bg-white hover:bg-slate-50 text-slate-600 border border-slate-200")">
                                    @i
                                </a>
                            }
                            else if (i == currentPage - 2 || i == currentPage + 2)
                            {
                                <span class="w-8 h-10 flex items-center justify-center text-slate-400 font-medium select-none">…</span>
                            }
                        }

                        @if (currentPage < totalPages)
                        {
                            <a asp-action="Index" asp-route-Page="@(currentPage + 1)" asp-route-Keyword="@ViewBag.Filter?.Keyword"
                               class="w-10 h-10 flex items-center justify-center rounded-xl border border-slate-200 bg-white hover:bg-slate-50 transition-colors text-slate-600 shadow-sm active:scale-95">
                                <span class="material-symbols-outlined text-lg">chevron_right</span>
                            </a>
                        }
                    </div>
                }
            </section>
        </div>
    </div>
</div>