@using JobConnect.Models
@model List<JobPost>
@{
    var f = ViewBag.Filter as JobConnect.ViewModels.JobSearchViewModel;
}

<div id="resultsContainer">
    <!-- Result count -->
    <p class="text-sm text-slate-600 mb-4">
        Tìm thấy <strong class="text-slate-900">@ViewBag.TotalCount</strong> việc làm phù hợp
        @if (!string.IsNullOrEmpty(f?.Keyword))
        {
            <span> cho "<strong class="text-blue-600">@f.Keyword</strong>"</span>
        }
    </p>

    <!-- Job List -->
    @if (!Model.Any())
    {
        <div class="bg-white rounded-2xl border border-slate-200 p-16 text-center">
            <span class="material-symbols-outlined text-5xl text-slate-400 block mb-3">search_off</span>
            <p class="text-slate-600 font-medium">Không tìm thấy việc làm phù hợp.</p>
            <a asp-action="Index" class="text-blue-600 text-sm mt-3 inline-block hover:underline">← Xóa bộ lọc</a>
        </div>
    }

    <div class="space-y-3">
        @foreach (var job in Model)
        {
            <div class="bg-white rounded-2xl border border-slate-200 p-5 job-card flex flex-col md:flex-row gap-4">
                <!-- Logo -->
                <div class="w-12 h-12 rounded-xl bg-slate-100 border border-slate-200 flex items-center justify-center shrink-0 overflow-hidden">
                    @if (!string.IsNullOrEmpty(job.Employer?.LogoURL))
                    {
                        <img src="@job.Employer.LogoURL" class="w-full h-full object-contain" />
                    }
                    else
                    {
                        <span class="material-symbols-outlined text-slate-600">business</span>
                    }
                </div>

                <!-- Info -->
                <div class="flex-1 min-w-0">
                    <div class="flex justify-between items-start gap-2">
                        <div>
                            <a asp-controller="Job" asp-action="Detail" asp-route-id="@job.JobId"
                               class="font-bold text-slate-900 hover:text-blue-600 transition-colors text-base block leading-snug">
                                @job.Title
                            </a>
                            <a asp-controller="Company" asp-action="Detail" asp-route-id="@job.Employer?.EmployerId"
                               class="text-blue-600 text-sm font-semibold hover:underline">
                                @job.Employer?.CompanyName
                            </a>
                        </div>
                        <button type="button" class="text-slate-300 hover:text-rose-600 transition-colors shrink-0">
                            <span class="material-symbols-outlined">favorite_border</span>
                        </button>
                    </div>

                    <div class="flex flex-wrap gap-4 mt-2.5 text-sm text-slate-600">
                        @if (!string.IsNullOrEmpty(job.Location))
                        {
                            <span class="flex items-center gap-1">
                                <span class="material-symbols-outlined text-base">location_on</span>
                                @job.Location
                            </span>
                        }
                        <span class="flex items-center gap-1">
                            <span class="material-symbols-outlined text-base">payments</span>
                            @job.FormatSalary()
                        </span>
                        <span class="flex items-center gap-1">
                            <span class="material-symbols-outlined text-base">schedule</span>
                            @((DateTime.Now - job.CreatedAt).TotalHours < 1 ? "Vừa đăng" :
                              (DateTime.Now - job.CreatedAt).TotalHours < 24 ? $"{(int)(DateTime.Now - job.CreatedAt).TotalHours} giờ trước" :
                              $"{(int)(DateTime.Now - job.CreatedAt).TotalDays} ngày trước")
                        </span>
                    </div>

                    <div class="flex flex-wrap gap-2 mt-3">
                        <span class="px-2.5 py-1 bg-slate-100 text-slate-600 rounded text-xs font-semibold border border-slate-200">@job.JobType</span>
                        @if (!string.IsNullOrEmpty(job.ExperienceLevel))
                        {
                            <span class="px-2.5 py-1 bg-slate-100 text-slate-600 rounded text-xs font-semibold border border-slate-200">@job.ExperienceLevel</span>
                        }
                        @if (job.Deadline.HasValue && job.Deadline.Value < DateTime.Now.AddDays(7))
                        {
                            <span class="px-2.5 py-1 bg-rose-50 text-rose-600 rounded text-xs font-semibold border border-rose-200">
                                ⏰ Hết hạn: @job.Deadline.Value.ToString("dd/MM/yyyy")
                            </span>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- PAGINATION -->
    @{
        int currentPage = (int)(f?.Page ?? 1);
        int totalPages = (int)(ViewBag.TotalPages ?? 1);
    }
    @if (totalPages > 1)
    {
        <div class="flex justify-center items-center gap-1.5 mt-8">
            @if (currentPage > 1)
            {
                <a href="@Context.Request.Path@Html.Raw(BuildPageQuery(Context.Request.Query, currentPage - 1))"
                   class="jc-page-link w-10 h-10 flex items-center justify-center rounded-lg border border-slate-200 hover:bg-slate-100 transition-colors text-slate-600">
                    <span class="material-symbols-outlined">chevron_left</span>
                </a>
            }

            @for (int i = 1; i <= totalPages; i++)
            {
                if (i == 1 || i == totalPages || (i >= currentPage - 1 && i <= currentPage + 1))
                {
                    <a href="@Context.Request.Path@Html.Raw(BuildPageQuery(Context.Request.Query, i))"
                       class="jc-page-link w-10 h-10 flex items-center justify-center rounded-lg text-sm font-bold transition-colors
                        @(i == currentPage ? "bg-blue-600 text-white" : "hover:bg-slate-100 text-slate-600 border border-slate-200")">
                        @i
                    </a>
                }
                else if (i == currentPage - 2 || i == currentPage + 2)
                {
                    <span class="w-10 h-10 flex items-center justify-center text-slate-600">…</span>
                }
            }

            @if (currentPage < totalPages)
            {
                <a href="@Context.Request.Path@Html.Raw(BuildPageQuery(Context.Request.Query, currentPage + 1))"
                   class="jc-page-link w-10 h-10 flex items-center justify-center rounded-lg border border-slate-200 hover:bg-slate-100 transition-colors text-slate-600">
                    <span class="material-symbols-outlined">chevron_right</span>
                </a>
            }
        </div>
    }
</div>

@functions {
    private string BuildPageQuery(Microsoft.AspNetCore.Http.IQueryCollection query, int page)
    {
        var pairs = new List<string>();
        foreach (var kv in query)
        {
            if (string.Equals(kv.Key, "Page", StringComparison.OrdinalIgnoreCase)) continue;
            foreach (var v in kv.Value)
            {
                pairs.Add($"{Uri.EscapeDataString(kv.Key)}={Uri.EscapeDataString(v ?? "")}");
            }
        }
        pairs.Add($"Page={page}");
        return "?" + string.Join("&", pairs);
    }
}
