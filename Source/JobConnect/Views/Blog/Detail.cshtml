@using JobConnect.Models
@model BlogPost
@{
    ViewData["Title"] = Model.Title;
    Layout = "_Layout";
}

<style>
    .prose h2 {
        font-size: 1.25rem;
        font-weight: 700;
        margin-top: 2rem;
        margin-bottom: 0.75rem;
        color: #f1f5f9;
    }

    .prose h3 {
        font-size: 1.1rem;
        font-weight: 600;
        margin-top: 1.5rem;
        margin-bottom: 0.5rem;
        color: #e2e8f0;
    }

    .prose p {
        margin-bottom: 1rem;
        color: #94a3b8;
        line-height: 1.75;
    }

    .prose ul {
        list-style: disc;
        padding-left: 1.5rem;
        margin-bottom: 1rem;
        color: #94a3b8;
    }

    .prose ol {
        list-style: decimal;
        padding-left: 1.5rem;
        margin-bottom: 1rem;
        color: #94a3b8;
    }

    .prose li {
        margin-bottom: 0.4rem;
    }

    .prose strong {
        color: #f1f5f9;
        font-weight: 600;
    }

    .prose a {
        color: #60a5fa;
        text-decoration: underline;
    }

    .prose blockquote {
        border-left: 4px solid #3b82f6;
        padding-left: 1rem;
        font-style: italic;
        color: #94a3b8;
        margin: 1.5rem 0;
        background: rgba(59,130,246,0.05);
        padding: 1rem;
        border-radius: 0 0.5rem 0.5rem 0;
    }

    .prose code {
        background: #1e293b;
        color: #60a5fa;
        padding: 0.15rem 0.4rem;
        border-radius: 4px;
        font-size: 0.8rem;
        font-family: monospace;
    }

    .prose img {
        border-radius: 0.75rem;
        margin: 1.5rem 0;
        max-width: 100%;
    }

    .section-card {
        background: rgba(255,255,255,0.03);
        border: 1px solid #1e293b;
        border-radius: 1rem;
        padding: 1.25rem;
    }
</style>

<div class="max-w-[1600px] mx-auto px-6 py-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">

        <!-- MAIN ARTICLE -->
        <article class="lg:col-span-8">

            <!-- Breadcrumb -->
            <nav class="flex items-center gap-1.5 text-xs text-slate-500 mb-6">
                <a asp-controller="Home" asp-action="Index" class="hover:text-blue-600 transition-colors">Trang chủ</a>
                <span class="material-symbols-outlined text-sm">chevron_right</span>
                <a asp-action="Index" class="hover:text-blue-600 transition-colors">Blog</a>
                <span class="material-symbols-outlined text-sm">chevron_right</span>
                <span class="text-slate-600 line-clamp-1">@Model.Title</span>
            </nav>

            <!-- Cover -->
            @if (!string.IsNullOrEmpty(Model.CoverURL))
            {
                <img src="@Model.CoverURL" alt="@Model.Title"
                     class="w-full h-64 md:h-80 object-cover rounded-2xl mb-8 border border-slate-200" />
            }

            <!-- Header -->
            <header class="mb-8">
                <div class="inline-flex items-center gap-1.5 bg-blue-500/10 text-blue-600 border border-blue-500/20 px-3 py-1 rounded-full text-xs font-bold mb-4">
                    <span class="material-symbols-outlined text-sm">article</span>
                    Blog nghề nghiệp
                </div>

                <h1 class="text-3xl md:text-4xl font-bold text-slate-900 leading-tight mb-4">@Model.Title</h1>

                <!-- Author + meta -->
                <div class="flex flex-wrap items-center gap-4 text-sm text-slate-500 pb-4 border-b border-slate-200">
                    <div class="flex items-center gap-2">
                        <div class="w-9 h-9 rounded-full bg-white flex items-center justify-center overflow-hidden border border-slate-200">
                            @if (!string.IsNullOrEmpty(Model.Author?.AvatarURL))
                            {
                                <img src="@Model.Author.AvatarURL" class="w-9 h-9 rounded-full object-cover" />
                            }
                            else
                            {
                                <span class="material-symbols-outlined text-sm text-slate-500">person</span>
                            }
                        </div>
                        <span class="font-semibold text-slate-700">@Model.Author?.FullName</span>
                    </div>
                    <span class="flex items-center gap-1">
                        <span class="material-symbols-outlined text-base text-slate-500">calendar_today</span>
                        @Model.PublishedAt?.ToString("dd 'tháng' MM, yyyy")
                    </span>
                    <span class="flex items-center gap-1">
                        <span class="material-symbols-outlined text-base text-slate-500">schedule</span>
                        8 phút đọc
                    </span>
                </div>

                <!-- Excerpt -->
                @if (!string.IsNullOrEmpty(Model.Excerpt))
                {
                    <p class="mt-5 text-slate-500 text-lg leading-relaxed border-l-4 border-blue-500 pl-4 italic bg-blue-500/5 py-3 rounded-r-lg">
                        @Model.Excerpt
                    </p>
                }
            </header>

            <!-- Content -->
            <div class="prose max-w-none">
                @Html.Raw(Model.Content)
            </div>

            <!-- Share + Report + Back -->
            <div class="mt-10 pt-6 border-t border-slate-200 flex flex-col sm:flex-row items-center justify-between gap-4">
                <div class="flex items-center gap-2 flex-wrap">
                    <span class="text-sm text-slate-500 font-medium">Chia sẻ:</span>
                    <button class="bg-blue-600 text-white px-3 py-1.5 rounded-lg text-xs font-bold flex items-center gap-1.5 hover:bg-blue-700 transition-colors">
                        <span class="material-symbols-outlined text-sm">facebook</span>
                        Facebook
                    </button>
                    <button class="bg-white border border-slate-200 text-slate-600 px-3 py-1.5 rounded-lg text-xs font-bold flex items-center gap-1.5 hover:bg-slate-50 transition-colors">
                        <span class="material-symbols-outlined text-sm">link</span>
                        Copy link
                    </button>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <button type="button" onclick="document.getElementById('reportModal').classList.remove('hidden')"
                                class="bg-red-600/20 border border-red-500/30 text-red-600 px-3 py-1.5 rounded-lg text-xs font-bold flex items-center gap-1.5 hover:bg-red-600/30 transition-colors">
                            <span class="material-symbols-outlined text-sm">report</span>
                            Báo cáo
                        </button>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login"
                           class="bg-red-600/20 border border-red-500/30 text-red-600 px-3 py-1.5 rounded-lg text-xs font-bold flex items-center gap-1.5 hover:bg-red-600/30 transition-colors">
                            <span class="material-symbols-outlined text-sm">report</span>
                            Báo cáo
                        </a>
                    }
                </div>
                <a asp-action="Index"
                   class="inline-flex items-center gap-2 px-5 py-2.5 border border-slate-200 rounded-xl text-sm font-semibold text-slate-600 hover:bg-white hover:border-slate-200 transition-colors">
                    <span class="material-symbols-outlined text-sm">arrow_back</span>
                    Quay lại Blog
                </a>
            </div>
        </article>

        <!-- SIDEBAR -->
        <aside class="lg:col-span-4 space-y-5">

            <!-- Author card -->
            <div class="section-card">
                <h3 class="font-bold text-slate-900 mb-4">Tác giả</h3>
                <div class="flex items-center gap-3">
                    <div class="w-12 h-12 rounded-full bg-white flex items-center justify-center overflow-hidden border border-slate-200 shrink-0">
                        @if (!string.IsNullOrEmpty(Model.Author?.AvatarURL))
                        {
                            <img src="@Model.Author.AvatarURL" class="w-full h-full object-cover" />
                        }
                        else
                        {
                            <span class="material-symbols-outlined text-slate-500">person</span>
                        }
                    </div>
                    <div>
                        <div class="font-bold text-slate-700 text-sm">@Model.Author?.FullName</div>
                        <div class="text-xs text-slate-500 mt-0.5">Chuyên gia nghề nghiệp</div>
                    </div>
                </div>
            </div>

            <!-- Related posts -->
            @if (ViewBag.RelatedPosts is List<BlogPost> related && related.Any())
            {
                <div class="section-card">
                    <h3 class="font-bold text-slate-900 mb-4">Bài viết liên quan</h3>
                    <div class="space-y-4">
                        @foreach (var rp in related.Take(4))
                        {
                            <a asp-action="Detail" asp-route-slug="@rp.Slug"
                               class="flex gap-3 group hover:bg-white rounded-lg p-2 -mx-2 transition-colors">
                                <div class="w-16 h-14 rounded-lg bg-white border border-slate-200 overflow-hidden shrink-0">
                                    @if (!string.IsNullOrEmpty(rp.CoverURL))
                                    {
                                        <img src="@rp.CoverURL" class="w-full h-full object-cover" />
                                    }
                                    else
                                    {
                                        <div class="w-full h-full flex items-center justify-center">
                                            <span class="material-symbols-outlined text-slate-600 text-lg">article</span>
                                        </div>
                                    }
                                </div>
                                <div class="flex-1 min-w-0">
                                    <p class="text-sm font-semibold text-slate-600 group-hover:text-blue-600 transition-colors line-clamp-2">@rp.Title</p>
                                    <p class="text-xs text-slate-500 mt-1">@rp.PublishedAt?.ToString("dd/MM/yyyy")</p>
                                </div>
                            </a>
                        }
                    </div>
                </div>
            }

            <!-- Newsletter -->
            <div class="bg-gradient-to-br from-blue-600 to-indigo-700 rounded-2xl p-5 text-white shadow-lg shadow-blue-500/20">
                <h3 class="font-bold text-base mb-2">Nhận bản tin hàng tuần</h3>
                <p class="text-blue-200 text-xs mb-4">Cập nhật xu hướng nghề nghiệp và cơ hội việc làm mới nhất.</p>
                <input type="email" placeholder="Email của bạn"
                       class="w-full px-3 py-2 rounded-lg text-sm text-slate-900 outline-none mb-2 bg-white placeholder-slate-400" />
                <button class="w-full py-2 bg-white text-blue-600 rounded-lg text-sm font-bold hover:bg-blue-50 transition-colors">
                    Đăng ký ngay
                </button>
            </div>
        </aside>
    </div>
</div>

@if (User.Identity?.IsAuthenticated == true)
{
    <!-- MODAL BÁO CÁO -->
    <div id="reportModal" class="hidden fixed inset-0 bg-slate-900/70 backdrop-blur-sm z-50 flex items-center justify-center p-4">
        <div class="bg-slate-900 border border-slate-700 rounded-2xl p-6 w-full max-w-lg shadow-2xl text-slate-100 relative">
            <div class="text-center mb-1">
                <div class="w-14 h-14 mx-auto mb-3 rounded-full bg-red-500/10 flex items-center justify-center">
                    <span class="material-symbols-outlined text-red-500 text-2xl">report</span>
                </div>
                <h3 class="font-bold text-xl text-white">Gửi báo cáo</h3>
                <p class="text-slate-400 text-sm mt-1">Báo cáo vi phạm hoặc nội dung không phù hợp</p>
            </div>
            <button type="button" onclick="document.getElementById('reportModal').classList.add('hidden')"
                    class="absolute top-4 right-4 w-8 h-8 flex items-center justify-center rounded-full hover:bg-white/10 text-slate-400 hover:text-white transition-colors">
                ✕
            </button>

            <form id="reportAntiForgeryForm">
                @Html.AntiForgeryToken()
            </form>

            <div id="reportFormWrapper" class="space-y-4 mt-5">
                <div>
                    <label class="block text-sm font-semibold mb-1.5 text-slate-300">Loại báo cáo</label>
                    <select id="reportType" class="w-full px-4 py-3 bg-white border border-slate-200 text-slate-800 rounded-xl focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none">
                        <option value="4">Nội dung không phù hợp</option>
                        <option value="3">Thông tin sai lệch</option>
                        <option value="2">Spam</option>
                    </select>
                </div>

                <div>
                    <label class="block text-sm font-semibold mb-1.5 text-slate-300">Lý do báo cáo <span class="text-red-500">*</span></label>
                    <input id="reportReason" type="text"
                           class="w-full px-4 py-3 bg-white border border-slate-200 text-slate-800 rounded-xl focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none placeholder-slate-400"
                           placeholder="Ví dụ: Nội dung sai sự thật, ngôn từ không phù hợp..." />
                </div>

                <div>
                    <label class="block text-sm font-semibold mb-1.5 text-slate-300">Mô tả chi tiết</label>
                    <textarea id="reportDescription" rows="4"
                              class="w-full px-4 py-3 bg-white border border-slate-200 text-slate-800 rounded-xl focus:border-blue-500 focus:ring-1 focus:ring-blue-500 resize-none outline-none placeholder-slate-400"
                              placeholder="Cung cấp thêm thông tin chi tiết về vấn đề bạn muốn báo cáo..."></textarea>
                </div>

                <div class="flex items-start gap-2.5 bg-amber-500/10 border border-amber-500/30 rounded-xl p-3.5">
                    <span class="material-symbols-outlined text-amber-500 text-lg shrink-0">warning</span>
                    <p class="text-xs text-amber-200 leading-relaxed">
                        <span class="font-bold text-amber-400">Lưu ý quan trọng:</span>
                        Báo cáo sai lệch hoặc spam có thể dẫn đến hạn chế tài khoản của bạn. Vui lòng chỉ báo cáo khi thực sự cần thiết.
                    </p>
                </div>

                <p id="reportError" class="hidden text-sm text-red-400 font-medium"></p>

                <div class="flex gap-3 pt-1">
                    <button type="button" onclick="document.getElementById('reportModal').classList.add('hidden')"
                            class="flex-1 py-3 bg-white text-slate-800 rounded-xl font-semibold hover:bg-slate-100 transition-colors">
                        Hủy bỏ
                    </button>
                    <button type="button" id="reportSubmitBtn" onclick="submitReport()"
                            class="flex-1 py-3 bg-red-600 text-white font-bold rounded-xl hover:bg-red-700 transition-all">
                        Gửi báo cáo
                    </button>
                </div>
            </div>

            <div id="reportSuccessMsg" class="hidden text-center py-6">
                <div class="w-14 h-14 mx-auto mb-3 rounded-full bg-green-500/10 flex items-center justify-center">
                    <span class="material-symbols-outlined text-green-500 text-2xl">check_circle</span>
                </div>
                <h3 class="font-bold text-lg text-white">Đã gửi báo cáo thành công</h3>
                <p class="text-slate-400 text-sm mt-1">Chúng tôi sẽ xem xét và xử lý sớm nhất có thể.</p>
            </div>
        </div>
    </div>

    @section Scripts {
        <script>
            async function submitReport() {
                const reasonEl = document.getElementById('reportReason');
                const errorEl = document.getElementById('reportError');
                const btn = document.getElementById('reportSubmitBtn');

                if (!reasonEl.value.trim()) {
                    errorEl.textContent = 'Vui lòng nhập lý do báo cáo.';
                    errorEl.classList.remove('hidden');
                    return;
                }
                errorEl.classList.add('hidden');
                btn.disabled = true;
                btn.textContent = 'Đang gửi...';

                const blogTitle = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Title));
                const fullReason = reasonEl.value.trim() + ' [Bài viết: ' + blogTitle + ' (ID: @Model.PostId)]';

                const formData = new URLSearchParams();
                formData.append('reportType', document.getElementById('reportType').value);
                formData.append('reason', fullReason);
                formData.append('description', document.getElementById('reportDescription').value.trim());

                const tokenInput = document.querySelector('#reportAntiForgeryForm input[name="__RequestVerificationToken"]');
                const token = tokenInput ? tokenInput.value : '';

                try {
                    const res = await fetch('/Report/CreateAjax', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'RequestVerificationToken': token
                        },
                        body: formData
                    });
                    const data = await res.json();

                    if (res.ok && data.success) {
                        document.getElementById('reportFormWrapper').classList.add('hidden');
                        document.getElementById('reportSuccessMsg').classList.remove('hidden');
                        setTimeout(() => {
                            document.getElementById('reportModal').classList.add('hidden');
                        }, 2000);
                    } else {
                        errorEl.textContent = data.message || 'Có lỗi xảy ra, vui lòng thử lại.';
                        errorEl.classList.remove('hidden');
                        btn.disabled = false;
                        btn.textContent = 'Gửi báo cáo';
                    }
                } catch (e) {
                    errorEl.textContent = 'Không thể kết nối máy chủ, vui lòng thử lại.';
                    errorEl.classList.remove('hidden');
                    btn.disabled = false;
                    btn.textContent = 'Gửi báo cáo';
                }
            }
        </script>
    }
}
