@* [VIEW-HEADER-ADDED]
   View cho action "Index" trong khu vực Blog (BlogController).
*@
@using JobConnect.Models
@model List<BlogPost>
@{
    ViewData["Title"] = "Blog nghề nghiệp";
    Layout = "_Layout";
    var featured = Model.FirstOrDefault();
    var rest = Model.Skip(1).ToList();
}

<style>
    /* NỀN ĐEN */
    body {
        background-color: #f8fafc !important;
    }

    .blog-card {
        transition: all 0.22s cubic-bezier(0.4, 0, 0.2, 1);
        background: #ffffff;
        border: 1px solid #e2e8f0;
    }

        .blog-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 24px rgba(59, 130, 246, 0.15);
            border-color: #3b82f6;
        }

    .tag-chip {
        transition: all 0.15s;
        background: #ffffff;
        border: 1px solid #e2e8f0;
        color: #94a3b8;
    }

        .tag-chip:hover {
            background: #3b82f6;
            color: white;
            border-color: #3b82f6;
        }

        .tag-chip.active {
            background: #3b82f6;
            color: white;
            border-color: #3b82f6;
        }

    .cover-zoom {
        overflow: hidden;
    }

        .cover-zoom img {
            transition: transform 0.4s ease;
        }

        .cover-zoom:hover img {
            transform: scale(1.05);
        }

    /* Scrollbar */
    ::-webkit-scrollbar {
        width: 8px;
    }

    ::-webkit-scrollbar-track {
        background: #f1f5f9;
    }

    ::-webkit-scrollbar-thumb {
        background: #cbd5e1;
        border-radius: 4px;
    }

        ::-webkit-scrollbar-thumb:hover {
            background: #3b82f6;
        }

    /* Line clamp */
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .line-clamp-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>

<!-- Thêm container mưa -->
<!-- Hero featured post -->
@if (featured != null)
{
    <div class="max-w-[1600px] mx-auto px-6 pt-8 pb-4 relative z-10">
        <a asp-action="Detail" asp-route-slug="@featured.Slug"
           class="grid grid-cols-1 md:grid-cols-2 bg-white rounded-2xl overflow-hidden border border-slate-200 hover:shadow-lg transition-shadow group">
            <div class="cover-zoom h-56 md:h-auto min-h-[240px]">
                @if (!string.IsNullOrEmpty(featured.CoverURL))
                {
                    <img src="@featured.CoverURL" class="w-full h-full object-cover" />
                }
                else
                {
                    <div class="w-full h-full bg-gradient-to-br from-blue-600 to-blue-400 flex items-center justify-center">
                        <span class="material-symbols-outlined text-slate-900 text-6xl">article</span>
                    </div>
                }
            </div>
            <div class="p-8 flex flex-col justify-center">
                <span class="inline-block bg-blue-600 text-white text-xs font-bold px-3 py-1 rounded-full mb-4 w-fit">
                    🔥 XU HƯỚNG THỊ TRƯỜNG
                </span>
                <h1 class="text-2xl font-bold text-slate-900 group-hover:text-blue-600 transition-colors leading-snug mb-3">
                    @featured.Title
                </h1>
                @if (!string.IsNullOrEmpty(featured.Excerpt))
                {
                    <p class="text-slate-600 text-sm leading-relaxed line-clamp-3 mb-5">@featured.Excerpt</p>
                }
                <div class="flex items-center gap-4">
                    <span class="bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-bold hover:bg-blue-500 transition-all">Đọc bài viết</span>
                    <span class="text-slate-600 text-xs flex items-center gap-1">
                        <span class="material-symbols-outlined text-sm">schedule</span>
                        12 phút đọc
                    </span>
                </div>
            </div>
        </a>
    </div>
}

<!-- Category filter chips -->
<div class="max-w-[1600px] mx-auto px-6 py-4 relative z-10">
    <div class="flex flex-wrap gap-2">
        @foreach (var (label, val) in new[]{
            ("Tất cả bài viết", ""),
            ("Bí quyết phỏng vấn", "interview"),
            ("Lộ trình nghề nghiệp", "career"),
            ("Quản lý tài chính", "finance"),
            ("Lãnh đạo & Quản lý", "leadership"),
            ("Thương hiệu cá nhân", "personal-brand"),
        })
        {
            <a href="?category=@val"
               class="tag-chip px-4 py-1.5 rounded-full text-sm font-semibold @(ViewBag.Category == val || (string.IsNullOrEmpty(val) && ViewBag.Category == null) ? "active" : "")">
                @label
            </a>
        }
    </div>
</div>

<!-- Main grid -->
<div class="max-w-[1600px] mx-auto px-6 pb-12 relative z-10">
    @if (!Model.Any())
    {
        <div class="text-center py-16 text-slate-600">
            <span class="material-symbols-outlined text-5xl block mb-3">article</span>
            <p>Chưa có bài viết nào.</p>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
            <!-- Left: large card -->
            @if (rest.Any())
            {
                var main = rest.First();
                <a asp-action="Detail" asp-route-slug="@main.Slug"
                   class="lg:col-span-2 bg-white rounded-2xl border border-slate-200 overflow-hidden blog-card group block">
                    <div class="cover-zoom h-64">
                        @if (!string.IsNullOrEmpty(main.CoverURL))
                        {
                            <img src="@main.CoverURL" class="w-full h-full object-cover" />
                        }
                        else
                        {
                            <div class="w-full h-full bg-slate-100 flex items-center justify-center">
                                <span class="material-symbols-outlined text-4xl text-slate-600">article</span>
                            </div>
                        }
                    </div>
                    <div class="p-6">
                        <h2 class="font-bold text-slate-900 text-lg group-hover:text-blue-600 transition-colors mt-1 mb-2 line-clamp-2">
                            @main.Title
                        </h2>
                        @if (!string.IsNullOrEmpty(main.Excerpt))
                        {
                            <p class="text-slate-600 text-sm line-clamp-2 mb-4">@main.Excerpt</p>
                        }
                        <div class="flex items-center justify-between text-xs text-slate-600 pt-3 border-t border-slate-200">
                            <span>@(main.Author?.FullName ?? "JobConnect") · @main.PublishedAt?.ToString("dd 'Tháng' MM, yyyy")</span>
                            <span class="text-blue-600 font-bold flex items-center gap-1">
                                Đọc tiếp <span class="material-symbols-outlined text-sm">arrow_forward</span>
                            </span>
                        </div>
                    </div>
                </a>
            }

            <!-- Right: stacked small cards -->
            <div class="space-y-4">
                @foreach (var post in rest.Skip(1).Take(2))
                {
                    <a asp-action="Detail" asp-route-slug="@post.Slug"
                       class="bg-white rounded-2xl border border-slate-200 overflow-hidden blog-card group flex flex-col block">
                        <div class="cover-zoom h-36">
                            @if (!string.IsNullOrEmpty(post.CoverURL))
                            {
                                <img src="@post.CoverURL" class="w-full h-full object-cover" />
                            }
                            else
                            {
                                <div class="w-full h-full bg-slate-100 flex items-center justify-center">
                                    <span class="material-symbols-outlined text-3xl text-slate-600">article</span>
                                </div>
                            }
                        </div>
                        <div class="p-4 flex flex-col flex-1">
                            <h3 class="font-bold text-slate-900 text-sm group-hover:text-blue-600 transition-colors line-clamp-2 mb-2">@post.Title</h3>
                            @if (!string.IsNullOrEmpty(post.Excerpt))
                            {
                                <p class="text-slate-600 text-xs line-clamp-2">@post.Excerpt</p>
                            }
                        </div>
                    </a>
                }
            </div>
        </div>

        <!-- [ĐÃ BỎ] Khối "Nhận tin tức sự nghiệp hàng tuần" (Newsletter CTA) từng nằm ở đây -->
        <!-- Xu hướng thị trường -->
        <div class="mb-6">
            <div class="flex justify-between items-center mb-4">
                <div>
                    <h2 class="text-xl font-bold text-slate-900">📈 Xu hướng thị trường</h2>
                    <p class="text-slate-600 text-sm mt-0.5">Cập nhật những chuyển động mới nhất của thị trường lao động Việt Nam</p>
                </div>
                <a asp-action="Index" class="text-blue-600 text-sm font-bold hover:underline flex items-center gap-1">
                    Xem tất cả <span class="material-symbols-outlined text-base">arrow_forward</span>
                </a>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                @foreach (var post in rest.Skip(3).Take(3))
                {
                    <a asp-action="Detail" asp-route-slug="@post.Slug"
                       class="bg-white rounded-2xl border border-slate-200 p-4 blog-card group flex gap-3 items-start">
                        <div class="w-12 h-12 rounded-xl bg-blue-50 flex items-center justify-center shrink-0 border border-blue-200">
                            <span class="material-symbols-outlined text-blue-600 text-xl">trending_up</span>
                        </div>
                        <div>
                            <h3 class="font-bold text-sm text-slate-900 group-hover:text-blue-600 transition-colors line-clamp-2 mb-1">@post.Title</h3>
                            @if (!string.IsNullOrEmpty(post.Excerpt))
                            {
                                <p class="text-slate-600 text-xs line-clamp-2">@post.Excerpt</p>
                            }
                        </div>
                    </a>
                }
                @if (!rest.Skip(3).Any())
                {
                    @foreach (var (title, desc) in new[]{
                        ("Mức lương ngành IT 2024", "Báo cáo khảo sát từ 500 doanh nghiệp hàng đầu."),
                        ("Sự trỗi dậy của Hybrid Work", "60% doanh nghiệp chuyển đổi sang mô hình linh hoạt."),
                        ("Nhu cầu nhân sự Gen Z", "Nhà tuyển dụng tìm kiếm gì ở thế hệ mới?"),
                    })
                    {
                        <div class="bg-white rounded-2xl border border-slate-200 p-4 flex gap-3 items-start">
                            <div class="w-12 h-12 rounded-xl bg-blue-50 flex items-center justify-center shrink-0 border border-blue-200">
                                <span class="material-symbols-outlined text-blue-600 text-xl">trending_up</span>
                            </div>
                            <div>
                                <h3 class="font-bold text-sm text-slate-900 mb-1">@title</h3>
                                <p class="text-slate-600 text-xs">@desc</p>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- More posts grid -->
        @if (rest.Count > 3)
        {
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mt-6">
                @foreach (var post in rest.Skip(3))
                {
                    <a asp-action="Detail" asp-route-slug="@post.Slug"
                       class="bg-white rounded-2xl border border-slate-200 overflow-hidden blog-card group block">
                        <div class="cover-zoom h-44">
                            @if (!string.IsNullOrEmpty(post.CoverURL))
                            {
                                <img src="@post.CoverURL" class="w-full h-full object-cover" />
                            }
                            else
                            {
                                <div class="w-full h-44 bg-slate-100 flex items-center justify-center">
                                    <span class="material-symbols-outlined text-3xl text-slate-600">article</span>
                                </div>
                            }
                        </div>
                        <div class="p-4">
                            <h3 class="font-bold text-slate-900 text-sm group-hover:text-blue-600 transition-colors line-clamp-2 mt-1 mb-2">@post.Title</h3>
                            <div class="flex items-center justify-between text-xs text-slate-600">
                                <span>@(post.Author?.FullName ?? "JobConnect")</span>
                                <span>@post.PublishedAt?.ToString("dd/MM/yyyy")</span>
                            </div>
                        </div>
                    </a>
                }
            </div>
        }

        <!-- Pagination -->
        @if ((int)(ViewBag.TotalPages ?? 1) > 1)
        {
            int currentPage = (int)(ViewBag.Page ?? 1);
            int totalPages = (int)ViewBag.TotalPages;
            <div class="flex justify-center items-center gap-1.5 mt-8">
                @if (currentPage > 1)
                {
                    <a asp-action="Index" asp-route-page="@(currentPage - 1)"
                       class="w-10 h-10 flex items-center justify-center rounded-lg border border-slate-200 hover:bg-slate-100 transition-colors text-slate-600">
                        <span class="material-symbols-outlined">chevron_left</span>
                    </a>
                }
                @for (int i = 1; i <= totalPages; i++)
                {
                    if (i == 1 || i == totalPages || (i >= currentPage - 1 && i <= currentPage + 1))
                    {
                        <a asp-action="Index" asp-route-page="@i"
                           class="w-10 h-10 flex items-center justify-center rounded-lg text-sm font-bold transition-colors
                            @(i == currentPage ? "bg-blue-600 text-white" : "border border-slate-200 text-slate-600 hover:bg-slate-100")">
                            @i
                        </a>
                    }
                    else if (i == currentPage - 2 || i == currentPage + 2)
                    {
                        <span class="w-10 h-10 flex items-center justify-center text-slate-600">…</span>
                    }
                }
                @if (currentPage < totalPages)
                {
                    <a asp-action="Index" asp-route-page="@(currentPage + 1)"
                       class="w-10 h-10 flex items-center justify-center rounded-lg border border-slate-200 hover:bg-slate-100 transition-colors text-slate-600">
                        <span class="material-symbols-outlined">chevron_right</span>
                    </a>
                }
            </div>
        }
    }
</div>

@section Scripts {
    <script>
        // Hiệu ứng mưa
    </script>
}