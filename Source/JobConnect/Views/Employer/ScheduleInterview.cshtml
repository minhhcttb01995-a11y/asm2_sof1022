@* [VIEW-HEADER-ADDED]
   View cho action "ScheduleInterview" trong khu vực trang quản lý Nhà tuyển dụng (EmployerController).
*@
@model JobConnect.Models.Interview
@using JobConnect.Models
@{
    ViewData["Title"] = "Mời phỏng vấn";
    Layout = "_LayoutEmployer";
    var app = ViewBag.Application as Application;
    var emp = ViewBag.Employer as Employer;
    var job = app?.Job;
    var candidate = app?.CandidateProfile;
}

<div class="max-w-3xl mx-auto px-4 py-8 space-y-6">

    <!-- Header -->
    <div class="flex items-center gap-3 mb-2">
        <a asp-action="ManageApplications" asp-route-jobId="@app?.JobId"
           class="text-slate-400 hover:text-blue-600 transition-colors">
            <span class="material-symbols-outlined text-xl">arrow_back</span>
        </a>
        <div>
            <h2 class="text-2xl font-bold text-white">Thư mời phỏng vấn</h2>
            <p class="text-sm text-slate-400 mt-0.5">Điền thông tin bên dưới để gửi lời mời tới ứng viên</p>
        </div>
    </div>

    <!-- Thông tin công ty / nhà tuyển dụng -->
    <div class="bg-[#1e293b] rounded-2xl border border-slate-700 shadow-sm overflow-hidden">
        <div class="bg-gradient-to-r from-blue-600 to-indigo-600 px-6 py-4">
            <p class="text-xs font-semibold text-blue-100 uppercase tracking-wider mb-1">Thông tin nhà tuyển dụng</p>
            <h3 class="text-lg font-bold text-white">@(emp?.CompanyName ?? job?.Employer?.CompanyName ?? "Công ty")</h3>
        </div>
        <div class="px-6 py-4 grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm">
            @if (!string.IsNullOrEmpty(emp?.Address ?? job?.Employer?.Address))
            {
                <div class="flex items-start gap-2 text-slate-300">
                    <span class="material-symbols-outlined text-base text-slate-400 mt-0.5">location_on</span>
                    <span>@(emp?.Address ?? job?.Employer?.Address)</span>
                </div>
            }
            @if (!string.IsNullOrEmpty(emp?.Website ?? job?.Employer?.Website))
            {
                <div class="flex items-start gap-2 text-slate-300">
                    <span class="material-symbols-outlined text-base text-slate-400 mt-0.5">language</span>
                    <a href="@(emp?.Website ?? job?.Employer?.Website)" target="_blank"
                       class="text-blue-600 hover:underline">@(emp?.Website ?? job?.Employer?.Website)</a>
                </div>
            }
            @if (!string.IsNullOrEmpty(emp?.Industry ?? job?.Employer?.Industry))
            {
                <div class="flex items-start gap-2 text-slate-300">
                    <span class="material-symbols-outlined text-base text-slate-400 mt-0.5">business</span>
                    <span>@(emp?.Industry ?? job?.Employer?.Industry)</span>
                </div>
            }
            @if (!string.IsNullOrEmpty(emp?.CompanySize ?? job?.Employer?.CompanySize))
            {
                <div class="flex items-start gap-2 text-slate-300">
                    <span class="material-symbols-outlined text-base text-slate-400 mt-0.5">group</span>
                    <span>Quy mô: @(emp?.CompanySize ?? job?.Employer?.CompanySize) nhân viên</span>
                </div>
            }
        </div>
    </div>

    <!-- Thông tin vị trí tuyển dụng -->
    <div class="bg-[#1e293b] rounded-2xl border border-slate-700 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-700">
            <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1">Vị trí tuyển dụng</p>
            <h3 class="text-base font-bold text-white">@job?.Title</h3>
        </div>
        <div class="px-6 py-4 grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm text-slate-300">
            @if (!string.IsNullOrEmpty(job?.Location))
            {
                <div class="flex items-start gap-2">
                    <span class="material-symbols-outlined text-base text-slate-400 mt-0.5">pin_drop</span>
                    <span>@job.Location</span>
                </div>
            }
            <div class="flex items-start gap-2">
                <span class="material-symbols-outlined text-base text-slate-400 mt-0.5">work</span>
                <span>
                    @(job?.JobType switch
                    {
                        "FullTime" => "Toàn thời gian",
                        "PartTime" => "Bán thời gian",
                        "Contract" => "Hợp đồng",
                        "Intern" => "Thực tập",
                        "Remote" => "Làm từ xa",
                        _ => job?.JobType
                    })
                </span>
            </div>
            <div class="flex items-start gap-2">
                <span class="material-symbols-outlined text-base text-slate-400 mt-0.5">payments</span>
                <span>@job?.FormatSalary()</span>
            </div>
            @if (!string.IsNullOrEmpty(job?.ExperienceLevel))
            {
                <div class="flex items-start gap-2">
                    <span class="material-symbols-outlined text-base text-slate-400 mt-0.5">military_tech</span>
                    <span>@job.ExperienceLevel</span>
                </div>
            }
        </div>
        @if (!string.IsNullOrEmpty(job?.Requirements))
        {
            <div class="px-6 pb-4 text-sm text-slate-300 border-t border-slate-700 pt-3">
                <p class="font-semibold text-slate-300 mb-1">Yêu cầu:</p>
                <p class="whitespace-pre-line">@job.Requirements</p>
            </div>
        }
    </div>

    <!-- Thông tin ứng viên -->
    <div class="bg-[#1e293b] rounded-2xl border border-slate-700 shadow-sm px-6 py-4">
        <div class="flex items-center justify-between mb-3">
            <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Ứng viên</p>
            <a asp-action="CandidateDetail" asp-route-appId="@app?.AppID"
               class="text-xs font-semibold text-blue-400 hover:text-blue-300 flex items-center gap-1">
                <span class="material-symbols-outlined text-sm">visibility</span>
                Xem chi tiết ứng viên
            </a>
        </div>
        <div class="flex items-center gap-4">
            <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center text-blue-600 font-bold text-lg">
                @((candidate?.FullName?[0].ToString().ToUpper() ?? "U"))
            </div>
            <div class="text-sm">
                <p class="font-semibold text-white text-base">@(candidate?.FullName ?? candidate?.User?.FullName)</p>
                <p class="text-slate-400">@candidate?.User?.Email</p>
                @if (!string.IsNullOrEmpty(candidate?.Phone))
                {
                    <p class="text-slate-400">@candidate.Phone</p>
                }
                @if (!string.IsNullOrEmpty(candidate?.JobTitle))
                {
                    <p class="text-blue-600 font-medium mt-0.5">@candidate.JobTitle</p>
                }
            </div>
        </div>
    </div>

    <!-- Form lên lịch -->
    <div class="bg-[#1e293b] rounded-2xl border border-slate-700 shadow-sm px-6 py-6">
        <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-5">Thông tin buổi phỏng vấn</p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="mb-4 px-4 py-3 bg-red-500/10 border border-red-500/20 text-red-800 rounded-xl text-sm">
                <div asp-validation-summary="ModelOnly" class="text-red-400 font-medium"></div>
            </div>
        }

        <form asp-action="ScheduleInterview" method="post" class="space-y-5">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="AppID" />

            <div class="grid grid-cols-2 gap-4">
                <div class="space-y-1.5">
                    <label class="text-xs font-semibold text-slate-300 uppercase tracking-wider">
                        Ngày phỏng vấn <span class="text-red-500">*</span>
                    </label>
                    <input type="text" name="dateStr" placeholder="VD: 30/06/2026"
                           value="@(Model.InterviewDate == default ? DateTime.Now.AddDays(1).ToString("dd/MM/yyyy") : Model.InterviewDate.ToString("dd/MM/yyyy"))"
                           class="w-full px-4 py-2.5 bg-[#0f172a] text-white border border-slate-700 rounded-xl text-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-100" required />
                </div>
                <div class="space-y-1.5">
                    <label class="text-xs font-semibold text-slate-300 uppercase tracking-wider">
                        Giờ phỏng vấn <span class="text-red-500">*</span>
                    </label>
                    <input type="text" name="timeStr" placeholder="VD: 09:00"
                           value="@(Model.InterviewDate == default ? "09:00" : Model.InterviewDate.ToString("HH:mm"))"
                           class="w-full px-4 py-2.5 bg-[#0f172a] text-white border border-slate-700 rounded-xl text-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-100" required />
                </div>
            </div>

            <div class="space-y-1.5">
                <label class="text-xs font-semibold text-slate-300 uppercase tracking-wider">
                    Số điện thoại liên hệ (hiển thị trong thư mời gửi ứng viên)
                </label>
                <input type="text" name="contactPhone" value="@(emp?.User?.PhoneNumber)"
                       placeholder="VD: 0901234567"
                       class="w-full px-4 py-2.5 bg-[#0f172a] text-white border border-slate-700 rounded-xl text-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-100" />
            </div>

            <div class="space-y-1.5">
                <label asp-for="Location" class="text-xs font-semibold text-slate-300 uppercase tracking-wider">
                    Địa điểm / Link phỏng vấn <span class="text-red-500">*</span>
                </label>
                <input asp-for="Location" type="text"
                       placeholder="VD: @(emp?.Address ?? "Phòng họp số 2") hoặc Link Google Meet..."
                       class="w-full px-4 py-2.5 bg-[#0f172a] text-white border border-slate-700 rounded-xl text-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-100" required />
                <span asp-validation-for="Location" class="text-red-500 text-xs"></span>
            </div>

            <div class="space-y-1.5">
                <label asp-for="Notes" class="text-xs font-semibold text-slate-300 uppercase tracking-wider">
                    Nội dung thư mời / Hướng dẫn ứng viên
                </label>
                <textarea asp-for="Notes" rows="5"
                          placeholder="Ví dụ: Kính gửi @(candidate?.FullName ?? "[Ứng viên]"), Chúng tôi xin mời bạn tham dự buổi phỏng vấn cho vị trí @(job?.Title)..."
                          class="w-full px-4 py-2.5 bg-[#0f172a] text-white border border-slate-700 rounded-xl text-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-100 resize-none"></textarea>
                <span asp-validation-for="Notes" class="text-red-500 text-xs"></span>
            </div>

            <!-- Preview thư mời -->
            <div class="bg-blue-500/10 border border-blue-500/20 rounded-xl p-4 text-sm text-slate-300 space-y-1">
                <p class="font-semibold text-blue-300 mb-2 flex items-center gap-1.5">
                    <span class="material-symbols-outlined text-base">mail</span>
                    Email sẽ được gửi tới <strong>@(candidate?.User?.Email)</strong> với nội dung:
                </p>
                <p>Kính gửi <strong>@(candidate?.FullName ?? candidate?.User?.FullName)</strong>,</p>
                <p>Công ty <strong>@(emp?.CompanyName ?? job?.Employer?.CompanyName)</strong> trân trọng mời bạn tham dự phỏng vấn cho vị trí <strong>@job?.Title</strong>.</p>
                <p class="text-slate-400 italic text-xs mt-2">* Thời gian, địa điểm và số điện thoại liên hệ cụ thể sẽ theo thông tin bạn điền ở trên.</p>
            </div>

            <div class="flex items-center gap-3 pt-2 border-t border-slate-700">
                <button type="submit"
                        class="flex-1 py-3 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white font-semibold rounded-xl transition-all shadow-sm flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined text-base">send</span>
                    Xác nhận gửi lời mời phỏng vấn
                </button>
                <a asp-action="ManageApplications" asp-route-jobId="@app?.JobId"
                   class="px-6 py-3 border border-slate-700 text-slate-300 rounded-xl hover:bg-[#0f172a] font-semibold transition-colors text-center text-sm">
                    Hủy
                </a>
            </div>
        </form>
    </div>
</div>
