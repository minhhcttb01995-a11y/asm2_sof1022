@model JobConnect.Models.Interview
@{
    ViewData["Title"] = "Cập nhật lịch phỏng vấn";
    Layout = "_LayoutEmployer";
}

<div class="max-w-xl mx-auto bg-[#1e293b] border border-slate-700 rounded-2xl p-8 shadow-lg">
    <div class="flex items-center gap-3 mb-6">
        <a asp-action="Interviews" class="text-secondary hover:text-primary">
            <span class="material-symbols-outlined text-lg">arrow_back</span>
        </a>
        <h2 class="text-xl font-bold text-white">Cập nhật lịch phỏng vấn</h2>
    </div>

    <!-- Candidate Info summary -->
    <div class="bg-slate-800 rounded-xl p-4 mb-6 text-sm text-slate-100">
        <p class="font-semibold text-primary mb-1">Thông tin ứng tuyển:</p>
        <p>Ứng viên: <strong class="text-white">@Model.Application?.CandidateProfile?.FullName</strong></p>
        <p>Vị trí ứng tuyển: <strong class="text-white">@Model.Application?.Job?.Title</strong></p>
        <p>Email: <span class="text-slate-300">@Model.Application?.CandidateProfile?.User?.Email</span></p>
    </div>

    <form asp-action="EditInterview" method="post" class="space-y-5">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="InterviewId" />
        <input type="hidden" asp-for="AppId" />

        <div class="space-y-1.5">
            <label asp-for="InterviewDate" class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Thời gian phỏng vấn mới</label>
            <input asp-for="InterviewDate" type="datetime-local" class="w-full px-4 py-2.5 bg-slate-800 text-white border border-slate-700 rounded-xl text-sm focus:border-primary focus:outline-none" required />
            <span asp-validation-for="InterviewDate" class="text-red-500 text-xs"></span>
        </div>

        <div class="space-y-1.5">
            <label asp-for="Location" class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Địa điểm hoặc Link phỏng vấn mới (Zoom/Meet)</label>
            <input asp-for="Location" type="text" placeholder="VD: Phòng họp số 2 hoặc Link Google Meet..." class="w-full px-4 py-2.5 bg-slate-800 text-white border border-slate-700 rounded-xl text-sm focus:border-primary focus:outline-none" required />
            <span asp-validation-for="Location" class="text-red-500 text-xs"></span>
        </div>

        <div class="space-y-1.5">
            <label asp-for="Notes" class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Ghi chú / Hướng dẫn ứng viên</label>
            <textarea asp-for="Notes" rows="4" placeholder="Nhập các chuẩn bị trước khi phỏng vấn, liên hệ phòng ban..." class="w-full px-4 py-2.5 bg-slate-800 text-white border border-slate-700 rounded-xl text-sm focus:border-primary focus:outline-none"></textarea>
            <span asp-validation-for="Notes" class="text-red-500 text-xs"></span>
        </div>

        <div class="flex items-center gap-3 pt-4 border-t border-slate-700">
            <button type="submit" class="flex-1 py-3 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white font-semibold rounded-xl transition-all shadow-sm">
                Lưu thay đổi
            </button>
            <a asp-action="Interviews" class="px-6 py-3 border border-slate-700 text-slate-300 rounded-xl hover:bg-slate-800 font-semibold transition-colors text-center">
                Hủy bỏ
            </a>
        </div>
    </form>
</div>
