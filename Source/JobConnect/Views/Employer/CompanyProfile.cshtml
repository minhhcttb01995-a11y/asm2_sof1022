@model JobConnect.Models.Employer
@{
    ViewData["Title"] = "Hồ sơ công ty";
    Layout = "_LayoutEmployer";
}

<div class="max-w-3xl mx-auto px-6 py-8">
    <!-- Header -->
    <div class="flex items-center gap-4 mb-6">
        <a asp-action="Dashboard" class="text-secondary hover:text-primary">
            <span class="material-symbols-outlined align-middle">arrow_back</span>
        </a>
        <div>
            <h1 class="text-2xl font-bold text-on-surface">Hồ sơ công ty</h1>
            <p class="text-secondary text-sm mt-0.5">Cập nhật thông tin công ty của bạn</p>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="mb-4 px-4 py-3 rounded-lg bg-green-50 text-green-700 border border-green-200 text-sm">
            <span class="material-symbols-outlined text-sm align-middle mr-1">check_circle</span>
            @TempData["Success"]
        </div>
    }

    <form asp-action="CompanyProfile" method="post" class="bg-white rounded-xl border border-outline-variant p-6 space-y-5">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="EmployerID" />
        <input type="hidden" asp-for="UserID" />
        <input type="hidden" asp-for="IsVerified" />
        <input type="hidden" asp-for="CreatedAt" />

        <!-- Company Name -->
        <div>
            <label class="block text-sm font-medium text-on-surface mb-1">
                Tên công ty <span class="text-red-500">*</span>
            </label>
            <input asp-for="CompanyName"
                   class="w-full border border-outline-variant rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary" />
            <span asp-validation-for="CompanyName" class="text-red-500 text-xs mt-1 block"></span>
        </div>

        <!-- Tax Code + Industry -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-medium text-on-surface mb-1">Mã số thuế</label>
                <input asp-for="TaxCode"
                       class="w-full border border-outline-variant rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary" />
            </div>
            <div>
                <label class="block text-sm font-medium text-on-surface mb-1">Ngành nghề</label>
                <input asp-for="Industry"
                       class="w-full border border-outline-variant rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary" />
            </div>
        </div>

        <!-- Company Size -->
        <div>
            <label class="block text-sm font-medium text-on-surface mb-1">Quy mô công ty</label>
            <select asp-for="CompanySize"
                    class="w-full border border-outline-variant rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary">
                <option value="">-- Chọn quy mô --</option>
                <option value="1-10">1 - 10 nhân viên</option>
                <option value="11-50">11 - 50 nhân viên</option>
                <option value="51-200">51 - 200 nhân viên</option>
                <option value="200+">Trên 200 nhân viên</option>
            </select>
        </div>

        <!-- Address -->
        <div>
            <label class="block text-sm font-medium text-on-surface mb-1">Địa chỉ</label>
            <input asp-for="Address"
                   class="w-full border border-outline-variant rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary" />
        </div>

        <!-- Website -->
        <div>
            <label class="block text-sm font-medium text-on-surface mb-1">Website</label>
            <input asp-for="Website" type="url" placeholder="https://example.com"
                   class="w-full border border-outline-variant rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary" />
        </div>

        <!-- Logo URL + Cover URL -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-medium text-on-surface mb-1">URL Logo</label>
                <input asp-for="LogoURL" placeholder="https://..."
                       class="w-full border border-outline-variant rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary" />
                @if (!string.IsNullOrEmpty(Model.LogoURL))
                {
                    <img src="@Model.LogoURL" class="mt-2 h-12 w-12 rounded-full object-cover border" />
                }
            </div>
            <div>
                <label class="block text-sm font-medium text-on-surface mb-1">URL Ảnh bìa</label>
                <input asp-for="CoverURL" placeholder="https://..."
                       class="w-full border border-outline-variant rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary" />
            </div>
        </div>

        <!-- Description -->
        <div>
            <label class="block text-sm font-medium text-on-surface mb-1">Mô tả công ty</label>
            <textarea asp-for="Description" rows="5" placeholder="Giới thiệu về công ty..."
                      class="w-full border border-outline-variant rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary resize-none"></textarea>
        </div>

        <!-- Submit -->
        <div class="flex justify-end pt-2">
            <button type="submit"
                    class="bg-primary text-white px-6 py-2.5 rounded-lg text-sm font-medium hover:opacity-90 transition-opacity">
                Lưu thay đổi
            </button>
        </div>
    </form>
</div>
