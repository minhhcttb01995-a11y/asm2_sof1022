@model JobConnect.Models.Employer
@{
    ViewData["Title"] = "Hồ sơ công ty";
    Layout = "_LayoutEmployer";
}

<div class="max-w-3xl mx-auto px-6 py-8">
    <div class="flex items-center gap-3 mb-6">
        <a asp-action="Dashboard" class="p-2 rounded-lg hover:bg-[#1e293b]/10 text-slate-300">
            <span class="material-icons">arrow_back</span>
        </a>
        <div>
            <h1 class="text-2xl font-bold text-white">Hồ sơ công ty</h1>
            <p class="text-slate-400 text-sm">Cập nhật thông tin công ty của bạn</p>
        </div>
    </div>

    <form asp-action="CompanyProfile" method="post" class="space-y-6">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="EmployerId" />
        <input type="hidden" asp-for="UserId" />
        <input type="hidden" asp-for="IsVerified" />
        <input type="hidden" asp-for="CreatedAt" />

        <div class="bg-[#1e293b] rounded-xl p-6 border border-slate-700 shadow-sm">
            <!-- Company Name -->
            <div>
                <label class="block text-sm font-medium text-slate-300 mb-1">
                    Tên công ty <span class="text-red-500">*</span>
                </label>
                <input asp-for="CompanyName"
                       class="w-full bg-[#0f172a] text-white border border-slate-700 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                <span asp-validation-for="CompanyName" class="text-red-500 text-xs mt-1 block"></span>
            </div>

            <!-- Tax Code + Industry -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-slate-300 mb-1">Mã số thuế</label>
                    <input asp-for="TaxCode"
                           class="w-full bg-[#0f172a] text-white border border-slate-700 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-300 mb-1">Ngành nghề</label>
                    <input asp-for="Industry"
                           class="w-full bg-[#0f172a] text-white border border-slate-700 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                </div>
            </div>

            <!-- Company Size -->
            <div>
                <label class="block text-sm font-medium text-slate-300 mb-1">Quy mô công ty</label>
                <select asp-for="CompanySize"
                        class="w-full bg-[#0f172a] text-white border border-slate-700 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                    <option value="">-- Chọn quy mô --</option>
                    <option value="1-10">1 - 10 nhân viên</option>
                    <option value="11-50">11 - 50 nhân viên</option>
                    <option value="51-200">51 - 200 nhân viên</option>
                    <option value="200+">Trên 200 nhân viên</option>
                </select>
            </div>

            <!-- Address -->
            <div>
                <label class="block text-sm font-medium text-slate-300 mb-1">Địa chỉ</label>
                <input asp-for="Address"
                       class="w-full bg-[#0f172a] text-white border border-slate-700 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
            </div>

            <!-- Website -->
            <div>
                <label class="block text-sm font-medium text-slate-300 mb-1">Website</label>
                <input asp-for="Website" type="url" placeholder="https://example.com"
                       class="w-full bg-[#0f172a] text-white border border-slate-700 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
            </div>

            <!-- Logo + Ảnh bìa -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-slate-300 mb-1">Logo công ty</label>

                    <!-- Preview -->
                    <div id="logoPreview" class="hidden relative w-24 h-24 rounded-full overflow-hidden border border-slate-700 mb-2 group">
                        <img id="logoImg" src="" class="w-full h-full object-cover" />
                        <button type="button" id="logoRemoveBtn" class="absolute top-0.5 right-0.5 w-6 h-6 rounded-full bg-[#1e293b] text-white flex items-center justify-center shadow">
                            <span class="material-icons text-sm">close</span>
                        </button>
                    </div>
                    <div id="logoPlaceholder" class="w-24 h-24 rounded-full border-2 border-dashed border-slate-700 bg-[#0f172a] flex flex-col items-center justify-center mb-2 cursor-pointer hover:border-blue-500 hover:bg-blue-500/10 transition-all">
                        <span class="material-icons text-lg text-slate-400">add_a_photo</span>
                    </div>

                    <input type="file" id="logoFileInput" accept="image/*" class="hidden" />
                    <button type="button" id="logoUploadBtn"
                            class="w-full mb-2 py-2 border border-slate-700 rounded-lg text-xs text-slate-300 hover:bg-[#0f172a] transition-colors flex items-center justify-center gap-1">
                        <span class="material-icons text-sm">upload</span> Tải ảnh từ máy tính
                    </button>
                    <input asp-for="LogoURL" id="logoUrlInput" placeholder="https://..."
                           class="w-full bg-[#0f172a] text-white border border-slate-700 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-300 mb-1">Ảnh bìa công ty</label>

                    <!-- Preview -->
                    <div id="coverPreview" class="hidden relative h-24 rounded-lg overflow-hidden border border-slate-700 mb-2 group">
                        <img id="coverImg" src="" class="w-full h-full object-cover" />
                        <button type="button" id="coverRemoveBtn" class="absolute top-1.5 right-1.5 w-6 h-6 rounded-full bg-[#1e293b] text-white flex items-center justify-center shadow">
                            <span class="material-icons text-sm">close</span>
                        </button>
                    </div>
                    <div id="coverPlaceholder" class="h-24 rounded-lg border-2 border-dashed border-slate-700 bg-[#0f172a] flex flex-col items-center justify-center mb-2 cursor-pointer hover:border-blue-500 hover:bg-blue-500/10 transition-all">
                        <span class="material-icons text-lg text-slate-400">add_photo_alternate</span>
                    </div>

                    <input type="file" id="coverFileInput" accept="image/*" class="hidden" />
                    <button type="button" id="coverUploadBtn"
                            class="w-full mb-2 py-2 border border-slate-700 rounded-lg text-xs text-slate-300 hover:bg-[#0f172a] transition-colors flex items-center justify-center gap-1">
                        <span class="material-icons text-sm">upload</span> Tải ảnh từ máy tính
                    </button>
                    <input asp-for="CoverURL" id="coverUrlInput" placeholder="https://..."
                           class="w-full bg-[#0f172a] text-white border border-slate-700 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                </div>
            </div>

            <!-- Description -->
            <div>
                <label class="block text-sm font-medium text-slate-300 mb-1">Mô tả công ty</label>
                <textarea asp-for="Description" rows="5" placeholder="Giới thiệu về công ty..."
                          class="w-full bg-[#0f172a] text-white border border-slate-700 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 resize-none"></textarea>
            </div>

            <!-- Why work here -->
            @{
                var highlights = Model.WhyWorkHereItems;
                if (!highlights.Any())
                {
                    highlights = new List<JobConnect.Models.CompanyHighlight>
                    {
                        new() { Icon = "diversity_3", Title = "", Description = "", IsHighlighted = false },
                        new() { Icon = "rocket_launch", Title = "", Description = "", IsHighlighted = false },
                        new() { Icon = "redeem", Title = "", Description = "", IsHighlighted = true }
                    };
                }
            }
            <div>
                <div class="flex items-center justify-between mb-2">
                    <div>
                        <label class="block text-sm font-medium text-slate-300">Tại sao nên làm việc tại công ty?</label>
                        <p class="text-xs text-slate-400 mt-0.5">Thêm các điểm nổi bật để thu hút ứng viên.</p>
                    </div>
                    <button type="button" id="addHighlightBtn"
                            class="text-blue-600 text-sm font-medium hover:underline flex items-center gap-1 shrink-0">
                        <span class="material-icons text-base">add</span> Thêm mục
                    </button>
                </div>
                <div id="highlightsContainer" class="space-y-3">
                    @for (var i = 0; i < highlights.Count; i++)
                    {
                        var h = highlights[i];
                        <div class="highlight-item border border-slate-700 rounded-lg p-4 bg-[#0f172a]">
                            <div class="flex items-center justify-between mb-3">
                                <span class="text-xs font-semibold text-slate-400 uppercase tracking-wide">Mục @(i + 1)</span>
                                <button type="button" class="remove-highlight text-red-400 text-xs hover:underline flex items-center gap-1">
                                    <span class="material-icons text-sm">delete</span> Xóa
                                </button>
                            </div>
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                                <div>
                                    <label class="block text-xs font-medium text-slate-300 mb-1">Biểu tượng</label>
                                    <select name="highlights[@i].Icon"
                                            class="w-full bg-[#0f172a] text-white border border-slate-700 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                                        @{
                                            var icons = new[] {
                                                ("diversity_3", "Đa văn hóa"),
                                                ("rocket_launch", "Thăng tiến"),
                                                ("redeem", "Phúc lợi"),
                                                ("groups", "Đội ngũ"),
                                                ("school", "Đào tạo"),
                                                ("health_and_safety", "Bảo hiểm"),
                                                ("fitness_center", "Gym / Sức khỏe"),
                                                ("work", "Công việc"),
                                                ("star", "Ngôi sao"),
                                                ("emoji_events", "Thành tựu")
                                            };
                                        }
                                        @foreach (var (icon, label) in icons)
                                        {
                                            @if (h.Icon == icon)
                                            {
                                                <option value="@icon" selected>@label</option>
                                            }
                                            else
                                            {
                                                <option value="@icon">@label</option>
                                            }
                                        }
                                    </select>
                                </div>
                                <div>
                                    <label class="block text-xs font-medium text-slate-300 mb-1">Tiêu đề <span class="text-red-500">*</span></label>
                                    <input name="highlights[@i].Title" value="@h.Title" placeholder="VD: Môi trường đa văn hóa"
                                           class="w-full bg-[#0f172a] text-white border border-slate-700 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                                </div>
                            </div>
                            <div class="mt-3">
                                <label class="block text-xs font-medium text-slate-300 mb-1">Mô tả</label>
                                <textarea name="highlights[@i].Description" rows="2" placeholder="Mô tả ngắn về điểm nổi bật..."
                                          class="w-full bg-[#0f172a] text-white border border-slate-700 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 resize-none">@h.Description</textarea>
                            </div>
                            <label class="flex items-center gap-2 mt-3 text-sm text-slate-300 cursor-pointer">
                                <input type="hidden" name="highlights[@i].IsHighlighted" value="false" />
                                <input type="checkbox" name="highlights[@i].IsHighlighted" value="true" @(h.IsHighlighted ? "checked" : "")
                                       class="rounded border-slate-700 text-blue-600 focus:ring-blue-500" />
                                Hiển thị dạng nổi bật
                            </label>
                        </div>
                    }
                </div>
            </div>

        </div>

        <!-- Submit -->
        <div class="flex justify-end pt-2">
            <button type="submit"
                    class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2.5 rounded-lg text-sm font-medium">
                Lưu thay đổi
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        // ----- Logo & Ảnh bìa: preview + upload từ máy tính -----
        (function () {
            function setImage(kind, value) {
                const urlInput = document.getElementById(kind + 'UrlInput');
                const img = document.getElementById(kind + 'Img');
                const preview = document.getElementById(kind + 'Preview');
                const placeholder = document.getElementById(kind + 'Placeholder');
                urlInput.value = value || '';
                if (value) {
                    img.src = value;
                    preview.classList.remove('hidden');
                    placeholder.classList.add('hidden');
                } else {
                    img.src = '';
                    preview.classList.add('hidden');
                    placeholder.classList.remove('hidden');
                }
            }

            function setupImageField(kind) {
                const urlInput = document.getElementById(kind + 'UrlInput');
                const uploadBtn = document.getElementById(kind + 'UploadBtn');
                const placeholder = document.getElementById(kind + 'Placeholder');
                const fileInput = document.getElementById(kind + 'FileInput');
                const removeBtn = document.getElementById(kind + 'RemoveBtn');

                // Hiển thị sẵn ảnh hiện có (nếu đã lưu trước đó)
                if (urlInput.value) setImage(kind, urlInput.value);

                // Gõ URL ảnh trực tiếp
                urlInput.addEventListener('input', function () {
                    setImage(kind, this.value.trim());
                });

                // Bấm nút hoặc bấm vào khung trống để mở hộp thoại chọn file
                uploadBtn.addEventListener('click', () => fileInput.click());
                placeholder.addEventListener('click', () => fileInput.click());

                // Đọc file ảnh đã chọn và chuyển thành base64 để lưu
                fileInput.addEventListener('change', function () {
                    const file = this.files[0];
                    if (!file) return;
                    if (!file.type.startsWith('image/')) {
                        alert('Vui lòng chọn một tệp hình ảnh.');
                        return;
                    }
                    const reader = new FileReader();
                    reader.onload = function (e) {
                        setImage(kind, e.target.result);
                    };
                    reader.readAsDataURL(file);
                });

                // Xóa ảnh hiện tại
                removeBtn.addEventListener('click', () => {
                    fileInput.value = '';
                    setImage(kind, '');
                });
            }

            setupImageField('logo');
            setupImageField('cover');
        })();

        (function () {
            const container = document.getElementById('highlightsContainer');
            const addBtn = document.getElementById('addHighlightBtn');

            const iconOptions = `
                <option value="diversity_3">Đa văn hóa</option>
                <option value="rocket_launch">Thăng tiến</option>
                <option value="redeem">Phúc lợi</option>
                <option value="groups">Đội ngũ</option>
                <option value="school">Đào tạo</option>
                <option value="health_and_safety">Bảo hiểm</option>
                <option value="fitness_center">Gym / Sức khỏe</option>
                <option value="work">Công việc</option>
                <option value="star">Ngôi sao</option>
                <option value="emoji_events">Thành tựu</option>`;

            function reindexItems() {
                container.querySelectorAll('.highlight-item').forEach((item, index) => {
                    item.querySelector('.text-xs.font-semibold').textContent = `Mục ${index + 1}`;
                    item.querySelectorAll('[name^="highlights["]').forEach(el => {
                        el.name = el.name.replace(/highlights\[\d+\]/, `highlights[${index}]`);
                    });
                });
            }

            function bindRemove(btn) {
                btn.addEventListener('click', () => {
                    if (container.querySelectorAll('.highlight-item').length <= 1) return;
                    btn.closest('.highlight-item').remove();
                    reindexItems();
                });
            }

            container.querySelectorAll('.remove-highlight').forEach(bindRemove);

            addBtn.addEventListener('click', () => {
                const index = container.querySelectorAll('.highlight-item').length;
                const div = document.createElement('div');
                div.className = 'highlight-item border border-slate-700 rounded-lg p-4 bg-[#0f172a]';
                div.innerHTML = `
                    <div class="flex items-center justify-between mb-3">
                        <span class="text-xs font-semibold text-slate-400 uppercase tracking-wide">Mục ${index + 1}</span>
                        <button type="button" class="remove-highlight text-red-400 text-xs hover:underline flex items-center gap-1">
                            <span class="material-icons text-sm">delete</span> Xóa
                        </button>
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                        <div>
                            <label class="block text-xs font-medium text-slate-300 mb-1">Biểu tượng</label>
                            <select name="highlights[${index}].Icon"
                                    class="w-full bg-[#0f172a] text-white border border-slate-700 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                                ${iconOptions}
                            </select>
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-slate-300 mb-1">Tiêu đề <span class="text-red-500">*</span></label>
                            <input name="highlights[${index}].Title" placeholder="VD: Môi trường đa văn hóa"
                                   class="w-full bg-[#0f172a] text-white border border-slate-700 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                        </div>
                    </div>
                    <div class="mt-3">
                        <label class="block text-xs font-medium text-slate-300 mb-1">Mô tả</label>
                        <textarea name="highlights[${index}].Description" rows="2" placeholder="Mô tả ngắn về điểm nổi bật..."
                                  class="w-full bg-[#0f172a] text-white border border-slate-700 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 resize-none"></textarea>
                    </div>
                    <label class="flex items-center gap-2 mt-3 text-sm text-slate-300 cursor-pointer">
                        <input type="hidden" name="highlights[${index}].IsHighlighted" value="false" />
                        <input type="checkbox" name="highlights[${index}].IsHighlighted" value="true"
                               class="rounded border-slate-700 text-blue-600 focus:ring-blue-500" />
                        Hiển thị dạng nổi bật
                    </label>`;
                container.appendChild(div);
                bindRemove(div.querySelector('.remove-highlight'));
            });
        })();
    </script>
}
