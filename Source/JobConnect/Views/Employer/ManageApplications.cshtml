@using JobConnect.Models
@model List<Application>
@{
    ViewData["Title"] = "Quản lý đơn ứng tuyển";
    Layout = "_LayoutEmployer";

    var job = ViewBag.Job as JobPost;

    var statuses = new[] { "Tất cả", "Pending", "Reviewing", "Interview", "Accepted", "Rejected" };
    var filterParam = Context.Request.Query["status"].ToString();
    var currentFilter = string.IsNullOrEmpty(filterParam) ? "Tất cả" : filterParam;
    var filteredApps = (currentFilter == "Tất cả")
        ? Model
        : Model.Where(a => a.Status == currentFilter).ToList();
}

<div class="max-w-6xl mx-auto px-6 py-8">
    <div class="flex items-center gap-4 mb-6">
        <a asp-controller="Employer" asp-action="Dashboard"
           class="text-secondary hover:text-primary flex items-center gap-1">
            <span class="material-symbols-outlined">arrow_back</span> Quay lại
        </a>
        <div>
            <h1 class="text-2xl font-bold text-on-surface">Quản lý đơn ứng tuyển</h1>
            <p class="text-secondary">
                Vị trí: <span class="font-semibold">@job?.Title</span>
                • @Model.Count đơn ứng tuyển
            </p>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="mb-4 px-4 py-3 bg-green-100 text-green-700 rounded-xl text-sm font-medium flex items-center gap-2">
            <span class="material-symbols-outlined text-base">check_circle</span>
            @TempData["Success"]
        </div>
    }

    @if (!Model.Any())
    {
        <div class="bg-white rounded-2xl p-12 text-center border border-outline-variant">
            <span class="material-symbols-outlined text-6xl text-secondary mb-4">inbox</span>
            <p class="text-lg text-secondary">Chưa có ứng viên nào nộp đơn cho tin tuyển dụng này.</p>
        </div>
    }
    else
    {
        <!-- Lọc theo trạng thái -->
        <div class="flex flex-wrap gap-2 mb-5">
            @foreach (var s in statuses)
            {
                var href = s == "Tất cả"
                    ? Url.Action("ManageApplications", new { jobId = job!.JobID })
                    : Url.Action("ManageApplications", new { jobId = job!.JobID, status = s });
                var isActive = currentFilter == s;
                var btnCls = isActive
                    ? "bg-primary text-white border-primary"
                    : "bg-white text-secondary border-outline-variant hover:border-primary hover:text-primary";
                <a href="@href" class="px-4 py-1.5 rounded-full text-sm font-medium border transition-colors @btnCls">@s</a>
            }
        </div>

        @if (!filteredApps.Any())
        {
            <div class="bg-white rounded-2xl p-10 text-center border border-outline-variant">
                <p class="text-secondary">Không có đơn nào ở trạng thái <strong>@currentFilter</strong>.</p>
            </div>
        }

        <div class="space-y-4">
            @foreach (var app in filteredApps)
            {
                var statusLabel = app.Status switch
                {
                    "Pending"   => "Chờ xử lý",
                    "Reviewing" => "Đang xem xét",
                    "Interview" => "Phỏng vấn",
                    "Accepted"  => "Chấp nhận",
                    "Rejected"  => "Từ chối",
                    _           => app.Status
                };
                var statusCls = app.Status switch
                {
                    "Accepted"  => "bg-green-100 text-green-700",
                    "Rejected"  => "bg-red-100 text-red-700",
                    "Interview" => "bg-purple-100 text-purple-700",
                    "Reviewing" => "bg-blue-100 text-blue-700",
                    _           => "bg-yellow-100 text-yellow-700"
                };

                <div class="bg-white border border-outline-variant rounded-2xl p-6 hover:shadow-md transition-all">
                    <div class="flex flex-col md:flex-row md:items-start gap-6">

                        <!-- Thông tin ứng viên -->
                        <div class="flex-1">
                            <div class="flex items-start gap-4">
                                <div class="w-12 h-12 bg-surface-container rounded-full flex items-center justify-center flex-shrink-0 overflow-hidden">
                                    @if (!string.IsNullOrEmpty(app.CandidateProfile?.Avatar))
                                    {
                                        <img src="@app.CandidateProfile.Avatar" class="w-12 h-12 rounded-full object-cover" alt="Avatar" />
                                    }
                                    else
                                    {
                                        <span class="material-symbols-outlined text-3xl text-secondary">person</span>
                                    }
                                </div>
                                <div class="flex-1 min-w-0">
                                    <h4 class="font-semibold text-on-surface">
                                        @(app.CandidateProfile?.FullName ?? "(Chưa có tên)")
                                    </h4>
                                    <p class="text-sm text-secondary">@app.CandidateProfile?.User?.Email</p>
                                    @if (!string.IsNullOrEmpty(app.CandidateProfile?.Phone))
                                    {
                                        <p class="text-sm text-secondary">@app.CandidateProfile.Phone</p>
                                    }
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(app.CoverLetter))
                            {
                                <div class="mt-4 bg-surface-container-low rounded-xl p-4">
                                    <p class="text-xs font-medium text-on-surface mb-1">Thư xin việc:</p>
                                    <p class="text-sm text-secondary line-clamp-4">@app.CoverLetter</p>
                                </div>
                            }
                        </div>

                        <!-- CV & Trạng thái & Hành động -->
                        <div class="flex flex-col items-end gap-3 min-w-[200px]">

                            <!-- Badge trạng thái -->
                            <span class="px-4 py-1.5 rounded-full text-xs font-semibold @statusCls">
                                @statusLabel
                            </span>

                            <p class="text-xs text-secondary">Nộp: @app.AppliedAt.ToString("dd/MM/yyyy HH:mm")</p>
                            @if (app.UpdatedAt.HasValue)
                            {
                                <p class="text-xs text-secondary">Cập nhật: @app.UpdatedAt.Value.ToString("dd/MM/yyyy HH:mm")</p>
                            }

                            <!-- Tải CV -->
                            @if (app.CvFile != null)
                            {
                                <a asp-controller="Employer" asp-action="DownloadCv" asp-route-cvId="@app.CvFile.CvID"
                                   class="flex items-center gap-2 px-4 py-2 bg-primary text-white rounded-xl hover:bg-primary/90 transition-colors text-sm font-medium w-full justify-center">
                                    <span class="material-symbols-outlined text-base">download</span>
                                    Tải CV
                                </a>
                            }
                            else
                            {
                                <span class="text-red-500 text-sm flex items-center gap-1">
                                    <span class="material-symbols-outlined text-base">warning</span>
                                    Không có CV
                                </span>
                            }

                            <!-- Nút cập nhật trạng thái -->
                            @if (app.Status != "Accepted" && app.Status != "Rejected")
                            {
                                <div class="w-full">
                                    <p class="text-xs text-secondary mb-1 text-right">Cập nhật trạng thái:</p>
                                    <div class="flex gap-1.5 flex-wrap justify-end">
                                        @if (app.Status != "Reviewing")
                                        {
                                            <form asp-controller="Employer" asp-action="UpdateApplicationStatus" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="appId" value="@app.AppID" />
                                                <input type="hidden" name="status" value="Reviewing" />
                                                <input type="hidden" name="jobId" value="@job!.JobID" />
                                                <button type="submit" class="flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs font-medium bg-blue-50 text-blue-700 hover:bg-blue-100 border border-blue-200 transition-colors">
                                                    <span class="material-symbols-outlined text-sm">visibility</span>
                                                    Xem xét
                                                </button>
                                            </form>
                                        }
                                        @if (app.Status != "Interview")
                                        {
                                            <form asp-controller="Employer" asp-action="UpdateApplicationStatus" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="appId" value="@app.AppID" />
                                                <input type="hidden" name="status" value="Interview" />
                                                <input type="hidden" name="jobId" value="@job!.JobID" />
                                                <button type="submit" class="flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs font-medium bg-purple-50 text-purple-700 hover:bg-purple-100 border border-purple-200 transition-colors">
                                                    <span class="material-symbols-outlined text-sm">event</span>
                                                    Phỏng vấn
                                                </button>
                                            </form>
                                        }
                                        <form asp-controller="Employer" asp-action="UpdateApplicationStatus" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="appId" value="@app.AppID" />
                                            <input type="hidden" name="status" value="Accepted" />
                                            <input type="hidden" name="jobId" value="@job!.JobID" />
                                            <button type="submit" class="flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs font-medium bg-green-50 text-green-700 hover:bg-green-100 border border-green-200 transition-colors">
                                                <span class="material-symbols-outlined text-sm">check_circle</span>
                                                Chấp nhận
                                            </button>
                                        </form>
                                        <form asp-controller="Employer" asp-action="UpdateApplicationStatus" method="post"
                                              onsubmit="return confirm('Bạn có chắc muốn từ chối đơn này?')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="appId" value="@app.AppID" />
                                            <input type="hidden" name="status" value="Rejected" />
                                            <input type="hidden" name="jobId" value="@job!.JobID" />
                                            <button type="submit" class="flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs font-medium bg-red-50 text-red-700 hover:bg-red-100 border border-red-200 transition-colors">
                                                <span class="material-symbols-outlined text-sm">cancel</span>
                                                Từ chối
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <form asp-controller="Employer" asp-action="UpdateApplicationStatus" method="post"
                                      onsubmit="return confirm('Đặt lại trạng thái đơn này về Đang xem xét?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="appId" value="@app.AppID" />
                                    <input type="hidden" name="status" value="Reviewing" />
                                    <input type="hidden" name="jobId" value="@job!.JobID" />
                                    <button type="submit" class="flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs font-medium bg-gray-100 text-gray-600 hover:bg-gray-200 border border-gray-300 transition-colors w-full justify-center">
                                        <span class="material-symbols-outlined text-sm">restart_alt</span>
                                        Đặt lại
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
