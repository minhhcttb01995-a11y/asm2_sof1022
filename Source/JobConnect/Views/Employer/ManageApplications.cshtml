@using JobConnect.Models
@model List<Application>
@{
    ViewData["Title"] = "Quản lý đơn ứng tuyển";
    Layout = "_LayoutEmployer";

    var job = ViewBag.Job as JobPost;

    var statuses = new[] { "Tất cả", "Pending", "Reviewing", "Interview", "Rejected" };
    var filterParam = Context.Request.Query["status"].ToString();
    var currentFilter = string.IsNullOrEmpty(filterParam) ? "Tất cả" : filterParam;
    var filteredApps = (currentFilter == "Tất cả")
        ? Model.ToList()
        : Model.Where(a => a.Status == currentFilter).ToList();
}

<div class="max-w-6xl mx-auto px-6 py-8">
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Quản lý đơn ứng tuyển</h1>
            <p class="text-gray-600 text-sm mt-1">
                Vị trí: <span class="font-semibold text-gray-900">@job?.Title</span> • @Model.Count đơn ứng tuyển
            </p>
        </div>
        <a asp-action="Dashboard"
           class="px-4 py-2 border border-gray-300 rounded-lg text-sm font-medium hover:bg-gray-50">
            Quay lại
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="mb-4 px-4 py-3 bg-green-50 border border-green-200 text-green-800 rounded-xl text-sm flex items-center gap-2">
            <span class="material-symbols-outlined text-green-600 text-base">check_circle</span>
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="mb-4 px-4 py-3 bg-red-50 border border-red-200 text-red-800 rounded-xl text-sm flex items-center gap-2">
            <span class="material-symbols-outlined text-red-600 text-base">error</span>
            @TempData["Error"]
        </div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-12">
            <span class="material-icons text-gray-400 text-6xl mb-4">inbox</span>
            <p class="text-lg text-gray-600">Chưa có ứng viên nào nộp đơn cho tin tuyển dụng này.</p>
        </div>
    }
    else
    {
        <!-- Lọc theo trạng thái -->
        <div class="flex flex-wrap gap-2 mb-5">
            @foreach (var status in statuses)
            {
                <a asp-action="ManageApplications" asp-route-jobId="@job?.JobID" asp-route-status="@(status == "Tất cả" ? "" : status)"
                   class="px-3 py-1.5 rounded-lg text-sm font-medium transition-colors
                    @(currentFilter == status ? "bg-blue-600 text-white" : "bg-gray-100 text-gray-700 hover:bg-gray-200")">
                    @status
                </a>
            }
        </div>

        <!-- Danh sách ứng viên -->
        <div class="bg-white rounded-xl border border-gray-200 overflow-hidden shadow-sm">
            <table class="w-full text-left">
                <thead class="bg-gray-50 border-b border-gray-200">
                    <tr>
                        <th class="px-5 py-3 text-left text-sm font-semibold text-gray-700">Ứng viên</th>
                        <th class="px-5 py-3 text-left text-sm font-semibold text-gray-700">Ngày nộp</th>
                        <th class="px-5 py-3 text-left text-sm font-semibold text-gray-700">Trạng thái</th>
                        <th class="px-5 py-3 text-left text-sm font-semibold text-gray-700">Hành động</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                    @foreach (var app in filteredApps)
                    {
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="px-5 py-3">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center text-blue-600 font-bold">
                                        @((app.CandidateProfile?.User?.FullName?[0].ToString().ToUpper() ?? "U"))
                                    </div>
                                    <div>
                                        <div class="font-medium text-gray-900">@app.CandidateProfile?.User?.FullName</div>
                                        <div class="text-xs text-gray-500">@app.CandidateProfile?.User?.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-5 py-3 text-gray-600 text-sm">@app.AppliedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="px-5 py-3">
                                <span class="px-2.5 py-1 rounded-full text-xs font-medium
                                    @(app.Status == "Pending" ? "bg-yellow-100 text-yellow-700" :
                                          app.Status == "Reviewing" ? "bg-blue-100 text-blue-700" :
                                          app.Status == "Interview" ? "bg-purple-100 text-purple-700" :
                                          app.Status == "Accepted" ? "bg-green-100 text-green-700" :
                                          app.Status == "Rejected" ? "bg-red-100 text-red-600" :
                                          "bg-gray-100 text-gray-600")">
                                    @(app.Status == "Pending" ? "Chờ xét duyệt" :
                                      app.Status == "Reviewing" ? "Đang xem xét" :
                                      app.Status == "Interview" ? "Mời phỏng vấn" :
                                      app.Status == "Accepted" ? "Đã nhận" :
                                      app.Status == "Rejected" ? "Từ chối" : app.Status)
                                </span>
                            </td>
                            <td class="px-5 py-3">
                                <div class="flex items-center gap-2 flex-wrap">
                                    @* Tải CV *@
                                    @if (app.CvFile != null)
                                    {
                                        <a asp-action="DownloadCv" asp-route-cvId="@app.CVID"
                                           class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-blue-600 border border-blue-200 rounded-lg hover:bg-blue-50 transition-colors">
                                            <span class="material-symbols-outlined text-sm">download</span>
                                            Tải CV
                                        </a>
                                    }

                                    @* Nút Mời phỏng vấn — chỉ hiện nếu chưa reject hoặc chưa phỏng vấn *@
                                    @if (app.Status != "Rejected" && app.Status != "Interview" && app.Status != "Accepted")
                                    {
                                        <a asp-action="ScheduleInterview" asp-route-appId="@app.AppID"
                                           class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors">
                                            <span class="material-symbols-outlined text-sm">event</span>
                                            Mời phỏng vấn
                                        </a>
                                    }
                                    @if (app.Status == "Interview")
                                    {
                                        <a asp-action="ScheduleInterview" asp-route-appId="@app.AppID"
                                           class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-purple-700 border border-purple-200 rounded-lg hover:bg-purple-50 transition-colors">
                                            <span class="material-symbols-outlined text-sm">edit_calendar</span>
                                            Cập nhật lịch
                                        </a>
                                    }

                                    @* Nút Từ chối *@
                                    @if (app.Status != "Rejected")
                                    {
                                        <form asp-action="RejectApplication" method="post" class="inline"
                                              onsubmit="return confirm('Bạn có chắc muốn từ chối ứng viên này?')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="appId" value="@app.AppID" />
                                            <button type="submit"
                                                    class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-red-600 border border-red-200 rounded-lg hover:bg-red-50 transition-colors">
                                                <span class="material-symbols-outlined text-sm">cancel</span>
                                                Từ chối
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
