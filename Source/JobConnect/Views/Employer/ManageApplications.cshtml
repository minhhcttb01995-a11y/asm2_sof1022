@using JobConnect.Models
@model List<Application>
@{
    ViewData["Title"] = "Quản lý đơn ứng tuyển";
    Layout = "_LayoutEmployer";
}

<div class="max-w-6xl mx-auto px-6 py-8">
    <!-- Header -->
    <div class="flex items-center gap-4 mb-6">
        <a asp-action="Dashboard" class="text-secondary hover:text-primary">
            <span class="material-symbols-outlined align-middle">arrow_back</span>
        </a>
        <div>
            <h1 class="text-2xl font-bold text-on-surface">Quản lý đơn ứng tuyển</h1>
            <p class="text-secondary text-sm mt-0.5">
                Vị trí: <span class="font-semibold text-on-surface">@(ViewBag.Job as JobPost)?.Title</span>
                &nbsp;·&nbsp; <span>@Model.Count đơn</span>
            </p>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="bg-white rounded-xl border border-outline-variant p-16 text-center">
            <span class="material-symbols-outlined text-5xl text-secondary block mb-3">inbox</span>
            <p class="text-secondary">Chưa có đơn ứng tuyển nào cho vị trí này.</p>
            <a asp-action="Dashboard" class="text-primary text-sm mt-3 inline-block hover:underline">← Quay lại Dashboard</a>
        </div>
    }
    else
    {
        <div class="space-y-4">
            @foreach (var app in Model)
            {
                <div class="bg-white rounded-xl border border-outline-variant p-5 hover:shadow-md transition-shadow">
                    <div class="flex items-start justify-between gap-4">

                        <!-- Candidate info -->
                        <div class="flex items-start gap-4 flex-1">
                            <div class="w-12 h-12 rounded-full bg-surface-container flex items-center justify-center flex-shrink-0">
                                @if (!string.IsNullOrEmpty(app.CandidateProfile?.User?.AvatarURL))
                                {
                                    <img src="@app.CandidateProfile.User.AvatarURL"
                                         class="w-12 h-12 rounded-full object-cover" />
                                }
                                else
                                {
                                    <span class="material-symbols-outlined text-secondary">person</span>
                                }
                            </div>
                            <div class="flex-1 min-w-0">
                                <p class="font-semibold text-on-surface">@app.CandidateProfile?.User?.FullName</p>
                                <p class="text-secondary text-sm">@app.CandidateProfile?.User?.Email</p>
                                @if (app.CandidateProfile?.User?.PhoneNumber != null)
                                {
                                    <p class="text-secondary text-sm">
                                        <span class="material-symbols-outlined text-xs align-middle">phone</span>
                                        @app.CandidateProfile.User.PhoneNumber
                                    </p>
                                }
                                <div class="flex flex-wrap gap-2 mt-2 text-xs text-secondary">
                                    <span>
                                        <span class="material-symbols-outlined text-xs align-middle">work</span>
                                        @app.CandidateProfile?.ExperienceYears năm kinh nghiệm
                                    </span>
                                    @if (app.CandidateProfile?.DesiredSalary.HasValue == true)
                                    {
                                        <span>
                                            <span class="material-symbols-outlined text-xs align-middle">payments</span>
                                            Lương muốn: @app.CandidateProfile.DesiredSalary.Value.ToString("N0") VND
                                        </span>
                                    }
                                </div>
                                @if (!string.IsNullOrEmpty(app.CoverLetter))
                                {
                                    <div class="mt-3 bg-surface-container-low rounded-lg p-3">
                                        <p class="text-xs font-medium text-on-surface mb-1">Thư giới thiệu:</p>
                                        <p class="text-sm text-secondary line-clamp-3">@app.CoverLetter</p>
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- Right side: status + actions -->
                        <div class="flex flex-col items-end gap-3 flex-shrink-0">
                            <span class="px-3 py-1 rounded-full text-xs font-semibold
                                @(app.Status == "Accepted" ? "bg-green-100 text-green-700" :
                                    app.Status == "Rejected" ? "bg-red-100 text-red-700" :
                                    app.Status == "Interview" ? "bg-blue-100 text-blue-700" :
                                    app.Status == "Reviewed" ? "bg-yellow-100 text-yellow-700" :
                                                                "bg-gray-100 text-gray-600")">
                                @(app.Status switch
                                {
                                    "Pending" => "Chờ xem xét",
                                    "Reviewed" => "Đã xem",
                                    "Interview" => "Mời phỏng vấn",
                                    "Accepted" => "Chấp nhận",
                                    "Rejected" => "Từ chối",
                                    _ => app.Status
                                })
                            </span>

                            <p class="text-xs text-secondary">
                                Nộp: @app.AppliedAt.ToString("dd/MM/yyyy HH:mm")
                            </p>

                            @if (app.CvFile != null)
                            {
                                <a href="@app.CvFile.FilePath" target="_blank"
                                   class="flex items-center gap-1.5 text-xs text-primary border border-primary px-3 py-1.5 rounded-lg hover:bg-primary hover:text-white transition-colors">
                                    <span class="material-symbols-outlined text-sm">download</span>
                                    Tải CV
                                </a>
                            }
                        </div>
                    </div>

                    <!-- Action buttons -->
                    <div class="mt-4 pt-4 border-t border-outline-variant flex flex-wrap gap-2">
                        @foreach (var (label, value, colorClass) in new[]{
              ("Đã xem",         "Reviewed",  "bg-yellow-100 text-yellow-700 hover:bg-yellow-200"),
              ("Mời phỏng vấn",  "Interview", "bg-blue-100 text-blue-700 hover:bg-blue-200"),
              ("Chấp nhận",      "Accepted",  "bg-green-100 text-green-700 hover:bg-green-200"),
              ("Từ chối",        "Rejected",  "bg-red-100 text-red-700 hover:bg-red-200"),
            })
                        {
                            <form asp-action="UpdateApplicationStatus" method="post" class="inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="appId" value="@app.AppID" />
                                <input type="hidden" name="jobId" value="@(ViewBag.Job as JobPost)?.JobID" />
                                <input type="hidden" name="status" value="@value" />
                                <button type="submit"
                                        class="px-4 py-1.5 rounded-lg text-xs font-medium transition-colors @colorClass
                                    @(app.Status == value ? "ring-2 ring-offset-1 ring-current" : "")">
                                    @label
                                </button>
                            </form>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>