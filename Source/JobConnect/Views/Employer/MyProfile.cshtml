@model JobConnect.Models.User
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
    Layout = "_LayoutEmployer";
    var emp = ViewBag.Employer as JobConnect.Models.Employer;
}

<div class="max-w-3xl mx-auto px-6 py-8">
    <div class="flex items-center gap-3 mb-6">
        <a asp-action="Dashboard" class="p-2 rounded-lg hover:bg-[#1e293b]/10 text-slate-300">
            <span class="material-icons">arrow_back</span>
        </a>
        <div>
            <h1 class="text-2xl font-bold text-white">Hồ sơ cá nhân</h1>
            <p class="text-slate-400 text-sm">Thông tin tài khoản người đại diện tuyển dụng</p>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="mb-4 px-4 py-3 bg-green-500/10 text-green-400 border border-green-500/30 rounded-xl text-sm font-medium flex items-center gap-2">
            <span class="material-icons text-base">check_circle</span>
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="mb-4 px-4 py-3 bg-red-500/10 text-red-400 border border-red-500/30 rounded-xl text-sm font-medium flex items-center gap-2">
            <span class="material-icons text-base">error</span>
            @TempData["Error"]
        </div>
    }

    <!-- ===== Thông tin cá nhân ===== -->
    <form asp-action="MyProfile" method="post" class="space-y-6">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="UserId" />
        <input type="hidden" asp-for="Email" />
        <input type="hidden" asp-for="Role" />
        <input type="hidden" asp-for="Status" />
        <input type="hidden" asp-for="CreatedAt" />
        <input type="hidden" asp-for="UserCode" />

        <div class="bg-[#1e293b] rounded-xl p-6 border border-slate-700 shadow-sm">
            <h2 class="text-base font-semibold text-white mb-4 flex items-center gap-2">
                <span class="material-icons text-blue-500 text-lg">badge</span>
                Thông tin tài khoản
            </h2>

            <!-- Avatar -->
            <div class="flex items-center gap-4 mb-6">
                <div class="relative">
                    <div id="avatarPreview" class="@(string.IsNullOrEmpty(Model.AvatarUrl) ? "hidden" : "") w-20 h-20 rounded-full overflow-hidden border border-slate-700">
                        <img id="avatarImg" src="@Model.AvatarUrl" class="w-full h-full object-cover" />
                    </div>
                    <div id="avatarPlaceholder" class="@(string.IsNullOrEmpty(Model.AvatarUrl) ? "" : "hidden") w-20 h-20 rounded-full border-2 border-dashed border-slate-700 bg-[#0f172a] flex items-center justify-center">
                        <span class="material-icons text-2xl text-slate-400">person</span>
                    </div>
                </div>
                <div>
                    <input type="file" id="avatarFileInput" accept="image/*" class="hidden" />
                    <button type="button" id="avatarUploadBtn"
                            class="px-4 py-2 border border-slate-700 rounded-lg text-xs text-slate-300 hover:bg-[#0f172a] transition-colors flex items-center gap-1">
                        <span class="material-icons text-sm">upload</span> Tải ảnh đại diện
                    </button>
                    <p class="text-xs text-slate-500 mt-1">PNG, JPG tối đa 5MB</p>
                </div>
            </div>
            <input asp-for="AvatarUrl" id="avatarUrlInput" class="hidden" />

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-slate-300 mb-1">
                        Họ và tên <span class="text-red-500">*</span>
                    </label>
                    <input asp-for="FullName"
                           class="w-full bg-[#0f172a] text-white border border-slate-700 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                    <span asp-validation-for="FullName" class="text-red-500 text-xs mt-1 block"></span>
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-300 mb-1">Số điện thoại</label>
                    <input asp-for="PhoneNumber" placeholder="09xxxxxxxx"
                           class="w-full bg-[#0f172a] text-white border border-slate-700 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-4">
                <div>
                    <label class="block text-sm font-medium text-slate-300 mb-1">Giới tính</label>
                    <select name="gender"
                            class="w-full bg-[#0f172a] text-white border border-slate-700 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                        <option value="">-- Chọn giới tính --</option>
                        @{
                            var genderOptions = new[] { "Nam", "Nữ", "Khác" };
                        }
                        @foreach (var g in genderOptions)
                        {
                            if (emp?.Gender == g)
                            {
                                <option value="@g" selected>@g</option>
                            }
                            else
                            {
                                <option value="@g">@g</option>
                            }
                        }
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-300 mb-1">Số CCCD</label>
                    <input type="text" name="cccd" value="@emp?.CCCD" placeholder="9 hoặc 12 chữ số" maxlength="12" inputmode="numeric"
                           class="w-full bg-[#0f172a] text-white border border-slate-700 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-4">
                <div>
                    <label class="block text-sm font-medium text-slate-300 mb-1">Email đăng nhập</label>
                    <input value="@Model.Email" disabled
                           class="w-full bg-[#0f172a]/60 text-slate-400 border border-slate-800 rounded-lg px-4 py-2.5 text-sm cursor-not-allowed" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-300 mb-1">Mã người dùng</label>
                    <input value="@Model.UserCode" disabled
                           class="w-full bg-[#0f172a]/60 text-slate-400 border border-slate-800 rounded-lg px-4 py-2.5 text-sm cursor-not-allowed" />
                </div>
            </div>

            @if (emp != null)
            {
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-4">
                    <div>
                        <label class="block text-sm font-medium text-slate-300 mb-1">Công ty đại diện</label>
                        <input value="@emp.CompanyName" disabled
                               class="w-full bg-[#0f172a]/60 text-slate-400 border border-slate-800 rounded-lg px-4 py-2.5 text-sm cursor-not-allowed" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-300 mb-1">Mã công ty</label>
                        <input value="@emp.CompanyCode" disabled
                               class="w-full bg-[#0f172a]/60 text-slate-400 border border-slate-800 rounded-lg px-4 py-2.5 text-sm cursor-not-allowed" />
                    </div>
                </div>
            }

            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mt-4 text-xs text-slate-500">
                <div>Ngày tạo tài khoản: <span class="text-slate-300">@Model.CreatedAt.ToString("dd/MM/yyyy")</span></div>
                <div>Đăng nhập gần nhất: <span class="text-slate-300">@(Model.LastLoginAt?.ToString("dd/MM/yyyy HH:mm") ?? "—")</span></div>
                <div>Trạng thái: <span class="text-green-400">@Model.Status</span></div>
            </div>
        </div>

        <div class="flex justify-end pt-2">
            <button type="submit"
                    class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2.5 rounded-lg text-sm font-medium">
                Lưu thay đổi
            </button>
        </div>
    </form>

    <!-- ===== Bảo mật tài khoản ===== -->
    <div class="bg-[#1e293b] rounded-xl p-6 border border-slate-700 shadow-sm mt-8">
        <div class="flex items-start justify-between gap-4 flex-wrap">
            <div class="flex items-start gap-3">
                <div class="w-10 h-10 rounded-full flex items-center justify-center shrink-0 bg-blue-500/10">
                    <span class="material-icons text-blue-500">lock</span>
                </div>
                <div>
                    <h2 class="text-base font-semibold text-white">Bảo mật tài khoản</h2>
                    <p class="text-sm text-slate-400 mt-1">
                        Đổi mật khẩu, đổi email đăng nhập hoặc xóa tài khoản. Các thao tác này
                        yêu cầu xác thực bằng mã OTP gửi qua email để đảm bảo an toàn.
                    </p>
                </div>
            </div>
            <a asp-controller="Account" asp-action="Settings"
               class="shrink-0 px-5 py-2.5 bg-slate-700 hover:bg-slate-600 text-white rounded-lg text-sm font-medium flex items-center gap-2">
                <span class="material-icons text-base">settings</span>
                Cài đặt bảo mật
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const urlInput = document.getElementById('avatarUrlInput');
            const img = document.getElementById('avatarImg');
            const preview = document.getElementById('avatarPreview');
            const placeholder = document.getElementById('avatarPlaceholder');
            const uploadBtn = document.getElementById('avatarUploadBtn');
            const fileInput = document.getElementById('avatarFileInput');

            uploadBtn.addEventListener('click', () => fileInput.click());

            fileInput.addEventListener('change', () => {
                const file = fileInput.files[0];
                if (!file) return;
                if (file.size > 5 * 1024 * 1024) {
                    alert('Ảnh vượt quá 5MB.');
                    return;
                }
                const reader = new FileReader();
                reader.onload = (e) => {
                    const dataUrl = e.target.result;
                    urlInput.value = dataUrl;
                    img.src = dataUrl;
                    preview.classList.remove('hidden');
                    placeholder.classList.add('hidden');
                };
                reader.readAsDataURL(file);
            });
        })();
    </script>
}
