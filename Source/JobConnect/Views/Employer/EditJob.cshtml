@* [VIEW-HEADER-ADDED]
   View cho action "EditJob" trong khu vực trang quản lý Nhà tuyển dụng (EmployerController).
*@
@using JobConnect.ViewModels
@model PostJobViewModel
@{
    ViewData["Title"] = "Sửa tin tuyển dụng";
    Layout = "_LayoutEmployer";
    var statusOptions = new List<(string Value, string Label)>
    {
        ("Active", "Đang hiển thị"),
        ("Paused", "Tạm dừng"),
        ("Draft", "Bản nháp")
    };
}

<!-- Quill CSS -->
<link href="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.snow.css" rel="stylesheet" />
<style>
    .ql-toolbar.ql-snow {
        border-radius: 12px 12px 0 0;
        border-color: #e2e8f0;
        background: #f8fafc;
    }

    .ql-container.ql-snow {
        border-radius: 0 0 12px 12px;
        border-color: #e2e8f0;
        font-size: 14px;
    }

    .ql-editor {
        min-height: 320px;
        line-height: 1.75;
    }

        .ql-editor.ql-blank::before {
            color: #94a3b8;
            font-style: normal;
        }
</style>

<div class="max-w-[1300px] mx-auto pb-10">

    <!-- Header -->
    <div class="flex items-center gap-3 mb-6">
        <a asp-action="Dashboard"
           class="w-9 h-9 flex items-center justify-center rounded-xl bg-[#1e293b] border border-slate-700 text-slate-300 hover:bg-slate-700 transition-colors">
            <span class="material-symbols-outlined text-xl">arrow_back</span>
        </a>
        <div>
            <h1 class="text-xl font-bold text-white">Sửa tin tuyển dụng</h1>
            <p class="text-sm text-slate-400">Cập nhật thông tin tin đã đăng</p>
        </div>
    </div>

    <form asp-action="EditJob" method="post" id="jobForm">
        <input type="hidden" asp-for="JobId" />

        <div asp-validation-summary="ModelOnly"
             class="bg-red-500/10 border border-red-500/20 text-red-400 text-sm rounded-xl px-4 py-3 mb-5"></div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">

            <!-- Cột chính -->
            <div class="lg:col-span-2 space-y-5">

                <!-- Thông tin cơ bản -->
                <div class="bg-[#1e293b] rounded-2xl border border-slate-700 p-5 shadow-sm">
                    <h3 class="font-semibold text-white mb-4 flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary text-base">edit_note</span>
                        Thông tin cơ bản
                    </h3>

                    <div class="space-y-1 mb-4">
                        <label class="block text-sm font-medium text-slate-300">
                            Tiêu đề công việc <span class="text-red-500">*</span>
                        </label>
                        <input asp-for="Title" id="titleInput" placeholder="VD: Senior Backend Developer" required
                               class="w-full px-4 py-2.5 bg-[#0f172a] border border-slate-700 rounded-xl text-sm text-white placeholder-slate-400 outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all" />
                        <div class="flex justify-between mt-1">
                            <span asp-validation-for="Title" class="text-red-500 text-xs"></span>
                            <span class="text-xs text-slate-400" id="titleCount">0 / 120</span>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="space-y-1">
                            <label class="block text-sm font-medium text-slate-300">Ngành nghề <span class="text-red-500">*</span></label>
                            <select asp-for="CategoryID" asp-items="ViewBag.Categories"
                                    class="w-full px-4 py-2.5 bg-[#0f172a] border border-slate-700 rounded-xl text-sm text-white outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all">
                                <option value="">-- Chọn ngành nghề --</option>
                            </select>
                        </div>
                        <div class="space-y-1">
                            <label class="block text-sm font-medium text-slate-300">Hình thức làm việc</label>
                            <select asp-for="JobType"
                                    class="w-full px-4 py-2.5 bg-[#0f172a] border border-slate-700 rounded-xl text-sm text-white outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all">
                                <option value="FullTime">Full-time</option>
                                <option value="PartTime">Part-time</option>
                                <option value="Contract">Hợp đồng</option>
                                <option value="Intern">Thực tập</option>
                                <option value="Remote">Remote</option>
                            </select>
                        </div>
                        <div class="space-y-1">
                            <label class="block text-sm font-medium text-slate-300">Cấp bậc kinh nghiệm</label>
                            <select asp-for="ExperienceLevel"
                                    class="w-full px-4 py-2.5 bg-[#0f172a] border border-slate-700 rounded-xl text-sm text-white outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all">
                                <option value="">Không yêu cầu</option>
                                <option value="Fresher">Fresher</option>
                                <option value="Junior">Junior</option>
                                <option value="Middle">Middle</option>
                                <option value="Senior">Senior</option>
                                <option value="Manager">Manager</option>
                            </select>
                        </div>
                        <div class="space-y-1">
                            <label class="block text-sm font-medium text-slate-300">Địa điểm làm việc</label>
                            <input asp-for="Location" placeholder="VD: Hà Nội, TP. HCM"
                                   class="w-full px-4 py-2.5 bg-[#0f172a] border border-slate-700 rounded-xl text-sm text-white placeholder-slate-400 outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all" />
                        </div>
                    </div>
                </div>

                <!-- Lương & Thời hạn -->
                <div class="bg-[#1e293b] rounded-2xl border border-slate-700 p-5 shadow-sm">
                    <h3 class="font-semibold text-white mb-4 flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary text-base">payments</span>
                        Lương &amp; Thời hạn
                    </h3>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <div class="space-y-1">
                            <label class="block text-sm font-medium text-slate-300">Lương tối thiểu (VND)</label>
                            <input asp-for="SalaryMin" type="number" placeholder="VD: 15000000"
                                   class="w-full px-4 py-2.5 bg-[#0f172a] border border-slate-700 rounded-xl text-sm text-white placeholder-slate-400 outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all" />
                        </div>
                        <div class="space-y-1">
                            <label class="block text-sm font-medium text-slate-300">Lương tối đa (VND)</label>
                            <input asp-for="SalaryMax" type="number" placeholder="VD: 30000000"
                                   class="w-full px-4 py-2.5 bg-[#0f172a] border border-slate-700 rounded-xl text-sm text-white placeholder-slate-400 outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all" />
                        </div>
                        <div class="space-y-1">
                            <label class="block text-sm font-medium text-slate-300">Ngày hết hạn</label>
                            <input asp-for="Deadline" type="date"
                                   class="w-full px-4 py-2.5 bg-[#0f172a] border border-slate-700 rounded-xl text-sm text-white outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all" />
                        </div>
                    </div>
                </div>

                <!-- Nội dung chi tiết -->
                <div class="bg-[#1e293b] rounded-2xl border border-slate-700 p-5 shadow-sm">
                    <h3 class="font-semibold text-white mb-4 flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary text-base">description</span>
                        Nội dung chi tiết
                    </h3>

                    <div class="space-y-1">
                        <label class="block text-sm font-medium text-slate-300 mb-2">
                            Mô tả công việc <span class="text-red-500">*</span>
                        </label>
                        <input type="hidden" asp-for="Description" id="descriptionHidden" />
                        <div id="descriptionEditor" class="rounded-xl overflow-hidden border border-slate-700"></div>
                        <span asp-validation-for="Description" class="text-red-500 text-xs mt-1 block"></span>
                        <p class="text-xs text-slate-400 mt-2 flex items-center gap-1">
                            <span class="material-symbols-outlined text-xs">info</span>
                            Hỗ trợ định dạng văn bản, heading, danh sách, link và hình ảnh
                        </p>
                    </div>

                    <div class="space-y-1 mt-5">
                        <label class="block text-sm font-medium text-slate-300 mb-2">
                            Yêu cầu ứng viên <span class="text-red-500">*</span>
                        </label>
                        <input type="hidden" asp-for="Requirements" id="requirementsHidden" />
                        <div id="requirementsEditor" class="rounded-xl overflow-hidden border border-slate-700"></div>
                        <span asp-validation-for="Requirements" class="text-red-500 text-xs mt-1 block"></span>
                        <p class="text-xs text-slate-400 mt-2 flex items-center gap-1">
                            <span class="material-symbols-outlined text-xs">info</span>
                            VD: số năm kinh nghiệm, bằng cấp, kỹ năng bắt buộc, ngoại ngữ...
                        </p>
                    </div>

                    <div class="space-y-1 mt-5">
                        <label class="block text-sm font-medium text-slate-300 mb-2">
                            Quyền lợi ứng viên <span class="text-red-500">*</span>
                        </label>
                        <input type="hidden" asp-for="Benefits" id="benefitsHidden" />
                        <div id="benefitsEditor" class="rounded-xl overflow-hidden border border-slate-700"></div>
                        <span asp-validation-for="Benefits" class="text-red-500 text-xs mt-1 block"></span>
                        <p class="text-xs text-slate-400 mt-2 flex items-center gap-1">
                            <span class="material-symbols-outlined text-xs">info</span>
                            VD: lương thưởng, bảo hiểm, lộ trình thăng tiến, chế độ nghỉ phép...
                        </p>
                    </div>
                </div>
            </div>

            <!-- Cột phụ -->
            <div class="space-y-5">

                <!-- Trạng thái tin -->
                <div class="bg-[#1e293b] rounded-2xl border border-slate-700 p-5 shadow-sm lg:sticky lg:top-5">
                    <h3 class="font-semibold text-white mb-3 flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary text-base">save</span>
                        Trạng thái tin
                    </h3>

                    <div class="space-y-1 mb-4">
                        <label class="block text-sm font-medium text-slate-300">Trạng thái</label>
                        <select asp-for="Status"
                                class="w-full px-4 py-2.5 bg-[#0f172a] border border-slate-700 rounded-xl text-sm text-white outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all">
                            @foreach (var opt in statusOptions)
                            {
                                <option value="@opt.Value">@opt.Label</option>
                            }
                        </select>
                    </div>

                    <div class="flex flex-col gap-2">
                        <button type="submit"
                                class="w-full px-4 py-2.5 bg-primary text-white text-sm font-semibold rounded-xl hover:opacity-90 transition-all shadow-sm flex items-center justify-center gap-2">
                            <span class="material-symbols-outlined text-base">save</span>
                            Lưu thay đổi
                        </button>
                        <a asp-action="Dashboard"
                           class="w-full text-center px-4 py-2.5 border border-slate-700 rounded-xl text-sm font-medium text-slate-400 hover:bg-slate-700 transition-colors">
                            Hủy
                        </a>
                    </div>
                </div>

                <!-- Quy mô công ty -->
                <div class="bg-[#1e293b] rounded-2xl border border-slate-700 p-5 shadow-sm">
                    <h3 class="font-semibold text-white mb-3 flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary text-base">groups</span>
                        Quy mô công ty
                    </h3>
                    @{
                        var companySize = ViewBag.CompanySize as string;
                        var companySizeLabel = companySize switch
                        {
                            "1-10" => "1 - 10 nhân viên",
                            "11-50" => "11 - 50 nhân viên",
                            "51-200" => "51 - 200 nhân viên",
                            "200+" => "Trên 200 nhân viên",
                            _ => null
                        };
                    }
                    @if (companySizeLabel != null)
                    {
                        <p class="text-sm font-medium text-slate-100">@companySizeLabel</p>
                    }
                    else
                    {
                        <p class="text-sm text-slate-400 italic">Chưa cập nhật quy mô công ty</p>
                    }
                    <a asp-action="CompanyProfile"
                       class="mt-3 inline-flex items-center gap-1 text-xs font-medium text-primary hover:underline">
                        <span class="material-symbols-outlined text-sm">edit</span>
                        Sửa tại Hồ sơ công ty
                    </a>
                </div>
            </div>
        </div>
    </form>
</div>

<script src="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.js"></script>
<script>
    const titleInput = document.getElementById('titleInput');
    const titleCount = document.getElementById('titleCount');
    if (titleInput && titleCount) {
    const updateCount = () => titleCount.textContent = titleInput.value.length + ' / 120';
    titleInput.addEventListener('input', updateCount);
    updateCount();
    }

    // Toolbar đầy đủ chức năng cho Mô tả công việc
    const descriptionQuill = new Quill('#descriptionEditor', {
    theme: 'snow',
    placeholder: 'Mô tả chi tiết về vị trí công việc...',
    modules: {
    toolbar: [
    [{ header: [2, 3, 4, false] }],
    ['bold', 'italic', 'underline', 'strike'],
    [{ color: [] }, { background: [] }],
    [{ list: 'ordered' }, { list: 'bullet' }],
    [{ indent: '-1' }, { indent: '+1' }],
    ['blockquote', 'code-block'],
    ['link', 'image'],
    ['clean']
    ]
    }
    });

    const simpleToolbar = [
    [{ header: [3, 4, false] }],
    ['bold', 'italic', 'underline'],
    [{ list: 'ordered' }, { list: 'bullet' }],
    ['link'],
    ['clean']
    ];

    const requirementsQuill = new Quill('#requirementsEditor', {
    theme: 'snow',
    placeholder: 'VD: Có 2-4 năm kinh nghiệm ở vị trí tương đương. Thành thạo ... Tốt nghiệp Đại học chuyên ngành liên quan...',
    modules: { toolbar: simpleToolbar }
    });

    const benefitsQuill = new Quill('#benefitsEditor', {
    theme: 'snow',
    placeholder: 'VD: Lương thỏa thuận theo năng lực. Thưởng hiệu suất theo quý. BHXH/BHYT/BHTN đầy đủ. Lộ trình thăng tiến rõ ràng...',
    modules: { toolbar: simpleToolbar }
    });

    // Nạp nội dung hiện có của tin đăng vào từng editor
    const descriptionHidden = document.getElementById('descriptionHidden');
    if (descriptionHidden && descriptionHidden.value) {
    descriptionQuill.root.innerHTML = descriptionHidden.value;
    }
    const requirementsHidden = document.getElementById('requirementsHidden');
    if (requirementsHidden && requirementsHidden.value) {
    requirementsQuill.root.innerHTML = requirementsHidden.value;
    }
    const benefitsHidden = document.getElementById('benefitsHidden');
    if (benefitsHidden && benefitsHidden.value) {
    benefitsQuill.root.innerHTML = benefitsHidden.value;
    }

    // Đồng bộ nội dung Quill → hidden input trước khi submit
    document.getElementById('jobForm').addEventListener('submit', function (e) {
    if (descriptionQuill.getText().trim().length === 0) {
    e.preventDefault();
    alert('Vui lòng nhập mô tả công việc!');
    return;
    }
    if (requirementsQuill.getText().trim().length === 0) {
    e.preventDefault();
    alert('Vui lòng nhập yêu cầu ứng viên!');
    return;
    }
    if (benefitsQuill.getText().trim().length === 0) {
    e.preventDefault();
    alert('Vui lòng nhập quyền lợi ứng viên!');
    return;
    }
    document.getElementById('descriptionHidden').value = descriptionQuill.root.innerHTML;
    document.getElementById('requirementsHidden').value = requirementsQuill.root.innerHTML;
    document.getElementById('benefitsHidden').value = benefitsQuill.root.innerHTML;
    });
</script>
