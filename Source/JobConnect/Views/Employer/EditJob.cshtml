@using JobConnect.ViewModels
@model PostJobViewModel
@{
    Layout = "_LayoutEmployer"; ViewData["Title"] = "Sửa tin tuyển dụng";
    var statusOptions = new List<(string Value, string Label)>
    {
        ("Active", "Đang hiển thị"),
        ("Paused", "Tạm dừng"),
        ("Draft", "Bản nháp")
    };
}

<div class="max-w-3xl mx-auto">
    <div class="flex items-center gap-3 mb-6">
        <a asp-action="Dashboard"
           class="p-2 rounded-lg hover:bg-surface-container text-secondary transition-colors">
            <span class="material-symbols-outlined">arrow_back</span>
        </a>
        <div>
            <h1 class="text-xl font-bold text-on-surface">Sửa tin tuyển dụng</h1>
            <p class="text-sm text-secondary">Cập nhật thông tin tin đã đăng</p>
        </div>
    </div>

    <form asp-action="EditJob" method="post" class="space-y-5">
        <input type="hidden" asp-for="JobID" />
        <div asp-validation-summary="ModelOnly"
             class="px-4 py-3 bg-red-50 border border-red-200 text-red-700 rounded-xl text-sm"></div>

        <!-- Thông tin cơ bản -->
        <div class="bg-white rounded-2xl p-5 shadow-sm border border-outline-variant space-y-4">
            <h2 class="font-semibold text-on-surface flex items-center gap-2">
                <span class="material-symbols-outlined text-primary text-sm">info</span>
                Thông tin cơ bản
            </h2>
            <div>
                <label asp-for="Title" class="block text-sm font-medium text-secondary mb-1">Tiêu đề công việc <span class="text-red-500">*</span></label>
                <input asp-for="Title" class="form-input" placeholder="VD: Lập trình viên .NET Senior" />
                <span asp-validation-for="Title" class="text-xs text-red-500 mt-1"></span>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                    <label asp-for="CategoryID" class="block text-sm font-medium text-secondary mb-1">Ngành nghề <span class="text-red-500">*</span></label>
                    <select asp-for="CategoryID" asp-items="ViewBag.Categories" class="form-input">
                        <option value="">-- Chọn ngành nghề --</option>
                    </select>
                </div>
                <div>
                    <label asp-for="JobType" class="block text-sm font-medium text-secondary mb-1">Hình thức làm việc</label>
                    <select asp-for="JobType" class="form-input">
                        <option value="FullTime">Toàn thời gian</option>
                        <option value="PartTime">Bán thời gian</option>
                        <option value="Remote">Làm việc từ xa</option>
                        <option value="Internship">Thực tập</option>
                    </select>
                </div>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                    <label asp-for="Location" class="block text-sm font-medium text-secondary mb-1">Địa điểm <span class="text-red-500">*</span></label>
                    <input asp-for="Location" class="form-input" placeholder="VD: Hà Nội, TP.HCM" />
                </div>
                <div>
                    <label asp-for="ExperienceLevel" class="block text-sm font-medium text-secondary mb-1">Kinh nghiệm</label>
                    <select asp-for="ExperienceLevel" class="form-input">
                        <option value="Fresher">Fresher (dưới 1 năm)</option>
                        <option value="Junior">Junior (1-2 năm)</option>
                        <option value="Mid">Middle (2-4 năm)</option>
                        <option value="Senior">Senior (4+ năm)</option>
                        <option value="Lead">Lead / Manager</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- Mức lương & deadline -->
        <div class="bg-white rounded-2xl p-5 shadow-sm border border-outline-variant space-y-4">
            <h2 class="font-semibold text-on-surface flex items-center gap-2">
                <span class="material-symbols-outlined text-primary text-sm">payments</span>
                Mức lương & Hạn nộp
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                <div>
                    <label asp-for="SalaryMin" class="block text-sm font-medium text-secondary mb-1">Lương tối thiểu (VND)</label>
                    <input asp-for="SalaryMin" type="number" class="form-input" placeholder="VD: 10000000" />
                </div>
                <div>
                    <label asp-for="SalaryMax" class="block text-sm font-medium text-secondary mb-1">Lương tối đa (VND)</label>
                    <input asp-for="SalaryMax" type="number" class="form-input" placeholder="VD: 20000000" />
                </div>
                <div>
                    <label asp-for="Deadline" class="block text-sm font-medium text-secondary mb-1">Hạn nộp hồ sơ</label>
                    <input asp-for="Deadline" type="date" class="form-input" />
                </div>
            </div>
        </div>

        <!-- Mô tả công việc -->
        <div class="bg-white rounded-2xl p-5 shadow-sm border border-outline-variant space-y-4">
            <h2 class="font-semibold text-on-surface flex items-center gap-2">
                <span class="material-symbols-outlined text-primary text-sm">description</span>
                Mô tả & Yêu cầu
            </h2>
            <div>
                <label asp-for="Description" class="block text-sm font-medium text-secondary mb-1">Mô tả công việc <span class="text-red-500">*</span></label>
                <textarea asp-for="Description" rows="6" class="form-input resize-y"
                          placeholder="Mô tả chi tiết công việc, trách nhiệm, môi trường làm việc..."></textarea>
                <span asp-validation-for="Description" class="text-xs text-red-500 mt-1"></span>
            </div>
            <div>
                <label asp-for="Requirements" class="block text-sm font-medium text-secondary mb-1">Yêu cầu ứng viên</label>
                <textarea asp-for="Requirements" rows="4" class="form-input resize-y"
                          placeholder="Kỹ năng, bằng cấp, kinh nghiệm yêu cầu..."></textarea>
            </div>
            <div>
                <label asp-for="Benefits" class="block text-sm font-medium text-secondary mb-1">Quyền lợi</label>
                <textarea asp-for="Benefits" rows="3" class="form-input resize-y"
                          placeholder="Bảo hiểm, thưởng, du lịch, đào tạo..."></textarea>
            </div>
        </div>

        <!-- Trạng thái -->
        <div class="bg-white rounded-2xl p-5 shadow-sm border border-outline-variant">
            <h2 class="font-semibold text-on-surface mb-4 flex items-center gap-2">
                <span class="material-symbols-outlined text-primary text-sm">toggle_on</span>
                Trạng thái hiển thị
            </h2>
            <div class="flex flex-wrap gap-3">
                @foreach (var s in statusOptions)
                {
                    <label class="flex items-center gap-2 px-4 py-2.5 border border-outline-variant rounded-xl cursor-pointer
                        has-[:checked]:border-primary has-[:checked]:bg-blue-50 text-sm">
                        <input type="radio" asp-for="Status" value="@s.Value" class="accent-primary" />
                        @s.Label
                    </label>
                }
            </div>
        </div>

        <!-- Actions -->
        <div class="flex items-center justify-between pt-2">
            <a asp-action="Dashboard"
               class="px-5 py-2.5 border border-outline-variant rounded-xl text-sm text-secondary hover:bg-surface-container transition-colors">
                Hủy bỏ
            </a>
            <button type="submit"
                    class="px-6 py-2.5 bg-primary text-white rounded-xl font-semibold text-sm hover:opacity-90 transition-opacity">
                Lưu thay đổi
            </button>
        </div>
    </form>
</div>