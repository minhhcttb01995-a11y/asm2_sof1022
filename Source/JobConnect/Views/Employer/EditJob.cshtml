@using JobConnect.ViewModels
@model PostJobViewModel
@{
    ViewData["Title"] = "Sửa tin tuyển dụng";
    Layout = "_LayoutEmployer";
    var statusOptions = new List<(string Value, string Label)>
    {
        ("Active", "Đang hiển thị"),
        ("Paused", "Tạm dừng"),
        ("Draft", "Bản nháp")
    };
}

<div class="max-w-3xl mx-auto px-6 py-8">
    <div class="flex items-center gap-3 mb-6">
        <a asp-action="Dashboard" class="p-2 rounded-lg hover:bg-gray-100 text-gray-600">
            <span class="material-icons">arrow_back</span>
        </a>
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Sửa tin tuyển dụng</h1>
            <p class="text-sm text-gray-600">Cập nhật thông tin tin đã đăng</p>
        </div>
    </div>

    <form asp-action="EditJob" method="post" class="space-y-6">
        <input type="hidden" asp-for="JobID" />
        <div asp-validation-summary="ModelOnly"
             class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg text-sm"></div>

        <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-sm">

            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div class="md:col-span-2">
                    <label asp-for="Title" class="block text-sm font-medium text-gray-700 mb-1">Tiêu đề công việc <span class="text-red-500">*</span></label>
                    <input asp-for="Title" placeholder="VD: Lập trình viên .NET Senior"
                           class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                    <span asp-validation-for="Title" class="text-xs text-red-500 mt-1"></span>
                </div>
                <div>
                    <label asp-for="CategoryID" class="block text-sm font-medium text-gray-700 mb-1">Ngành nghề <span class="text-red-500">*</span></label>
                    <select asp-for="CategoryID" asp-items="ViewBag.Categories"
                            class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                        <option value="">-- Chọn ngành nghề --</option>
                    </select>
                </div>
                <div>
                    <label asp-for="JobType" class="block text-sm font-medium text-gray-700 mb-1">Hình thức làm việc</label>
                    <select asp-for="JobType"
                            class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                        <option value="FullTime">Full-time</option>
                        <option value="PartTime">Part-time</option>
                        <option value="Contract">Hợp đồng</option>
                        <option value="Intern">Thực tập</option>
                        <option value="Remote">Remote</option>
                    </select>
                </div>
                <div>
                    <label asp-for="ExperienceLevel" class="block text-sm font-medium text-gray-700 mb-1">Kinh nghiệm</label>
                    <select asp-for="ExperienceLevel"
                            class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                        <option value="">Không yêu cầu</option>
                        <option value="Fresher">Fresher</option>
                        <option value="Junior">Junior</option>
                        <option value="Middle">Middle</option>
                        <option value="Senior">Senior</option>
                        <option value="Manager">Manager</option>
                    </select>
                </div>
                <div>
                    <label asp-for="Location" class="block text-sm font-medium text-gray-700 mb-1">Địa điểm</label>
                    <input asp-for="Location" placeholder="VD: Hà Nội, TP. HCM"
                           class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                </div>
                <div>
                    <label asp-for="SalaryMin" class="block text-sm font-medium text-gray-700 mb-1">Lương tối thiểu (VND)</label>
                    <input asp-for="SalaryMin" type="number" placeholder="VD: 15000000"
                           class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                </div>
                <div>
                    <label asp-for="SalaryMax" class="block text-sm font-medium text-gray-700 mb-1">Lương tối đa (VND)</label>
                    <input asp-for="SalaryMax" type="number" placeholder="VD: 30000000"
                           class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                </div>
                <div>
                    <label asp-for="Deadline" class="block text-sm font-medium text-gray-700 mb-1">Ngày hết hạn</label>
                    <input asp-for="Deadline" type="date"
                           class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                </div>
                <div>
                    <label asp-for="Status" class="block text-sm font-medium text-gray-700 mb-1">Trạng thái</label>
                    <select asp-for="Status"
                            class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                        @foreach (var opt in statusOptions)
                        {
                            <option value="@opt.Value">@opt.Label</option>
                        }
                    </select>
                </div>
                <div class="md:col-span-2">
                    <label asp-for="Description" class="block text-sm font-medium text-gray-700 mb-1">Mô tả công việc <span class="text-red-500">*</span></label>
                    <textarea asp-for="Description" rows="6" placeholder="Mô tả chi tiết về vị trí công việc..."
                              class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 resize-y"></textarea>
                </div>
                <div class="md:col-span-2">
                    <label asp-for="Requirements" class="block text-sm font-medium text-gray-700 mb-1">Yêu cầu ứng viên</label>
                    <textarea asp-for="Requirements" rows="4" placeholder="Kỹ năng, kinh nghiệm yêu cầu..."
                              class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 resize-y"></textarea>
                </div>
                <div class="md:col-span-2">
                    <label asp-for="Benefits" class="block text-sm font-medium text-gray-700 mb-1">Quyền lợi</label>
                    <textarea asp-for="Benefits" rows="3" placeholder="Các quyền lợi hấp dẫn dành cho ứng viên..."
                              class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 resize-y"></textarea>
                </div>
            </div>

        </div>

        <div class="flex gap-3">
            <button type="submit" class="px-6 py-2.5 bg-blue-600 text-white rounded-xl font-semibold text-sm hover:bg-blue-700">
                Lưu thay đổi
            </button>
            <a asp-action="Dashboard" class="px-6 py-2.5 border border-gray-300 rounded-xl text-sm text-gray-700 hover:bg-gray-50">
                Hủy
            </a>
        </div>
    </form>
</div>