@* [VIEW-HEADER-ADDED]
   View cho action "CandidateDetail" trong khu vực trang quản lý Nhà tuyển dụng (EmployerController).
*@
@using JobConnect.Models
@model Application
@{
    ViewData["Title"] = "Chi tiết ứng viên";
    Layout = "_LayoutEmployer";
    var profile = Model.CandidateProfile;
    var user = profile?.User;
}

<div class="max-w-5xl mx-auto px-4 py-8 space-y-6">

    <!-- Header -->
    <div class="flex items-center gap-3 mb-2">
        <a href="javascript:history.back()" class="text-slate-400 hover:text-blue-400 transition-colors">
            <span class="material-symbols-outlined text-xl">arrow_back</span>
        </a>
        <div>
            <h2 class="text-2xl font-bold text-white">Chi tiết ứng viên</h2>
            <p class="text-sm text-slate-400 mt-0.5">Ứng tuyển vị trí: <strong>@Model.Job?.Title</strong></p>
        </div>
    </div>

    <!-- Thông tin cá nhân -->
    <div class="bg-[#1e293b] rounded-2xl border border-slate-700 shadow-sm overflow-hidden">
        <div class="bg-gradient-to-r from-blue-600 to-indigo-600 px-6 py-5 flex items-center gap-4">
            <div class="w-16 h-16 rounded-full bg-white/20 text-white flex items-center justify-center text-2xl font-bold shrink-0">
                @((profile?.FullName ?? user?.FullName)?.Trim().Length > 0 ? (profile?.FullName ?? user?.FullName)!.Trim()[0].ToString().ToUpper() : "U")
            </div>
            <div>
                <h3 class="text-xl font-bold text-white">@(profile?.FullName ?? user?.FullName)</h3>
                @if (!string.IsNullOrEmpty(profile?.JobTitle))
                {
                    <p class="text-blue-100">@profile.JobTitle</p>
                }
            </div>
        </div>

        <div class="px-6 py-5 grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
            <div class="flex items-start gap-2 text-slate-300">
                <span class="material-symbols-outlined text-base text-slate-400 mt-0.5">mail</span>
                <span>@user?.Email</span>
            </div>
            @if (!string.IsNullOrEmpty(profile?.Phone) || !string.IsNullOrEmpty(user?.PhoneNumber))
            {
                <div class="flex items-start gap-2 text-slate-300">
                    <span class="material-symbols-outlined text-base text-slate-400 mt-0.5">call</span>
                    <span>@(profile?.Phone ?? user?.PhoneNumber)</span>
                </div>
            }
            @if (!string.IsNullOrEmpty(profile?.Address))
            {
                <div class="flex items-start gap-2 text-slate-300">
                    <span class="material-symbols-outlined text-base text-slate-400 mt-0.5">location_on</span>
                    <span>@profile.Address</span>
                </div>
            }
            @if (profile?.DateOfBirth != null)
            {
                <div class="flex items-start gap-2 text-slate-300">
                    <span class="material-symbols-outlined text-base text-slate-400 mt-0.5">cake</span>
                    <span>@profile.DateOfBirth.Value.ToString("dd/MM/yyyy")</span>
                </div>
            }
            @if (!string.IsNullOrEmpty(profile?.Gender))
            {
                <div class="flex items-start gap-2 text-slate-300">
                    <span class="material-symbols-outlined text-base text-slate-400 mt-0.5">wc</span>
                    <span>@profile.Gender</span>
                </div>
            }
            <div class="flex items-start gap-2 text-slate-300">
                <span class="material-symbols-outlined text-base text-slate-400 mt-0.5">work_history</span>
                <span>@profile?.ExperienceYears năm kinh nghiệm</span>
            </div>
            @if (profile?.DesiredSalary != null)
            {
                <div class="flex items-start gap-2 text-slate-300">
                    <span class="material-symbols-outlined text-base text-slate-400 mt-0.5">payments</span>
                    <span>Mức lương mong muốn: @profile.DesiredSalary.Value.ToString("N0") VNĐ</span>
                </div>
            }
        </div>

        @if (!string.IsNullOrEmpty(profile?.Summary))
        {
            <div class="px-6 pb-5 border-t border-slate-700 pt-4">
                <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Giới thiệu bản thân</p>
                <p class="text-slate-300 text-sm whitespace-pre-line">@profile.Summary</p>
            </div>
        }
    </div>

    <!-- Kỹ năng -->
    @if (profile?.CandidateSkills?.Any() == true)
    {
        <div class="bg-[#1e293b] rounded-2xl border border-slate-700 shadow-sm px-6 py-5">
            <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-3">Kỹ năng</p>
            <div class="flex flex-wrap gap-2">
                @foreach (var cs in profile.CandidateSkills)
                {
                    <span class="px-3 py-1.5 bg-blue-500/10 text-blue-300 border border-blue-500/20 rounded-lg text-sm">
                        @cs.Skill?.Name <span class="text-slate-500">· @cs.ProficiencyLevel · @cs.YearsOfExperience năm</span>
                    </span>
                }
            </div>
        </div>
    }

    <!-- Thư xin việc -->
    @if (!string.IsNullOrEmpty(Model.CoverLetter))
    {
        <div class="bg-[#1e293b] rounded-2xl border border-slate-700 shadow-sm px-6 py-5">
            <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Thư xin việc</p>
            <p class="text-slate-300 text-sm whitespace-pre-line">@Model.CoverLetter</p>
        </div>
    }

    <!-- CV đã nộp -->
    <div class="bg-[#1e293b] rounded-2xl border border-slate-700 shadow-sm px-6 py-5">
        <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-3">CV đã nộp cho đơn ứng tuyển này</p>
        @if (Model.Cv != null)
        {
            <div class="flex items-center justify-between bg-[#0f172a] border border-slate-700 rounded-xl px-4 py-3">
                <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-blue-400">description</span>
                    <span class="text-sm text-slate-200">@Model.Cv.FileName</span>
                </div>
                <a asp-action="DownloadCv" asp-route-cvId="@Model.Cv.Cvid"
                   class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-xs font-semibold rounded-lg flex items-center gap-1.5">
                    <span class="material-symbols-outlined text-sm">download</span>
                    Tải CV
                </a>
            </div>
        }
        else
        {
            <p class="text-slate-500 text-sm">Ứng viên chưa đính kèm CV cho đơn này.</p>
        }
    </div>

    <!-- Trạng thái đơn ứng tuyển -->
    <div class="bg-[#1e293b] rounded-2xl border border-slate-700 shadow-sm px-6 py-5 flex items-center justify-between">
        <div>
            <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1">Trạng thái đơn ứng tuyển</p>
            <p class="text-sm text-slate-300">Ứng tuyển lúc: @Model.AppliedAt.ToString("HH:mm dd/MM/yyyy")</p>
        </div>
        <span class="px-4 py-2 rounded-full text-sm font-semibold
            @(Model.Status switch
            {
                "Pending" => "bg-yellow-500/10 text-yellow-400 border border-yellow-500/20",
                "Reviewing" => "bg-blue-500/10 text-blue-400 border border-blue-500/20",
                "Interview" => "bg-purple-500/10 text-purple-400 border border-purple-500/20",
                "Rejected" => "bg-red-500/10 text-red-400 border border-red-500/20",
                _ => "bg-slate-500/10 text-slate-400 border border-slate-500/20"
            })">
            @Model.Status
        </span>
    </div>

    <!-- Hành động nhanh -->
    <div class="flex items-center gap-3">
        @if (Model.Status != "Interview" && Model.Status != "Rejected")
        {
            <a asp-action="ScheduleInterview" asp-route-appId="@Model.AppID"
               class="flex-1 py-3 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white font-semibold rounded-xl transition-all shadow-sm flex items-center justify-center gap-2">
                <span class="material-symbols-outlined text-base">event_available</span>
                Mời phỏng vấn
            </a>
        }
        <a asp-action="ManageApplications" asp-route-jobId="@Model.JobId"
           class="px-6 py-3 border border-slate-700 text-slate-300 rounded-xl hover:bg-[#0f172a] font-semibold transition-colors text-center text-sm">
            Quay lại danh sách
        </a>
    </div>
</div>
