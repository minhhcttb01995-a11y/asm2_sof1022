@using JobConnect.Models
@{
    ViewData["Title"] = "Quản lý Kỹ năng";
    Layout = "_Layout";
}

<style>
    body {
        background-color: #f8fafc !important;
    }

    .glass-card {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 1.5rem;
        box-shadow: 0 1px 3px rgba(15, 23, 42, 0.06);
        transition: all 0.3s ease;
    }

        .glass-card:hover {
            border-color: rgba(59, 130, 246, 0.4);
        }

    .skill-tag {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1rem;
        border-radius: 0.75rem;
        font-size: 0.875rem;
        font-weight: 500;
        transition: all 0.2s;
    }

    .skill-beginner { background: #fee2e2; color: #b91c1c; border: 1px solid #fecaca; }
    .skill-elementary { background: #fef3c7; color: #b45309; border: 1px solid #fde68a; }
    .skill-intermediate { background: #dbeafe; color: #1d4ed8; border: 1px solid #bfdbfe; }
    .skill-advanced { background: #ede9fe; color: #6d28d9; border: 1px solid #ddd6fe; }
    .skill-expert { background: #dcfce7; color: #15803d; border: 1px solid #bbf7d0; }

    .progress-bar {
        height: 8px;
        background: #e2e8f0;
        border-radius: 9999px;
        overflow: hidden;
    }

    .progress-fill {
        height: 100%;
        background: linear-gradient(90deg, #3b82f6, #8b5cf6);
        transition: width 0.3s ease;
    }
</style>

<div class="max-w-[1600px] mx-auto px-4 py-8">
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
        <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-3xl text-blue-600">psychology</span>
            <div>
                <h1 class="text-2xl font-bold text-slate-900">Quản lý Kỹ năng</h1>
                <p class="text-slate-500 text-sm">Thêm và quản lý kỹ năng của bạn</p>
            </div>
        </div>
        <button onclick="document.getElementById('addSkillModal').classList.remove('hidden')"
                class="px-5 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 text-white rounded-xl text-sm font-bold hover:from-blue-700 hover:to-indigo-700 transition-all flex items-center gap-2">
            <span class="material-symbols-outlined text-base">add</span>
            Thêm kỹ năng
        </button>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="mb-4 px-4 py-3 bg-green-500/20 text-green-600 rounded-xl text-sm font-medium flex items-center gap-2 border border-green-500/30 auto-hide-alert">
            <span class="material-symbols-outlined text-base">check_circle</span>
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="mb-4 px-4 py-3 bg-red-500/20 text-red-600 rounded-xl text-sm font-medium flex items-center gap-2 border border-red-500/30">
            <span class="material-symbols-outlined text-base">error</span>
            @TempData["Error"]
        </div>
    }

    <!-- Profile Completion -->
    <div class="glass-card p-6 mb-6">
        <div class="flex items-center justify-between mb-3">
            <span class="text-slate-900 font-semibold">Độ hoàn thiện hồ sơ (Kỹ năng)</span>
            <span class="text-blue-600 font-bold">@ViewBag.ProfileCompletion%</span>
        </div>
        <div class="progress-bar">
            <div class="progress-fill" style="width: @ViewBag.ProfileCompletion%"></div>
        </div>
        <p class="text-slate-500 text-xs mt-2">Thêm ít nhất 5 kỹ năng để hồ sơ hoàn thiện</p>
    </div>

    <!-- My Skills -->
    <div class="glass-card p-6 mb-6">
        <h2 class="text-lg font-bold text-slate-900 mb-4 flex items-center gap-2">
            <span class="material-symbols-outlined text-blue-600">workspace_premium</span>
            Kỹ năng của tôi
        </h2>

        @if (ViewBag.CandidateSkills != null && ((List<CandidateSkill>)ViewBag.CandidateSkills).Any())
        {
            <div class="flex flex-wrap gap-3">
                @foreach (var candidateSkill in (List<CandidateSkill>)ViewBag.CandidateSkills)
                {
                    var proficiencyClass = candidateSkill.ProficiencyLevel.ToString().ToLower();
                    <div class="skill-tag skill-@proficiencyClass">
                        <span>@candidateSkill.Skill.Name</span>
                        <span class="text-xs opacity-75">(@candidateSkill.ProficiencyLevel)</span>
                        @if (candidateSkill.YearsOfExperience > 0)
                        {
                            <span class="text-xs opacity-75">@candidateSkill.YearsOfExperience năm</span>
                        }
                        <button onclick="editSkill(@candidateSkill.SkillID, '@candidateSkill.ProficiencyLevel', @candidateSkill.YearsOfExperience)"
                                class="text-xs hover:text-slate-900 opacity-50 hover:opacity-100 transition-opacity">
                            <span class="material-symbols-outlined text-sm">edit</span>
                        </button>
                        <form asp-action="RemoveSkill" method="post" class="inline"
                              onsubmit="return confirm('Bạn có chắc muốn xóa kỹ năng này?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="skillId" value="@candidateSkill.SkillID" />
                            <button type="submit" class="text-xs hover:text-red-600 opacity-50 hover:opacity-100 transition-opacity">
                                <span class="material-symbols-outlined text-sm">close</span>
                            </button>
                        </form>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-8">
                <span class="material-symbols-outlined text-4xl text-slate-500 mb-2">psychology</span>
                <p class="text-slate-500">Bạn chưa thêm kỹ năng nào</p>
                <button onclick="document.getElementById('addSkillModal').classList.remove('hidden')"
                        class="mt-3 px-4 py-2 bg-blue-500/20 text-blue-600 rounded-lg text-sm font-medium hover:bg-blue-500/30 transition-colors">
                    Thêm kỹ năng đầu tiên
                </button>
            </div>
        }
    </div>

    <!-- Available Skills -->
    <div class="glass-card p-6">
        <h2 class="text-lg font-bold text-slate-900 mb-4 flex items-center gap-2">
            <span class="material-symbols-outlined text-blue-600">list</span>
            Kỹ năng có sẵn
        </h2>

        @if (ViewBag.AvailableSkills != null && ((List<Skill>)ViewBag.AvailableSkills).Any())
        {
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
                @foreach (var skill in ((List<Skill>)ViewBag.AvailableSkills).Where(s => !((List<CandidateSkill>)ViewBag.CandidateSkills ?? new List<CandidateSkill>()).Any(cs => cs.SkillID == s.SkillID)))
                {
                    <div class="bg-white rounded-xl p-4 border border-slate-200 hover:border-blue-500/50 transition-colors">
                        <div class="flex items-center justify-between mb-2">
                            <span class="text-slate-900 font-medium">@skill.Name</span>
                            <span class="px-2 py-0.5 bg-blue-500/20 text-blue-600 rounded text-xs">@skill.Category</span>
                        </div>
                        @if (!string.IsNullOrEmpty(skill.Description))
                        {
                            <p class="text-slate-500 text-xs line-clamp-2 mb-3">@skill.Description</p>
                        }
                        <button onclick="quickAddSkill(@skill.SkillID)"
                                class="w-full py-2 bg-blue-500/20 text-blue-600 rounded-lg text-sm font-medium hover:bg-blue-500/30 transition-colors">
                            Thêm nhanh
                        </button>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="text-slate-500 text-center py-4">Không có kỹ năng nào khả dụng</p>
        }
    </div>
</div>

<!-- Add Skill Modal -->
<div id="addSkillModal" class="hidden fixed inset-0 bg-white backdrop-blur-sm z-50 flex items-center justify-center p-4">
    <div class="bg-white border border-slate-200 rounded-2xl p-6 w-full max-w-lg shadow-2xl">
        <div class="flex justify-between items-center mb-5">
            <div>
                <h3 class="font-bold text-lg text-slate-900">Thêm Kỹ năng</h3>
                <p class="text-blue-600 text-sm">Chọn kỹ năng và mức độ thành thạo</p>
            </div>
            <button onclick="document.getElementById('addSkillModal').classList.add('hidden')"
                    class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-white text-slate-500 hover:text-slate-900 transition-colors">
                ✕
            </button>
        </div>

        <form asp-action="AddSkill" method="post" class="space-y-4">
            @Html.AntiForgeryToken()
            
            <div>
                <label class="block text-sm font-semibold mb-1.5 text-slate-600">Kỹ năng <span class="text-red-600">*</span></label>
                <select name="skillId" id="skillSelect" class="w-full px-4 py-3 bg-white border border-slate-200 text-slate-700 rounded-xl focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none" required>
                    <option value="">-- Chọn kỹ năng --</option>
                    @if (ViewBag.AvailableSkills != null)
                    {
                        @foreach (var skill in (List<Skill>)ViewBag.AvailableSkills)
                        {
                            <option value="@skill.SkillID">@skill.Name (@skill.Category)</option>
                        }
                    }
                </select>
            </div>

            <div>
                <label class="block text-sm font-semibold mb-1.5 text-slate-600">Mức độ thành thạo <span class="text-red-600">*</span></label>
                <select name="proficiency" class="w-full px-4 py-3 bg-white border border-slate-200 text-slate-700 rounded-xl focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none" required>
                    <option value="Beginner">Beginner - Mới bắt đầu</option>
                    <option value="Elementary">Elementary - Cơ bản</option>
                    <option value="Intermediate" selected>Intermediate - Trung cấp</option>
                    <option value="Advanced">Advanced - Nâng cao</option>
                    <option value="Expert">Expert - Chuyên gia</option>
                </select>
            </div>

            <div>
                <label class="block text-sm font-semibold mb-1.5 text-slate-600">Kinh nghiệm (năm)</label>
                <input type="number" name="yearsOfExp" min="0" max="50" step="0.5" value="0"
                       class="w-full px-4 py-3 bg-white border border-slate-200 text-slate-700 rounded-xl focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none" />
            </div>

            <div>
                <label class="block text-sm font-semibold mb-1.5 text-slate-600">Lần sử dụng gần nhất</label>
                <input type="date" name="lastUsed"
                       class="w-full px-4 py-3 bg-white border border-slate-200 text-slate-700 rounded-xl focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none" />
            </div>

            <div class="flex gap-3 pt-2">
                <button type="button" onclick="document.getElementById('addSkillModal').classList.add('hidden')"
                        class="flex-1 py-3 border border-slate-200 text-slate-600 rounded-xl font-semibold hover:bg-white transition-colors">
                    Hủy
                </button>
                <button type="submit"
                        class="flex-1 py-3 bg-gradient-to-r from-blue-600 to-indigo-600 text-white font-bold rounded-xl hover:from-blue-700 hover:to-indigo-700 transition-all">
                    Thêm kỹ năng
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    function quickAddSkill(skillId) {
        document.getElementById('skillSelect').value = skillId;
        document.getElementById('addSkillModal').classList.remove('hidden');
    }

    function editSkill(skillId, proficiency, yearsOfExp) {
        // For now, just show the add modal - you can extend this to pre-fill and update
        document.getElementById('skillSelect').value = skillId;
        document.getElementById('addSkillModal').classList.remove('hidden');
    }
</script>
