@using JobConnect.Models
@using JobConnect.Extensions
@model CandidateProfile
@{
    ViewData["Title"] = "Quản lý CV";
    Layout = "_Layout";
}

<div class="max-w-[1300px] mx-auto px-6 py-8">
    <div class="flex items-center gap-3 mb-6">
        <a asp-action="Profile" class="text-secondary hover:text-primary transition-colors">
            <span class="material-symbols-outlined align-middle">arrow_back</span>
        </a>
        <h1 class="text-2xl font-bold text-on-surface">Quản lý CV</h1>
    </div>

    <!-- Thông báo -->
    @if (TempData["Success"] != null)
    {
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-xl mb-6 flex items-center gap-2 auto-hide-alert">
            <span class="material-symbols-outlined">check_circle</span>
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-xl mb-6 flex items-center gap-2">
            <span class="material-symbols-outlined">error</span>
            @TempData["Error"]
        </div>
    }

    <!-- Upload form -->
    <div class="bg-white rounded-2xl border border-outline-variant p-6 mb-8">
        <h2 class="font-semibold text-on-surface mb-4 flex items-center gap-2">
            <span class="material-symbols-outlined">upload_file</span>
            Tải lên CV mới
        </h2>
        <form asp-action="UploadCv" method="post" enctype="multipart/form-data" class="flex flex-col sm:flex-row gap-4">
            @Html.AntiForgeryToken()
            <div class="flex-1">
                <label class="block text-sm font-medium text-gray-700 mb-1">
                    Chọn file CV
                    <span class="text-secondary text-xs">(PDF hoặc DOCX, tối đa 5MB)</span>
                </label>
                <input type="file" name="cvFile" accept=".pdf,.docx" required
                       class="w-full text-sm text-secondary border border-outline-variant rounded-xl px-4 py-3
                file:mr-4 file:py-2 file:px-6 file:rounded-xl file:border-0
                file:bg-primary file:text-slate-900 file:font-medium cursor-pointer" />
            </div>
            <button type="submit"
                    class="px-8 py-3 bg-primary text-slate-900 font-semibold rounded-xl hover:bg-primary/90 transition-all whitespace-nowrap self-end">
                Tải lên CV
            </button>
        </form>
    </div>

    <!-- Danh sách CV -->
    @if (Model?.CvFiles?.Any() == true)
    {
        <div class="space-y-4">
            @foreach (var cv in Model.CvFiles.OrderByDescending(c => c.IsDefault).ThenByDescending(c => c.UploadedAt))
            {
                <div class="bg-white rounded-2xl border border-outline-variant p-5 flex flex-col sm:flex-row sm:items-center gap-4">
                    <!-- Icon -->
                    <div class="w-12 h-12 rounded-2xl bg-red-50 flex items-center justify-center flex-shrink-0">
                        <span class="material-symbols-outlined text-3xl text-red-500">
                            @(System.IO.Path.GetExtension(cv.FileName ?? "").ToLower() == ".pdf" ? "picture_as_pdf" : "description")
                        </span>
                    </div>

                    <!-- Info -->
                    <div class="flex-1 min-w-0">
                        <p class="font-medium text-on-surface truncate">@cv.FileName</p>
                        <p class="text-xs text-secondary mt-1">
                            @if (cv.FileSize.HasValue)
                            {
                                @(((double)cv.FileSize.Value / 1024).ToString("N0"))
                                <span> KB</span>
                            }
                            <span class="mx-2">·</span>
                            @cv.UploadedAt.ToString("dd/MM/yyyy HH:mm")
                        </p>
                    </div>

                    <!-- Actions -->
                    <div class="flex items-center gap-2 flex-wrap">
                        @if (cv.IsDefault)
                        {
                            <span class="inline-flex items-center px-3 py-1 bg-green-100 text-green-700 rounded-full text-xs font-medium">
                                <span class="material-symbols-outlined text-sm mr-1">check</span>
                                Mặc định
                            </span>
                        }
                        else
                        {
                            <form asp-action="SetDefaultCv" method="post" class="inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="cvId" value="@cv.Cvid" />
                                <button type="submit"
                                        class="text-sm px-4 py-2 text-primary border border-primary rounded-xl hover:bg-primary hover:text-slate-900 transition-all">
                                    Đặt mặc định
                                </button>
                            </form>
                        }

                        <a href="@cv.FilePath" target="_blank"
                           class="flex items-center gap-1.5 text-sm text-primary border border-primary px-5 py-2 rounded-xl hover:bg-primary hover:text-slate-900 transition-all">
                            <span class="material-symbols-outlined text-base">download</span>
                            Tải xuống
                        </a>

                        <form asp-action="DeleteCv" method="post" class="inline"
                              onsubmit="return confirm('Bạn có chắc muốn xóa CV này?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="cvId" value="@cv.Cvid" />
                            <button type="submit"
                                    class="flex items-center gap-1.5 text-sm text-red-600 border border-red-200 px-4 py-2 rounded-xl hover:bg-red-50 transition-all">
                                <span class="material-symbols-outlined text-base">delete</span>
                                Xóa
                            </button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="bg-white rounded-2xl border border-outline-variant p-16 text-center">
            <span class="material-symbols-outlined text-6xl text-secondary/50 block mb-4">folder_open</span>
            <p class="text-lg text-secondary font-medium">Bạn chưa có CV nào</p>
            <p class="text-secondary mt-1">Hãy tải lên CV đầu tiên của bạn</p>
        </div>
    }
</div>
