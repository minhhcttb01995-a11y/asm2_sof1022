@using JobConnect.Models
@model CandidateProfile
@{
    ViewData["Title"] = "Quản lý CV";
    Layout = "_Layout";
}

<div class="max-w-4xl mx-auto px-6 py-8">
    <div class="flex items-center gap-3 mb-6">
        <a asp-action="Profile" class="text-secondary hover:text-primary">
            <span class="material-symbols-outlined align-middle">arrow_back</span>
        </a>
        <h1 class="text-2xl font-bold text-on-surface">Quản lý CV</h1>
    </div>

    <!-- Thông báo -->
    @if (TempData["Success"] != null)
    {
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-xl mb-6">
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-xl mb-6">
            @TempData["Error"]
        </div>
    }

    <!-- Upload form -->
    <div class="bg-white rounded-xl border border-outline-variant p-6 mb-8">
        <h2 class="font-semibold text-on-surface mb-4">Tải lên CV mới</h2>
        <form asp-action="UploadCv" method="post" enctype="multipart/form-data" class="flex gap-4 items-end">
            @Html.AntiForgeryToken()
            <div class="flex-1">
                <label class="block text-sm font-medium text-gray-700 mb-1">
                    Chọn file CV <span class="text-secondary text-xs">(PDF hoặc DOCX, tối đa 5MB)</span>
                </label>
                <input type="file" name="cvFile" accept=".pdf,.docx"
                       class="w-full text-sm text-secondary border border-outline-variant rounded-xl px-4 py-2.5
                file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0
                file:bg-primary file:text-white file:text-sm file:font-medium
                hover:file:opacity-90 cursor-pointer" />
            </div>
            <button type="submit"
                    class="px-6 py-2.5 bg-primary text-white font-semibold rounded-xl text-sm hover:opacity-90 transition-opacity whitespace-nowrap">
                Tải lên
            </button>
        </form>
    </div>

    <!-- CV list -->
    @if (Model?.CvFiles?.Any() == true)
    {
        <div class="space-y-3">
            @foreach (var cv in Model.CvFiles.OrderByDescending(c => c.UploadedAt))
            {
                <div class="bg-white rounded-xl border border-outline-variant p-4 flex items-center gap-4">
                    <div class="w-10 h-10 rounded-xl bg-red-50 flex items-center justify-center flex-shrink-0">
                        <span class="material-symbols-outlined text-red-500">
                            @((System.IO.Path.GetExtension(cv.FileName)?.ToLower() == ".pdf") ? "picture_as_pdf" : "description")
                        </span>
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="font-medium text-on-surface text-sm truncate">@cv.FileName</p>
                        <p class="text-xs text-secondary mt-0.5">
                            @(((double)cv.FileSize / 1024.0).ToString("N0")) KB
                            &nbsp;·&nbsp;
                            Tải lên: @cv.UploadedAt.ToString("dd/MM/yyyy HH:mm")
                        </p>
                    </div>

                    @if (cv.IsDefault)
                    {
                        <span class="px-3 py-1 bg-green-100 text-green-700 rounded-full text-xs font-medium flex-shrink-0">
                            CV mặc định
                        </span>
                    }

                    <a href="@cv.FilePath" target="_blank"
                       class="flex items-center gap-1.5 text-sm text-primary border border-primary px-4 py-1.5 rounded-lg
                        hover:bg-primary hover:text-white transition-colors flex-shrink-0">
                        <span class="material-symbols-outlined text-sm">download</span>
                        Tải xuống
                    </a>
                </div>
            }
        </div>
    }
    else
    {
        <div class="bg-white rounded-xl border border-outline-variant p-12 text-center">
            <span class="material-symbols-outlined text-5xl text-secondary block mb-3">description</span>
            <p class="text-secondary">Bạn chưa có CV nào. Hãy tải lên ngay!</p>
        </div>
    }
</div>