@using JobConnect.Models
@model CandidateProfile
@{
    ViewData["Title"] = "Hồ sơ của tôi";
    Layout = "_Layout";
}

<div class="max-w-4xl mx-auto px-6 py-8">
    <h1 class="text-2xl font-bold text-on-surface mb-6">Hồ sơ ứng viên</h1>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Avatar + basic info -->
        <div class="bg-white rounded-xl p-5 border border-outline-variant text-center">
            @if (!string.IsNullOrEmpty(Model?.User?.AvatarURL))
            {
                <img src="@Model.User.AvatarURL" class="w-24 h-24 rounded-full object-cover mx-auto mb-3" />
            }
            else
            {
                <div class="w-24 h-24 rounded-full bg-surface-container flex items-center justify-center mx-auto mb-3">
                    <span class="material-symbols-outlined text-4xl text-secondary">person</span>
                </div>
            }
            <p class="font-semibold text-on-surface">@Model?.User?.FullName</p>
            <p class="text-secondary text-sm">@Model?.User?.Email</p>
            @if (Model?.IsOpenToWork == true)
            {
                <span class="mt-2 inline-block bg-green-100 text-green-700 text-xs px-3 py-1 rounded-full">Đang tìm việc</span>
            }
        </div>

        <!-- Edit form -->
        <div class="md:col-span-2 bg-white rounded-xl p-5 border border-outline-variant">
            <h2 class="font-semibold text-on-surface mb-4">Cập nhật hồ sơ</h2>
            <form asp-action="UpdateProfile" method="post" enctype="multipart/form-data" class="space-y-4">
                @Html.AntiForgeryToken()
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Ảnh đại diện</label>
                    <input type="file" name="avatarFile" accept="image/*"
                           class="w-full text-sm text-secondary file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:bg-surface-container file:text-on-surface hover:file:bg-surface-container-high" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Giới thiệu bản thân</label>
                    <textarea name="summary" rows="4" placeholder="Mô tả về bản thân, kinh nghiệm, mục tiêu..."
                              class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary resize-none">@Model?.Summary</textarea>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Năm kinh nghiệm</label>
                        <input type="number" name="experienceYears" value="@Model?.ExperienceYears" min="0"
                               class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Lương mong muốn (VND)</label>
                        <input type="number" name="desiredSalary" value="@Model?.DesiredSalary"
                               class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Địa chỉ</label>
                    <input type="text" name="address" value="@Model?.Address"
                           class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
                </div>
                <label class="flex items-center gap-2 text-sm cursor-pointer">
                    <input type="checkbox" name="isOpenToWork" value="true" @(Model?.IsOpenToWork == true ? "checked" : "")
                           class="rounded border-gray-300 text-primary" />
                    <span class="text-gray-700">Tôi đang tìm kiếm cơ hội việc làm mới</span>
                </label>
                <button type="submit" class="px-6 py-2.5 bg-primary text-white font-semibold rounded-xl hover:opacity-90 transition-opacity text-sm">
                    Lưu hồ sơ
                </button>
            </form>
        </div>
    </div>

    <!-- Quick nav -->
    <div class="mt-6 grid grid-cols-3 gap-4">
        <a asp-action="CvManager"
           class="bg-white rounded-xl p-4 border border-outline-variant text-center hover:shadow-md transition-shadow">
            <span class="material-symbols-outlined text-primary block text-3xl mb-2">description</span>
            <p class="text-sm font-medium text-on-surface">Quản lý CV</p>
            <p class="text-xs text-secondary mt-1">@Model?.CvFiles?.Count ?? 0 file</p>
        </a>
        <a asp-action="Applications"
           class="bg-white rounded-xl p-4 border border-outline-variant text-center hover:shadow-md transition-shadow">
            <span class="material-symbols-outlined text-primary block text-3xl mb-2">send</span>
            <p class="text-sm font-medium text-on-surface">Đơn đã nộp</p>
        </a>
        <a asp-action="SavedJobs"
           class="bg-white rounded-xl p-4 border border-outline-variant text-center hover:shadow-md transition-shadow">
            <span class="material-symbols-outlined text-primary block text-3xl mb-2">bookmark</span>
            <p class="text-sm font-medium text-on-surface">Việc đã lưu</p>
        </a>
    </div>
</div>