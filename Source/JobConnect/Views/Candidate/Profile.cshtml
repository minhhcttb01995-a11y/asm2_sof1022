@using JobConnect.Models
@model CandidateProfile

@{
    ViewData["Title"] = "Hồ sơ của tôi";
    Layout = "_Layout";
}

<style>
    body {
        background-color: #000000 !important;
    }

    /* Glassmorphism Card */
    .glass-card {
        background: rgba(10, 10, 10, 0.85);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(59, 130, 246, 0.2);
        border-radius: 1.5rem;
        transition: all 0.3s ease;
    }

        .glass-card:hover {
            border-color: rgba(59, 130, 246, 0.4);
            box-shadow: 0 8px 32px rgba(59, 130, 246, 0.1);
        }

    /* Input fields */
    .input-field {
        width: 100%;
        padding: 0.75rem 1rem;
        background: #000000;
        border: 1.5px solid #1a1a1a;
        border-radius: 0.75rem;
        color: #ffffff;
        font-size: 0.875rem;
        transition: all 0.2s;
    }

        .input-field:focus {
            border-color: #3b82f6;
            outline: none;
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.15);
        }

        .input-field::placeholder {
            color: #475569;
        }

    textarea.input-field {
        resize: vertical;
        min-height: 100px;
    }

    /* Labels */
    .label {
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #94a3b8;
        margin-bottom: 0.5rem;
        display: block;
    }

    /* Avatar */
    .avatar-preview {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid #3b82f6;
        background: #0a0a0a;
        box-shadow: 0 0 20px rgba(59, 130, 246, 0.3);
    }

    /* CV Card */
    .cv-card {
        background: rgba(0, 0, 0, 0.5);
        border: 1px solid #1a1a1a;
        border-radius: 1rem;
        transition: all 0.2s;
    }

        .cv-card:hover {
            border-color: #3b82f6;
            transform: translateY(-2px);
            background: rgba(59, 130, 246, 0.05);
        }

    /* Buttons */
    .btn-primary {
        background: linear-gradient(135deg, #3b82f6, #1d4ed8);
        transition: all 0.2s;
    }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(59, 130, 246, 0.4);
        }

    .btn-success {
        background: linear-gradient(135deg, #10b981, #059669);
    }

        .btn-success:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(16, 185, 129, 0.4);
        }

    /* Info row */
    .info-row {
        display: flex;
        justify-content: space-between;
        padding: 0.75rem 0;
        border-bottom: 1px solid rgba(59, 130, 246, 0.1);
    }

        .info-row:last-child {
            border-bottom: none;
        }

    /* Status badge */
    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        padding: 0.25rem 0.75rem;
        border-radius: 9999px;
        font-size: 0.7rem;
        font-weight: bold;
    }

    .status-open {
        background: rgba(16, 185, 129, 0.2);
        color: #10b981;
        border: 1px solid rgba(16, 185, 129, 0.3);
    }

    .status-closed {
        background: rgba(100, 116, 139, 0.2);
        color: #94a3b8;
        border: 1px solid rgba(100, 116, 139, 0.3);
    }

    /* Scrollbar */
    ::-webkit-scrollbar {
        width: 6px;
    }

    ::-webkit-scrollbar-track {
        background: #0a0a0a;
    }

    ::-webkit-scrollbar-thumb {
        background: #3b82f6;
        border-radius: 4px;
    }
</style>

<div class="max-w-6xl mx-auto px-4 py-8">
    <!-- Header -->
    <div class="flex items-center gap-3 mb-8">
        <div class="w-12 h-12 rounded-xl bg-blue-600/20 flex items-center justify-center">
            <span class="material-symbols-outlined text-3xl text-blue-400">badge</span>
        </div>
        <div>
            <h1 class="text-2xl font-bold text-white">Hồ sơ của tôi</h1>
            <p class="text-slate-500 text-sm">Quản lý thông tin cá nhân và CV</p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- ========== SIDEBAR - AVATAR & THÔNG TIN ========== -->
        <div class="glass-card p-6">
            <div class="flex flex-col items-center text-center">
                <!-- Avatar -->
                <div class="relative">
                    @if (Model?.User?.AvatarURL != null && !string.IsNullOrEmpty(Model.User.AvatarURL))
                    {
                        <img src="@Model.User.AvatarURL" alt="Avatar" class="avatar-preview" />
                    }
                    else
                    {
                        <div class="avatar-preview flex items-center justify-center bg-slate-800">
                            <span class="material-symbols-outlined text-5xl text-slate-500">person</span>
                        </div>
                    }
                    <div class="absolute -bottom-2 -right-2 w-8 h-8 bg-green-500 rounded-full border-2 border-black flex items-center justify-center">
                        <span class="material-symbols-outlined text-white text-sm">check</span>
                    </div>
                </div>

                <h3 class="text-white font-bold text-xl mt-4">@(Model?.User?.FullName ?? "Chưa cập nhật")</h3>
                <p class="text-slate-400 text-sm">@(Model?.User?.Email ?? "")</p>
                <span class="mt-2 px-3 py-1 bg-blue-600/20 text-blue-400 rounded-full text-xs font-semibold">
                    📋 Ứng viên
                </span>
            </div>

            <div class="mt-6 pt-6 border-t border-slate-700">
                <div class="info-row">
                    <span class="text-slate-400 flex items-center gap-2">
                        <span class="material-symbols-outlined text-sm">work</span>
                        Kinh nghiệm
                    </span>
                    <span class="text-white font-semibold">@(Model?.ExperienceYears ?? 0) năm</span>
                </div>
                <div class="info-row">
                    <span class="text-slate-400 flex items-center gap-2">
                        <span class="material-symbols-outlined text-sm">payments</span>
                        Lương mong muốn
                    </span>
                    <span class="text-green-400 font-semibold">@(Model?.DesiredSalary?.ToString("N0") ?? "0")đ</span>
                </div>
                <div class="info-row">
                    <span class="text-slate-400 flex items-center gap-2">
                        <span class="material-symbols-outlined text-sm">location_on</span>
                        Địa chỉ
                    </span>
                    <span class="text-white">@(Model?.Address ?? "Chưa cập nhật")</span>
                </div>
                <div class="info-row">
                    <span class="text-slate-400 flex items-center gap-2">
                        <span class="material-symbols-outlined text-sm">trending_up</span>
                        Trạng thái
                    </span>
                    @if (Model?.IsOpenToWork == true)
                    {
                        <span class="status-badge status-open">
                            <span class="material-symbols-outlined text-xs">check_circle</span>
                            Đang tìm việc
                        </span>
                    }
                    else
                    {
                        <span class="status-badge status-closed">
                            <span class="material-symbols-outlined text-xs">pause_circle</span>
                            Không tìm việc
                        </span>
                    }
                </div>
            </div>

            <!-- Thông báo -->
            @if (TempData["Success"] != null)
            {
                <div class="mt-4 p-3 bg-green-950/40 border border-green-800/50 rounded-xl text-green-400 text-sm flex items-center gap-2">
                    <span class="material-symbols-outlined text-sm">check_circle</span>
                    @TempData["Success"]
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="mt-4 p-3 bg-red-950/40 border border-red-800/50 rounded-xl text-red-400 text-sm flex items-center gap-2">
                    <span class="material-symbols-outlined text-sm">error</span>
                    @TempData["Error"]
                </div>
            }
        </div>

        <!-- ========== MAIN CONTENT ========== -->
        <div class="lg:col-span-2 space-y-6">
            <!-- Form cập nhật thông tin -->
            <div class="glass-card p-6">
                <h2 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
                    <span class="material-symbols-outlined text-blue-400">edit_note</span>
                    Chỉnh sửa thông tin
                </h2>

                <form asp-action="UpdateProfile" asp-controller="Candidate" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()

                    <div class="space-y-4">
                        <div>
                            <label class="label">📝 Giới thiệu bản thân</label>
                            <textarea name="summary" rows="3" class="input-field" placeholder="Giới thiệu về bản thân, kỹ năng, định hướng nghề nghiệp...">@Model?.Summary</textarea>
                        </div>

                        <div>
                            <label class="label">📍 Địa chỉ</label>
                            <input type="text" name="address" value="@Model?.Address" class="input-field" placeholder="Địa chỉ hiện tại" />
                        </div>

                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="label">📊 Năm kinh nghiệm</label>
                                <input type="number" name="experienceYears" value="@Model?.ExperienceYears" class="input-field" min="0" max="50" />
                            </div>
                            <div>
                                <label class="label">💰 Mức lương mong muốn</label>
                                <input type="number" name="desiredSalary" value="@Model?.DesiredSalary" class="input-field" placeholder="VNĐ" />
                            </div>
                        </div>

                        <div>
                            <label class="label">🖼️ Ảnh đại diện</label>
                            <input type="file" name="avatarFile" accept="image/*" class="input-field" />
                            <p class="text-xs text-slate-500 mt-1">Chấp nhận JPG, PNG (tối đa 2MB)</p>
                        </div>

                        <div class="flex items-center gap-3 py-2">
                            <input type="checkbox" name="isOpenToWork" value="true" @(Model?.IsOpenToWork == true ? "checked" : "") id="openToWork" class="w-5 h-5 rounded border-slate-600 bg-black text-blue-500 focus:ring-blue-500" />
                            <label for="openToWork" class="text-slate-300 text-sm cursor-pointer flex items-center gap-2">
                                <span class="material-symbols-outlined text-green-400">work</span>
                                Đang tìm kiếm cơ hội việc làm
                            </label>
                        </div>

                        <button type="submit" class="btn-primary w-full py-3 text-white font-bold rounded-xl transition-all">
                            <span class="material-symbols-outlined text-sm align-middle mr-1">save</span>
                            Lưu thay đổi
                        </button>
                    </div>
                </form>
            </div>

            <!-- Quản lý CV - Toggle -->
            <div class="glass-card p-6">
                <div class="flex justify-between items-center mb-4">
                    <h2 class="text-lg font-bold text-white flex items-center gap-2">
                        <span class="material-symbols-outlined text-blue-400">description</span>
                        CV của tôi
                    </h2>
                    <button id="toggleCvBtn" class="px-4 py-2 bg-slate-700 text-white rounded-xl hover:bg-slate-600 transition-all flex items-center gap-2">
                        <span class="material-symbols-outlined text-sm">add</span>
                        Quản lý CV
                    </button>
                </div>

                <!-- Hiển thị CV mặc định -->
                @if (Model?.CvFiles != null && Model.CvFiles.Any(c => c.IsDefault))
                {
                    var defaultCv = Model.CvFiles.FirstOrDefault(c => c.IsDefault);
                    <div class="cv-card p-4 flex items-center justify-between">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-lg bg-blue-600/20 flex items-center justify-center">
                                <span class="material-symbols-outlined text-blue-400">picture_as_pdf</span>
                            </div>
                            <div>
                                <p class="text-white font-medium">@defaultCv?.FileName</p>
                                <p class="text-slate-500 text-xs">CV mặc định • Upload: @defaultCv?.UploadedAt.ToString("dd/MM/yyyy")</p>
                            </div>
                        </div>
                        <a href="@defaultCv?.FilePath" target="_blank" class="px-3 py-1.5 bg-blue-600/20 text-blue-400 rounded-lg text-sm hover:bg-blue-600 hover:text-white transition-all">
                            Xem CV
                        </a>
                    </div>
                }
                else
                {
                    <div class="text-center py-6">
                        <span class="material-symbols-outlined text-4xl text-slate-600">upload_file</span>
                        <p class="text-slate-500 text-sm mt-2">Chưa có CV nào</p>
                    </div>
                }

                <!-- Panel quản lý CV (ẩn mặc định) -->
                <div id="cvManagerPanel" style="display: none;" class="mt-4 pt-4 border-t border-slate-700">
                    <form asp-action="UploadCv" asp-controller="Candidate" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <div class="flex gap-3">
                            <input type="file" name="cvFile" accept=".pdf,.docx" class="flex-1 input-field" required />
                            <button type="submit" class="btn-success px-4 py-2 text-white rounded-xl transition-all flex items-center gap-2">
                                <span class="material-symbols-outlined text-sm">upload</span>
                                Upload
                            </button>
                        </div>
                        <p class="text-xs text-slate-500 mt-2">Hỗ trợ file PDF, DOCX (tối đa 5MB)</p>
                    </form>

                    @if (Model?.CvFiles != null && Model.CvFiles.Any())
                    {
                        <div class="mt-4 space-y-2 max-h-64 overflow-y-auto pr-1">
                            @foreach (var cv in Model.CvFiles)
                            {
                                <div class="cv-card p-3 flex justify-between items-center">
                                    <div class="flex items-center gap-3">
                                        <span class="material-symbols-outlined text-blue-400">picture_as_pdf</span>
                                        <div>
                                            <p class="text-white text-sm font-medium">@cv.FileName</p>
                                            <p class="text-slate-500 text-xs">@cv.UploadedAt.ToString("dd/MM/yyyy HH:mm")</p>
                                        </div>
                                        @if (cv.IsDefault)
                                        {
                                            <span class="px-2 py-0.5 bg-green-600/20 text-green-400 text-xs rounded-full border border-green-800/50">Mặc định</span>
                                        }
                                    </div>
                                    <div class="flex gap-2">
                                        <a href="@cv.FilePath" target="_blank" class="text-blue-400 hover:text-blue-300 text-sm flex items-center gap-1">
                                            <span class="material-symbols-outlined text-sm">visibility</span>
                                        </a>
                                        @if (!cv.IsDefault)
                                        {
                                            <form method="post" asp-action="SetDefaultCv" style="display:inline">
                                                <input type="hidden" name="cvId" value="@cv.Id" />
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="text-green-400 hover:text-green-300 text-sm flex items-center gap-1">
                                                    <span class="material-symbols-outlined text-sm">star</span>
                                                </button>
                                            </form>
                                        }

                                        <!-- Delete CV -->
                                        <form method="post" asp-action="DeleteCv" style="display:inline" onsubmit="return confirm('Bạn có chắc muốn xóa CV này?');">
                                            <input type="hidden" name="cvId" value="@cv.Id" />
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="text-red-400 hover:text-red-300 text-sm flex items-center gap-1">
                                                <span class="material-symbols-outlined text-sm">delete</span>
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Toggle CV Manager Panel
    (function () {
        const toggleBtn = document.getElementById('toggleCvBtn');
        const panel = document.getElementById('cvManagerPanel');

        if (toggleBtn && panel) {
            toggleBtn.addEventListener('click', function (e) {
                e.preventDefault();
                if (panel.style.display === 'none' || panel.style.display === '') {
                    panel.style.display = 'block';
                    toggleBtn.innerHTML = '<span class="material-symbols-outlined text-sm">close</span> Đóng';
                    toggleBtn.classList.add('bg-red-600', 'hover:bg-red-700');
                    toggleBtn.classList.remove('bg-slate-700', 'hover:bg-slate-600');
                } else {
                    panel.style.display = 'none';
                    toggleBtn.innerHTML = '<span class="material-symbols-outlined text-sm">add</span> Quản lý CV';
                    toggleBtn.classList.remove('bg-red-600', 'hover:bg-red-700');
                    toggleBtn.classList.add('bg-slate-700', 'hover:bg-slate-600');
                }
            });
        }
    })();
</script>