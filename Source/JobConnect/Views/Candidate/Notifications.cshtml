@model List<JobConnect.Models.Notification>
@{
    ViewData["Title"] = "Thông báo";
    Layout = "_Layout";
}

<style>
    body {
        background-color: #000000 !important;
    }

    .glass-card {
        background: rgba(10, 10, 10, 0.85);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(59, 130, 246, 0.1);
        border-radius: 1.5rem;
        transition: all 0.3s ease;
    }

        .glass-card:hover {
            border-color: rgba(59, 130, 246, 0.3);
            box-shadow: 0 8px 32px rgba(59, 130, 246, 0.08);
        }

    .notif-item {
        border-bottom: 1px solid #1a1a1a;
        transition: all 0.2s;
    }

        .notif-item:last-child {
            border-bottom: none;
        }

        .notif-item:hover {
            background: rgba(255, 255, 255, 0.02);
        }

    .badge-interview {
        background-color: rgba(168, 85, 247, 0.15);
        color: #c084fc;
        border: 1px solid rgba(168, 85, 247, 0.3);
    }

    .badge-rejected {
        background-color: rgba(239, 68, 68, 0.15);
        color: #f87171;
        border: 1px solid rgba(239, 68, 68, 0.3);
    }

    .badge-warning {
        background-color: rgba(234, 179, 8, 0.15);
        color: #facc15;
        border: 1px solid rgba(234, 179, 8, 0.3);
    }

    .badge-default {
        background-color: rgba(59, 130, 246, 0.15);
        color: #60a5fa;
        border: 1px solid rgba(59, 130, 246, 0.3);
    }
</style>

<div class="max-w-4xl mx-auto px-4 py-8">
    <div class="flex items-center gap-3 mb-8">
        <div class="w-12 h-12 rounded-xl bg-blue-600/20 flex items-center justify-center">
            <span class="material-symbols-outlined text-3xl text-blue-400">notifications</span>
        </div>
        <div>
            <h1 class="text-2xl font-bold text-white">Thông báo của tôi</h1>
            <p class="text-slate-500 text-sm">Cập nhật tin tức phỏng vấn, hồ sơ và kết quả ứng tuyển</p>
        </div>
    </div>

    <div class="glass-card overflow-hidden">
        @if (Model == null || !Model.Any())
        {
            <div class="p-12 text-center text-slate-500">
                <span class="material-symbols-outlined text-5xl mb-3 block text-slate-600">notifications_off</span>
                <p class="text-base">Bạn không có thông báo nào.</p>
            </div>
        }
        else
        {
            <div class="divide-y divide-[#1a1a1a]">
                @foreach (var notif in Model)
                {
                    var isWarning = notif.Type == "Warning";
                    var isInterview = notif.Title.Contains("phỏng vấn", StringComparison.OrdinalIgnoreCase) || notif.Title.Contains("thư mời", StringComparison.OrdinalIgnoreCase);
                    var isRejected = notif.Title.Contains("từ chối", StringComparison.OrdinalIgnoreCase) || notif.Title.Contains("kết quả", StringComparison.OrdinalIgnoreCase) && notif.Content != null && notif.Content.Contains("Rất tiếc", StringComparison.OrdinalIgnoreCase);

                    var badgeCls = "badge-default";
                    var badgeIcon = "info";
                    var badgeText = "Hệ thống";

                    if (isWarning)
                    {
                        badgeCls = "badge-warning";
                        badgeIcon = "warning";
                        badgeText = "Hồ sơ";
                    }
                    else if (isInterview)
                    {
                        badgeCls = "badge-interview";
                        badgeIcon = "event";
                        badgeText = "Lịch phỏng vấn";
                    }
                    else if (isRejected)
                    {
                        badgeCls = "badge-rejected";
                        badgeIcon = "cancel";
                        badgeText = "Kết quả";
                    }

                    <div class="p-6 notif-item flex items-start gap-4">
                        <div class="w-10 h-10 rounded-xl shrink-0 flex items-center justify-center @(isWarning ? "bg-yellow-500/10 text-yellow-400" : isInterview ? "bg-purple-500/10 text-purple-400" : isRejected ? "bg-red-500/10 text-red-400" : "bg-blue-500/10 text-blue-400")">
                            <span class="material-symbols-outlined">@badgeIcon</span>
                        </div>

                        <div class="flex-1 min-w-0">
                            <div class="flex flex-wrap items-center gap-2 mb-1.5">
                                <h4 class="font-bold text-white text-base">@notif.Title</h4>
                                <span class="px-2 py-0.5 rounded text-[10px] font-semibold uppercase tracking-wider @badgeCls">
                                    @badgeText
                                </span>
                                @if (notif.NotifID > 0 && !notif.IsRead)
                                {
                                    <span class="w-1.5 h-1.5 rounded-full bg-blue-500" title="Chưa đọc"></span>
                                }
                            </div>
                            <p class="text-slate-400 text-sm whitespace-pre-line leading-relaxed">@notif.Content</p>
                            
                            @if (isWarning)
                            {
                                <div class="mt-3">
                                    <a asp-controller="Candidate" asp-action="Profile" class="inline-flex items-center gap-1 text-xs font-semibold text-blue-400 hover:text-blue-300 transition-colors">
                                        Cập nhật hồ sơ ngay <span class="material-symbols-outlined text-xs">arrow_forward</span>
                                    </a>
                                </div>
                            }
                            else if (notif.RelatedID.HasValue)
                            {
                                <div class="mt-3">
                                    <a asp-controller="Job" asp-action="Detail" asp-route-id="@notif.RelatedID.Value" class="inline-flex items-center gap-1 text-xs font-semibold text-blue-400 hover:text-blue-300 transition-colors">
                                        Xem chi tiết công việc <span class="material-symbols-outlined text-xs">arrow_forward</span>
                                    </a>
                                </div>
                            }

                            <div class="mt-2.5 text-xs text-slate-600 flex items-center gap-1">
                                <span class="material-symbols-outlined text-xs">schedule</span>
                                @notif.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
