@using JobConnect.Models
@model List<Application>
@{
    ViewData["Title"] = "Đơn ứng tuyển của tôi";
    Layout = "_Layout";
}

<div class="max-w-4xl mx-auto px-6 py-8">
    <div class="flex items-center gap-3 mb-6">
        <a asp-action="Profile" class="text-secondary hover:text-primary">
            <span class="material-symbols-outlined align-middle">arrow_back</span>
        </a>
        <h1 class="text-2xl font-bold text-on-surface">Đơn ứng tuyển của tôi</h1>
        <span class="ml-2 bg-surface-container text-secondary text-sm px-3 py-1 rounded-full">@Model.Count đơn</span>
    </div>

    @if (!Model.Any())
    {
        <div class="bg-white rounded-xl border border-outline-variant p-16 text-center">
            <span class="material-symbols-outlined text-5xl text-secondary block mb-3">send</span>
            <p class="text-secondary mb-3">Bạn chưa ứng tuyển vào vị trí nào.</p>
            <a asp-controller="Job" asp-action="Index"
               class="px-5 py-2.5 bg-primary text-white rounded-xl text-sm font-semibold hover:opacity-90">
                Tìm việc làm ngay
            </a>
        </div>
    }
    else
    {
        <div class="space-y-3">
            @foreach (var app in Model)
            {
                <div class="bg-white rounded-xl border border-outline-variant p-5 hover:shadow-md transition-shadow">
                    <div class="flex items-start gap-4">
                        <div class="w-12 h-12 rounded-xl border border-outline-variant bg-surface-container-low flex items-center justify-center flex-shrink-0">
                            @if (!string.IsNullOrEmpty(app.JobPost?.Employer?.LogoURL))
                            {
                                <img src="@app.JobPost.Employer.LogoURL" class="w-full h-full object-contain rounded-xl" />
                            }
                            else
                            {
                                <span class="material-symbols-outlined text-secondary">business</span>
                            }
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="flex items-start justify-between gap-3">
                                <div>
                                    <a asp-controller="Job" asp-action="Detail" asp-route-id="@app.JobID"
                                       class="font-semibold text-on-surface hover:text-primary text-sm">
                                        @app.JobPost?.Title
                                    </a>
                                    <p class="text-secondary text-xs mt-0.5">@app.JobPost?.Employer?.CompanyName</p>
                                </div>
                                <span class="px-3 py-1 rounded-full text-xs font-semibold flex-shrink-0
                                    @(app.Status == "Accepted" ? "bg-green-100 text-green-700" :
                                        app.Status == "Rejected" ? "bg-red-100 text-red-700" :
                                        app.Status == "Interview" ? "bg-blue-100 text-blue-700" :
                                        app.Status == "Reviewed" ? "bg-yellow-100 text-yellow-700" :
                                                                    "bg-gray-100 text-gray-600")">
                                    @(app.Status switch
                                    {
                                        "Pending" => "Chờ xem xét",
                                        "Reviewed" => "Đã xem",
                                        "Interview" => "Mời phỏng vấn",
                                        "Accepted" => "Chấp nhận",
                                        "Rejected" => "Từ chối",
                                        _ => app.Status
                                    })
                                </span>
                            </div>
                            <div class="flex flex-wrap gap-4 mt-2 text-xs text-secondary">
                                <span>
                                    <span class="material-symbols-outlined text-xs align-middle">schedule</span>
                                    Nộp: @app.AppliedAt.ToString("dd/MM/yyyy")
                                </span>
                                @if (app.JobPost?.Location != null)
                                {
                                    <span>
                                        <span class="material-symbols-outlined text-xs align-middle">location_on</span>
                                        @app.JobPost.Location
                                    </span>
                                }
                                <span>
                                    <span class="material-symbols-outlined text-xs align-middle">work</span>
                                    @app.JobPost?.JobType
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>