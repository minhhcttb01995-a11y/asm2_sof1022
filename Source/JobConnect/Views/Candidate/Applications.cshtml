@using JobConnect.Models
@model List<Application>

@{
    ViewData["Title"] = "Việc làm đã ứng tuyển";
    Layout = "_Layout";
}

<style>
    body {
        background-color: #f8fafc !important;
    }

    .glass-card {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 1.5rem;
        box-shadow: 0 1px 3px rgba(15, 23, 42, 0.06);
        transition: all 0.3s ease;
    }

        .glass-card:hover {
            border-color: rgba(59, 130, 246, 0.4);
        }

    .status-badge {
        padding: 0.25rem 0.75rem;
        border-radius: 9999px;
        font-size: 0.7rem;
        font-weight: bold;
        text-transform: uppercase;
    }

    .status-pending {
        background: #fef3c7;
        color: #b45309;
        border: 1px solid #fde68a;
    }

    .status-reviewed {
        background: #dbeafe;
        color: #1d4ed8;
        border: 1px solid #bfdbfe;
    }

    .status-interview {
        background: #ede9fe;
        color: #6d28d9;
        border: 1px solid #ddd6fe;
    }

    .status-offered {
        background: #dcfce7;
        color: #15803d;
        border: 1px solid #bbf7d0;
    }

    .status-rejected {
        background: #fee2e2;
        color: #b91c1c;
        border: 1px solid #fecaca;
    }
</style>

<div class="max-w-[1600px] mx-auto px-4 py-8">
    <!-- Header -->
    <div class="flex items-center gap-3 mb-6">
        <span class="material-symbols-outlined text-3xl text-blue-600">work_history</span>
        <h1 class="text-2xl font-bold text-slate-900">Việc làm đã ứng tuyển</h1>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="glass-card p-16 text-center">
            <span class="material-symbols-outlined text-6xl text-slate-500 block mb-4">send</span>
            <p class="text-slate-500 text-lg mb-2">Bạn chưa ứng tuyển việc làm nào</p>
            <p class="text-slate-500 text-sm mb-6">Hãy khám phá các cơ hội việc làm hấp dẫn ngay hôm nay!</p>
            <a href="/Job" class="inline-block px-6 py-3 bg-gradient-to-r from-blue-600 to-indigo-600 text-white font-bold rounded-xl hover:from-blue-700 hover:to-indigo-700 transition-all">
                🔍 Tìm việc ngay
            </a>
        </div>
    }
    else
    {
        <div class="space-y-4">
            @foreach (var app in Model)
            {
                <div class="glass-card p-6 transition-all hover:scale-[1.01]">
                    <div class="flex flex-col md:flex-row justify-between gap-4">
                        <div class="flex-1">
                            <div class="flex items-start gap-3">
                                <div class="w-12 h-12 rounded-xl bg-white flex items-center justify-center overflow-hidden">
                                    @if (app.Job?.Employer != null && !string.IsNullOrEmpty(app.Job.Employer.LogoURL))
                                    {
                                        <img src="@app.Job.Employer.LogoURL" class="w-full h-full object-contain" />
                                    }
                                    else
                                    {
                                        <span class="material-symbols-outlined text-slate-500">business</span>
                                    }
                                </div>
                                <div>
                                    <a href="/Job/Detail/@app.JobId" class="text-slate-900 font-bold text-lg hover:text-blue-600 transition-colors">
                                        @(app.Job?.Title ?? "Không có tiêu đề")
                                    </a>
                                    <p class="text-slate-500 text-sm">@(app.Job?.Employer?.CompanyName ?? "Đang cập nhật")</p>
                                    <div class="flex flex-wrap gap-3 mt-2 text-xs text-slate-500">
                                        <span class="flex items-center gap-1">
                                            <span class="material-symbols-outlined text-sm">location_on</span>
                                            @(app.Job?.Location ?? "Toàn quốc")
                                        </span>
                                        <span class="flex items-center gap-1">
                                            <span class="material-symbols-outlined text-sm">payments</span>
                                            @(app.Job?.SalaryMin?.ToString("N0") ?? "0") - @(app.Job?.SalaryMax?.ToString("N0") ?? "0")đ
                                        </span>
                                        <span class="flex items-center gap-1">
                                            <span class="material-symbols-outlined text-sm">schedule</span>
                                            @app.AppliedAt.ToString("dd/MM/yyyy HH:mm")
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="flex flex-col items-end gap-2">
                            <span class="status-badge status-@(app.Status?.ToLower() ?? "pending")">
                                @(app.Status switch
                                {
                                    "Pending" => "⏳ Chờ xét duyệt",
                                    "Reviewed" => "📄 Đã xem hồ sơ",
                                    "Interview" => "🎯 Phỏng vấn",
                                    "Offered" => "🎉 Nhận offer",
                                    "Rejected" => "❌ Không phù hợp",
                                    _ => "📌 " + (app.Status ?? "Chờ xét duyệt")
                                })
                            </span>

                            <!-- Comment hoặc bỏ phần Note nếu chưa có -->
                            @* @if (!string.IsNullOrEmpty(app.Note))
                            {
                                <p class="text-slate-500 text-xs mt-2 text-right italic">📝 Ghi chú: @app.Note</p>
                            } *@
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Thống kê -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-8">
            <div class="glass-card p-4 text-center">
                <div class="text-2xl font-bold text-blue-600">@Model.Count</div>
                <div class="text-slate-500 text-xs">Tổng ứng tuyển</div>
            </div>
            <div class="glass-card p-4 text-center">
                <div class="text-2xl font-bold text-yellow-600">@Model.Count(x => x.Status == "Pending")</div>
                <div class="text-slate-500 text-xs">Đang xét duyệt</div>
            </div>
            <div class="glass-card p-4 text-center">
                <div class="text-2xl font-bold text-purple-600">@Model.Count(x => x.Status == "Interview")</div>
                <div class="text-slate-500 text-xs">Phỏng vấn</div>
            </div>
            <div class="glass-card p-4 text-center">
                <div class="text-2xl font-bold text-green-600">@Model.Count(x => x.Status == "Offered")</div>
                <div class="text-slate-500 text-xs">Offer nhận được</div>
            </div>
        </div>
    }
</div>