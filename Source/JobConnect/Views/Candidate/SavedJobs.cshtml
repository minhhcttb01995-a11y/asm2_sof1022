@using JobConnect.Models
@model List<SavedJob>
@{
    ViewData["Title"] = "Việc làm đã lưu";
    Layout = "_Layout";
}

<div class="max-w-[1300px] mx-auto px-6 py-8">
    <div class="flex items-center gap-3 mb-6">
        <a asp-action="Profile" class="text-secondary hover:text-primary">
            <span class="material-symbols-outlined align-middle">arrow_back</span>
        </a>
        <h1 class="text-2xl font-bold text-on-surface">Việc làm đã lưu</h1>
        <span class="ml-2 bg-surface-container text-secondary text-sm px-3 py-1 rounded-full">@Model.Count tin</span>
    </div>

    @if (!Model.Any())
    {
        <div class="bg-white rounded-xl border border-outline-variant p-16 text-center">
            <span class="material-symbols-outlined text-5xl text-secondary block mb-3">bookmark</span>
            <p class="text-secondary mb-3">Bạn chưa lưu tin tuyển dụng nào.</p>
            <a asp-controller="Job" asp-action="Index"
               class="px-5 py-2.5 bg-primary text-slate-900 rounded-xl text-sm font-semibold hover:opacity-90">
                Khám phá việc làm
            </a>
        </div>
    }
    else
    {
        <div class="space-y-3">
            @foreach (var saved in Model)
            {
                var job = saved.JobPost;
                <div class="bg-white rounded-xl border border-outline-variant p-5 hover:shadow-md transition-shadow">
                    <div class="flex items-start gap-4">
                        <div class="w-12 h-12 rounded-xl border border-outline-variant bg-surface-container-low flex items-center justify-center flex-shrink-0">
                            @if (!string.IsNullOrEmpty(job?.Employer?.LogoURL))
                            {
                                <img src="@job.Employer.LogoURL" class="w-full h-full object-contain rounded-xl" />
                            }
                            else
                            {
                                <span class="material-symbols-outlined text-secondary">business</span>
                            }
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="flex items-start justify-between gap-3">
                                <div>
                                    <a asp-controller="Job" asp-action="Detail" asp-route-id="@job?.JobId"
                                       class="font-semibold text-on-surface hover:text-primary text-sm">@job?.Title</a>
                                    <p class="text-secondary text-xs mt-0.5">@job?.Employer?.CompanyName</p>
                                </div>
                                <p class="text-sm font-semibold text-primary whitespace-nowrap flex-shrink-0">@job?.FormatSalary()</p>
                            </div>
                            <div class="flex flex-wrap gap-2 mt-2">
                                @if (job?.JobType != null)
                                {
                                    <span class="text-xs bg-surface-container px-2 py-0.5 rounded-full text-secondary">@job.JobType</span>
                                }
                                @if (job?.Location != null)
                                {
                                    <span class="text-xs bg-surface-container px-2 py-0.5 rounded-full text-secondary">
                                        <span class="material-symbols-outlined text-xs align-middle">location_on</span> @job.Location
                                    </span>
                                }
                                <span class="text-xs text-secondary">
                                    Lưu: @saved.SavedAt.ToString("dd/MM/yyyy")
                                </span>
                            </div>
                        </div>
                    </div>
                    <div class="mt-3 pt-3 border-t border-outline-variant flex gap-3">
                        <a asp-controller="Job" asp-action="Detail" asp-route-id="@job?.JobId"
                           class="px-4 py-1.5 bg-primary text-slate-900 text-xs font-semibold rounded-lg hover:opacity-90 transition-opacity">
                            Xem chi tiết
                        </a>
                        <form asp-controller="Job" asp-action="ToggleSave" method="post" class="inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="jobId" value="@job?.JobId" />
                            <button type="submit"
                                    class="px-4 py-1.5 border border-outline-variant text-secondary text-xs rounded-lg hover:bg-surface-container transition-colors">
                                Bỏ lưu
                            </button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }
</div>