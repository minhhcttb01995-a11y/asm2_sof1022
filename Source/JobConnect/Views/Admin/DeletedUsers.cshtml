@* [VIEW-HEADER-ADDED]
   View cho action "DeletedUsers" trong khu vực trang quản trị Admin (AdminController).
*@
@using JobConnect.Models
@model List<User>
@{
    ViewData["Title"] = "Người dùng đã xóa";
    Layout = "_LayoutAdmin";
}

<!-- Modal Xác nhận xóa vĩnh viễn -->
<div id="modalPermanentDelete" class="fixed inset-0 z-50 hidden items-center justify-center bg-white">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-sm mx-4 p-6">
        <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-red-100 rounded-full flex items-center justify-center">
                <span class="material-symbols-outlined text-red-600">delete_forever</span>
            </div>
            <div>
                <h2 class="text-base font-bold text-on-surface">Xóa vĩnh viễn</h2>
                <p class="text-sm text-secondary">Hành động này không thể hoàn tác.</p>
            </div>
        </div>
        <p class="text-sm text-secondary mb-5">Toàn bộ dữ liệu liên quan tới tài khoản <strong id="pdUserName"></strong> sẽ bị xóa hoàn toàn khỏi hệ thống. Bạn có chắc chắn?</p>
        <form asp-action="PermanentDeleteUser" method="post" id="permanentDeleteForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="userId" id="pdUserId" />
            <div class="flex gap-3">
                <button type="button" onclick="closePermanentDeleteModal()"
                        class="flex-1 px-4 py-2.5 border border-outline-variant rounded-xl text-sm font-medium text-secondary hover:bg-surface-container">
                    Huỷ
                </button>
                <button type="submit"
                        class="flex-1 px-4 py-2.5 bg-red-600 text-white rounded-xl text-sm font-semibold hover:bg-red-700">
                    Xóa vĩnh viễn
                </button>
            </div>
        </form>
    </div>
</div>

<div class="max-w-[1700px] mx-auto px-6 py-8">
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-2xl font-bold text-on-surface">Người dùng đã xóa</h1>
            <p class="text-sm text-secondary mt-1">Các tài khoản đã bị xóa mềm, có thể khôi phục lại trạng thái hoạt động.</p>
        </div>
        <a asp-action="Users"
           class="flex items-center gap-2 px-4 py-2.5 border border-outline-variant text-secondary rounded-xl text-sm font-semibold hover:bg-surface-container">
            <span class="material-symbols-outlined text-base">arrow_back</span>
            Quay lại danh sách
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="mb-4 px-4 py-3 bg-green-100 text-green-700 rounded-xl text-sm font-medium flex items-center gap-2 auto-hide-alert">
            <span class="material-symbols-outlined text-base">check_circle</span>
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="mb-4 px-4 py-3 bg-red-100 text-red-700 rounded-xl text-sm font-medium flex items-center gap-2">
            <span class="material-symbols-outlined text-base">error</span>
            @TempData["Error"]
        </div>
    }

    <!-- Search -->
    <form method="get" class="flex gap-3 mb-6">
        <input name="keyword" value="@ViewBag.Keyword" type="text" placeholder="Tìm theo tên, email..."
               class="flex-1 px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
        <button type="submit" class="px-6 py-2.5 bg-primary text-slate-900 rounded-xl text-sm font-semibold hover:opacity-90">Tìm</button>
    </form>

    <!-- Table -->
    <div class="bg-white rounded-xl border border-outline-variant overflow-hidden">
        <table class="w-full text-sm">
            <thead class="bg-surface-container-low border-b border-outline-variant">
                <tr>
                    <th class="text-left px-4 py-3 font-semibold text-xs">ID</th>
                    <th class="text-left px-5 py-3 font-semibold">Người dùng</th>
                    <th class="text-left px-5 py-3 font-semibold">Vai trò</th>
                    <th class="text-left px-5 py-3 font-semibold">Ngày xóa</th>
                    <th class="px-5 py-3 text-center font-semibold">Thao tác</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-outline-variant">
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="px-5 py-10 text-center text-secondary text-sm">
                            Không có tài khoản nào đã bị xóa.
                        </td>
                    </tr>
                }
                @foreach (var user in Model)
                {
                    var roleCls = user.Role == "Admin" ? "bg-purple-100 text-purple-700" :
                                  user.Role == "Staff" ? "bg-orange-100 text-orange-700" :
                                  user.Role == "Employer" ? "bg-blue-100 text-blue-700" :
                                                            "bg-gray-100 text-gray-600";
                    var roleLabel = user.Role == "Admin" ? "Admin" :
                                    user.Role == "Staff" ? "Nhân viên" :
                                    user.Role == "Employer" ? "Nhà tuyển dụng" : "Ứng viên";

                    <tr class="hover:bg-surface-container-low transition-colors">
                        <td class="px-4 py-3">
                            <span class="font-mono text-xs text-secondary bg-surface-container px-2 py-1 rounded-lg select-all">@user.UserId</span>
                        </td>
                        <td class="px-5 py-3">
                            <div class="flex items-center gap-3">
                                <div class="w-9 h-9 rounded-full bg-surface-container flex items-center justify-center flex-shrink-0 overflow-hidden">
                                    @if (!string.IsNullOrEmpty(user.AvatarURL))
                                    {
                                        <img src="@user.AvatarURL" class="w-9 h-9 rounded-full object-cover" />
                                    }
                                    else
                                    {
                                        <span class="material-symbols-outlined text-sm text-secondary">person</span>
                                    }
                                </div>
                                <div>
                                    <p class="font-medium text-on-surface">@user.FullName</p>
                                    <p class="text-xs text-secondary">@user.Email</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-5 py-3">
                            <span class="px-2.5 py-1 rounded-full text-xs font-medium @roleCls">@roleLabel</span>
                        </td>
                        <td class="px-5 py-3 text-secondary text-xs">
                            @(user.DeletedAt.HasValue ? user.DeletedAt.Value.ToString("dd/MM/yyyy HH:mm") : "-")
                        </td>
                        <td class="px-5 py-3">
                            <div class="flex items-center justify-center gap-2">
                                <!-- Khôi phục -->
                                <form asp-action="RestoreUser" method="post" class="inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="userId" value="@user.UserId" />
                                    <button type="submit"
                                            class="flex items-center gap-1 px-3 py-1.5 bg-green-50 text-green-700 hover:bg-green-100 border border-green-200 rounded-lg text-xs font-medium transition-colors">
                                        <span class="material-symbols-outlined text-sm">restore</span>
                                        Khôi phục
                                    </button>
                                </form>

                                <!-- Xóa vĩnh viễn -->
                                <button onclick="openPermanentDeleteModal(@user.UserId, '@user.FullName.Replace("'", "\\'")')"
                                        class="flex items-center gap-1 px-3 py-1.5 bg-red-50 text-red-600 hover:bg-red-100 border border-red-200 rounded-lg text-xs font-medium transition-colors">
                                    <span class="material-symbols-outlined text-sm">delete_forever</span>
                                    Xóa vĩnh viễn
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @if (ViewBag.TotalPages > 1)
    {
        <div class="flex justify-center gap-2 mt-6">
            @for (int i = 1; i <= (int)ViewBag.TotalPages; i++)
            {
                <a asp-action="DeletedUsers" asp-route-page="@i" asp-route-keyword="@ViewBag.Keyword"
                   class="w-9 h-9 flex items-center justify-center rounded-lg text-sm border
                    @(i == (int)(ViewBag.Page ?? 1) ? "bg-primary text-slate-900 border-primary" : "border-outline-variant text-secondary hover:bg-surface-container")">
                    @i
                </a>
            }
        </div>
    }
</div>

<script>
    function openPermanentDeleteModal(userId, userName) {
        document.getElementById('pdUserId').value = userId;
        document.getElementById('pdUserName').textContent = userName;
        document.getElementById('modalPermanentDelete').classList.remove('hidden');
        document.getElementById('modalPermanentDelete').classList.add('flex');
    }
    function closePermanentDeleteModal() {
        document.getElementById('modalPermanentDelete').classList.add('hidden');
        document.getElementById('modalPermanentDelete').classList.remove('flex');
    }
    document.getElementById('modalPermanentDelete').addEventListener('click', function (e) {
        if (e.target === this) closePermanentDeleteModal();
    });
</script>
