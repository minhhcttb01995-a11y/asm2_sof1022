@* [VIEW-HEADER-ADDED]
   View cho action "EditCandidateProfile" trong khu vực trang quản trị Admin (AdminController).
*@
@using JobConnect.Models
@model CandidateProfile
@{
    ViewData["Title"] = "Chỉnh sửa thông tin ứng viên";
    Layout = "_LayoutAdmin";
}

<div class="max-w-3xl mx-auto px-6 py-8">
    <!-- Header -->
    <div class="mb-6">
        <a asp-action="UserDetail" asp-route-id="@Model.UserId" class="inline-flex items-center gap-2 text-secondary hover:text-on-surface mb-4">
            <span class="material-symbols-outlined text-base">arrow_back</span>
            Quay lại chi tiết
        </a>
        <h1 class="text-2xl font-bold text-on-surface">Chỉnh sửa thông tin ứng viên</h1>
        <p class="text-secondary text-sm mt-1">Cập nhật hồ sơ ứng viên</p>
    </div>

    <div class="bg-white rounded-2xl border border-outline-variant p-6">
        <form asp-action="EditCandidateProfile" asp-route-id="@Model.ProfileId" method="post" class="space-y-5">
            @Html.AntiForgeryToken()
            <input type="hidden" name="ProfileId" value="@Model.ProfileId" />
            <input type="hidden" name="UserId" value="@Model.UserId" />

            <div>
                <label asp-for="FullName" class="block text-sm font-medium text-on-surface mb-2">Họ tên <span class="text-red-600">*</span></label>
                <input asp-for="FullName" class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" required />
                <span asp-validation-for="FullName" class="text-red-600 text-sm"></span>
            </div>

            <div>
                <label asp-for="Phone" class="block text-sm font-medium text-on-surface mb-2">Điện thoại</label>
                <input asp-for="Phone" class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
                <span asp-validation-for="Phone" class="text-red-600 text-sm"></span>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div>
                    <label asp-for="DateOfBirth" class="block text-sm font-medium text-on-surface mb-2">Ngày sinh</label>
                    <input asp-for="DateOfBirth" type="date" class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
                    <span asp-validation-for="DateOfBirth" class="text-red-600 text-sm"></span>
                </div>
                <div>
                    <label asp-for="Gender" class="block text-sm font-medium text-on-surface mb-2">Giới tính</label>
                    <select asp-for="Gender" class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary">
                        <option value="">-- Chọn --</option>
                        <option value="Nam">Nam</option>
                        <option value="Nữ">Nữ</option>
                        <option value="Khác">Khác</option>
                    </select>
                    <span asp-validation-for="Gender" class="text-red-600 text-sm"></span>
                </div>
            </div>

            <div>
                <label asp-for="Address" class="block text-sm font-medium text-on-surface mb-2">Địa chỉ</label>
                <input asp-for="Address" class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
                <span asp-validation-for="Address" class="text-red-600 text-sm"></span>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div>
                    <label asp-for="ExperienceYears" class="block text-sm font-medium text-on-surface mb-2">Kinh nghiệm (năm)</label>
                    <input asp-for="ExperienceYears" type="number" min="0" class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
                    <span asp-validation-for="ExperienceYears" class="text-red-600 text-sm"></span>
                </div>
                <div>
                    <label asp-for="DesiredSalary" class="block text-sm font-medium text-on-surface mb-2">Lương mong muốn (VNĐ)</label>
                    <input asp-for="DesiredSalary" type="number" min="0" class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
                    <span asp-validation-for="DesiredSalary" class="text-red-600 text-sm"></span>
                </div>
            </div>

            <div>
                <label asp-for="Summary" class="block text-sm font-medium text-on-surface mb-2">Giới thiệu bản thân</label>
                <textarea asp-for="Summary" rows="4" class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary resize-none"></textarea>
                <span asp-validation-for="Summary" class="text-red-600 text-sm"></span>
            </div>

            <div class="flex gap-3 pt-2">
                <a asp-action="UserDetail" asp-route-id="@Model.UserId" class="flex-1 px-4 py-2.5 border border-outline-variant rounded-xl text-sm font-medium text-secondary hover:bg-surface-container">
                    Huỷ
                </a>
                <button type="submit" class="flex-1 px-4 py-2.5 bg-primary text-slate-900 rounded-xl text-sm font-semibold hover:opacity-90">
                    Lưu thay đổi
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
