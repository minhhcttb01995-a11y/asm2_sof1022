@using JobConnect.Models
@model List<JobPost>
@{
    ViewData["Title"] = "Quản lý tin tuyển dụng";
    Layout = "_LayoutAdmin";
    var currentStatus = ViewBag.Status?.ToString() ?? "";

    int cntAll = (int)(ViewBag.CntAll ?? 0);
    int cntPending = (int)(ViewBag.CntPending ?? 0);
    int cntOpen = (int)(ViewBag.CntOpen ?? 0);
    int cntRejected = (int)(ViewBag.CntRejected ?? 0);
    int cntClosed = (int)(ViewBag.CntClosed ?? 0);
    int cntDraft = (int)(ViewBag.CntDraft ?? 0);
}

@* ── Modal xác nhận xóa ── *@
<div id="modalDelete" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 backdrop-blur-sm">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-sm mx-4 p-6">
        <div class="flex items-center gap-3 mb-4">
            <div class="w-11 h-11 rounded-full flex items-center justify-center flex-shrink-0" style="background:#fef2f2">
                <span class="material-symbols-outlined" style="color:#dc2626">delete_forever</span>
            </div>
            <div>
                <h2 class="text-base font-bold" style="color:#1e293b">Xác nhận xóa tin</h2>
                <p class="text-xs" style="color:#64748b">Toàn bộ đơn ứng tuyển liên quan sẽ bị xóa theo.</p>
            </div>
        </div>
        <p class="text-sm mb-5" style="color:#475569">
            Bạn có chắc muốn xóa tin <strong id="deleteJobTitle" style="color:#1e293b"></strong>?
            Hành động này <span style="color:#dc2626;font-weight:600">không thể hoàn tác</span>.
        </p>
        <form asp-action="DeleteJob" method="post" id="deleteJobForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="jobId" id="deleteJobId" />
            <input type="hidden" name="filterStatus" value="@currentStatus" />
            <div class="flex gap-3">
                <button type="button" onclick="closeDeleteModal()"
                        class="flex-1 px-4 py-2.5 rounded-xl text-sm font-medium"
                        style="border:1px solid #e2e8f0;color:#64748b">
                    Huỷ
                </button>
                <button type="submit"
                        class="flex-1 px-4 py-2.5 bg-red-600 text-white rounded-xl text-sm font-semibold hover:bg-red-700">
                    Xác nhận xóa
                </button>
            </div>
        </form>
    </div>
</div>

<div style="padding:24px" class="space-y-5">

    @* ── Header ── *@
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3">
        <div>
            <h1 class="text-2xl font-bold" style="color:#1e293b">Quản lý tin tuyển dụng</h1>
            <p class="text-sm mt-0.5" style="color:#64748b">Tổng <strong style="color:#1e293b">@cntAll</strong> tin đã đăng</p>
        </div>
        @* Badge nổi bật: pending cần duyệt *@
        @if (cntPending > 0)
        {
            <a asp-action="Jobs" asp-route-status="Pending"
               class="flex items-center gap-2 px-4 py-2 rounded-xl text-sm font-semibold animate-pulse"
               style="background:#fefce8;color:#a16207;border:1px solid #fef08a">
                <span class="material-symbols-outlined text-base">pending_actions</span>
                @cntPending tin đang chờ duyệt
            </a>
        }
    </div>

    @* ── Flash ── *@
    @if (TempData["Success"] != null)
    {
        <div class="px-4 py-3 rounded-xl text-sm font-medium flex items-center gap-2" style="background:#f0fdf4;color:#16a34a;border:1px solid #bbf7d0">
            <span class="material-symbols-outlined text-base">check_circle</span> @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="px-4 py-3 rounded-xl text-sm font-medium flex items-center gap-2" style="background:#fef2f2;color:#dc2626;border:1px solid #fecaca">
            <span class="material-symbols-outlined text-base">error</span> @TempData["Error"]
        </div>
    }

    @* ── Tab filters ── *@
    <div class="flex flex-wrap gap-2">
        @{
            var tabs = new[]
            {
                ("Tất cả",     "",         cntAll,      "#64748b", "#f8fafc", "#e2e8f0"),
                ("Chờ duyệt",  "Pending",  cntPending,  "#a16207", "#fefce8", "#fef08a"),
                ("Đang mở",    "Open",     cntOpen,     "#16a34a", "#f0fdf4", "#bbf7d0"),
                ("Đã từ chối", "Rejected", cntRejected, "#dc2626", "#fef2f2", "#fecaca"),
                ("Đã ẩn",      "Closed",   cntClosed,   "#64748b", "#f8fafc", "#e2e8f0"),
                ("Nháp",       "Draft",    cntDraft,    "#7c3aed", "#faf5ff", "#ddd6fe"),
            };
        }
        @foreach (var (label, val, cnt, color, bg, border) in tabs)
        {
            bool active = currentStatus == val;
            <a asp-action="Jobs" asp-route-status="@val"
               class="flex items-center gap-1.5 px-4 py-2 rounded-xl text-sm font-medium transition-all"
               style="@(active
                                  ? $"background:{color};color:#fff;border:1px solid {color}"
                                  : $"background:{bg};color:{color};border:1px solid {border}")">
                @label
                <span class="text-xs px-1.5 py-0.5 rounded-full font-bold"
                      style="background:rgba(0,0,0,.12)">@cnt</span>
            </a>
        }
    </div>

    @* ── Table ── *@
    <div class="bg-white rounded-2xl overflow-hidden" style="border:1px solid #e2e8f0;box-shadow:0 1px 3px rgba(0,0,0,.05)">
        @if (!Model.Any())
        {
            <div class="py-20 text-center" style="color:#94a3b8">
                <span class="material-symbols-outlined text-5xl block mb-3" style="opacity:.3">work_off</span>
                <p class="text-sm font-medium" style="color:#64748b">Không có tin nào</p>
                <p class="text-xs mt-1">Thử chọn tab khác hoặc xóa bộ lọc</p>
            </div>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead style="background:#f8fafc;border-bottom:1px solid #e2e8f0">
                        <tr>
                            <th class="px-5 py-3.5 text-left text-xs font-semibold uppercase tracking-wide" style="color:#64748b">Tin tuyển dụng</th>
                            <th class="px-4 py-3.5 text-left text-xs font-semibold uppercase tracking-wide" style="color:#64748b">Công ty</th>
                            <th class="px-4 py-3.5 text-center text-xs font-semibold uppercase tracking-wide" style="color:#64748b">Trạng thái</th>
                            <th class="px-4 py-3.5 text-center text-xs font-semibold uppercase tracking-wide" style="color:#64748b">Đơn UV</th>
                            <th class="px-4 py-3.5 text-center text-xs font-semibold uppercase tracking-wide" style="color:#64748b">Ngày đăng</th>
                            <th class="px-4 py-3.5 text-center text-xs font-semibold uppercase tracking-wide" style="color:#64748b">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var job in Model)
                        {
                            var (sBg, sColor, sLabel) = job.Status switch
                            {
                                "Open" => ("#f0fdf4", "#16a34a", "Đang mở"),
                                "Pending" => ("#fefce8", "#a16207", "Chờ duyệt"),
                                "Rejected" => ("#fef2f2", "#dc2626", "Từ chối"),
                                "Closed" => ("#f8fafc", "#64748b", "Đã ẩn"),
                                "Draft" => ("#faf5ff", "#7c3aed", "Nháp"),
                                _ => ("#f8fafc", "#64748b", job.Status)
                            };

                            <tr style="border-bottom:1px solid #f1f5f9;transition:background .1s"
                                onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background=''">

                                @* Tiêu đề *@
                                <td class="px-5 py-3.5" style="max-width:280px">
                                    <div>
                                        <a asp-controller="Job" asp-action="Detail" asp-route-id="@job.JobID"
                                           class="font-semibold hover:underline line-clamp-2" style="color:#1e293b" target="_blank">
                                            @job.Title
                                        </a>
                                        <div class="flex items-center gap-2 mt-1 flex-wrap">
                                            <span class="text-xs" style="color:#94a3b8">@job.JobType</span>
                                            @if (!string.IsNullOrEmpty(job.Location))
                                            {
                                                <span class="text-xs" style="color:#94a3b8">• @job.Location</span>
                                            }
                                            @if (job.IsFeatured)
                                            {
                                                <span class="text-xs px-1.5 py-0.5 rounded font-semibold" style="background:#fef3c7;color:#d97706">⭐ Nổi bật</span>
                                            }
                                        </div>
                                    </div>
                                </td>

                                @* Công ty *@
                                <td class="px-4 py-3.5">
                                    <p class="font-medium text-sm" style="color:#374151">@(job.Employer?.CompanyName ?? "—")</p>
                                    <p class="text-xs mt-0.5" style="color:#94a3b8">@(job.Employer?.Industry ?? "")</p>
                                </td>

                                @* Status badge *@
                                <td class="px-4 py-3.5 text-center">
                                    <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-semibold"
                                          style="background:@sBg;color:@sColor">
                                        @sLabel
                                    </span>
                                </td>

                                @* Đơn ứng tuyển *@
                                <td class="px-4 py-3.5 text-center">
                                    <span class="inline-flex items-center justify-center w-8 h-8 rounded-lg text-sm font-bold"
                                          style="background:#eff6ff;color:#3b82f6">
                                        @(job.Applications?.Count ?? 0)
                                    </span>
                                </td>

                                @* Ngày đăng *@
                                <td class="px-4 py-3.5 text-center">
                                    <p class="text-xs font-medium" style="color:#475569">@job.CreatedAt.ToString("dd/MM/yyyy")</p>
                                    @if (job.Deadline.HasValue)
                                    {
                                        bool expired = job.Deadline.Value < DateTime.Now;
                                        <p class="text-xs mt-0.5" style="color:@(expired ? "#dc2626" : "#94a3b8")">
                                            HH: @job.Deadline.Value.ToString("dd/MM/yyyy")
                                        </p>
                                    }
                                </td>

                                @* Thao tác *@
                                <td class="px-4 py-3.5">
                                    <div class="flex items-center justify-center gap-1.5 flex-wrap">

                                        @* Xem *@
                                        <a asp-controller="Job" asp-action="Detail" asp-route-id="@job.JobID"
                                           target="_blank" class="jb-btn" style="background:#f8fafc;color:#475569;border:1px solid #e2e8f0"
                                           title="Xem tin">
                                            <span class="material-symbols-outlined text-sm">visibility</span>
                                            Xem
                                        </a>

                                        @* Duyệt (Open) — khi chưa Open *@
                                        @if (job.Status != "Open")
                                        {
                                            <form asp-action="SetJobStatus" method="post" class="inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="jobId" value="@job.JobID" />
                                                <input type="hidden" name="status" value="Open" />
                                                <input type="hidden" name="filterStatus" value="@currentStatus" />
                                                <button type="submit" class="jb-btn" title="Duyệt tin"
                                                        style="background:#f0fdf4;color:#16a34a;border:1px solid #bbf7d0">
                                                    <span class="material-symbols-outlined text-sm">check_circle</span>
                                                    Duyệt
                                                </button>
                                            </form>
                                        }

                                        @* Từ chối — khi Pending hoặc Open *@
                                        @if (job.Status == "Pending" || job.Status == "Open")
                                        {
                                            <form asp-action="SetJobStatus" method="post" class="inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="jobId" value="@job.JobID" />
                                                <input type="hidden" name="status" value="Rejected" />
                                                <input type="hidden" name="filterStatus" value="@currentStatus" />
                                                <button type="submit" class="jb-btn" title="Từ chối tin"
                                                        style="background:#fef2f2;color:#dc2626;border:1px solid #fecaca">
                                                    <span class="material-symbols-outlined text-sm">cancel</span>
                                                    Từ chối
                                                </button>
                                            </form>
                                        }

                                        @* Ẩn (Closed) — khi đang Open *@
                                        @if (job.Status == "Open")
                                        {
                                            <form asp-action="SetJobStatus" method="post" class="inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="jobId" value="@job.JobID" />
                                                <input type="hidden" name="status" value="Closed" />
                                                <input type="hidden" name="filterStatus" value="@currentStatus" />
                                                <button type="submit" class="jb-btn" title="Ẩn tin"
                                                        style="background:#fefce8;color:#ca8a04;border:1px solid #fde68a">
                                                    <span class="material-symbols-outlined text-sm">visibility_off</span>
                                                    Ẩn
                                                </button>
                                            </form>
                                        }

                                        @* Mở lại (Open) — khi đang Closed hoặc Rejected *@
                                        @if (job.Status == "Closed" || job.Status == "Rejected")
                                        {
                                            <form asp-action="SetJobStatus" method="post" class="inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="jobId" value="@job.JobID" />
                                                <input type="hidden" name="status" value="Open" />
                                                <input type="hidden" name="filterStatus" value="@currentStatus" />
                                                <button type="submit" class="jb-btn" title="Mở lại tin"
                                                        style="background:#eff6ff;color:#3b82f6;border:1px solid #bfdbfe">
                                                    <span class="material-symbols-outlined text-sm">refresh</span>
                                                    Mở lại
                                                </button>
                                            </form>
                                        }

                                        @* Xóa *@
                                        <button onclick="openDeleteModal(@job.JobID, '@job.Title.Replace("'", "\\'").Replace("\"", "&quot;")')"
                                                class="jb-btn" title="Xóa tin"
                                                style="background:#fef2f2;color:#dc2626;border:1px solid #fecaca">
                                            <span class="material-symbols-outlined text-sm">delete</span>
                                            Xóa
                                        </button>

                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @* Pagination *@
            @if ((int)(ViewBag.TotalPages ?? 1) > 1)
            {
                <div class="flex justify-center gap-2 p-4" style="border-top:1px solid #f1f5f9">
                    @for (int i = 1; i <= (int)ViewBag.TotalPages; i++)
                    {
                        bool active = i == (int)(ViewBag.Page ?? 1);
                        <a asp-action="Jobs" asp-route-page="@i" asp-route-status="@ViewBag.Status"
                           class="w-9 h-9 flex items-center justify-center rounded-lg text-sm font-medium transition-colors"
                           style="@(active ? "background:#3b82f6;color:#fff;border:1px solid #3b82f6" : "border:1px solid #e2e8f0;color:#64748b")">
                            @i
                        </a>
                    }
                </div>
            }
        }
    </div>

</div>

<style>
    .jb-btn {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 5px 10px;
        border-radius: 8px;
        font-size: .75rem;
        font-weight: 500;
        cursor: pointer;
        transition: opacity .15s, transform .1s;
        white-space: nowrap;
        font-family: inherit;
        text-decoration: none;
    }

        .jb-btn:hover {
            opacity: .8;
            transform: translateY(-1px);
        }
</style>

<script>
    function openDeleteModal(id, title) {
        document.getElementById('deleteJobId').value = id;
        document.getElementById('deleteJobTitle').textContent = title;
        const m = document.getElementById('modalDelete');
        m.classList.remove('hidden');
        m.classList.add('flex');
    }
    function closeDeleteModal() {
        const m = document.getElementById('modalDelete');
        m.classList.add('hidden');
        m.classList.remove('flex');
    }
    document.getElementById('modalDelete').addEventListener('click', function(e) {
        if (e.target === this) closeDeleteModal();
    });
</script>
