@* [VIEW-HEADER-ADDED]
   View cho action "Categories" trong khu vực trang quản trị Admin (AdminController).
*@
@using JobConnect.Models
@using JobConnect.Helpers
@{
    ViewData["Title"] = "Quản lý Danh mục";
    Layout = "_LayoutAdmin";
}

<div class="w-full px-6 py-8 xl:px-10">
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-2xl font-bold text-on-surface">Quản lý Danh mục</h1>
            <p class="text-secondary text-sm">Quản lý danh mục ngành nghề, địa điểm, cấp độ, loại công việc</p>
        </div>
        <button type="button" onclick="openCreateCategoryModal()" class="px-5 py-2.5 bg-primary text-slate-900 rounded-xl text-sm font-semibold hover:opacity-90 flex items-center gap-2">
            <span class="material-symbols-outlined text-base">add</span>
            Thêm danh mục
        </button>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="mb-4 px-4 py-3 bg-green-100 text-green-700 rounded-xl text-sm font-medium flex items-center gap-2 auto-hide-alert">
            <span class="material-symbols-outlined text-base">check_circle</span>
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="mb-4 px-4 py-3 bg-red-100 text-red-700 rounded-xl text-sm font-medium flex items-center gap-2">
            <span class="material-symbols-outlined text-base">error</span>
            @TempData["Error"]
        </div>
    }

    <!-- Filters -->
    <div class="bg-white rounded-2xl p-4 border border-outline-variant mb-6">
        <form asp-action="Categories" method="get" class="flex flex-wrap gap-4">
            <div class="flex-1 min-w-[200px]">
                <input type="text" name="keyword" value="@ViewBag.KeywordFilter" placeholder="Tìm kiếm danh mục..."
                       class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
            </div>
            <div class="min-w-[150px]">
                <select name="type" class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary">
                    @if (ViewBag.TypeFilter == "Industry")
                    {
                        <option value="Industry" selected>Ngành nghề</option>
                    }
                    else
                    {
                        <option value="Industry">Ngành nghề</option>
                    }
                    @if (ViewBag.TypeFilter == "Location")
                    {
                        <option value="Location" selected>Địa điểm</option>
                    }
                    else
                    {
                        <option value="Location">Địa điểm</option>
                    }
                    @if (ViewBag.TypeFilter == "Level")
                    {
                        <option value="Level" selected>Cấp độ</option>
                    }
                    else
                    {
                        <option value="Level">Cấp độ</option>
                    }
                    @if (ViewBag.TypeFilter == "JobType")
                    {
                        <option value="JobType" selected>Loại công việc</option>
                    }
                    else
                    {
                        <option value="JobType">Loại công việc</option>
                    }
                </select>
            </div>
            <button type="submit" class="px-5 py-2.5 bg-primary text-slate-900 rounded-xl text-sm font-semibold hover:opacity-90">
                Lọc
            </button>
            <a asp-action="Categories" class="px-5 py-2.5 border border-outline-variant rounded-xl text-sm font-medium text-secondary hover:bg-surface-container">
                Đặt lại
            </a>
        </form>
    </div>

    <!-- Table -->
    <div class="bg-white rounded-2xl border border-outline-variant overflow-hidden">
        <table class="w-full">
            <thead class="bg-surface-container">
                <tr>
                    <th class="px-6 py-3 text-left text-xs font-semibold text-secondary uppercase">Tên</th>
                    <th class="px-6 py-3 text-left text-xs font-semibold text-secondary uppercase">Slug</th>
                    <th class="px-6 py-3 text-left text-xs font-semibold text-secondary uppercase">Loại</th>
                    <th class="px-6 py-3 text-left text-xs font-semibold text-secondary uppercase">Ngày tạo</th>
                    <th class="px-6 py-3 text-right text-xs font-semibold text-secondary uppercase">Thao tác</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-outline-variant">
                @if (ViewBag.Categories != null && ((List<Category>)ViewBag.Categories).Any())
                {
                    @foreach (var category in (List<Category>)ViewBag.Categories)
                    {
                        <tr class="hover:bg-surface-container transition-colors">
                            <td class="px-6 py-4 text-sm font-medium text-on-surface">@category.Name</td>
                            <td class="px-6 py-4 text-sm text-secondary">@category.Slug</td>
                            <td class="px-6 py-4">
                                <span class="px-2 py-1 bg-blue-50 text-blue-600 rounded-lg text-xs font-medium">@CategoryTypeLabels.GetLabel(category.Type)</span>
                            </td>
                            <td class="px-6 py-4 text-sm text-secondary">@category.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="px-6 py-4 text-right">
                                <div class="flex items-center justify-end gap-2">
                                    <a asp-action="CategoryEdit" asp-route-id="@category.CategoryID"
                                       class="p-2 rounded-lg hover:bg-surface-container text-secondary hover:text-primary transition-colors">
                                        <span class="material-symbols-outlined text-sm">edit</span>
                                    </a>
                                    <form asp-action="CategoryDelete" method="post" class="inline"
                                          onsubmit="return confirm('Bạn có chắc muốn xóa danh mục này?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@category.CategoryID" />
                                        <button type="submit" class="p-2 rounded-lg hover:bg-red-50 text-secondary hover:text-red-600 transition-colors">
                                            <span class="material-symbols-outlined text-sm">delete</span>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="px-6 py-12 text-center text-secondary">
                            <span class="material-symbols-outlined text-4xl mb-2">folder_open</span>
                            <p>Không có danh mục nào</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @if (ViewBag.TotalPages > 1)
    {
        <div class="flex items-center justify-between mt-6">
            <p class="text-sm text-secondary">
                Hiển thị @((ViewBag.Page - 1) * ViewBag.PageSize + 1) - @Math.Min(ViewBag.Page * ViewBag.PageSize, ViewBag.TotalItems) của @ViewBag.TotalItems danh mục
            </p>
            <div class="flex gap-2">
                @if (ViewBag.Page > 1)
                {
                    <a asp-action="Categories" asp-route-page="@(ViewBag.Page - 1)" asp-route-keyword="@ViewBag.KeywordFilter" asp-route-type="@ViewBag.TypeFilter"
                       class="px-3 py-2 border border-outline-variant rounded-lg text-sm text-secondary hover:bg-surface-container">
                        Trước
                    </a>
                }
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    if (i == ViewBag.Page)
                    {
                        <span class="px-3 py-2 bg-primary text-slate-900 rounded-lg text-sm font-medium">@i</span>
                    }
                    else
                    {
                        <a asp-action="Categories" asp-route-page="@i" asp-route-keyword="@ViewBag.KeywordFilter" asp-route-type="@ViewBag.TypeFilter"
                           class="px-3 py-2 border border-outline-variant rounded-lg text-sm text-secondary hover:bg-surface-container">
                            @i
                        </a>
                    }
                }
                @if (ViewBag.Page < ViewBag.TotalPages)
                {
                    <a asp-action="Categories" asp-route-page="@(ViewBag.Page + 1)" asp-route-keyword="@ViewBag.KeywordFilter" asp-route-type="@ViewBag.TypeFilter"
                       class="px-3 py-2 border border-outline-variant rounded-lg text-sm text-secondary hover:bg-surface-container">
                        Sau
                    </a>
                }
            </div>
        </div>
    }
</div>

<!-- Create Category Modal -->
<div id="createCategoryModal" class="hidden fixed inset-0 bg-black/40 z-50 items-center justify-center">
    <div class="bg-white rounded-2xl border border-outline-variant p-6 w-full max-w-2xl mx-4 max-h-[90vh] overflow-y-auto">
        <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl font-bold text-on-surface">Thêm Danh mục mới</h2>
            <button type="button" onclick="closeCreateCategoryModal()" class="p-2 text-secondary hover:bg-surface-container rounded-lg">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>

        <div id="createCategoryError" class="hidden mb-4 px-4 py-3 bg-red-100 text-red-700 rounded-xl text-sm font-medium items-center gap-2">
            <span class="material-symbols-outlined text-base">error</span>
            <span id="createCategoryErrorText"></span>
        </div>

        <form id="createCategoryForm" method="post" class="space-y-5">
            @Html.AntiForgeryToken()

            <div>
                <label for="categoryName" class="block text-sm font-medium text-on-surface mb-1">Tên danh mục <span class="text-red-500">*</span></label>
                <input id="categoryName" name="Name" required type="text" placeholder="Ví dụ: Công nghệ thông tin, Hà Nội, Senior"
                       class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
            </div>

            <div>
                <label for="categoryType" class="block text-sm font-medium text-on-surface mb-1">Loại danh mục <span class="text-red-500">*</span></label>
                <select id="categoryType" name="Type" class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary">
                    <option value="Industry">Ngành nghề</option>
                    <option value="Location">Địa điểm</option>
                    <option value="Level">Cấp độ</option>
                    <option value="JobType">Loại công việc</option>
                </select>
            </div>

            <div>
                <label for="categorySlug" class="block text-sm font-medium text-on-surface mb-1">Slug <span class="text-red-500">*</span></label>
                <input id="categorySlug" name="Slug" required type="text" placeholder="Ví dụ: cong-nghe-thong-tin, ha-noi, senior"
                       class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
                <p class="text-xs text-secondary mt-1">Slug sẽ được dùng trong URL, chỉ chứa chữ thường, số và dấu gạch ngang</p>
            </div>

            <div class="flex gap-3 pt-4">
                <button type="button" onclick="closeCreateCategoryModal()" class="flex-1 px-4 py-2.5 border border-outline-variant rounded-xl text-sm font-medium text-secondary hover:bg-surface-container text-center whitespace-nowrap">
                    Huỷ
                </button>
                <button type="submit" class="flex-1 px-4 py-2.5 bg-primary text-slate-900 rounded-xl text-sm font-semibold hover:opacity-90 whitespace-nowrap">
                    Tạo danh mục
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    function openCreateCategoryModal() {
        document.getElementById('createCategoryModal').classList.remove('hidden');
        document.getElementById('createCategoryModal').classList.add('flex');
    }

    function closeCreateCategoryModal() {
        document.getElementById('createCategoryModal').classList.add('hidden');
        document.getElementById('createCategoryModal').classList.remove('flex');
        document.getElementById('createCategoryForm').reset();
        document.getElementById('createCategoryError').classList.add('hidden');
    }

    document.getElementById('createCategoryModal').addEventListener('click', function (e) {
        if (e.target === this) closeCreateCategoryModal();
    });

    document.getElementById('createCategoryForm').addEventListener('submit', async function (e) {
        e.preventDefault();

        const formData = new FormData(this);
        const token = document.querySelector('#createCategoryForm input[name="__RequestVerificationToken"]').value;
        const errorBox = document.getElementById('createCategoryError');
        const errorText = document.getElementById('createCategoryErrorText');

        try {
            const response = await fetch('@Url.Action("CategoryCreate", "Admin")', {
                method: 'POST',
                headers: { 'RequestVerificationToken': token },
                body: formData
            });

            if (response.ok || response.redirected) {
                window.location.reload();
            } else {
                errorText.textContent = 'Không thể thêm danh mục. Vui lòng kiểm tra lại thông tin (có thể Slug đã tồn tại).';
                errorBox.classList.remove('hidden');
                errorBox.classList.add('flex');
            }
        } catch (err) {
            errorText.textContent = 'Có lỗi xảy ra. Vui lòng thử lại.';
            errorBox.classList.remove('hidden');
            errorBox.classList.add('flex');
        }
    });
</script>