@model JobConnect.Models.StatusCatalog
@{
    ViewData["Title"] = "Sửa trạng thái";
    Layout = "_LayoutAdmin";
    var entityTypes = (string[])ViewBag.EntityTypes;
    var entityTypeLabels = (Dictionary<string, string>)ViewBag.EntityTypeLabels;
}

<div class="max-w-2xl mx-auto px-6 py-8">
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-on-surface">Sửa trạng thái</h1>
        <p class="text-secondary text-sm">Cập nhật trạng thái tùy chỉnh cho một đối tượng trong hệ thống</p>
    </div>

    <div class="bg-white rounded-2xl border border-outline-variant p-6">
        <form asp-action="StatusEdit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-red-600 text-sm mb-4"></div>

            <div class="mb-4">
                <label class="block text-sm font-medium text-on-surface mb-1">Đối tượng áp dụng <span class="text-red-500">*</span></label>
                <select asp-for="EntityType" class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm">
                    @foreach (var et in entityTypes)
                    {
                        <option value="@et">@entityTypeLabels[et]</option>
                    }
                </select>
                <span asp-validation-for="EntityType" class="text-red-500 text-xs"></span>
            </div>

            <div class="mb-4">
                <label class="block text-sm font-medium text-on-surface mb-1">Mã trạng thái (Code) <span class="text-red-500">*</span></label>
                <input asp-for="Code" placeholder="Ví dụ: Active, Open, Banned..." class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm" />
                <p class="text-xs text-secondary mt-1">
                    Lưu ý: với "Nhân viên" (Staff), Code phải là số nguyên (0 = Đang làm việc, 1 = Đã khóa...) vì cột trạng thái của Nhân viên đang là kiểu số.
                </p>
                <span asp-validation-for="Code" class="text-red-500 text-xs"></span>
            </div>

            <div class="mb-4">
                <label class="block text-sm font-medium text-on-surface mb-1">Tên hiển thị <span class="text-red-500">*</span></label>
                <input asp-for="Name" placeholder="Ví dụ: Hoạt động" class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm" />
                <span asp-validation-for="Name" class="text-red-500 text-xs"></span>
            </div>

            <div class="mb-4">
                <label class="block text-sm font-medium text-on-surface mb-1">Class màu badge (Tailwind)</label>
                <input asp-for="ColorClass" placeholder="Ví dụ: bg-green-100 text-green-700" class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm" />
                <span asp-validation-for="ColorClass" class="text-red-500 text-xs"></span>
            </div>

            <div class="mb-6">
                <label class="block text-sm font-medium text-on-surface mb-1">Mô tả</label>
                <textarea asp-for="Description" rows="3" placeholder="Mô tả chi tiết về trạng thái này..." class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm"></textarea>
                <span asp-validation-for="Description" class="text-red-500 text-xs"></span>
            </div>

            <div class="mb-6 flex items-center gap-2">
                <input asp-for="IsActive" type="checkbox" class="w-4 h-4" />
                <label asp-for="IsActive" class="text-sm text-on-surface">Hiển thị trạng thái này</label>
            </div>

            <div class="flex items-center gap-3">
                <button type="submit" class="px-5 py-2.5 bg-primary text-slate-900 rounded-xl text-sm font-semibold hover:opacity-90">
                    Lưu trạng thái
                </button>
                <a asp-action="Statuses" class="px-5 py-2.5 border border-outline-variant rounded-xl text-sm font-medium text-secondary hover:bg-surface-container">
                    Hủy
                </a>
            </div>
        </form>
    </div>
</div>
