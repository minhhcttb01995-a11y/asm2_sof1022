@using JobConnect.Models
@model List<JobPost>
@{
    ViewData["Title"] = "Quản lý Tin/Công ty Hot";
    Layout = "_LayoutAdmin";
    var tab = ViewBag.Tab?.ToString() ?? "jobs";
    var q = ViewBag.Q?.ToString() ?? "";
    var page = (int)(ViewBag.Page ?? 1);
    var hotCompanies = ViewBag.HotCompanies as List<Employer> ?? new List<Employer>();
    int hotJobsCount = (int)(ViewBag.HotJobsCount ?? 0);
    int hotCompaniesCount = (int)(ViewBag.HotCompaniesCount ?? 0);
}

<div style="padding:24px" class="space-y-5">

    @* ── Header ── *@
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3">
        <div>
            <h1 class="text-2xl font-bold flex items-center gap-2" style="color:#1e293b">
                <span class="material-symbols-outlined" style="color:#f97316">local_fire_department</span>
                Quản lý Tin / Công ty Hot
            </h1>
            <p class="text-sm mt-0.5" style="color:#64748b">
                Đánh dấu tin tuyển dụng và công ty nổi bật để hiển thị ưu tiên trên trang chủ.
            </p>
        </div>
        <div class="flex gap-2">
            <span class="px-3 py-1.5 rounded-xl text-xs font-semibold" style="background:#fff7ed;color:#c2410c;border:1px solid #fed7aa">
                🔥 @hotJobsCount tin hot
            </span>
            <span class="px-3 py-1.5 rounded-xl text-xs font-semibold" style="background:#fff7ed;color:#c2410c;border:1px solid #fed7aa">
                🏢 @hotCompaniesCount công ty hot
            </span>
        </div>
    </div>

    @* ── Flash ── *@
    @if (TempData["Success"] != null)
    {
        <div class="px-4 py-3 rounded-xl text-sm font-medium flex items-center gap-2 auto-hide-alert" style="background:#f0fdf4;color:#16a34a;border:1px solid #bbf7d0">
            <span class="material-symbols-outlined text-base">check_circle</span> @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="px-4 py-3 rounded-xl text-sm font-medium flex items-center gap-2" style="background:#fef2f2;color:#dc2626;border:1px solid #fecaca">
            <span class="material-symbols-outlined text-base">error</span> @TempData["Error"]
        </div>
    }

    @* ── Tabs ── *@
    <div class="flex gap-2 border-b" style="border-color:#e2e8f0">
        <a href="@Url.Action("Hot", new { tab = "jobs" })"
           class="px-4 py-2.5 text-sm font-semibold -mb-px border-b-2 transition-colors"
           style="@(tab == "jobs" ? "color:#ea580c;border-color:#ea580c" : "color:#64748b;border-color:transparent")">
            <span class="material-symbols-outlined text-sm align-middle">work</span> Tin tuyển dụng Hot
        </a>
        <a href="@Url.Action("Hot", new { tab = "companies" })"
           class="px-4 py-2.5 text-sm font-semibold -mb-px border-b-2 transition-colors"
           style="@(tab == "companies" ? "color:#ea580c;border-color:#ea580c" : "color:#64748b;border-color:transparent")">
            <span class="material-symbols-outlined text-sm align-middle">apartment</span> Công ty Hot
        </a>
    </div>

    @* ── Search ── *@
    <form method="get" class="bg-white rounded-2xl p-4 border border-outline-variant flex flex-wrap gap-3 items-end shadow-sm">
        <input type="hidden" name="tab" value="@tab" />
        <div class="flex-1 min-w-[200px]">
            <label class="block text-xs text-secondary mb-1">Tìm kiếm</label>
            <input type="text" name="q" value="@q"
                   class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary"
                   placeholder="@(tab == "jobs" ? "Tên hoặc mã tin tuyển dụng..." : "Tên hoặc mã công ty...")" />
        </div>
        <button type="submit" class="px-5 py-2.5 bg-primary text-white rounded-xl text-sm font-medium hover:opacity-90">Tìm</button>
        <a href="@Url.Action("Hot", new { tab })" class="px-5 py-2.5 border border-outline-variant rounded-xl text-sm font-medium text-secondary hover:bg-surface-container">
            Đặt lại
        </a>
    </form>

    @if (tab == "jobs")
    {
        @* ══════════════════ TAB: TIN TUYỂN DỤNG HOT ══════════════════ *@
        <div class="bg-white rounded-2xl overflow-hidden" style="border:1px solid #e2e8f0;box-shadow:0 1px 3px rgba(0,0,0,.05)">
            @if (!Model.Any())
            {
                <div class="py-20 text-center" style="color:#94a3b8">
                    <span class="material-symbols-outlined text-5xl block mb-3" style="opacity:.3">work_off</span>
                    <p class="text-sm font-medium" style="color:#64748b">Không có tin nào</p>
                </div>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead style="background:#f8fafc;border-bottom:1px solid #e2e8f0">
                            <tr>
                                <th class="px-4 py-3.5 text-left text-xs font-semibold uppercase tracking-wide" style="color:#64748b">Mã</th>
                                <th class="px-5 py-3.5 text-left text-xs font-semibold uppercase tracking-wide" style="color:#64748b">Tin tuyển dụng</th>
                                <th class="px-4 py-3.5 text-left text-xs font-semibold uppercase tracking-wide" style="color:#64748b">Công ty</th>
                                <th class="px-4 py-3.5 text-center text-xs font-semibold uppercase tracking-wide" style="color:#64748b">Lượt xem</th>
                                <th class="px-4 py-3.5 text-center text-xs font-semibold uppercase tracking-wide" style="color:#64748b">Đơn UV</th>
                                <th class="px-4 py-3.5 text-center text-xs font-semibold uppercase tracking-wide" style="color:#64748b">Hot</th>
                                <th class="px-4 py-3.5 text-center text-xs font-semibold uppercase tracking-wide" style="color:#64748b">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var job in Model)
                            {
                                <tr style="border-bottom:1px solid #f1f5f9;transition:background .1s"
                                    onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background=''">
                                    <td class="px-4 py-3.5">
                                        <span class="font-mono text-xs" style="color:#64748b;background:#f1f5f9;padding:4px 8px;border-radius:8px">@(job.JobCode ?? job.JobId.ToString())</span>
                                    </td>
                                    <td class="px-5 py-3.5" style="max-width:280px">
                                        <a asp-controller="Job" asp-action="Detail" asp-route-id="@job.JobId"
                                           class="font-semibold hover:underline line-clamp-2" style="color:#1e293b" target="_blank">
                                            @job.Title
                                        </a>
                                        <div class="flex items-center gap-2 mt-1 flex-wrap">
                                            <span class="text-xs" style="color:#94a3b8">@job.JobType</span>
                                            @if (!string.IsNullOrEmpty(job.Location))
                                            {
                                                <span class="text-xs" style="color:#94a3b8">• @job.Location</span>
                                            }
                                        </div>
                                    </td>
                                    <td class="px-4 py-3.5">
                                        <p class="font-medium text-sm" style="color:#374151">@(job.Employer?.CompanyName ?? "—")</p>
                                        <p class="text-xs mt-0.5" style="color:#94a3b8">@(job.Employer?.Industry ?? "")</p>
                                    </td>
                                    <td class="px-4 py-3.5 text-center">
                                        <span class="inline-flex items-center justify-center px-2.5 py-1 rounded-lg text-sm font-bold" style="background:#eff6ff;color:#3b82f6">
                                            @job.ViewCount
                                        </span>
                                    </td>
                                    <td class="px-4 py-3.5 text-center">
                                        <span class="inline-flex items-center justify-center w-8 h-8 rounded-lg text-sm font-bold" style="background:#f5f3ff;color:#7c3aed">
                                            @(job.Applications?.Count ?? 0)
                                        </span>
                                    </td>
                                    <td class="px-4 py-3.5 text-center">
                                        @if (job.IsFeatured)
                                        {
                                            <span class="text-xs px-2 py-1 rounded-full font-semibold" style="background:#fef3c7;color:#d97706">🔥 Hot</span>
                                        }
                                        else
                                        {
                                            <span class="text-xs px-2 py-1 rounded-full font-medium" style="background:#f1f5f9;color:#94a3b8">Thường</span>
                                        }
                                    </td>
                                    <td class="px-4 py-3.5 text-center">
                                        <form asp-action="ToggleJobFeatured" method="post" class="inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="jobId" value="@job.JobId" />
                                            <input type="hidden" name="q" value="@q" />
                                            <input type="hidden" name="page" value="@(page)" />
                                            <button type="submit" class="jb-btn"
                                                    style="@(job.IsFeatured ? "background:#fef3c7;color:#d97706;border:1px solid #fde68a" : "background:#f8fafc;color:#475569;border:1px solid #e2e8f0")">
                                                <span class="material-symbols-outlined text-sm">@(job.IsFeatured ? "star" : "star_outline")</span>
                                                @(job.IsFeatured ? "Bỏ Hot" : "Đánh dấu Hot")
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if ((int)(ViewBag.JobTotalPages ?? 1) > 1)
                {
                    <div class="flex justify-center gap-2 p-4" style="border-top:1px solid #f1f5f9">
                        @for (int i = 1; i <= (int)ViewBag.JobTotalPages; i++)
                        {
                            bool active = i == page;
                            <a href="@Url.Action("Hot", new { tab = "jobs", page = i, q })"
                               class="w-9 h-9 flex items-center justify-center rounded-lg text-sm font-medium transition-colors"
                               style="@(active ? "background:#ea580c;color:#fff;border:1px solid #ea580c" : "border:1px solid #e2e8f0;color:#64748b")">
                                @i
                            </a>
                        }
                    </div>
                }
            }
        </div>
    }
    else
    {
        @* ══════════════════ TAB: CÔNG TY HOT ══════════════════ *@
        <div class="bg-white rounded-2xl overflow-hidden" style="border:1px solid #e2e8f0;box-shadow:0 1px 3px rgba(0,0,0,.05)">
            @if (!hotCompanies.Any())
            {
                <div class="py-20 text-center" style="color:#94a3b8">
                    <span class="material-symbols-outlined text-5xl block mb-3" style="opacity:.3">domain_disabled</span>
                    <p class="text-sm font-medium" style="color:#64748b">Không có công ty nào</p>
                </div>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead style="background:#f8fafc;border-bottom:1px solid #e2e8f0">
                            <tr>
                                <th class="px-4 py-3.5 text-left text-xs font-semibold uppercase tracking-wide" style="color:#64748b">Mã</th>
                                <th class="px-5 py-3.5 text-left text-xs font-semibold uppercase tracking-wide" style="color:#64748b">Công ty</th>
                                <th class="px-4 py-3.5 text-center text-xs font-semibold uppercase tracking-wide" style="color:#64748b">Tin đang tuyển</th>
                                <th class="px-4 py-3.5 text-center text-xs font-semibold uppercase tracking-wide" style="color:#64748b">Xác minh</th>
                                <th class="px-4 py-3.5 text-center text-xs font-semibold uppercase tracking-wide" style="color:#64748b">Hot</th>
                                <th class="px-4 py-3.5 text-center text-xs font-semibold uppercase tracking-wide" style="color:#64748b">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in hotCompanies)
                            {
                                var activeJobs = c.JobPosts?.Count(j => j.Status == "Active") ?? 0;
                                <tr style="border-bottom:1px solid #f1f5f9;transition:background .1s"
                                    onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background=''">
                                    <td class="px-4 py-3.5">
                                        <span class="font-mono text-xs" style="color:#64748b;background:#f1f5f9;padding:4px 8px;border-radius:8px">@(c.CompanyCode ?? c.EmployerId.ToString())</span>
                                    </td>
                                    <td class="px-5 py-3.5">
                                        <a asp-controller="Company" asp-action="Detail" asp-route-id="@c.EmployerId"
                                           class="font-semibold hover:underline" style="color:#1e293b" target="_blank">
                                            @c.CompanyName
                                        </a>
                                        <p class="text-xs mt-0.5" style="color:#94a3b8">@(c.Industry ?? "")</p>
                                    </td>
                                    <td class="px-4 py-3.5 text-center">
                                        <span class="inline-flex items-center justify-center px-2.5 py-1 rounded-lg text-sm font-bold" style="background:#eff6ff;color:#3b82f6">
                                            @activeJobs
                                        </span>
                                    </td>
                                    <td class="px-4 py-3.5 text-center">
                                        @if (c.IsVerified)
                                        {
                                            <span class="text-xs px-2 py-1 rounded-full font-semibold" style="background:#eff6ff;color:#2563eb">✔ Đã xác minh</span>
                                        }
                                        else
                                        {
                                            <span class="text-xs px-2 py-1 rounded-full font-medium" style="background:#f1f5f9;color:#94a3b8">Chưa</span>
                                        }
                                    </td>
                                    <td class="px-4 py-3.5 text-center">
                                        @if (c.IsFeatured)
                                        {
                                            <span class="text-xs px-2 py-1 rounded-full font-semibold" style="background:#fef3c7;color:#d97706">🔥 Hot</span>
                                        }
                                        else
                                        {
                                            <span class="text-xs px-2 py-1 rounded-full font-medium" style="background:#f1f5f9;color:#94a3b8">Thường</span>
                                        }
                                    </td>
                                    <td class="px-4 py-3.5 text-center">
                                        <form asp-action="ToggleCompanyFeatured" method="post" class="inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="employerId" value="@c.EmployerId" />
                                            <input type="hidden" name="q" value="@q" />
                                            <input type="hidden" name="page" value="@(page)" />
                                            <button type="submit" class="jb-btn"
                                                    style="@(c.IsFeatured ? "background:#fef3c7;color:#d97706;border:1px solid #fde68a" : "background:#f8fafc;color:#475569;border:1px solid #e2e8f0")">
                                                <span class="material-symbols-outlined text-sm">@(c.IsFeatured ? "star" : "star_outline")</span>
                                                @(c.IsFeatured ? "Bỏ Hot" : "Đánh dấu Hot")
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if ((int)(ViewBag.CompanyTotalPages ?? 1) > 1)
                {
                    <div class="flex justify-center gap-2 p-4" style="border-top:1px solid #f1f5f9">
                        @for (int i = 1; i <= (int)ViewBag.CompanyTotalPages; i++)
                        {
                            bool active = i == page;
                            <a href="@Url.Action("Hot", new { tab = "companies", page = i, q })"
                               class="w-9 h-9 flex items-center justify-center rounded-lg text-sm font-medium transition-colors"
                               style="@(active ? "background:#ea580c;color:#fff;border:1px solid #ea580c" : "border:1px solid #e2e8f0;color:#64748b")">
                                @i
                            </a>
                        }
                    </div>
                }
            }
        </div>
    }
</div>

<style>
    .jb-btn {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 5px 10px;
        border-radius: 8px;
        font-size: .75rem;
        font-weight: 500;
        cursor: pointer;
        transition: opacity .15s, transform .1s;
        white-space: nowrap;
        font-family: inherit;
        border: none;
    }

        .jb-btn:hover {
            opacity: .8;
            transform: translateY(-1px);
        }
</style>
