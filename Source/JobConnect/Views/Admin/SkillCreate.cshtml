@* [VIEW-HEADER-ADDED]
   View cho action "SkillCreate" trong khu vực trang quản trị Admin (AdminController).
*@
@using JobConnect.Models
@model Skill
@{
    ViewData["Title"] = "Thêm Kỹ năng mới";
    Layout = "_LayoutAdmin";
}

<div class="max-w-2xl mx-auto px-6 py-8">
    <!-- Header -->
    <div class="flex items-center gap-4 mb-6">
        <a asp-action="Skills" class="text-secondary hover:text-primary flex items-center gap-1">
            <span class="material-symbols-outlined">arrow_back</span> Quay lại
        </a>
        <div>
            <h1 class="text-2xl font-bold text-on-surface">Thêm Kỹ năng mới</h1>
            <p class="text-secondary text-sm">Tạo kỹ năng mới cho hệ thống</p>
        </div>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="mb-4 px-4 py-3 bg-red-100 text-red-700 rounded-xl text-sm font-medium flex items-center gap-2">
            <span class="material-symbols-outlined text-base">error</span>
            @TempData["Error"]
        </div>
    }

    <!-- Form -->
    <div class="bg-white rounded-2xl p-6 border border-outline-variant">
        <form asp-action="SkillCreate" method="post" class="space-y-5">
            @Html.AntiForgeryToken()
            
            <div>
                <label asp-for="Name" class="block text-sm font-medium text-on-surface mb-1">Tên kỹ năng <span class="text-red-500">*</span></label>
                <input asp-for="Name" required type="text" placeholder="Ví dụ: C#, UI/UX Design, Digital Marketing"
                       class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
                <span asp-validation-for="Name" class="text-xs text-red-500"></span>
            </div>

            <div>
                <label asp-for="Category" class="block text-sm font-medium text-on-surface mb-1">Danh mục <span class="text-red-500">*</span></label>
                <select asp-for="Category" class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary">
                    @if (ViewBag.Categories != null)
                    {
                        foreach (SkillCategory cat in ViewBag.Categories)
                        {
                            <option value="@cat">@cat</option>
                        }
                    }
                </select>
                <span asp-validation-for="Category" class="text-xs text-red-500"></span>
            </div>

            <div>
                <label asp-for="Description" class="block text-sm font-medium text-on-surface mb-1">Mô tả</label>
                <textarea asp-for="Description" rows="4" placeholder="Mô tả ngắn về kỹ năng này..."
                          class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary resize-none"></textarea>
                <span asp-validation-for="Description" class="text-xs text-red-500"></span>
            </div>

            <div class="flex items-center gap-3">
                <input asp-for="IsActive" type="checkbox" id="isActive" class="w-5 h-5 rounded border-outline-variant text-primary focus:ring-primary" />
                <label for="isActive" class="text-sm font-medium text-on-surface">Kích hoạt ngay</label>
            </div>

            <div class="flex gap-3 pt-4">
                <a asp-action="Skills" class="flex-1 px-4 py-2.5 border border-outline-variant rounded-xl text-sm font-medium text-secondary hover:bg-surface-container text-center whitespace-nowrap">
                    Huỷ
                </a>
                <button type="submit" class="flex-1 px-4 py-2.5 bg-primary text-slate-900 rounded-xl text-sm font-semibold hover:opacity-90 whitespace-nowrap">
                    Tạo kỹ năng
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
