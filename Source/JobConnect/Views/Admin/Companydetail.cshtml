@using JobConnect.Models
@model Employer
@{
    ViewData["Title"] = "Chi tiết công ty";
    Layout = "_LayoutAdmin";
    int openJobs = Model.JobPosts.Count(j => j.Status == "Active");
    int pendingJobs = Model.JobPosts.Count(j => j.Status == "Pending");
    int closedJobs = Model.JobPosts.Count(j => j.Status == "Banned" || j.Status == "Rejected");
}

@* ── Modal xóa ── *@
<div id="modalDelete" class="fixed inset-0 z-50 hidden items-center justify-center bg-white backdrop-blur-sm">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-sm mx-4 p-6">
        <div class="flex items-center gap-3 mb-4">
            <div class="w-11 h-11 rounded-full flex items-center justify-center flex-shrink-0" style="background:#fef2f2">
                <span class="material-symbols-outlined" style="color:#dc2626">delete_forever</span>
            </div>
            <div>
                <h2 class="text-base font-bold" style="color:#1e293b">Xóa công ty này?</h2>
                <p class="text-xs" style="color:#64748b">Toàn bộ tin tuyển dụng sẽ bị xóa theo.</p>
            </div>
        </div>
        <p class="text-sm mb-5" style="color:#475569">
            Bạn có chắc muốn xóa <strong style="color:#1e293b">@Model.CompanyName</strong>?
            Hành động này <span style="color:#dc2626;font-weight:600">không thể hoàn tác</span>.
        </p>
        <form asp-action="DeleteCompany" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.EmployerId" />
            <div class="flex gap-3">
                <button type="button" onclick="document.getElementById('modalDelete').classList.add('hidden');document.getElementById('modalDelete').classList.remove('flex')"
                        class="flex-1 px-4 py-2.5 rounded-xl text-sm font-medium transition-colors"
                        style="border:1px solid #e2e8f0;color:#64748b">
                    Huỷ
                </button>
                <button type="submit" class="flex-1 px-4 py-2.5 bg-red-600 text-white rounded-xl text-sm font-semibold hover:bg-red-700 transition-colors">
                    Xác nhận xóa
                </button>
            </div>
        </form>
    </div>
</div>

<div style="padding:24px" class="space-y-6">

    @* ── Breadcrumb + Title ── *@
    <div class="flex items-center gap-3">
        <a asp-action="Companies"
           class="flex items-center gap-1 text-sm font-medium transition-colors"
           style="color:#64748b" onmouseover="this.style.color='#3b82f6'" onmouseout="this.style.color='#64748b'">
            <span class="material-symbols-outlined text-base">arrow_back</span>
            Quay lại
        </a>
        <span style="color:#cbd5e1">/</span>
        <h1 class="text-xl font-bold" style="color:#1e293b">Chi tiết công ty</h1>
    </div>

    @* ── Flash ── *@
    @if (TempData["Success"] != null)
    {
        <div class="px-4 py-3 rounded-xl text-sm font-medium flex items-center gap-2 auto-hide-alert" style="background:#f0fdf4;color:#16a34a;border:1px solid #bbf7d0">
            <span class="material-symbols-outlined text-base">check_circle</span> @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="px-4 py-3 rounded-xl text-sm font-medium flex items-center gap-2" style="background:#fef2f2;color:#dc2626;border:1px solid #fecaca">
            <span class="material-symbols-outlined text-base">error</span> @TempData["Error"]
        </div>
    }

    <div class="grid gap-6" style="grid-template-columns:280px 1fr">

        @* ── Cột trái ── *@
        <div class="space-y-4">

            @* Card hồ sơ *@
            <div class="bg-white rounded-2xl overflow-hidden" style="border:1px solid #e2e8f0;box-shadow:0 1px 3px rgba(0,0,0,.05)">
                @* Cover *@
                @if (!string.IsNullOrEmpty(Model.CoverURL))
                {
                    <div class="h-24 overflow-hidden">
                        <img src="@Model.CoverURL" class="w-full h-full object-cover" />
                    </div>
                }
                else
                {
                    <div class="h-20" style="background:linear-gradient(135deg,#3b82f6,#8b5cf6)"></div>
                }

                <div class="px-5 pb-5 text-center -mt-8">
                    <div class="w-16 h-16 rounded-xl mx-auto mb-3 overflow-hidden flex items-center justify-center"
                         style="background:#fff;border:2px solid #e2e8f0;box-shadow:0 2px 8px rgba(0,0,0,.1)">
                        @if (!string.IsNullOrEmpty(Model.LogoURL))
                        {
                            <img src="@Model.LogoURL" class="w-full h-full object-contain" />
                        }
                        else
                        {
                            <span class="material-symbols-outlined text-4xl" style="color:#94a3b8">apartment</span>
                        }
                    </div>
                    <h2 class="text-base font-bold" style="color:#1e293b">@Model.CompanyName</h2>
                    <p class="text-xs mt-0.5 mb-3" style="color:#64748b">@(Model.Industry ?? "Chưa cập nhật ngành")</p>
                    <div class="flex justify-center gap-2 flex-wrap">
                        @if (Model.IsVerified)
                        {
                            <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-semibold"
                                  style="background:#f0fdf4;color:#16a34a;border:1px solid #bbf7d0">
                                <span class="material-symbols-outlined text-xs">verified</span> Đã xác minh
                            </span>
                        }
                        else
                        {
                            <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-semibold"
                                  style="background:#fefce8;color:#a16207;border:1px solid #fef08a">
                                <span class="material-symbols-outlined text-xs">pending</span> Chưa xác minh
                            </span>
                        }
                        @if (Model.IsLocked)
                        {
                            <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-semibold"
                                  style="background:#fef2f2;color:#dc2626;border:1px solid #fecaca">
                                <span class="material-symbols-outlined text-xs">lock</span> Đã khoá
                            </span>
                        }
                    </div>
                </div>
            </div>

            @* KPI mini *@
            <div class="grid grid-cols-3 gap-2">
                <div class="bg-white rounded-xl p-3 text-center" style="border:1px solid #e2e8f0">
                    <p class="text-xl font-bold" style="color:#3b82f6">@openJobs</p>
                    <p class="text-xs mt-0.5" style="color:#64748b">Đang mở</p>
                </div>
                <div class="bg-white rounded-xl p-3 text-center" style="border:1px solid #e2e8f0">
                    <p class="text-xl font-bold" style="color:#f59e0b">@pendingJobs</p>
                    <p class="text-xs mt-0.5" style="color:#64748b">Chờ duyệt</p>
                </div>
                <div class="bg-white rounded-xl p-3 text-center" style="border:1px solid #e2e8f0">
                    <p class="text-xl font-bold" style="color:#94a3b8">@closedJobs</p>
                    <p class="text-xs mt-0.5" style="color:#64748b">Đóng/Từ chối</p>
                </div>
            </div>

            @* Panel thao tác *@
            <div class="bg-white rounded-2xl p-5 space-y-2.5" style="border:1px solid #e2e8f0;box-shadow:0 1px 3px rgba(0,0,0,.05)">
                <p class="text-xs font-semibold uppercase tracking-wide mb-3" style="color:#94a3b8">⚡ Thao tác quản trị</p>

                @* Duyệt / Từ chối xác minh *@
                @if (!Model.IsVerified)
                {
                    <form asp-action="ApproveCompany" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.EmployerId" />
                        <button type="submit" class="mgmt-btn" style="background:#f0fdf4;color:#16a34a;border:1px solid #bbf7d0">
                            <span class="material-symbols-outlined text-base">verified</span>
                            Duyệt xác minh công ty
                        </button>
                    </form>
                }
                else
                {
                    <form asp-action="SuspendCompany" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.EmployerId" />
                        <button type="submit" class="mgmt-btn" style="background:#fff7ed;color:#ea580c;border:1px solid #fed7aa">
                            <span class="material-symbols-outlined text-base">unpublished</span>
                            Từ chối / Hủy xác minh
                        </button>
                    </form>
                }

                @* Khoá / Mở khoá *@
                <form asp-action="LockCompany" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.EmployerId" />
                    <input type="hidden" name="returnUrl" value="@Url.Action("CompanyDetail", new { id = Model.EmployerId })" />
                    <button type="submit" class="mgmt-btn"
                            style="@(Model.IsLocked
                                                                                        ? "background:#eff6ff;color:#3b82f6;border:1px solid #bfdbfe"
                                                                                        : "background:#fefce8;color:#ca8a04;border:1px solid #fde68a")">
                        <span class="material-symbols-outlined text-base">@(Model.IsLocked ? "lock_open" : "lock")</span>
                        @(Model.IsLocked ? "Mở khoá công ty" : "Khoá công ty")
                    </button>
                </form>

                @* Xóa *@
                <button onclick="document.getElementById('modalDelete').classList.remove('hidden');document.getElementById('modalDelete').classList.add('flex')"
                        class="mgmt-btn" style="background:#fef2f2;color:#dc2626;border:1px solid #fecaca">
                    <span class="material-symbols-outlined text-base">delete</span>
                    Xóa công ty
                </button>

                <div class="pt-3 mt-1" style="border-top:1px solid #f1f5f9">
                    <p class="text-xs font-semibold uppercase tracking-wide mb-2.5" style="color:#94a3b8">🛠 Hỗ trợ trực tiếp</p>
                    <div class="space-y-2">
                        <a asp-action="PostJobForEmployer" asp-route-id="@Model.EmployerId" class="mgmt-btn"
                           style="background:#eff6ff;color:#3b82f6;border:1px solid #bfdbfe">
                            <span class="material-symbols-outlined text-base">post_add</span>
                            Đăng tin hộ NTD
                        </a>
                        <a asp-action="EmployerApplications" asp-route-id="@Model.EmployerId" class="mgmt-btn"
                           style="background:#faf5ff;color:#7c3aed;border:1px solid #ddd6fe">
                            <span class="material-symbols-outlined text-base">folder_shared</span>
                            Xem đơn & hỗ trợ CV
                        </a>
                    </div>
                </div>
            </div>
        </div>

        @* ── Cột phải ── *@
        <div class="space-y-5">

            @* Thông tin công ty *@
            <div class="bg-white rounded-2xl p-6" style="border:1px solid #e2e8f0;box-shadow:0 1px 3px rgba(0,0,0,.05)">
                <h3 class="font-semibold mb-5 flex items-center gap-2" style="color:#1e293b">
                    <span class="material-symbols-outlined" style="color:#3b82f6">info</span>
                    Thông tin công ty
                </h3>
                <div class="grid grid-cols-2 gap-x-6 gap-y-4">
                    @{
                        void InfoRow(string label, string? value)
                        {
                            <div>
                                <p class="text-xs mb-1 font-medium" style="color:#94a3b8">@label</p>
                                <p class="text-sm font-medium" style="color:#1e293b">@(string.IsNullOrEmpty(value) ? "—" : value)</p>
                            </div>
                        }
                    }
                    @{
                        InfoRow("Mã công ty", Model.CompanyCode);
                    }
                    @{
                        InfoRow("Tên công ty", Model.CompanyName);
                    }
                    @{
                        InfoRow("Email NTD", Model.User?.Email);
                    }
                    @{
                        InfoRow("Ngành nghề", Model.Industry);
                    }
                    @{
                        InfoRow("Quy mô", Model.CompanySize);
                    }
                    @{
                        InfoRow("Mã số thuế", Model.TaxCode);
                    }
                    @{
                        InfoRow("Địa chỉ", Model.Address);
                    }
                    <div>
                        <p class="text-xs mb-1 font-medium" style="color:#94a3b8">Website</p>
                        @if (!string.IsNullOrEmpty(Model.Website))
                        {
                            <a href="@Model.Website" target="_blank" class="text-sm font-medium hover:underline" style="color:#3b82f6">@Model.Website</a>
                        }
                        else
                        {

                            <p class="text-sm font-medium" style="color:#1e293b">—</p>
                        }
                    </div>
                    <div>
                        <p class="text-xs mb-1 font-medium" style="color:#94a3b8">Ngày đăng ký</p>
                        <p class="text-sm font-medium" style="color:#1e293b">@Model.CreatedAt.ToString("dd/MM/yyyy")</p>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <div class="mt-4 pt-4" style="border-top:1px solid #f1f5f9">
                        <p class="text-xs mb-2 font-medium" style="color:#94a3b8">Giới thiệu công ty</p>
                        <p class="text-sm leading-relaxed" style="color:#475569">@Model.Description</p>
                    </div>
                }
            </div>

            @* Tin tuyển dụng *@
            <div class="bg-white rounded-2xl overflow-hidden" style="border:1px solid #e2e8f0;box-shadow:0 1px 3px rgba(0,0,0,.05)">
                <div class="px-6 py-4 flex justify-between items-center" style="border-bottom:1px solid #f1f5f9">
                    <h3 class="font-semibold flex items-center gap-2" style="color:#1e293b">
                        <span class="material-symbols-outlined" style="color:#3b82f6">work</span>
                        Tin tuyển dụng
                        <span class="px-2 py-0.5 rounded-full text-xs font-bold" style="background:#eff6ff;color:#3b82f6">@Model.JobPosts.Count</span>
                    </h3>
                    <a asp-action="PostJobForEmployer" asp-route-id="@Model.EmployerId"
                       class="flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs font-medium transition-colors"
                       style="background:#eff6ff;color:#3b82f6;border:1px solid #bfdbfe">
                        <span class="material-symbols-outlined text-sm">add</span> Đăng tin hộ
                    </a>
                </div>

                @if (!Model.JobPosts.Any())
                {
                    <div class="py-12 text-center" style="color:#94a3b8">
                        <span class="material-symbols-outlined text-4xl block mb-2" style="opacity:.3">work_off</span>
                        <p class="text-sm" style="color:#64748b">Chưa có tin tuyển dụng nào</p>
                    </div>
                }
                else
                {
                    <div class="divide-y" style="border-color:#f1f5f9">
                        @foreach (var job in Model.JobPosts.OrderByDescending(j => j.CreatedAt).Take(20))
                        {
                            var (jobBg, jobColor, jobLabel) = job.Status switch
                            {
                                "Active" => ("#f0fdf4", "#16a34a", "Đang mở"),
                                "Pending" => ("#fefce8", "#a16207", "Chờ duyệt"),
                                "Rejected" => ("#fef2f2", "#dc2626", "Từ chối"),
                                "Banned" => ("#fef2f2", "#dc2626", "Đã khóa"),
                                "Draft" => ("#f8fafc", "#94a3b8", "Nháp"),
                                _ => ("#f8fafc", "#94a3b8", job.Status)
                            };
                            <div class="px-6 py-3.5 flex items-center justify-between gap-4 transition-colors"
                                 onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background=''">
                                <div class="min-w-0">
                                    <p class="text-sm font-semibold truncate" style="color:#1e293b">@job.Title</p>
                                    <p class="text-xs mt-0.5" style="color:#94a3b8">
                                        @(job.Location ?? "—") • @job.CreatedAt.ToString("dd/MM/yyyy")
                                        @if (!string.IsNullOrEmpty(job.JobType))
                                        {
                                            <span> • @job.JobType</span>
                                        }
                                    </p>
                                </div>
                                <span class="px-2.5 py-1 rounded-full text-xs font-semibold flex-shrink-0"
                                      style="background:@jobBg;color:@jobColor">
                                    @jobLabel
                                </span>
                            </div>
                        }
                    </div>
                    @if (Model.JobPosts.Count > 20)
                    {
                        <div class="px-6 py-3 text-center text-xs" style="color:#94a3b8;border-top:1px solid #f1f5f9">
                            Hiển thị 20 / @Model.JobPosts.Count tin gần nhất
                        </div>
                    }
                }
            </div>

        </div>
    </div>
</div>

<style>
    .mgmt-btn {
        display: flex;
        align-items: center;
        gap: 8px;
        width: 100%;
        padding: 10px 14px;
        border-radius: 12px;
        font-size: 0.855rem;
        font-weight: 500;
        cursor: pointer;
        transition: opacity .15s, transform .1s;
        font-family: inherit;
        text-decoration: none;
        justify-content: center;
    }

        .mgmt-btn:hover {
            opacity: .85;
            transform: translateY(-1px);
        }
</style>
