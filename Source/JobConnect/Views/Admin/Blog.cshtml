@using JobConnect.Models
@model IEnumerable<BlogPost>
@{
    Layout = "_LayoutAdmin"; ViewData["Title"] = "Quản lý Blog";
}

<div class="space-y-5">
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3">
        <div>
            <h1 class="text-2xl font-bold text-on-surface">Quản lý Blog</h1>
            <p class="text-sm text-secondary">Tổng: <strong>@Model.Count()</strong> bài viết</p>
        </div>
        <a asp-action="BlogCreate"
           class="flex items-center gap-2 px-5 py-2.5 bg-primary text-white rounded-xl text-sm font-semibold hover:opacity-90 transition-all shadow-sm">
            <span class="material-symbols-outlined text-base">edit_note</span>
            Viết bài mới
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="px-4 py-3 bg-green-100 text-green-700 rounded-xl text-sm flex items-center gap-2 auto-hide-alert">
            <span class="material-symbols-outlined text-base">check_circle</span> @TempData["Success"]
        </div>
    }

    <!-- Filter -->
    <form method="get" class="bg-white rounded-2xl p-4 border border-outline-variant flex flex-wrap gap-3 items-end shadow-sm">
        <div class="flex-1 min-w-[200px]">
            <label class="block text-xs text-secondary mb-1">Tìm bài viết</label>
            <input type="text" name="q" value="@ViewBag.Q"
                   class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary"
                   placeholder="Tiêu đề bài viết hoặc mã blog..." />
        </div>
        <div>
            <label class="block text-xs text-secondary mb-1">Trạng thái</label>
            <select name="status" class="px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary w-36">
                <option value="">Tất cả</option>
                <option value="Published" selected="@(ViewBag.Status == "Published" ? "selected" : null)">Đã đăng</option>
                <option value="Draft" selected="@(ViewBag.Status == "Draft" ? "selected" : null)">Bản nháp</option>
            </select>
        </div>
        <button type="submit" class="px-5 py-2.5 bg-primary text-white rounded-xl text-sm font-medium hover:opacity-90">Lọc</button>
    </form>

    @if (!Model.Any())
    {
        <div class="bg-white rounded-2xl p-16 text-center border border-outline-variant">
            <span class="material-symbols-outlined text-5xl text-secondary mb-3 block opacity-30">article</span>
            <p class="text-secondary">Chưa có bài viết nào.</p>
            <a asp-action="BlogCreate" class="inline-flex items-center gap-2 mt-4 px-5 py-2.5 bg-primary text-white rounded-xl text-sm font-semibold hover:opacity-90">
                <span class="material-symbols-outlined text-sm">add</span> Viết bài đầu tiên
            </a>
        </div>
    }
    else
    {
        <!-- Card grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
            @foreach (var post in Model)
            {
                // Get status info from StatusCatalog
                List<StatusCatalog>? blogStatuses = null;
                if (ViewBag.BlogPostStatuses != null)
                    blogStatuses = ViewBag.BlogPostStatuses as List<StatusCatalog>;

                var statusInfo = blogStatuses?.FirstOrDefault(s => s.Code == post.Status);
                var statusName = statusInfo?.Name ?? post.Status;
                var statusColor = statusInfo?.ColorClass ?? "bg-gray-100 text-gray-700";

                <div class="bg-white rounded-2xl border border-outline-variant overflow-hidden hover:shadow-lg transition-all group">
                    <!-- Cover -->
                    <div class="h-40 bg-surface-container relative overflow-hidden">
                        @if (!string.IsNullOrEmpty(post.CoverURL))
                        {
                            <img src="@post.CoverURL" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
                        }
                        else
                        {
                            <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-blue-50 to-indigo-50">
                                <span class="material-symbols-outlined text-4xl text-blue-200">article</span>
                            </div>
                        }
                        <!-- Badge trạng thái -->
                        <div class="absolute top-3 left-3">
                            <span class="px-2.5 py-1 @statusColor text-white text-xs font-semibold rounded-full shadow">@statusName</span>
                        </div>
                    </div>

                    <div class="p-4">
                        <h3 class="font-semibold text-on-surface line-clamp-2 mb-1 group-hover:text-primary transition-colors">@post.Title</h3>
                        <span class="font-mono text-[10px] text-secondary bg-surface-container px-1.5 py-0.5 rounded select-all">@(post.BlogCode ?? post.PostID.ToString())</span>
                        @if (!string.IsNullOrEmpty(post.Excerpt))
                        {
                            <p class="text-xs text-secondary line-clamp-2 mb-3">@post.Excerpt</p>
                        }
                        <div class="flex items-center justify-between text-xs text-secondary mb-3">
                            <span class="flex items-center gap-1">
                                <span class="material-symbols-outlined text-xs">person</span>
                                @(post.Author?.FullName ?? "—")
                            </span>
                            <span class="flex items-center gap-1">
                                <span class="material-symbols-outlined text-xs">calendar_today</span>
                                @(post.PublishedAt?.ToString("dd/MM/yyyy") ?? "Chưa đăng")
                            </span>
                        </div>

                        <!-- Actions -->
                        <div class="flex gap-2 pt-3 border-t border-outline-variant">
                            <a asp-action="BlogEdit" asp-route-id="@post.PostID"
                               class="flex-1 flex items-center justify-center gap-1.5 py-2 rounded-xl text-xs font-medium bg-blue-50 text-blue-700 hover:bg-blue-100 transition-colors">
                                <span class="material-symbols-outlined text-sm">edit</span> Sửa
                            </a>
                            @if (!post.IsPublished)
                            {
                                <form asp-action="BlogPublish" method="post" class="flex-1">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@post.PostID" />
                                    <button type="submit"
                                            class="w-full flex items-center justify-center gap-1.5 py-2 rounded-xl text-xs font-medium bg-green-50 text-green-700 hover:bg-green-100 transition-colors">
                                        <span class="material-symbols-outlined text-sm">publish</span> Đăng
                                    </button>
                                </form>
                            }
                            else
                            {
                                <a asp-controller="Blog" asp-action="Detail" asp-route-slug="@post.Slug" target="_blank"
                                   class="flex-1 flex items-center justify-center gap-1.5 py-2 rounded-xl text-xs font-medium bg-surface-container text-secondary hover:bg-surface-container-high transition-colors">
                                    <span class="material-symbols-outlined text-sm">open_in_new</span> Xem
                                </a>
                            }
                            <form asp-action="ChangeBlogPostStatus" method="post" class="flex-1">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="postId" value="@post.PostID" />
                                <select name="newStatus" class="w-full px-2 py-2 rounded-xl text-xs font-medium border border-outline-variant outline-none focus:border-primary" onchange="changeBlogPostStatus(this, @post.PostID)">
                                    <option value="" disabled selected>Trạng thái</option>
                                    @foreach (var status in ViewBag.BlogPostStatuses as List<StatusCatalog>)
                                    {
                                        <option value="@status.Code" selected="@(post.Status == status.Code ? "selected" : null)">@status.Name</option>
                                    }
                                </select>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Pagination -->
        @if ((int)(ViewBag.TotalPages ?? 1) > 1)
        {
            <div class="flex justify-center gap-2 pt-2">
                @for (int i = 1; i <= (int)ViewBag.TotalPages; i++)
                {
                    var pgCls = i == (int)(ViewBag.Page ?? 1)
                        ? "bg-primary text-white border-primary"
                        : "border-outline-variant text-secondary hover:bg-surface-container";
                    <a asp-action="Blog" asp-route-page="@i" asp-route-q="@ViewBag.Q" asp-route-status="@ViewBag.Status"
                       class="w-9 h-9 flex items-center justify-center rounded-lg text-sm border @pgCls">@i</a>
                }
            </div>
        }
    }
</div>

<script>
    function changeBlogPostStatus(selectElement, postId) {
        const newStatus = selectElement.value;
        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

        fetch('/Admin/ChangeBlogPostStatus', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'RequestVerificationToken': token
            },
            body: `postId=${postId}&newStatus=${newStatus}&__RequestVerificationToken=${token}`
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                location.reload();
            } else {
                alert(data.message || 'Không thể thay đổi trạng thái');
                selectElement.value = selectElement.getAttribute('data-original-value');
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('Có lỗi xảy ra khi thay đổi trạng thái');
            selectElement.value = selectElement.getAttribute('data-original-value');
        });
    }
</script>
