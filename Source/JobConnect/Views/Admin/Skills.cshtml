@using JobConnect.Models
@{
    ViewData["Title"] = "Quản lý Kỹ năng";
    Layout = "_LayoutAdmin";
}

<div class="w-full px-6 py-8 xl:px-10">
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-2xl font-bold text-on-surface">Quản lý Kỹ năng</h1>
            <p class="text-secondary text-sm">Quản lý danh sách kỹ năng cho ứng viên</p>
        </div>
        <button type="button" onclick="openCreateSkillModal()" class="px-5 py-2.5 bg-primary text-slate-900 rounded-xl text-sm font-semibold hover:opacity-90 flex items-center gap-2">
            <span class="material-symbols-outlined text-base">add</span>
            Thêm kỹ năng mới
        </button>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="mb-4 px-4 py-3 bg-green-100 text-green-700 rounded-xl text-sm font-medium flex items-center gap-2 auto-hide-alert">
            <span class="material-symbols-outlined text-base">check_circle</span>
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="mb-4 px-4 py-3 bg-red-100 text-red-700 rounded-xl text-sm font-medium flex items-center gap-2">
            <span class="material-symbols-outlined text-base">error</span>
            @TempData["Error"]
        </div>
    }

    <!-- Filters -->
    <div class="bg-white rounded-2xl p-5 border border-outline-variant mb-6">
        <form asp-action="Skills" method="get" class="flex flex-wrap gap-4">
            <div class="flex-1 min-w-[200px]">
                <input type="text" name="keyword" value="@ViewBag.KeywordFilter" placeholder="Tìm kiếm kỹ năng..."
                       class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
            </div>
            <div class="min-w-[150px]">
                <select name="category" class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary">
                    <option value="">Tất cả danh mục</option>
                    @if (ViewBag.Categories != null)
                    {
                        @foreach (SkillCategory cat in ViewBag.Categories)
                        {
                            @if (ViewBag.CategoryFilter?.ToString() == cat.ToString())
                            {
                                <option value="@cat" selected>@cat</option>
                            }
                            else
                            {
                                <option value="@cat">@cat</option>
                            }
                        }
                    }
                </select>
            </div>
            <button type="submit" class="px-5 py-2.5 bg-primary text-slate-900 rounded-xl text-sm font-semibold hover:opacity-90">
                Lọc
            </button>
            <a asp-action="Skills" class="px-5 py-2.5 border border-outline-variant rounded-xl text-sm font-medium text-secondary hover:bg-surface-container">
                Đặt lại
            </a>
        </form>
    </div>

    <!-- Skills Table -->
    @if (ViewBag.Skills != null && ((List<Skill>)ViewBag.Skills).Any())
    {
        <div class="bg-white rounded-2xl border border-outline-variant overflow-hidden">
            <table class="w-full">
                <thead class="bg-surface-container">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-on-surface">Tên kỹ năng</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-on-surface">Danh mục</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-on-surface">Mô tả</th>
                        <th class="px-6 py-3 text-center text-xs font-semibold text-on-surface">Trạng thái</th>
                        <th class="px-6 py-3 text-center text-xs font-semibold text-on-surface">Ngày tạo</th>
                        <th class="px-6 py-3 text-center text-xs font-semibold text-on-surface">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var skill in (List<Skill>)ViewBag.Skills)
                    {
                        <tr class="border-t border-outline-variant hover:bg-surface-container-low">
                            <td class="px-6 py-4">
                                <span class="font-medium text-on-surface">@skill.Name</span>
                            </td>
                            <td class="px-6 py-4">
                                <span class="px-3 py-1 bg-blue-50 text-blue-700 rounded-full text-xs font-medium">@skill.Category</span>
                            </td>
                            <td class="px-6 py-4">
                                <span class="text-sm text-secondary line-clamp-1">@skill.Description</span>
                            </td>
                            <td class="px-6 py-4 text-center">
                                @if (skill.IsActive)
                                {
                                    <span class="px-3 py-1 bg-green-100 text-green-700 rounded-full text-xs font-medium">Hoạt động</span>
                                }
                                else
                                {
                                    <span class="px-3 py-1 bg-gray-100 text-gray-600 rounded-full text-xs font-medium">Đã khóa</span>
                                }
                            </td>
                            <td class="px-6 py-4 text-center">
                                <span class="text-sm text-secondary">@skill.CreatedAt.ToString("dd/MM/yyyy")</span>
                            </td>
                            <td class="px-6 py-4 text-center">
                                <div class="flex items-center justify-center gap-2">
                                    <a asp-action="SkillEdit" asp-route-id="@skill.SkillID"
                                       class="p-2 text-blue-600 hover:bg-blue-50 rounded-lg" title="Sửa">
                                        <span class="material-symbols-outlined text-sm">edit</span>
                                    </a>
                                    <form asp-action="SkillToggle" asp-route-id="@skill.SkillID" method="post"
                                          onsubmit="return confirm('Bạn có chắc muốn thay đổi trạng thái kỹ năng này?')"
                                          class="inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="p-2 @(skill.IsActive ? "text-orange-600 hover:bg-orange-50" : "text-green-600 hover:bg-green-50") rounded-lg"
                                                title="@(skill.IsActive ? "Khóa" : "Kích hoạt")">
                                            <span class="material-symbols-outlined text-sm">@(skill.IsActive ? "lock" : "lock_open")</span>
                                        </button>
                                    </form>
                                    <form asp-action="SkillDelete" asp-route-id="@skill.SkillID" method="post"
                                          onsubmit="return confirm('Bạn có chắc muốn xóa kỹ năng này?')"
                                          class="inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="p-2 text-red-600 hover:bg-red-50 rounded-lg" title="Xóa">
                                            <span class="material-symbols-outlined text-sm">delete</span>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @if (ViewBag.TotalPages > 1)
        {
            <div class="flex items-center justify-center gap-2 mt-6">
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <a asp-action="Skills" asp-route-page="@i" asp-route-category="@ViewBag.CategoryFilter" asp-route-keyword="@ViewBag.KeywordFilter"
                       class="px-4 py-2 rounded-lg text-sm font-medium @(i == ViewBag.CurrentPage ? "bg-primary text-slate-900" : "bg-white border border-outline-variant text-secondary hover:bg-surface-container")">
                        @i
                    </a>
                }
            </div>
        }
    }
    else
    {
        <div class="bg-white rounded-2xl p-12 text-center border border-outline-variant">
            <span class="material-symbols-outlined text-6xl text-secondary mb-4">psychology</span>
            <p class="text-lg text-secondary">Không tìm thấy kỹ năng nào</p>
            <button type="button" onclick="openCreateSkillModal()" class="inline-block mt-4 px-5 py-2.5 bg-primary text-slate-900 rounded-xl text-sm font-semibold hover:opacity-90">
                Thêm kỹ năng đầu tiên
            </button>
        </div>
    }
</div>

<!-- Create Skill Modal -->
<div id="createSkillModal" class="hidden fixed inset-0 bg-black/40 z-50 items-center justify-center">
    <div class="bg-white rounded-2xl border border-outline-variant p-6 w-full max-w-2xl mx-4 max-h-[90vh] overflow-y-auto">
        <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl font-bold text-on-surface">Thêm Kỹ năng mới</h2>
            <button type="button" onclick="closeCreateSkillModal()" class="p-2 text-secondary hover:bg-surface-container rounded-lg">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>

        <div id="createSkillError" class="hidden mb-4 px-4 py-3 bg-red-100 text-red-700 rounded-xl text-sm font-medium items-center gap-2">
            <span class="material-symbols-outlined text-base">error</span>
            <span id="createSkillErrorText"></span>
        </div>

        <form id="createSkillForm" method="post" class="space-y-5">
            @Html.AntiForgeryToken()

            <div>
                <label for="skillName" class="block text-sm font-medium text-on-surface mb-1">Tên kỹ năng <span class="text-red-500">*</span></label>
                <input id="skillName" name="Name" required type="text" placeholder="Ví dụ: C#, UI/UX Design, Digital Marketing"
                       class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
            </div>

            <div>
                <label for="skillCategory" class="block text-sm font-medium text-on-surface mb-1">Danh mục <span class="text-red-500">*</span></label>
                <select id="skillCategory" name="Category" class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary">
                    @if (ViewBag.Categories != null)
                    {
                        foreach (SkillCategory cat in ViewBag.Categories)
                        {
                            <option value="@cat">@cat</option>
                        }
                    }
                </select>
            </div>

            <div>
                <label for="skillDescription" class="block text-sm font-medium text-on-surface mb-1">Mô tả</label>
                <textarea id="skillDescription" name="Description" rows="4" placeholder="Mô tả ngắn về kỹ năng này..."
                          class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary resize-none"></textarea>
            </div>

            <div class="flex items-center gap-3">
                <input type="hidden" name="IsActive" value="false" />
                <input id="skillIsActive" name="IsActive" type="checkbox" value="true" class="w-5 h-5 rounded border-outline-variant text-primary focus:ring-primary" />
                <label for="skillIsActive" class="text-sm font-medium text-on-surface">Kích hoạt ngay</label>
            </div>

            <div class="flex gap-3 pt-4">
                <button type="button" onclick="closeCreateSkillModal()" class="flex-1 px-4 py-2.5 border border-outline-variant rounded-xl text-sm font-medium text-secondary hover:bg-surface-container text-center whitespace-nowrap">
                    Huỷ
                </button>
                <button type="submit" class="flex-1 px-4 py-2.5 bg-primary text-slate-900 rounded-xl text-sm font-semibold hover:opacity-90 whitespace-nowrap">
                    Tạo kỹ năng
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    function openCreateSkillModal() {
        document.getElementById('createSkillModal').classList.remove('hidden');
        document.getElementById('createSkillModal').classList.add('flex');
    }

    function closeCreateSkillModal() {
        document.getElementById('createSkillModal').classList.add('hidden');
        document.getElementById('createSkillModal').classList.remove('flex');
        document.getElementById('createSkillForm').reset();
        document.getElementById('createSkillError').classList.add('hidden');
    }

    document.getElementById('createSkillModal').addEventListener('click', function (e) {
        if (e.target === this) closeCreateSkillModal();
    });

    document.getElementById('createSkillForm').addEventListener('submit', async function (e) {
        e.preventDefault();

        const formData = new FormData(this);
        const token = document.querySelector('#createSkillForm input[name="__RequestVerificationToken"]').value;
        const errorBox = document.getElementById('createSkillError');
        const errorText = document.getElementById('createSkillErrorText');

        try {
            const response = await fetch('@Url.Action("SkillCreate", "Admin")', {
                method: 'POST',
                headers: { 'RequestVerificationToken': token },
                body: formData
            });

            if (response.ok || response.redirected) {
                window.location.reload();
            } else {
                errorText.textContent = 'Không thể thêm kỹ năng. Vui lòng kiểm tra lại thông tin.';
                errorBox.classList.remove('hidden');
                errorBox.classList.add('flex');
            }
        } catch (err) {
            errorText.textContent = 'Có lỗi xảy ra. Vui lòng thử lại.';
            errorBox.classList.remove('hidden');
            errorBox.classList.add('flex');
        }
    });
</script>