@using JobConnect.Models
@model List<User>
@{
    ViewData["Title"] = "Quản lý người dùng";
    Layout = "_LayoutAdmin";
}

<!-- Modal Thêm người dùng -->
<div id="modalCreate" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-md mx-4 p-6">
        <div class="flex items-center justify-between mb-5">
            <h2 class="text-lg font-bold text-on-surface">Thêm người dùng mới</h2>
            <button onclick="closeModal()" class="text-secondary hover:text-on-surface">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <form id="createUserForm" asp-action="CreateUser" method="post" class="space-y-4">
            @Html.AntiForgeryToken()
            <div id="createUserError" class="hidden px-4 py-2.5 bg-red-100 text-red-700 rounded-xl text-sm font-medium"></div>
            <div>
                <label class="block text-sm font-medium text-on-surface mb-1">Họ tên</label>
                <input name="fullName" required type="text" placeholder="Nguyễn Văn A"
                       class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
            </div>
            <div>
                <label class="block text-sm font-medium text-on-surface mb-1">Email</label>
                <input name="email" required type="email" placeholder="email@example.com"
                       class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
            </div>
            <div>
                <label class="block text-sm font-medium text-on-surface mb-1">Mật khẩu</label>
                <input name="password" required type="password" placeholder="Tối thiểu 6 ký tự"
                       class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
            </div>
            <div>
                <label class="block text-sm font-medium text-on-surface mb-1">Vai trò</label>
                <select name="role" class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary">
                    <option value="Candidate">Ứng viên</option>
                    <option value="Employer">Nhà tuyển dụng</option>
                </select>
            </div>
            <div class="flex gap-3 pt-2">
                <button type="button" onclick="closeModal()"
                        class="flex-1 px-4 py-2.5 border border-outline-variant rounded-xl text-sm font-medium text-secondary hover:bg-surface-container">
                    Huỷ
                </button>
                <button type="submit" id="createUserSubmitBtn"
                        class="flex-1 px-4 py-2.5 bg-primary text-white rounded-xl text-sm font-semibold hover:opacity-90">
                    Tạo tài khoản
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Modal Xác nhận xóa -->
<div id="modalDelete" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-sm mx-4 p-6">
        <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-red-100 rounded-full flex items-center justify-center">
                <span class="material-symbols-outlined text-red-600">delete</span>
            </div>
            <div>
                <h2 class="text-base font-bold text-on-surface">Xác nhận xóa vĩnh viễn</h2>
                <p class="text-sm text-secondary">Tài khoản sẽ bị xóa hoàn toàn khỏi hệ thống và KHÔNG THỂ khôi phục.</p>
            </div>
        </div>
        <p class="text-sm text-secondary mb-5">Bạn có chắc muốn xóa tài khoản <strong id="deleteUserName"></strong>?</p>
        <form asp-action="DeleteUser" method="post" id="deleteForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="userId" id="deleteUserId" />
            <div class="flex gap-3">
                <button type="button" onclick="closeDeleteModal()"
                        class="flex-1 px-4 py-2.5 border border-outline-variant rounded-xl text-sm font-medium text-secondary hover:bg-surface-container">
                    Huỷ
                </button>
                <button type="submit"
                        class="flex-1 px-4 py-2.5 bg-red-600 text-white rounded-xl text-sm font-semibold hover:bg-red-700">
                    Xóa
                </button>
            </div>
        </form>
    </div>
</div>

<div class="w-full px-6 py-8 xl:px-10">
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold text-on-surface">Quản lý người dùng</h1>
        <div class="flex items-center gap-3">
            <button onclick="openModal()"
                    class="flex items-center gap-2 px-4 py-2.5 bg-primary text-white rounded-xl text-sm font-semibold hover:opacity-90">
                <span class="material-symbols-outlined text-base">person_add</span>
                Thêm người dùng
            </button>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="mb-4 px-4 py-3 bg-green-100 text-green-700 rounded-xl text-sm font-medium flex items-center gap-2 auto-hide-alert">
            <span class="material-symbols-outlined text-base">check_circle</span>
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="mb-4 px-4 py-3 bg-red-100 text-red-700 rounded-xl text-sm font-medium flex items-center gap-2">
            <span class="material-symbols-outlined text-base">error</span>
            @TempData["Error"]
        </div>
    }

    <!-- Search & Filter -->
    <form method="get" class="flex gap-3 mb-6">
        <input name="keyword" value="@ViewBag.Keyword" type="text" placeholder="Tìm theo tên, email hoặc mã người dùng..."
               class="flex-1 px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
        <select name="role" class="px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary">
            <option value="">Tất cả vai trò</option>
            <option value="Candidate" selected="@(ViewBag.Role == "Candidate" ? "selected" : null)">Ứng viên</option>
            <option value="Employer" selected="@(ViewBag.Role == "Employer" ? "selected" : null)">Nhà tuyển dụng</option>
            <option value="Staff" selected="@(ViewBag.Role == "Staff" ? "selected" : null)">Nhân viên</option>
            <option value="Admin" selected="@(ViewBag.Role == "Admin" ? "selected" : null)">Admin</option>
        </select>
        <button type="submit" class="px-6 py-2.5 bg-primary text-white rounded-xl text-sm font-semibold hover:opacity-90">Tìm</button>
    </form>

    <!-- Table -->
    <div class="bg-white rounded-xl border border-outline-variant overflow-hidden">
        <table class="w-full text-sm">
            <thead class="bg-surface-container-low border-b border-outline-variant">
                <tr>
                    <th class="text-left px-4 py-3 font-semibold text-xs">Mã</th>
                    <th class="text-left px-5 py-3 font-semibold">Người dùng</th>
                    <th class="text-left px-5 py-3 font-semibold">Vai trò</th>
                    <th class="text-left px-5 py-3 font-semibold">Trạng thái</th>
                    <th class="text-left px-5 py-3 font-semibold">Ngày tạo</th>
                    <th class="px-5 py-3 text-center font-semibold">Thao tác</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-outline-variant">
                @foreach (var user in Model)
                {
                    var roleCls = user.Role == "Admin" ? "bg-purple-100 text-purple-700" :
                                  user.Role == "Staff" ? "bg-orange-100 text-orange-700" :
                                  user.Role == "Employer" ? "bg-blue-100 text-blue-700" :
                                                            "bg-gray-100 text-gray-600";
                    var roleLabel = user.Role == "Admin" ? "Admin" :
                                    user.Role == "Staff" ? "Nhân viên" :
                                    user.Role == "Employer" ? "Nhà tuyển dụng" : "Ứng viên";

                    // Get status info from StatusCatalog
                    List<StatusCatalog>? statuses = null;
                    if (user.Role == "Candidate" && ViewBag.CandidateStatuses != null)
                        statuses = ViewBag.CandidateStatuses as List<StatusCatalog>;
                    else if (user.Role == "Employer" && ViewBag.EmployerStatuses != null)
                        statuses = ViewBag.EmployerStatuses as List<StatusCatalog>;
                    else if (user.Role == "Staff" && ViewBag.StaffStatuses != null)
                        statuses = ViewBag.StaffStatuses as List<StatusCatalog>;

                    var statusInfo = statuses?.FirstOrDefault(s => s.Code == user.Status);
                    var statusName = statusInfo?.Name ?? user.Status;
                    var statusColor = statusInfo?.ColorClass ?? "bg-gray-100 text-gray-700";

                    // Determine if user is banned (status is not Active)
                    var isBanned = user.Status != "Active";

                    <tr class="hover:bg-surface-container-low transition-colors">
                        <td class="px-4 py-3">
                            <span class="font-mono text-xs text-secondary bg-surface-container px-2 py-1 rounded-lg select-all">@(user.UserCode ?? user.UserId.ToString())</span>
                        </td>
                        <!-- Tên + Email -->
                        <td class="px-5 py-3">
                            <div class="flex items-center gap-3">
                                <div class="w-9 h-9 rounded-full bg-surface-container flex items-center justify-center flex-shrink-0 overflow-hidden">
                                    @if (!string.IsNullOrEmpty(user.AvatarURL))
                                    {
                                        <img src="@user.AvatarURL" class="w-9 h-9 rounded-full object-cover" />
                                    }
                                    else
                                    {
                                        <span class="material-symbols-outlined text-sm text-secondary">person</span>
                                    }
                                </div>
                                <div>
                                    <p class="font-medium text-on-surface">@user.FullName</p>
                                    <p class="text-xs text-secondary">@user.Email</p>
                                </div>
                            </div>
                        </td>
                        <!-- Vai trò -->
                        <td class="px-5 py-3">
                            <span class="px-2.5 py-1 rounded-full text-xs font-medium @roleCls">@roleLabel</span>
                        </td>
                        <!-- Trạng thái -->
                        <td class="px-5 py-3">
                            <span class="px-2.5 py-1 rounded-full text-xs font-medium @statusColor">
                                @statusName
                            </span>
                        </td>
                        <!-- Ngày tạo -->
                        <td class="px-5 py-3 text-secondary text-xs">@user.CreatedAt.ToString("dd/MM/yyyy")</td>
                        <!-- Thao tác -->
                        <td class="px-5 py-3">
                            <div class="flex items-center justify-center gap-2">
                                <!-- Xem chi tiết -->
                                <a asp-action="UserDetail" asp-route-id="@user.UserId"
                                   class="flex items-center gap-1 px-3 py-1.5 bg-surface-container text-secondary hover:text-primary hover:bg-surface-container-high rounded-lg text-xs font-medium transition-colors">
                                    <span class="material-symbols-outlined text-sm">visibility</span>
                                    Xem
                                </a>

                                @if (user.Role != "Admin")
                                {
                                    <!-- Thay đổi trạng thái -->
                                    <form asp-action="ChangeUserStatus" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="userId" value="@user.UserId" />
                                        <select name="newStatus" class="px-2 py-1.5 rounded-lg text-xs font-medium border border-outline-variant outline-none focus:border-primary" onchange="changeUserStatus(this, @user.UserId)">
                                            <option value="" disabled selected>Trạng thái</option>
                                            @if (user.Role == "Candidate")
                                            {
                                                @foreach (var status in ViewBag.CandidateStatuses as List<StatusCatalog>)
                                                {
                                                    <option value="@status.Code" selected="@(user.Status == status.Code ? "selected" : null)">@status.Name</option>
                                                }
                                            }
                                            else if (user.Role == "Employer")
                                            {
                                                @foreach (var status in ViewBag.EmployerStatuses as List<StatusCatalog>)
                                                {
                                                    <option value="@status.Code" selected="@(user.Status == status.Code ? "selected" : null)">@status.Name</option>
                                                }
                                            }
                                            else if (user.Role == "Staff")
                                            {
                                                @foreach (var status in ViewBag.StaffStatuses as List<StatusCatalog>)
                                                {
                                                    <option value="@status.Code" selected="@(user.Status == status.Code ? "selected" : null)">@status.Name</option>
                                                }
                                            }
                                        </select>
                                    </form>

                                    <!-- Xóa -->
                                    <button onclick="openDeleteModal(@user.UserId, '@user.FullName.Replace("'", "\\'")' )"
                                            class="flex items-center gap-1 px-3 py-1.5 bg-red-50 text-red-600 hover:bg-red-100 border border-red-200 rounded-lg text-xs font-medium transition-colors">
                                        <span class="material-symbols-outlined text-sm">delete</span>
                                        Xóa
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @if (ViewBag.TotalPages > 1)
    {
        <div class="flex justify-center gap-2 mt-6">
            @for (int i = 1; i <= (int)ViewBag.TotalPages; i++)
            {
                <a asp-action="Users" asp-route-page="@i" asp-route-keyword="@ViewBag.Keyword" asp-route-role="@ViewBag.Role"
                   class="w-9 h-9 flex items-center justify-center rounded-lg text-sm border
                    @(i == (int)(ViewBag.Page ?? 1) ? "bg-primary text-white border-primary" : "border-outline-variant text-secondary hover:bg-surface-container")">
                    @i
                </a>
            }
        </div>
    }
</div>

<script>
    function openModal() {
        document.getElementById('createUserError').classList.add('hidden');
        document.getElementById('modalCreate').classList.remove('hidden');
        document.getElementById('modalCreate').classList.add('flex');
    }
    function closeModal() {
        document.getElementById('modalCreate').classList.add('hidden');
        document.getElementById('modalCreate').classList.remove('flex');
    }

    // Submit form Tạo tài khoản bằng AJAX để hiển thị lỗi (VD: trùng email)
    // ngay trong modal thay vì chuyển hẳn sang trang khác.
    document.getElementById('createUserForm').addEventListener('submit', async function (e) {
        e.preventDefault();
        const form = e.target;
        const errorBox = document.getElementById('createUserError');
        const submitBtn = document.getElementById('createUserSubmitBtn');
        errorBox.classList.add('hidden');
        submitBtn.disabled = true;
        const originalText = submitBtn.textContent;
        submitBtn.textContent = 'Đang xử lý...';

        try {
            const res = await fetch(form.action, {
                method: 'POST',
                headers: { 'X-Requested-With': 'XMLHttpRequest' },
                body: new FormData(form)
            });
            const data = await res.json();

            if (data.success) {
                location.reload();
            } else {
                errorBox.textContent = data.message || 'Có lỗi xảy ra, vui lòng thử lại.';
                errorBox.classList.remove('hidden');
            }
        } catch (err) {
            errorBox.textContent = 'Không thể kết nối máy chủ, vui lòng thử lại.';
            errorBox.classList.remove('hidden');
        } finally {
            submitBtn.disabled = false;
            submitBtn.textContent = originalText;
        }
    });

    function openDeleteModal(userId, userName) {
        document.getElementById('deleteUserId').value = userId;
        document.getElementById('deleteUserName').textContent = userName;
        document.getElementById('modalDelete').classList.remove('hidden');
        document.getElementById('modalDelete').classList.add('flex');
    }
    function closeDeleteModal() {
        document.getElementById('modalDelete').classList.add('hidden');
        document.getElementById('modalDelete').classList.remove('flex');
    }

    function changeUserStatus(selectElement, userId) {
        const newStatus = selectElement.value;
        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

        fetch('/Admin/ChangeUserStatus', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'RequestVerificationToken': token
            },
            body: `userId=${userId}&newStatus=${newStatus}&__RequestVerificationToken=${token}`
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                // Reload the page to show updated status
                location.reload();
            } else {
                alert(data.message || 'Không thể thay đổi trạng thái');
                selectElement.value = selectElement.getAttribute('data-original-value');
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('Có lỗi xảy ra khi thay đổi trạng thái');
            selectElement.value = selectElement.getAttribute('data-original-value');
        });
    }

    // Đóng modal khi click nền
    document.getElementById('modalCreate').addEventListener('click', function (e) {
        if (e.target === this) closeModal();
    });
    document.getElementById('modalDelete').addEventListener('click', function (e) {
        if (e.target === this) closeDeleteModal();
    });
</script>
