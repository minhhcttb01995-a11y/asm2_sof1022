@using JobConnect.Models
@model Category
@{
    ViewData["Title"] = "Thêm Danh mục mới";
    Layout = "_LayoutAdmin";
}

<div class="max-w-2xl mx-auto px-6 py-8">
    <!-- Header -->
    <div class="flex items-center gap-4 mb-6">
        <a asp-action="Categories" class="text-secondary hover:text-primary flex items-center gap-1">
            <span class="material-symbols-outlined">arrow_back</span> Quay lại
        </a>
        <div>
            <h1 class="text-2xl font-bold text-on-surface">Thêm Danh mục mới</h1>
            <p class="text-secondary text-sm">Tạo danh mục mới cho hệ thống</p>
        </div>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="mb-4 px-4 py-3 bg-red-100 text-red-700 rounded-xl text-sm font-medium flex items-center gap-2">
            <span class="material-symbols-outlined text-base">error</span>
            @TempData["Error"]
        </div>
    }

    <!-- Form -->
    <div class="bg-white rounded-2xl p-6 border border-outline-variant">
        <form asp-action="CategoryCreate" method="post" class="space-y-5">
            @Html.AntiForgeryToken()
            
            <div>
                <label asp-for="Name" class="block text-sm font-medium text-on-surface mb-1">Tên danh mục <span class="text-red-500">*</span></label>
                <input asp-for="Name" required type="text" placeholder="Ví dụ: Công nghệ thông tin, Hà Nội, Senior"
                       class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
                <span asp-validation-for="Name" class="text-xs text-red-500"></span>
            </div>

            <div>
                <label asp-for="Type" class="block text-sm font-medium text-on-surface mb-1">Loại danh mục <span class="text-red-500">*</span></label>
                <select asp-for="Type" class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary">
                    @if (ViewBag.Types != null)
                    {
                        foreach (string type in ViewBag.Types)
                        {
                            <option value="@type">@type</option>
                        }
                    }
                </select>
                <span asp-validation-for="Type" class="text-xs text-red-500"></span>
            </div>

            <div>
                <label asp-for="Slug" class="block text-sm font-medium text-on-surface mb-1">Slug <span class="text-red-500">*</span></label>
                <input asp-for="Slug" required type="text" placeholder="Ví dụ: cong-nghe-thong-tin, ha-noi, senior"
                       class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
                <span asp-validation-for="Slug" class="text-xs text-red-500"></span>
                <p class="text-xs text-secondary mt-1">Slug sẽ được dùng trong URL, chỉ chứa chữ thường, số và dấu gạch ngang</p>
            </div>

            <div class="flex gap-3 pt-4">
                <a asp-action="Categories" class="flex-1 px-4 py-2.5 border border-outline-variant rounded-xl text-sm font-medium text-secondary hover:bg-surface-container text-center whitespace-nowrap">
                    Huỷ
                </a>
                <button type="submit" class="flex-1 px-4 py-2.5 bg-primary text-white rounded-xl text-sm font-semibold hover:opacity-90 whitespace-nowrap">
                    Tạo danh mục
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
