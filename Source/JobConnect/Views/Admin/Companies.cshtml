@* [VIEW-HEADER-ADDED]
   View cho action "Companies" trong khu vực trang quản trị Admin (AdminController).
*@
@using JobConnect.Models
@model IEnumerable<Employer>
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Quản lý công ty";
}

<!-- Modal thêm công ty mới -->
<div id="modalCreateCompany" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-lg mx-4 p-6">
        <div class="flex items-center justify-between mb-5">
            <h2 class="text-lg font-bold text-on-surface">Thêm công ty mới</h2>
            <button onclick="closeCreateCompanyModal()" class="text-secondary hover:text-on-surface">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <form asp-action="CreateCompany" method="post" class="space-y-4">
            @Html.AntiForgeryToken()
            <div>
                <label class="block text-sm font-medium text-on-surface mb-1">Tên công ty *</label>
                <input name="companyName" required type="text" placeholder="Công ty CP Ví dụ Việt Nam"
                       class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-1">Ngành nghề</label>
                    <input name="industry" type="text" placeholder="Công nghệ thông tin"
                           class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-1">Mã số thuế</label>
                    <input name="taxCode" type="text" placeholder="0123456789"
                           class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
                </div>
            </div>
            <div>
                <label class="block text-sm font-medium text-on-surface mb-1">Địa chỉ</label>
                <input name="address" type="text" placeholder="Số 1 đường ABC, Quận X, Thành phố Y"
                       class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
            </div>
            <hr class="border-outline-variant" />
            <p class="text-xs text-secondary -mt-2">Tài khoản đăng nhập của người đại diện công ty (nhà tuyển dụng):</p>
            <div>
                <label class="block text-sm font-medium text-on-surface mb-1">Họ tên người liên hệ *</label>
                <input name="contactName" required type="text" placeholder="Nguyễn Văn A"
                       class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-1">Email *</label>
                    <input name="email" required type="email" placeholder="email@congty.vn"
                           class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-1">Mật khẩu *</label>
                    <input name="password" required type="password" placeholder="Tối thiểu 6 ký tự"
                           class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
                </div>
            </div>
            <div class="flex gap-3 pt-2">
                <button type="button" onclick="closeCreateCompanyModal()"
                        class="flex-1 px-4 py-2.5 border border-outline-variant rounded-xl text-sm font-medium text-secondary hover:bg-surface-container">
                    Huỷ
                </button>
                <button type="submit"
                        class="flex-1 px-4 py-2.5 bg-primary text-white rounded-xl text-sm font-semibold hover:opacity-90">
                    Tạo công ty
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Modal xác nhận xóa -->
<div id="modalDelete" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-sm mx-4 p-6">
        <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-red-100 rounded-full flex items-center justify-center">
                <span class="material-symbols-outlined text-red-600">delete</span>
            </div>
            <div>
                <h2 class="text-base font-bold text-on-surface">Xác nhận xóa công ty</h2>
                <p class="text-xs text-secondary">Toàn bộ tin tuyển dụng sẽ bị xóa theo.</p>
            </div>
        </div>
        <p class="text-sm text-secondary mb-5">
            Bạn có chắc muốn xóa công ty <strong id="deleteCompanyName"></strong>?
        </p>
        <form asp-action="DeleteCompany" method="post" id="deleteForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="deleteCompanyId" />
            <div class="flex gap-3">
                <button type="button" onclick="closeDeleteModal()"
                        class="flex-1 px-4 py-2.5 border border-outline-variant rounded-xl text-sm font-medium text-secondary hover:bg-surface-container">
                    Huỷ
                </button>
                <button type="submit"
                        class="flex-1 px-4 py-2.5 bg-red-600 text-white rounded-xl text-sm font-semibold hover:bg-red-700">
                    Xóa
                </button>
            </div>
        </form>
    </div>
</div>

<div class="space-y-5">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3">
        <div>
            <h1 class="text-xl font-bold text-on-surface">Quản lý công ty</h1>
            <p class="text-sm text-secondary">Tổng: <strong>@Model.Count()</strong> công ty đã đăng ký</p>
        </div>
        <button onclick="openCreateCompanyModal()"
                class="flex items-center gap-2 px-4 py-2.5 bg-primary text-white rounded-xl text-sm font-semibold hover:opacity-90">
            <span class="material-symbols-outlined text-base">domain_add</span>
            Thêm công ty
        </button>
    </div>

    @{
        var orphanCount = (int)(ViewBag.OrphanEmployerCount ?? 0);
    }
    @if (orphanCount > 0)
    {
        <div class="px-4 py-3 bg-amber-50 border border-amber-200 text-amber-800 rounded-xl text-sm flex items-center justify-between gap-3 flex-wrap">
            <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-amber-600 text-base">warning</span>
                Có <strong>@orphanCount</strong> tài khoản nhà tuyển dụng đã tạo nhưng chưa có hồ sơ công ty (bị thiếu công ty).
            </div>
            <form asp-action="FixOrphanEmployers" method="post" onsubmit="return confirm('Hệ thống sẽ tự tạo hồ sơ công ty tạm (trạng thái Chờ duyệt) cho các tài khoản này. Bạn có thể sửa lại tên/thông tin công ty sau. Tiếp tục?')">
                @Html.AntiForgeryToken()
                <button type="submit" class="px-3 py-1.5 bg-amber-600 text-white rounded-lg text-xs font-semibold hover:bg-amber-700">
                    Khắc phục ngay
                </button>
            </form>
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="px-4 py-3 bg-green-100 text-green-700 rounded-xl text-sm font-medium flex items-center gap-2 auto-hide-alert">
            <span class="material-symbols-outlined text-base">check_circle</span>
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="px-4 py-3 bg-red-100 text-red-700 rounded-xl text-sm font-medium flex items-center gap-2">
            <span class="material-symbols-outlined text-base">error</span>
            @TempData["Error"]
        </div>
    }

    <!-- Filter bar -->
    <form method="get" class="bg-white rounded-2xl p-4 shadow-sm border border-outline-variant flex flex-wrap gap-3 items-end">
        <div class="flex-1 min-w-[200px]">
            <label class="block text-xs text-secondary mb-1">Tìm công ty</label>
            <input type="text" name="q" value="@ViewBag.Q"
                   class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary"
                   placeholder="Tên công ty hoặc mã công ty..." />
        </div>
        <div>
            <label class="block text-xs text-secondary mb-1">Trạng thái</label>
            <select name="status" class="px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary w-44">
                <option value="">Tất cả</option>
                <option value="Verified" selected="@(ViewBag.Status == "Verified" ? "selected" : null)">Đã xác minh</option>
                <option value="Unverified" selected="@(ViewBag.Status == "Unverified" ? "selected" : null)">Chưa xác minh</option>
                <option value="Locked" selected="@(ViewBag.Status == "Locked" ? "selected" : null)">Đã khoá</option>
            </select>
        </div>
        <button type="submit"
                class="px-4 py-2.5 bg-primary text-white rounded-xl text-sm font-medium hover:opacity-90">
            Lọc
        </button>
    </form>

    <!-- Table -->
    <div class="bg-white rounded-2xl shadow-sm border border-outline-variant overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead class="bg-surface-container text-secondary text-xs uppercase">
                    <tr>
                        <th class="px-4 py-3 text-left">Mã</th>
                        <th class="px-4 py-3 text-left">Công ty</th>
                        <th class="px-4 py-3 text-left">Email liên hệ</th>
                        <th class="px-4 py-3 text-center">Tin đăng</th>
                        <th class="px-4 py-3 text-center">Trạng thái</th>
                        <th class="px-4 py-3 text-center">Ngày đăng ký</th>
                        <th class="px-4 py-3 text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-outline-variant">
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="px-4 py-10 text-center text-secondary">
                                <span class="material-symbols-outlined text-3xl block mb-2 opacity-40">apartment</span>
                                Không tìm thấy công ty nào.
                            </td>
                        </tr>
                    }
                    @foreach (var c in Model)
                    {
                        // Get status info from StatusCatalog
                        List<StatusCatalog>? employerStatuses = null;
                        if (ViewBag.EmployerStatuses != null)
                            employerStatuses = ViewBag.EmployerStatuses as List<StatusCatalog>;

                        var statusInfo = employerStatuses?.FirstOrDefault(s => s.Code == c.Status);
                        var statusName = statusInfo?.Name ?? c.Status;
                        var statusColor = statusInfo?.ColorClass ?? "bg-gray-100 text-gray-700";

                        <tr class="hover:bg-surface-container/50 transition-colors">
                            <!-- Mã công ty -->
                            <td class="px-4 py-3">
                                <span class="font-mono text-xs text-secondary bg-surface-container px-2 py-1 rounded-lg select-all">@(c.CompanyCode ?? c.EmployerId.ToString())</span>
                            </td>
                            <!-- Tên công ty -->
                            <td class="px-4 py-3">
                                <div class="flex items-center gap-3">
                                    @if (!string.IsNullOrEmpty(c.LogoURL))
                                    {
                                        <img src="@c.LogoURL" class="w-9 h-9 rounded-lg object-contain border border-outline-variant" />
                                    }
                                    else
                                    {
                                        <div class="w-9 h-9 rounded-lg bg-surface-container flex items-center justify-center text-secondary flex-shrink-0">
                                            <span class="material-symbols-outlined text-sm">apartment</span>
                                        </div>
                                    }
                                    <div>
                                        <p class="font-medium text-on-surface">@c.CompanyName</p>
                                        <p class="text-xs text-secondary">@(c.Industry ?? "—")</p>
                                    </div>
                                </div>
                            </td>
                            <!-- Email -->
                            <td class="px-4 py-3 text-secondary text-sm">@(c.User?.Email ?? "—")</td>
                            <!-- Số tin -->
                            <td class="px-4 py-3 text-center font-medium">@(c.JobPosts?.Count ?? 0)</td>
                            <!-- Trạng thái -->
                            <td class="px-4 py-3 text-center">
                                <span class="px-2.5 py-1 rounded-full text-xs font-medium @statusColor">
                                    @statusName
                                </span>
                            </td>
                            <!-- Ngày đăng ký -->
                            <td class="px-4 py-3 text-center text-secondary text-xs">@c.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <!-- Thao tác -->
                            <td class="px-4 py-3">
                                <div class="flex items-center justify-center gap-1.5 flex-wrap">

                                    <!-- Xem chi tiết -->
                                    <a asp-action="CompanyDetail" asp-route-id="@c.EmployerId"
                                       class="flex items-center gap-1 px-2.5 py-1.5 rounded-lg text-xs font-medium bg-surface-container text-secondary hover:text-primary hover:bg-surface-container-high border border-outline-variant transition-colors">
                                        <span class="material-symbols-outlined text-sm">visibility</span>
                                        Xem
                                    </a>

                                    <!-- Xác minh / Hủy xác minh -->
                                    @if (!c.IsVerified)
                                    {
                                        <form asp-action="ApproveCompany" method="post" class="inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@c.EmployerId" />
                                            <button type="submit"
                                                    class="flex items-center gap-1 px-2.5 py-1.5 rounded-lg text-xs font-medium bg-green-50 text-green-700 hover:bg-green-100 border border-green-200 transition-colors">
                                                <span class="material-symbols-outlined text-sm">verified</span>
                                                Xác minh
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="SuspendCompany" method="post" class="inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@c.EmployerId" />
                                            <button type="submit"
                                                    class="flex items-center gap-1 px-2.5 py-1.5 rounded-lg text-xs font-medium bg-orange-50 text-orange-700 hover:bg-orange-100 border border-orange-200 transition-colors">
                                                <span class="material-symbols-outlined text-sm">unpublished</span>
                                                Hủy XM
                                            </button>
                                        </form>
                                    }

                                    <!-- Thay đổi trạng thái -->
                                    <form asp-action="ChangeEmployerStatus" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="employerId" value="@c.EmployerId" />
                                        <select name="newStatus" class="px-2 py-1.5 rounded-lg text-xs font-medium border border-outline-variant outline-none focus:border-primary" onchange="changeEmployerStatus(this, @c.EmployerId)">
                                            <option value="" disabled selected>Trạng thái</option>
                                            @foreach (var status in ViewBag.EmployerStatuses as List<StatusCatalog>)
                                            {
                                                <option value="@status.Code" selected="@(c.User?.Status == status.Code ? "selected" : null)">@status.Name</option>
                                            }
                                        </select>
                                    </form>

                                    <!-- Xóa -->
                                    <button onclick="openDeleteModal(@c.EmployerId, '@c.CompanyName.Replace("'", "\\'")')"
                                            class="flex items-center gap-1 px-2.5 py-1.5 rounded-lg text-xs font-medium bg-red-50 text-red-600 hover:bg-red-100 border border-red-200 transition-colors">
                                        <span class="material-symbols-outlined text-sm">delete</span>
                                        Xóa
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @if ((int)(ViewBag.TotalPages ?? 1) > 1)
        {
            <div class="flex justify-center gap-2 p-4 border-t border-outline-variant">
                @for (int i = 1; i <= (int)ViewBag.TotalPages; i++)
                {
                    var pgCls = i == (int)(ViewBag.Page ?? 1)
                        ? "bg-primary text-white border-primary"
                        : "border-outline-variant text-secondary hover:bg-surface-container";
                    <a asp-action="Companies" asp-route-page="@i" asp-route-q="@ViewBag.Q" asp-route-status="@ViewBag.Status"
                       class="w-9 h-9 flex items-center justify-center rounded-lg text-sm border @pgCls">
                        @i
                    </a>
                }
            </div>
        }
    </div>
</div>

<script>
    function openCreateCompanyModal() {
        document.getElementById('modalCreateCompany').classList.remove('hidden');
        document.getElementById('modalCreateCompany').classList.add('flex');
    }
    function closeCreateCompanyModal() {
        document.getElementById('modalCreateCompany').classList.add('hidden');
        document.getElementById('modalCreateCompany').classList.remove('flex');
    }
    document.getElementById('modalCreateCompany').addEventListener('click', function(e) {
        if (e.target === this) closeCreateCompanyModal();
    });

    function openDeleteModal(id, name) {
        document.getElementById('deleteCompanyId').value = id;
        document.getElementById('deleteCompanyName').textContent = name;
        document.getElementById('modalDelete').classList.remove('hidden');
        document.getElementById('modalDelete').classList.add('flex');
    }
    function closeDeleteModal() {
        document.getElementById('modalDelete').classList.add('hidden');
        document.getElementById('modalDelete').classList.remove('flex');
    }

    function changeEmployerStatus(selectElement, employerId) {
        const newStatus = selectElement.value;
        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

        fetch('/Admin/ChangeEmployerStatus', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'RequestVerificationToken': token
            },
            body: `employerId=${employerId}&newStatus=${newStatus}&__RequestVerificationToken=${token}`
        })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    location.reload();
                } else {
                    alert(data.message || 'Không thể thay đổi trạng thái');
                    selectElement.value = selectElement.getAttribute('data-original-value');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Có lỗi xảy ra khi thay đổi trạng thái');
                selectElement.value = selectElement.getAttribute('data-original-value');
            });
    }

    document.getElementById('modalDelete').addEventListener('click', function(e) {
        if (e.target === this) closeDeleteModal();
    });
</script>
