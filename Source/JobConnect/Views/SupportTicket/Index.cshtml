@using JobConnect.Models
@model List<SupportTicket>
@{
    ViewData["Title"] = "Support Tickets";
    Layout = "_LayoutAdmin";
}

<div class="max-w-[1700px] mx-auto px-6 py-8">
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold text-on-surface">Support Tickets</h1>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="mb-4 px-4 py-3 bg-green-100 text-green-700 rounded-xl text-sm font-medium flex items-center gap-2 auto-hide-alert">
            <span class="material-symbols-outlined text-base">check_circle</span>
            @TempData["Success"]
        </div>
    }

    <!-- Filter -->
    <form method="get" class="flex gap-3 mb-6">
        <select name="status" class="px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary">
            <option value="">Tất cả trạng thái</option>
            <option value="Open" selected="@(ViewBag.StatusFilter == TicketStatus.Open ? "selected" : null)">Chờ xử lý</option>
            <option value="InProgress" selected="@(ViewBag.StatusFilter == TicketStatus.InProgress ? "selected" : null)">Đang xử lý</option>
            <option value="Resolved" selected="@(ViewBag.StatusFilter == TicketStatus.Resolved ? "selected" : null)">Đã giải quyết</option>
            <option value="Closed" selected="@(ViewBag.StatusFilter == TicketStatus.Closed ? "selected" : null)">Đã đóng</option>
        </select>
        <button type="submit" class="px-6 py-2.5 bg-primary text-slate-900 rounded-xl text-sm font-semibold hover:opacity-90">Lọc</button>
        <a asp-action="Index" class="px-4 py-2.5 border border-outline-variant rounded-xl text-sm font-medium text-secondary hover:bg-surface-container">
            Đặt lại
        </a>
    </form>

    <!-- Table -->
    <div class="bg-white rounded-xl border border-outline-variant overflow-hidden">
        <table class="w-full text-sm">
            <thead class="bg-surface-container-low border-b border-outline-variant">
                <tr>
                    <th class="text-left px-4 py-3 font-semibold text-xs">Người tạo</th>
                    <th class="text-left px-5 py-3 font-semibold">Loại</th>
                    <th class="text-left px-5 py-3 font-semibold">Tiêu đề</th>
                    <th class="text-left px-5 py-3 font-semibold">Người xử lý</th>
                    <th class="text-left px-5 py-3 font-semibold">Trạng thái</th>
                    <th class="text-left px-5 py-3 font-semibold">Ngày tạo</th>
                    <th class="px-5 py-3 text-center font-semibold">Thao tác</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-outline-variant">
                @foreach (var ticket in Model)
                {
                    var statusClass = ticket.StatusEnum switch
                    {
                        TicketStatus.Open => "bg-red-100 text-red-700",
                        TicketStatus.InProgress => "bg-blue-100 text-blue-700",
                        TicketStatus.Resolved => "bg-green-100 text-green-700",
                        TicketStatus.Closed => "bg-gray-100 text-gray-700",
                        _ => "bg-gray-100 text-gray-700"
                    };

                    var typeLabel = ticket.TypeEnum switch
                    {
                        TicketType.AccountIssue => "Tài khoản",
                        TicketType.JobPosting => "Đăng tin",
                        TicketType.Application => "Ứng tuyển",
                        TicketType.Billing => "Thanh toán",
                        TicketType.Technical => "Kỹ thuật",
                        TicketType.Other => "Khác",
                        _ => "Khác"
                    };

                    <tr class="hover:bg-surface-container-low transition-colors">
                        <td class="px-4 py-3">
                            <p class="font-medium text-on-surface">@ticket.User?.FullName</p>
                            <p class="text-xs text-secondary">@ticket.User?.Email</p>
                        </td>
                        <td class="px-5 py-3">
                            <span class="px-2.5 py-1 rounded-full text-xs font-medium bg-purple-100 text-purple-700">@typeLabel</span>
                        </td>
                        <td class="px-5 py-3" style="max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                            @ticket.Subject
                        </td>
                        <td class="px-5 py-3 text-secondary">
                            @(ticket.AssignedToStaff?.FullName ?? "Chưa gán")
                        </td>
                        <td class="px-5 py-3">
                            <span class="px-2.5 py-1 rounded-full text-xs font-medium @statusClass">@ticket.StatusEnum</span>
                        </td>
                        <td class="px-5 py-3 text-secondary text-xs">@ticket.CreatedAt.ToString("dd/MM/yyyy")</td>
                        <td class="px-5 py-3">
                            <div class="flex items-center justify-center gap-2">
                                <a asp-action="Details" asp-route-id="@ticket.Id"
                                   class="flex items-center gap-1 px-3 py-1.5 bg-surface-container text-secondary hover:text-primary hover:bg-surface-container-high rounded-lg text-xs font-medium transition-colors">
                                    <span class="material-symbols-outlined text-sm">visibility</span>
                                    Xem
                                </a>
                                @if (ticket.StatusEnum == TicketStatus.Open)
                                {
                                    <form asp-action="Assign" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@ticket.Id" />
                                        <button type="submit" onclick="return confirm('Bạn có chắc muốn gán ticket này cho mình?')"
                                                class="flex items-center gap-1 px-3 py-1.5 bg-blue-50 text-blue-700 hover:bg-blue-100 border border-blue-200 rounded-lg text-xs font-medium transition-colors">
                                            <span class="material-symbols-outlined text-sm">person_add</span>
                                            Gán
                                        </button>
                                    </form>
                                }
                                @if (ticket.StatusEnum == TicketStatus.InProgress)
                                {
                                    <form asp-action="Resolve" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@ticket.Id" />
                                        <button type="submit" onclick="return confirm('Bạn có chắc muốn giải quyết ticket này?')"
                                                class="flex items-center gap-1 px-3 py-1.5 bg-green-50 text-green-700 hover:bg-green-100 border border-green-200 rounded-lg text-xs font-medium transition-colors">
                                            <span class="material-symbols-outlined text-sm">check</span>
                                            Giải quyết
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @if (ViewBag.TotalPages > 1)
    {
        <div class="flex justify-center gap-2 mt-6">
            @for (int i = 1; i <= (int)ViewBag.TotalPages; i++)
            {
                <a asp-action="Index" asp-route-page="@i" asp-route-status="@ViewBag.StatusFilter"
                   class="w-9 h-9 flex items-center justify-center rounded-lg text-sm border @(i == (int)(ViewBag.CurrentPage ?? 1) ? "bg-primary text-slate-900 border-primary" : "border-outline-variant text-secondary hover:bg-surface-container")">
                    @i
                </a>
            }
        </div>
    }
</div>
