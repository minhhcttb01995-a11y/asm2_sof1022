@section Scripts {
    <script>
        (function() {
            var PAGE_SIZE = 12; // 3 cột x 4 hàng
            var grid = document.getElementById('featJobsGrid');
            if (!grid) return;

            var allCards = Array.prototype.slice.call(grid.querySelectorAll('.feat-job-card'));
            var currentFilter = 'all';
            var currentPage = 1;

            var pageLabel = document.getElementById('featJobsPageLabel');
            var prevBtns = [document.getElementById('featJobsPrev'), document.getElementById('featJobsPrevBottom')];
            var nextBtns = [document.getElementById('featJobsNext'), document.getElementById('featJobsNextBottom')];
            var filterBtns = document.querySelectorAll('.feat-filter-btn');

            function matchesFilter(card, filter) {
                if (filter === 'all') return true;
                if (filter === 'hanoi') return card.dataset.region === 'hanoi';
                if (filter === 'hcm') return card.dataset.region === 'hcm';
                if (filter === 'mienbac') return card.dataset.mienBac === 'true';
                if (filter === 'miennam') return card.dataset.mienNam === 'true';
                return true;
            }

            function getFilteredCards() {
                return allCards.filter(function(c) { return matchesFilter(c, currentFilter); });
            }

            function render() {
                var filtered = getFilteredCards();
                var totalPages = Math.max(1, Math.ceil(filtered.length / PAGE_SIZE));
                if (currentPage > totalPages) currentPage = totalPages;
                if (currentPage < 1) currentPage = 1;

                var start = (currentPage - 1) * PAGE_SIZE;
                var end = start + PAGE_SIZE;

                allCards.forEach(function(c) { c.style.display = 'none'; });
                filtered.slice(start, end).forEach(function(c) { c.style.display = ''; });

                if (pageLabel) pageLabel.textContent = currentPage + ' / ' + totalPages + ' trang';

                var atFirst = currentPage <= 1;
                var atLast = currentPage >= totalPages;
                prevBtns.forEach(function(b) { if (b) b.disabled = atFirst; if (b) b.classList.toggle('opacity-40', atFirst); });
                nextBtns.forEach(function(b) { if (b) b.disabled = atLast; if (b) b.classList.toggle('opacity-40', atLast); });

                if (filtered.length === 0 && grid) {
                    if (!document.getElementById('featJobsEmpty')) {
                        var empty = document.createElement('div');
                        empty.id = 'featJobsEmpty';
                        empty.className = 'col-span-full text-center text-slate-500 text-sm py-10';
                        empty.textContent = 'Không có việc làm phù hợp với bộ lọc này.';
                        grid.appendChild(empty);
                    }
                } else {
                    var empty = document.getElementById('featJobsEmpty');
                    if (empty) empty.remove();
                }
            }

            filterBtns.forEach(function(btn) {
                btn.addEventListener('click', function() {
                    currentFilter = btn.dataset.filter;
                    currentPage = 1;
                    filterBtns.forEach(function(b) {
                        b.classList.remove('bg-blue-600', 'text-white', 'border-blue-600', 'font-bold');
                        b.classList.add('bg-white', 'text-slate-600', 'border-slate-300', 'font-semibold');
                    });
                    btn.classList.remove('bg-white', 'text-slate-600', 'border-slate-300', 'font-semibold');
                    btn.classList.add('bg-blue-600', 'text-white', 'border-blue-600', 'font-bold');
                    render();
                });
            });

            prevBtns.forEach(function(b) {
                if (!b) return;
                b.addEventListener('click', function() {
                    if (currentPage > 1) { currentPage--; render(); }
                });
            });
            nextBtns.forEach(function(b) {
                if (!b) return;
                b.addEventListener('click', function() {
                    var filtered = getFilteredCards();
                    var totalPages = Math.max(1, Math.ceil(filtered.length / PAGE_SIZE));
                    if (currentPage < totalPages) { currentPage++; render(); }
                });
            });

            render();
        })();
    </script>
}
