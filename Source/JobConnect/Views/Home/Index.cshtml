@* [VIEW-HEADER-ADDED]
   View cho action "Index" trong khu vực trang chủ (HomeController).
*@
@using JobConnect.Extensions
@model JobConnect.ViewModels.HomeViewModel
@{
    ViewData["Title"] = "Trang chủ";
}

<style>
    /* RESET & BASE - NỀN SÁNG */
    body {
        background-color: #f8fafc !important;
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
    }

    .ambient-shadow {
        box-shadow: 0 8px 20px rgba(15, 23, 42, 0.06);
    }

    .hero-bg {
        background: linear-gradient(135deg, #eff6ff 0%, #f8fafc 60%, #ffffff 100%);
        position: relative;
    }

    .cta-section {
        background: linear-gradient(135deg, #2563eb 0%, #3b82f6 60%, #1d4ed8 100%);
    }

    /* ========== GLASS CARD EFFECT ========== */
    .glass-card {
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(59, 130, 246, 0.15);
    }

        .glass-card:hover {
            border-color: rgba(59, 130, 246, 0.35);
        }

    /* ========== CUSTOM SCROLLBAR ========== */
    ::-webkit-scrollbar {
        width: 8px;
    }

    ::-webkit-scrollbar-track {
        background: #f1f5f9;
    }

    ::-webkit-scrollbar-thumb {
        background: #cbd5e1;
        border-radius: 4px;
    }

        ::-webkit-scrollbar-thumb:hover {
            background: #3b82f6;
        }

    /* ========== ANIMATION ========== */
    @@keyframes float {
        0%, 100% {
            transform: translateY(0px);
        }

        50% {
            transform: translateY(-10px);
        }
    }

    .float-animation {
        animation: float 4s ease-in-out infinite;
    }
</style>

<!-- HERO SECTION -->
<section class="hero-bg relative overflow-hidden py-24 md:py-32 border-b border-slate-200">
    <!-- Orbs trang trí như login/register -->
    <div class="absolute -top-24 -right-24 w-96 h-96 bg-blue-600/20 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute -bottom-24 -left-24 w-80 h-80 bg-indigo-600/20 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-64 h-64 bg-cyan-500/10 rounded-full blur-3xl pointer-events-none"></div>

    <div class="max-w-[1920px] mx-auto px-4 sm:px-6 relative z-10 flex flex-col items-center text-center">
        <div class="inline-flex items-center gap-2 bg-white backdrop-blur-md border border-blue-500/30 px-5 py-2 rounded-full text-sm font-bold text-blue-600 mb-8 shadow-sm">
            <span class="material-symbols-outlined text-base animate-pulse">bolt</span>
            @Model.TotalJobs.ToString("N0")+ việc làm đang tuyển
        </div>

        <h1 class="text-5xl md:text-7xl lg:text-8xl font-black text-slate-900 mb-6 leading-tight tracking-tight">
            Kết nối sự nghiệp<br />
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-indigo-400 to-purple-400">tương lai</span> của bạn
        </h1>
        <p class="text-slate-600 text-lg md:text-2xl mb-12 max-w-3xl font-medium">
            Hàng ngàn cơ hội việc làm hấp dẫn từ những công ty hàng đầu đang chờ đón bạn.
        </p>

        <!-- Search Bar - Glassmorphism -->
        <form asp-controller="Job" asp-action="Index" method="get"
              class="w-full max-w-5xl bg-white backdrop-blur-md rounded-2xl shadow-2xl border border-blue-500/30 p-3 flex flex-col md:flex-row gap-2 items-stretch relative z-20">
            <div class="flex items-center gap-3 flex-1 px-5 py-3 md:py-0 border-b md:border-b-0 md:border-r border-slate-200">
                <span class="material-symbols-outlined text-slate-600 text-2xl">search</span>
                <input name="Keyword" type="text" placeholder="Vị trí, kỹ năng hoặc công ty..."
                       class="w-full border-none outline-none text-base bg-transparent placeholder-slate-400 text-slate-700 font-medium" />
            </div>
            <div class="flex items-center gap-3 flex-1 px-5 py-3 md:py-0">
                <span class="material-symbols-outlined text-slate-600 text-2xl">location_on</span>
                <select name="Location" class="w-full border-none outline-none text-base bg-transparent text-slate-600 font-medium cursor-pointer">
                    <option value="" class="bg-white text-slate-600">Tất cả địa điểm</option>
                    @foreach (var loc in Model.Locations)
                    {
                        <option value="@loc.Name" class="bg-white text-slate-600">@loc.Name</option>
                    }
                </select>
            </div>
            <button type="submit"
                    class="bg-gradient-to-r from-blue-600 to-indigo-600 text-white px-10 py-4 rounded-xl text-base font-bold hover:from-blue-700 hover:to-indigo-700 active:scale-[0.98] transition-all whitespace-nowrap shadow-lg shadow-blue-900/30">
                Tìm kiếm ngay
            </button>
        </form>

        <!-- Trending tags -->
        <div class="flex flex-wrap justify-center items-center gap-3 mt-8 text-sm text-slate-600">
            <span class="font-bold text-slate-600">🔥 Xu hướng:</span>
            @foreach (var tag in new[] { "Frontend Developer", "UI/UX Designer", "Data Analyst", "Marketing" })
            {
                <a asp-controller="Job" asp-action="Index" asp-route-Keyword="@tag"
                   class="bg-white hover:bg-blue-600 hover:text-white px-4 py-1.5 rounded-lg transition-all font-medium border border-slate-200 backdrop-blur-sm">@tag</a>
            }
        </div>

        <!-- Stats - Glassmorphism -->
        <div class="grid grid-cols-3 gap-6 sm:gap-16 mt-16 bg-white backdrop-blur-md border border-blue-500/20 rounded-2xl p-6 sm:p-10 min-w-[320px] sm:min-w-[640px] shadow-sm">
            <div class="flex flex-col items-center">
                <span class="text-3xl sm:text-4xl font-black text-slate-900">@Model.TotalJobs.ToString("N0")</span>
                <span class="text-xs sm:text-sm font-bold text-blue-600 uppercase tracking-wider mt-1">Việc làm</span>
            </div>
            <div class="flex flex-col items-center border-x border-blue-500/20">
                <span class="text-3xl sm:text-4xl font-black text-slate-900">@Model.TotalCompanies.ToString("N0")</span>
                <span class="text-xs sm:text-sm font-bold text-blue-600 uppercase tracking-wider mt-1">Công ty</span>
            </div>
            <div class="flex flex-col items-center">
                <span class="text-3xl sm:text-4xl font-black text-slate-900">@Model.TotalCandidates.ToString("N0")</span>
                <span class="text-xs sm:text-sm font-bold text-blue-600 uppercase tracking-wider mt-1">Ứng viên</span>
            </div>
        </div>
    </div>
</section>

<!-- CATEGORIES BENTO GRID -->
<section class="max-w-[1600px] mx-auto px-4 sm:px-6 py-16">
    <div class="flex flex-col sm:flex-row sm:justify-between sm:items-end gap-3 mb-10">
        <div>
            <h2 class="text-2xl font-black text-slate-900 tracking-tight flex items-center gap-2">
                <span class="material-symbols-outlined text-blue-600">grid_view</span>
                Khám phá theo ngành nghề
            </h2>
            <p class="text-slate-600 text-sm mt-1">Tìm kiếm công việc mơ ước theo lĩnh vực bạn quan tâm</p>
        </div>
        <a asp-controller="Job" asp-action="Index" class="text-blue-600 text-sm font-bold hover:text-blue-700 flex items-center gap-1 group">
            Xem tất cả <span class="material-symbols-outlined text-base group-hover:translate-x-1 transition-transform">arrow_forward</span>
        </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4">
        <!-- IT -->
        <div class="sm:col-span-2 bg-gradient-to-br from-blue-50 to-indigo-50 backdrop-blur-sm rounded-2xl p-6 flex flex-col justify-between ambient-shadow hover:-translate-y-1 hover:border-blue-500/30 border border-slate-200 transition-all duration-300 min-h-[190px] group cursor-pointer">
            <div class="flex justify-between items-start">
                <div class="p-3 bg-blue-500/10 backdrop-blur-md rounded-xl border border-blue-500/20">
                    <span class="material-symbols-outlined text-blue-600 text-3xl">code</span>
                </div>
                <span class="bg-gradient-to-r from-blue-600 to-indigo-600 text-white text-[11px] font-bold px-3 py-1 rounded-full uppercase tracking-wider shadow-lg">Hot Job</span>
            </div>
            <div class="mt-6">
                <h3 class="text-xl font-bold group-hover:text-blue-600 transition-colors text-slate-900">💻 Công nghệ thông tin</h3>
                <p class="text-slate-600 text-xs mt-1">Phát triển phần mềm, AI, Cloud, và Cyber Security.</p>
            </div>
        </div>

        <!-- Design -->
        <div class="bg-white backdrop-blur-sm border border-slate-200 rounded-2xl p-6 ambient-shadow hover:-translate-y-1 transition-all duration-300 flex flex-col justify-between min-h-[190px] group cursor-pointer">
            <div>
                <div class="p-3 bg-purple-500/10 border border-purple-500/20 rounded-xl inline-block mb-4">
                    <span class="material-symbols-outlined text-purple-600 text-2xl">palette</span>
                </div>
                <h3 class="font-bold text-slate-900 mb-1 group-hover:text-blue-600 transition-colors">🎨 Thiết kế đồ họa</h3>
                <p class="text-slate-600 text-xs">UI/UX, Graphic Design, Product Illustration.</p>
            </div>
            <span class="text-blue-600 text-xs font-bold mt-2 group-hover:translate-x-1 transition-transform inline-block">Khám phá ngay →</span>
        </div>

        <!-- Marketing -->
        <div class="bg-white backdrop-blur-sm border border-slate-200 rounded-2xl p-6 ambient-shadow hover:-translate-y-1 transition-all duration-300 flex flex-col justify-between min-h-[190px] group cursor-pointer">
            <div>
                <div class="p-3 bg-emerald-500/10 border border-emerald-500/20 rounded-xl inline-block mb-4">
                    <span class="material-symbols-outlined text-emerald-600 text-2xl">campaign</span>
                </div>
                <h3 class="font-bold text-slate-900 mb-1 group-hover:text-blue-600 transition-colors">📢 Marketing</h3>
                <p class="text-slate-600 text-xs">SEO, Social Media, Content Creator.</p>
            </div>
            <span class="text-blue-600 text-xs font-bold mt-2 group-hover:translate-x-1 transition-transform inline-block">Khám phá ngay →</span>
        </div>

        <!-- Business -->
        <div class="sm:col-span-2 bg-gradient-to-br from-slate-50 to-indigo-50 backdrop-blur-sm border border-slate-200 rounded-2xl p-6 flex flex-col justify-between ambient-shadow hover:-translate-y-1 transition-all duration-300 min-h-[170px] group cursor-pointer">
            <div>
                <div class="p-3 bg-slate-50 rounded-xl inline-block mb-3 border border-slate-200 shadow-sm transition-transform group-hover:scale-110">
                    <span class="material-symbols-outlined text-blue-600 text-2xl">trending_up</span>
                </div>
                <h3 class="text-xl font-bold text-slate-900 group-hover:text-blue-600 transition-colors">📈 Kinh doanh &amp; Bán hàng</h3>
                <p class="text-slate-600 text-xs mt-1">Phát triển thị trường, B2B Account Executive, Sales Manager.</p>
            </div>
            <span class="text-indigo-600 text-xs font-bold mt-3 block">📈 Đang có nhiều lượt ứng tuyển</span>
        </div>

        <!-- Finance -->
        <div class="bg-white backdrop-blur-sm border border-slate-200 rounded-2xl p-6 ambient-shadow hover:-translate-y-1 transition-all duration-300 flex flex-col justify-between min-h-[170px] group cursor-pointer">
            <div>
                <div class="p-3 bg-amber-500/10 border border-amber-500/20 rounded-xl inline-block mb-4">
                    <span class="material-symbols-outlined text-amber-600 text-2xl">payments</span>
                </div>
                <h3 class="font-bold text-slate-900 mb-1 group-hover:text-blue-600 transition-colors">💰 Tài chính</h3>
                <p class="text-slate-600 text-xs">Kế toán, Kiểm toán, Ngân hàng, Đầu tư.</p>
            </div>
            <span class="text-blue-600 text-xs font-bold mt-2 group-hover:translate-x-1 transition-transform inline-block">Khám phá ngay →</span>
        </div>

        <!-- Education -->
        <div class="bg-white backdrop-blur-sm border border-slate-200 rounded-2xl p-6 ambient-shadow hover:-translate-y-1 transition-all duration-300 flex flex-col justify-between min-h-[170px] group cursor-pointer">
            <div>
                <div class="p-3 bg-rose-500/10 border border-rose-500/20 rounded-xl inline-block mb-4">
                    <span class="material-symbols-outlined text-rose-600 text-2xl">school</span>
                </div>
                <h3 class="font-bold text-slate-900 mb-1 group-hover:text-blue-600 transition-colors">📚 Giáo dục</h3>
                <p class="text-slate-600 text-xs">Giảng viên, Đào tạo, Tư vấn giáo dục.</p>
            </div>
            <span class="text-blue-600 text-xs font-bold mt-2 group-hover:translate-x-1 transition-transform inline-block">Khám phá ngay →</span>
        </div>
    </div>
</section>

<!-- FEATURED JOBS (TopCV style) -->
<section class="bg-slate-50 border-y border-slate-200 py-12">
    <div class="max-w-[1600px] mx-auto px-4 sm:px-6">

        <!-- Header row: title + xem tất cả + prev/next -->
        <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-3 mb-5">
            <h2 class="text-2xl font-black text-slate-900 tracking-tight flex items-center gap-2">
                <span class="material-symbols-outlined text-blue-600">work</span>
                Việc làm tốt nhất
                <span class="hidden sm:inline-flex items-center gap-1 bg-blue-50 border border-blue-200 text-blue-600 text-[10px] font-bold px-2 py-1 rounded-full ml-1">
                    <span class="material-symbols-outlined text-xs">bolt</span> Đề xuất bởi JobConnect AI
                </span>
            </h2>
            <div class="flex items-center gap-3 shrink-0">
                <a asp-controller="Job" asp-action="Index"
                   class="text-blue-600 text-sm font-bold hover:underline underline-offset-2">
                    Xem tất cả →
                </a>
                <div class="flex items-center gap-1.5">
                    <button type="button" id="featJobsPrev"
                            class="w-8 h-8 rounded-full border border-slate-300 text-slate-500 flex items-center justify-center hover:border-blue-500 hover:text-blue-600 transition-colors">
                        <span class="material-symbols-outlined text-base">chevron_left</span>
                    </button>
                    <button type="button" id="featJobsNext"
                            class="w-8 h-8 rounded-full border border-slate-300 text-slate-500 flex items-center justify-center hover:border-blue-500 hover:text-blue-600 transition-colors">
                        <span class="material-symbols-outlined text-base">chevron_right</span>
                    </button>
                </div>
            </div>
        </div>

        <!-- Filter row: quick pills -->
        <div class="flex flex-col sm:flex-row sm:items-center gap-3 mb-4">
            <div id="featJobsFilters" class="flex items-center gap-2 overflow-x-auto no-scrollbar">
                <button type="button" data-filter="all" class="feat-filter-btn shrink-0 px-4 py-2 rounded-full text-sm font-bold bg-blue-600 text-white border border-blue-600">
                    Ngẫu nhiên
                </button>
                <button type="button" data-filter="hanoi" class="feat-filter-btn shrink-0 px-4 py-2 rounded-full text-sm font-semibold bg-white text-slate-600 border border-slate-300 hover:border-blue-500 hover:text-blue-600 transition-colors">
                    Hà Nội
                </button>
                <button type="button" data-filter="hcm" class="feat-filter-btn shrink-0 px-4 py-2 rounded-full text-sm font-semibold bg-white text-slate-600 border border-slate-300 hover:border-blue-500 hover:text-blue-600 transition-colors">
                    Thành phố Hồ Chí Minh
                </button>
                <button type="button" data-filter="mienbac" class="feat-filter-btn shrink-0 px-4 py-2 rounded-full text-sm font-semibold bg-white text-slate-600 border border-slate-300 hover:border-blue-500 hover:text-blue-600 transition-colors">
                    Miền Bắc
                </button>
                <button type="button" data-filter="miennam" class="feat-filter-btn shrink-0 px-4 py-2 rounded-full text-sm font-semibold bg-white text-slate-600 border border-slate-300 hover:border-blue-500 hover:text-blue-600 transition-colors">
                    Miền Nam
                </button>
            </div>
        </div>

        <!-- Hint banner -->
        <div id="featJobsHint" class="flex items-center justify-between gap-3 bg-blue-50 border border-blue-200 text-blue-700 text-sm font-medium rounded-xl px-4 py-2.5 mb-5">
            <span class="flex items-center gap-2">
                <span class="material-symbols-outlined text-base">lightbulb</span>
                Gợi ý: Di chuột vào tiêu đề việc làm để xem thêm thông tin chi tiết
            </span>
            <button type="button" onclick="document.getElementById('featJobsHint').style.display='none'"
                    class="text-blue-500 hover:text-blue-700">
                <span class="material-symbols-outlined text-base">close</span>
            </button>
        </div>

        <!-- Job grid -->
        <div id="featJobsGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            @{
                int _idx = 0;
            }
            @foreach (var job in Model.FeaturedJobs)
            {
                _idx++;
                bool isNew = (DateTime.Now - job.CreatedAt).TotalHours < 24;
                bool isTop = _idx == 5;
                bool isUrgent = _idx == 6;

                string _region = "khac";
                var _loc = (job.Location ?? "").ToLower();
                if (_loc.Contains("hà nội") || _loc.Contains("ha noi")) { _region = "hanoi"; }
                else if (_loc.Contains("hồ chí minh") || _loc.Contains("ho chi minh") || _loc.Contains("hcm")) { _region = "hcm"; }
                bool _isMienBac = _loc.Contains("hà nội") || _loc.Contains("hải phòng") || _loc.Contains("bắc ninh") || _loc.Contains("quảng ninh") || _loc.Contains("thái nguyên");
                bool _isMienNam = _loc.Contains("hồ chí minh") || _loc.Contains("cần thơ") || _loc.Contains("bình dương") || _loc.Contains("đồng nai") || _loc.Contains("vũng tàu");

                bool _isSaved = Model.SavedJobIds.Contains(job.JobId);
                bool _hasApplied = Model.AppliedJobIds.Contains(job.JobId);

                <div class="feat-job-card bg-white rounded-xl p-4 border @(isTop ? "border-blue-500 ring-1 ring-blue-500/30" : "border-slate-200") hover:shadow-md hover:border-blue-400 transition-all group relative cursor-pointer"
                     data-region="@_region" data-mien-bac="@_isMienBac.ToString().ToLower()" data-mien-nam="@_isMienNam.ToString().ToLower()"
                     onclick="location.href='@Url.Action("Detail", "Job", new { id = job.JobId })'">

                    @if (isTop)
                    {
                        <span class="absolute -top-2.5 left-4 bg-blue-600 text-white text-[10px] font-bold px-2 py-0.5 rounded-full flex items-center gap-1">
                            <span class="material-symbols-outlined text-[11px]">favorite</span> TOP
                        </span>
                    }
                    @if (_hasApplied)
                    {
                        <span class="absolute -top-2.5 right-4 bg-emerald-600 text-white text-[10px] font-bold px-2 py-0.5 rounded-full flex items-center gap-1">
                            <span class="material-symbols-outlined text-[11px]">check_circle</span> Đã ứng tuyển
                        </span>
                    }

                    <div class="flex items-start gap-3">
                        <div class="w-11 h-11 rounded-lg bg-white border border-slate-200 flex items-center justify-center overflow-hidden shrink-0">
                            @if (job.Employer != null && !string.IsNullOrEmpty(job.Employer.LogoURL))
                            {
                                <img src="@job.Employer.LogoURL" alt="logo" class="w-full h-full object-contain" />
                            }
                            else
                            {
                                <span class="material-symbols-outlined text-slate-400 text-lg">business</span>
                            }
                        </div>

                        <div class="min-w-0 flex-1">
                            @if (isNew)
                            {
                                <span class="inline-flex items-center gap-1 bg-blue-50 text-blue-600 text-[10px] font-bold px-1.5 py-0.5 rounded mb-1">
                                    <span class="material-symbols-outlined text-[11px]">bolt</span> TIN MỚI
                                </span>
                            }
                            else if (isUrgent)
                            {
                                <span class="inline-flex items-center gap-1 bg-amber-50 text-amber-600 text-[10px] font-bold px-1.5 py-0.5 rounded mb-1">
                                    GẤP
                                </span>
                            }
                            <a asp-controller="Job" asp-action="Detail" asp-route-id="@job.JobId"
                               title="@job.Title" onclick="event.stopPropagation()"
                               class="font-bold text-slate-900 group-hover:text-blue-600 transition-colors block text-sm leading-snug line-clamp-2">
                                @job.Title
                            </a>
                            @if (job.Employer != null)
                            {
                                <a asp-controller="Company" asp-action="Detail" asp-route-id="@job.Employer.EmployerId"
                                   onclick="event.stopPropagation()"
                                   class="text-slate-500 text-xs mt-1 truncate block hover:text-blue-600 hover:underline">
                                    @(job.Employer.CompanyName ?? "Đang cập nhật")
                                </a>
                            }
                            else
                            {
                                <p class="text-slate-500 text-xs mt-1 truncate">Đang cập nhật</p>
                            }
                        </div>
                        <!-- [ĐÃ BỎ] Nút thả tim (lưu việc làm) từng nằm ở đây -->
                    </div>

                    <div class="flex flex-wrap gap-1.5 mt-3">
                        <span class="bg-slate-50 text-slate-600 px-2 py-1 rounded-md text-[11px] font-semibold border border-slate-200">
                            @job.FormatSalary()
                        </span>
                        @if (!string.IsNullOrEmpty(job.Location))
                        {
                            <span class="bg-slate-50 text-slate-600 px-2 py-1 rounded-md text-[11px] font-semibold border border-slate-200">
                                @job.Location
                            </span>
                        }
                    </div>
                </div>
            }
        </div>

        <!-- Pagination -->
        <div class="flex items-center justify-center gap-4 mt-8">
            <button type="button" id="featJobsPrevBottom" class="w-9 h-9 rounded-full border border-slate-300 text-slate-500 flex items-center justify-center hover:border-blue-500 hover:text-blue-600 transition-colors">
                <span class="material-symbols-outlined text-base">chevron_left</span>
            </button>
            <span id="featJobsPageLabel" class="text-sm font-semibold text-slate-600">1 / 1 trang</span>
            <button type="button" id="featJobsNextBottom" class="w-9 h-9 rounded-full border border-slate-300 text-slate-500 flex items-center justify-center hover:border-blue-500 hover:text-blue-600 transition-colors">
                <span class="material-symbols-outlined text-base">chevron_right</span>
            </button>
        </div>
    </div>
</section>

<!-- TOP COMPANIES -->
<section class="max-w-[1600px] mx-auto px-4 sm:px-6 py-16">
    <h2 class="text-2xl font-black text-center text-slate-900 tracking-tight mb-2 flex items-center justify-center gap-2">
        <span class="material-symbols-outlined text-blue-600">partnership</span>
        Đối tác Tuyển dụng Chiến lược
