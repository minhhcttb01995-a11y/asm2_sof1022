@model JobConnect.ViewModels.HomeViewModel
@{
    ViewData["Title"] = "Trang chủ";
}

<style>
    .ambient-shadow {
        box-shadow: 0px 2px 8px rgba(0,0,0,0.06);
    }

    .ambient-shadow-hover {
        transition: all 0.25s cubic-bezier(0.4,0,0.2,1);
    }

        .ambient-shadow-hover:hover {
            box-shadow: 0px 8px 24px rgba(0,61,155,0.13);
            transform: translateY(-2px);
        }

    .hero-bg {
        background: linear-gradient(135deg, #eef3ff 0%, #f0f3ff 60%, #dae2ff 100%);
    }

    .category-card {
        transition: all 0.25s cubic-bezier(0.4,0,0.2,1);
    }

        .category-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 24px rgba(0,61,155,0.12);
        }

    .job-card {
        transition: all 0.25s cubic-bezier(0.4,0,0.2,1);
    }

        .job-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0,61,155,0.10);
        }

    .blur-blob {
        filter: blur(80px);
        opacity: 0.25;
        pointer-events: none;
    }

    .cta-section {
        background: linear-gradient(135deg, #003d9b 0%, #0052cc 60%, #004b59 100%);
    }
</style>

<!-- HERO SECTION -->
<section class="hero-bg relative overflow-hidden py-16 md:py-24">
    <!-- Decorative blobs -->
    <div class="blur-blob absolute -top-24 -right-24 w-96 h-96 bg-blue-300 rounded-full"></div>
    <div class="blur-blob absolute -bottom-24 -left-24 w-80 h-80 bg-cyan-200 rounded-full"></div>

    <div class="max-w-6xl mx-auto px-6 relative z-10 flex flex-col items-center text-center">
        <div class="inline-flex items-center gap-2 bg-white/70 backdrop-blur-sm border border-outline-variant px-4 py-1.5 rounded-full text-xs font-semibold text-primary mb-5 shadow-sm">
            <span class="material-symbols-outlined text-sm">bolt</span>
            @Model.TotalJobs.ToString("N0")+ việc làm đang tuyển
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-on-surface mb-4 leading-tight tracking-tight">
            Kết nối sự nghiệp<br />
            <span class="text-primary">tương lai</span> của bạn
        </h1>
        <p class="text-secondary text-lg mb-8 max-w-xl">
            Hàng ngàn cơ hội việc làm hấp dẫn từ những công ty hàng đầu đang chờ đón bạn.
        </p>

        <!-- Search Bar -->
        <form asp-controller="Job" asp-action="Index" method="get"
              class="w-full max-w-3xl bg-white rounded-xl shadow-lg border border-outline-variant p-2 flex flex-col md:flex-row gap-2 items-stretch md:items-center">
            <div class="flex items-center gap-2 flex-1 px-3 border-b md:border-b-0 md:border-r border-outline-variant pb-2 md:pb-0">
                <span class="material-symbols-outlined text-secondary text-xl">search</span>
                <input name="Keyword" type="text" placeholder="Vị trí, kỹ năng hoặc công ty"
                       class="flex-1 border-none outline-none text-sm bg-transparent placeholder-secondary" />
            </div>
            <div class="flex items-center gap-2 flex-1 px-3">
                <span class="material-symbols-outlined text-secondary text-xl">location_on</span>
                <select name="Location" class="flex-1 border-none outline-none text-sm bg-transparent text-on-surface">
                    <option value="">Tất cả địa điểm</option>
                    <option>Hà Nội</option>
                    <option>TP. Hồ Chí Minh</option>
                    <option>Đà Nẵng</option>
                </select>
            </div>
            <button type="submit"
                    class="bg-primary text-white px-8 py-3 rounded-lg text-sm font-bold hover:opacity-90 transition-opacity whitespace-nowrap">
                Tìm kiếm
            </button>
        </form>

        <!-- Trending tags -->
        <div class="flex flex-wrap justify-center gap-2 mt-5 text-xs text-secondary">
            <span class="font-medium">Xu hướng:</span>
            @foreach (var tag in new[] { "Frontend Developer", "UI/UX Designer", "Data Analyst", "Marketing Manager" })
            {
                <a asp-controller="Job" asp-action="Index" asp-route-Keyword="@tag"
                   class="hover:text-primary underline transition-colors">@tag</a>
            }
        </div>

        <!-- Stats -->
        <div class="flex flex-wrap justify-center gap-8 mt-10 text-sm text-secondary">
            <div class="flex flex-col items-center">
                <span class="text-2xl font-bold text-on-surface">@Model.TotalJobs.ToString("N0")</span>
                <span>Việc làm</span>
            </div>
            <div class="w-px h-10 bg-outline-variant hidden sm:block self-center"></div>
            <div class="flex flex-col items-center">
                <span class="text-2xl font-bold text-on-surface">@Model.TotalCompanies.ToString("N0")</span>
                <span>Công ty</span>
            </div>
            <div class="w-px h-10 bg-outline-variant hidden sm:block self-center"></div>
            <div class="flex flex-col items-center">
                <span class="text-2xl font-bold text-on-surface">@Model.TotalCandidates.ToString("N0")</span>
                <span>Ứng viên</span>
            </div>
        </div>
    </div>
</section>

<!-- CATEGORIES BENTO GRID -->
<section class="max-w-6xl mx-auto px-6 py-14">
    <div class="flex justify-between items-end mb-8">
        <div>
            <h2 class="text-2xl font-bold text-on-surface">Khám phá theo ngành nghề</h2>
            <p class="text-secondary text-sm mt-1">Tìm kiếm công việc mơ ước theo lĩnh vực bạn quan tâm</p>
        </div>
        <a asp-controller="Job" asp-action="Index" class="text-primary text-sm font-bold hover:underline flex items-center gap-1">
            Xem tất cả <span class="material-symbols-outlined text-base">arrow_forward</span>
        </a>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <!-- IT - Large card -->
        <div class="col-span-2 bg-surface-container-high rounded-2xl p-6 flex flex-col justify-between category-card ambient-shadow cursor-pointer min-h-[180px]">
            <div class="flex justify-between items-start">
                <div class="p-3 bg-white rounded-xl shadow-sm">
                    <span class="material-symbols-outlined text-primary text-3xl">code</span>
                </div>
                <span class="bg-primary text-white text-xs font-bold px-3 py-1 rounded-full">1,200+ việc làm</span>
            </div>
            <div class="mt-6">
                <h3 class="text-xl font-bold text-on-surface">Công nghệ thông tin</h3>
                <p class="text-secondary text-sm mt-1">Phát triển phần mềm, AI, Cloud Computing, và Security.</p>
            </div>
        </div>

        <!-- Design -->
        <div class="bg-white rounded-2xl p-5 category-card ambient-shadow cursor-pointer">
            <div class="p-3 bg-surface-container rounded-xl inline-block mb-4">
                <span class="material-symbols-outlined text-tertiary text-2xl">palette</span>
            </div>
            <h3 class="font-bold text-on-surface mb-1">Thiết kế</h3>
            <p class="text-secondary text-xs mb-3">UI/UX, Graphic Design, Product Design.</p>
            <span class="text-primary text-xs font-bold">450+ cơ hội</span>
        </div>

        <!-- Marketing -->
        <div class="bg-white rounded-2xl p-5 category-card ambient-shadow cursor-pointer">
            <div class="p-3 bg-surface-container rounded-xl inline-block mb-4">
                <span class="material-symbols-outlined text-primary text-2xl">campaign</span>
            </div>
            <h3 class="font-bold text-on-surface mb-1">Marketing</h3>
            <p class="text-secondary text-xs mb-3">SEO, Social Media, Content Creator.</p>
            <span class="text-primary text-xs font-bold">680+ cơ hội</span>
        </div>

        <!-- Finance -->
        <div class="bg-white rounded-2xl p-5 category-card ambient-shadow cursor-pointer">
            <div class="p-3 bg-surface-container rounded-xl inline-block mb-4">
                <span class="material-symbols-outlined text-error text-2xl">payments</span>
            </div>
            <h3 class="font-bold text-on-surface mb-1">Tài chính</h3>
            <p class="text-secondary text-xs mb-3">Kế toán, Kiểm toán, Ngân hàng.</p>
            <span class="text-primary text-xs font-bold">320+ cơ hội</span>
        </div>

        <!-- Business - Large -->
        <div class="col-span-2 bg-surface-variant rounded-2xl p-6 flex flex-col justify-between category-card ambient-shadow cursor-pointer min-h-[160px]">
            <div>
                <div class="p-3 bg-white rounded-xl inline-block mb-3 shadow-sm">
                    <span class="material-symbols-outlined text-on-surface text-2xl">trending_up</span>
                </div>
                <h3 class="text-xl font-bold text-on-surface">Kinh doanh &amp; Bán hàng</h3>
                <p class="text-secondary text-sm mt-1">Phát triển thị trường, Account Executive, Sales Manager.</p>
            </div>
            <span class="text-primary text-xs font-bold mt-3 block">+25 công ty tuyển gấp hôm nay</span>
        </div>

        <!-- Education -->
        <div class="bg-white rounded-2xl p-5 category-card ambient-shadow cursor-pointer">
            <div class="p-3 bg-surface-container rounded-xl inline-block mb-4">
                <span class="material-symbols-outlined text-secondary text-2xl">school</span>
            </div>
            <h3 class="font-bold text-on-surface mb-1">Giáo dục</h3>
            <p class="text-secondary text-xs mb-3">Giảng viên, Đào tạo, Tư vấn giáo dục.</p>
            <span class="text-primary text-xs font-bold">150+ cơ hội</span>
        </div>
    </div>
</section>

<!-- FEATURED JOBS -->
<section class="bg-surface-container-lowest border-y border-outline-variant py-14">
    <div class="max-w-6xl mx-auto px-6">
        <div class="flex justify-between items-end mb-8">
            <div>
                <div class="inline-flex items-center gap-1.5 bg-error-container text-on-error-container px-3 py-1 rounded-full text-xs font-bold mb-2">
                    <span class="material-symbols-outlined text-sm">bolt</span>
                    TUYỂN DỤNG GẤP
                </div>
                <h2 class="text-2xl font-bold text-on-surface">Việc làm lương cao &amp; Đãi ngộ tốt</h2>
            </div>
            <a asp-controller="Job" asp-action="Index"
               class="bg-surface-container text-primary px-4 py-2 rounded-lg text-sm font-bold hover:bg-primary hover:text-white transition-all hidden md:block">
                Xem tất cả việc gấp
            </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            @foreach (var job in Model.FeaturedJobs)
            {
                <div class="bg-white border border-outline-variant rounded-2xl p-5 job-card ambient-shadow group">
                    <div class="flex justify-between items-start mb-4">
                        <div class="w-12 h-12 rounded-xl bg-surface-container flex items-center justify-center overflow-hidden border border-outline-variant">
                            @if (!string.IsNullOrEmpty(job.Employer.LogoURL))
                            {
                                <img src="@job.Employer.LogoURL" alt="logo" class="w-full h-full object-contain" />
                            }
                            else
                            {
                                <span class="material-symbols-outlined text-secondary text-xl">business</span>
                            }
                        </div>
                        <a asp-controller="Job" asp-action="Detail" asp-route-id="@job.JobID"
                           class="text-secondary hover:text-primary transition-colors">
                            <span class="material-symbols-outlined">bookmark</span>
                        </a>
                    </div>

                    <a asp-controller="Job" asp-action="Detail" asp-route-id="@job.JobID"
                       class="font-bold text-on-surface group-hover:text-primary transition-colors block mb-1 line-clamp-2">
                        @job.Title
                    </a>
                    <p class="text-secondary text-sm mb-3">@job.Employer.CompanyName</p>

                    <div class="flex flex-wrap gap-1.5 mb-4">
                        <span class="bg-surface-container-low text-on-surface-variant px-2.5 py-1 rounded text-xs font-semibold">@job.JobType</span>
                        @if (!string.IsNullOrEmpty(job.Location))
                        {
                            <span class="bg-surface-container-low text-on-surface-variant px-2.5 py-1 rounded text-xs font-semibold">@job.Location</span>
                        }
                        <span class="bg-surface-container-low text-primary px-2.5 py-1 rounded text-xs font-semibold">@job.SalaryDisplay</span>
                    </div>

                    <div class="flex justify-between items-center pt-3 border-t border-outline-variant">
                        <span class="text-xs text-secondary flex items-center gap-1">
                            <span class="material-symbols-outlined text-sm">schedule</span>
                            @((DateTime.Now - job.CreatedAt).TotalHours < 24
                                ? $"{(int)(DateTime.Now - job.CreatedAt).TotalHours} giờ trước"
                                : $"{(int)(DateTime.Now - job.CreatedAt).TotalDays} ngày trước")
                        </span>
                        <a asp-controller="Job" asp-action="Detail" asp-route-id="@job.JobID"
                           class="bg-primary-container text-primary px-3 py-1.5 rounded-lg text-xs font-bold hover:bg-primary hover:text-white transition-all">
                            Ứng tuyển ngay
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- TOP COMPANIES -->
<section class="max-w-6xl mx-auto px-6 py-14">
    <h2 class="text-2xl font-bold text-center text-on-surface mb-2">Đối tác Tuyển dụng Chiến lược</h2>
    <p class="text-center text-secondary text-sm mb-10">Những công ty hàng đầu đang tuyển dụng trên JobConnect</p>

    <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-8 gap-4">
        @foreach (var emp in Model.TopCompanies)
        {
            <a asp-controller="Company" asp-action="Detail" asp-route-id="@emp.EmployerID"
               class="bg-white rounded-2xl p-4 flex flex-col items-center text-center ambient-shadow category-card border border-outline-variant">
                @if (!string.IsNullOrEmpty(emp.LogoURL))
                {
                    <img src="@emp.LogoURL" alt="logo" class="w-12 h-12 object-contain mb-2" />
                }
                else
                {
                    <div class="w-12 h-12 bg-surface-container rounded-xl flex items-center justify-center mb-2">
                        <span class="material-symbols-outlined text-secondary">business</span>
                    </div>
                }
                <p class="text-xs font-semibold text-on-surface line-clamp-2">@emp.CompanyName</p>
                @if (emp.IsVerified)
                {
                    <span class="material-symbols-outlined text-primary text-sm mt-1">verified</span>
                }
            </a>
        }
    </div>
</section>

<!-- CTA SECTION -->
<section class="max-w-6xl mx-auto px-6 pb-14">
    <div class="cta-section rounded-3xl p-10 md:p-14 relative overflow-hidden flex flex-col md:flex-row items-center justify-between gap-8">
        <!-- Decorative circles -->
        <div class="absolute top-0 right-0 w-96 h-96 bg-white/5 rounded-full -translate-y-1/2 translate-x-1/2"></div>
        <div class="absolute bottom-0 left-1/3 w-64 h-64 bg-white/5 rounded-full translate-y-1/2"></div>

        <div class="relative z-10 text-white text-center md:text-left max-w-lg">
            <h2 class="text-3xl md:text-4xl font-bold mb-3 leading-tight">Sẵn sàng để bắt đầu chưa?</h2>
            <p class="text-blue-200 text-base mb-6">
                Tạo hồ sơ chuyên nghiệp của bạn ngay hôm nay và để các nhà tuyển dụng hàng đầu tìm thấy bạn.
            </p>
            <div class="flex flex-col sm:flex-row gap-3 justify-center md:justify-start">
                <a asp-controller="Candidate" asp-action="CvManager"
                   class="bg-white text-primary px-6 py-3 rounded-xl font-bold hover:opacity-90 transition-opacity text-sm">
                    Tạo CV miễn phí
                </a>
                <a asp-controller="Job" asp-action="Index"
                   class="bg-white/10 text-white border border-white/30 px-6 py-3 rounded-xl font-bold hover:bg-white/20 transition-all text-sm">
                    Tìm hiểu thêm
                </a>
            </div>
        </div>

        <div class="relative z-10 hidden lg:flex items-center gap-4">
            <div class="bg-white/10 backdrop-blur-sm border border-white/20 rounded-2xl p-5 text-white text-center w-36">
                <span class="material-symbols-outlined text-4xl text-blue-200 block mb-2">work</span>
                <div class="text-2xl font-bold">@Model.TotalJobs.ToString("N0")</div>
                <div class="text-blue-200 text-xs mt-1">Việc làm</div>
            </div>
            <div class="bg-white/10 backdrop-blur-sm border border-white/20 rounded-2xl p-5 text-white text-center w-36">
                <span class="material-symbols-outlined text-4xl text-blue-200 block mb-2">apartment</span>
                <div class="text-2xl font-bold">@Model.TotalCompanies.ToString("N0")</div>
                <div class="text-blue-200 text-xs mt-1">Công ty</div>
            </div>
            <div class="bg-white/10 backdrop-blur-sm border border-white/20 rounded-2xl p-5 text-white text-center w-36">
                <span class="material-symbols-outlined text-4xl text-blue-200 block mb-2">people</span>
                <div class="text-2xl font-bold">@Model.TotalCandidates.ToString("N0")</div>
                <div class="text-blue-200 text-xs mt-1">Ứng viên</div>
            </div>
        </div>
    </div>
</section>
