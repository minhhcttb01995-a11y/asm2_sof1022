@* [VIEW-HEADER-ADDED]
   Partial view dùng chung: hiển thị ảnh đại diện (avatar) của 1 User, tự động dùng
// ảnh mặc định (chữ cái đầu) nếu người dùng chưa upload avatar.
*@
@using JobConnect.Helpers
@model JobConnect.Helpers.AvatarViewModel
@{
    // Model.ImageUrl: đường dẫn avatar (có thể null/rỗng)
    // Model.Name: họ tên đầy đủ (dùng để lấy chữ cái đầu + màu)
    // Model.SizePx: kích thước avatar (mặc định 40)
    int size = Model.SizePx > 0 ? Model.SizePx : 40;
    int fontSize = (int)(size * 0.42);
}

@if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
{
    <img src="@Model.ImageUrl"
         alt="@Model.Name"
         style="width:@(size)px;height:@(size)px;border-radius:50%;object-fit:cover;flex-shrink:0" />
}
else
{
    var initial = AvatarHelper.GetInitial(Model.Name);
    var color = AvatarHelper.GetColor(Model.Name);

    <div title="@Model.Name"
         style="width:@(size)px;height:@(size)px;border-radius:50%;flex-shrink:0;
                display:flex;align-items:center;justify-content:center;
                background:@color;color:#fff;font-weight:600;
                font-size:@(fontSize)px;font-family:'Segoe UI',Arial,sans-serif;
                user-select:none">
        @initial
    </div>
}
