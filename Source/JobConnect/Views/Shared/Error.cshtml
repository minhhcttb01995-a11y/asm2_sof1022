@* [VIEW-HEADER-ADDED]
   Trang hiển thị khi có lỗi hệ thống (exception) không được xử lý — xem HomeController.Error
// và app.UseExceptionHandler trong Program.cs.
*@
@{
    ViewData["Title"] = "Lỗi";
    var statusCode = Context.Response.StatusCode;
}

<div class="min-h-screen flex items-center justify-center bg-background px-6">
    <div class="text-center max-w-md">
        <!-- Icon -->
        <div class="w-20 h-20 rounded-full bg-red-50 flex items-center justify-center mx-auto mb-6">
            <span class="material-symbols-outlined text-error text-4xl">
                @(statusCode == 404 ? "search_off" : statusCode == 403 ? "lock" : "error")
            </span>
        </div>

        <!-- Error code -->
        <p class="text-6xl font-bold text-outline-variant mb-2">@statusCode</p>

        <!-- Message -->
        <h1 class="text-2xl font-bold text-on-surface mb-3">
            @(statusCode switch
            {
                404 => "Trang không tồn tại",
                403 => "Bạn không có quyền truy cập",
                500 => "Lỗi máy chủ",
                _ => "Đã xảy ra lỗi"
            })
        </h1>

        <p class="text-secondary text-sm mb-8">
            @(statusCode switch
            {
                404 => "Trang bạn đang tìm không tồn tại hoặc đã bị xóa.",
                403 => "Bạn không có quyền truy cập vào trang này. Vui lòng đăng nhập với tài khoản phù hợp.",
                500 => "Máy chủ gặp sự cố. Vui lòng thử lại sau.",
                _ => "Đã xảy ra lỗi không mong muốn. Vui lòng thử lại."
            })
        </p>

        <!-- Actions -->
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a asp-controller="Home" asp-action="Index"
               class="px-6 py-3 bg-primary text-slate-900 font-semibold rounded-xl hover:opacity-90 transition-opacity text-sm">
                Về trang chủ
            </a>
            <button onclick="history.back()"
                    class="px-6 py-3 border border-outline-variant text-secondary rounded-xl hover:bg-surface-container transition-colors text-sm">
                Quay lại trang trước
            </button>
        </div>

        @if (statusCode == 403)
        {
            <div class="mt-6">
                <a asp-controller="Account" asp-action="Login"
                   class="text-primary text-sm hover:underline">
                    Đăng nhập để tiếp tục →
                </a>
            </div>
        }
    </div>
</div>