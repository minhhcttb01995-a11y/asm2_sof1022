@using System.Security.Claims
@{
    var adminName = User.FindFirst(ClaimTypes.Name)?.Value ?? "Admin";
    var currentPath = Context.Request.Path.Value ?? "";
    bool IsActive(string path) => currentPath.StartsWith(path, StringComparison.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – Admin | JobConnect</title>
    <partial name="_HeadAssets" />
    <style>
            /* ── Reset ── */
            *, *::before, *::after {
                box-sizing: border-box;
            }

            body {
                margin: 0;
                font-family: 'Inter','Segoe UI',sans-serif;
                background: #f1f5f9;
                color: #1e293b;
            }

            /* ── Shell ── */
            .jc-dashboard {
                display: flex;
                min-height: 100vh;
            }

            /* ── Sidebar ── */
            .jc-sidebar {
                width: 240px;
                background: #0f172a;
                border-right: 1px solid #1e293b;
                display: flex;
                flex-direction: column;
                position: fixed;
                top: 0;
                left: 0;
                height: 100vh;
                z-index: 100;
                overflow-y: auto;
            }

                .jc-sidebar::-webkit-scrollbar {
                    width: 4px;
                }

                .jc-sidebar::-webkit-scrollbar-thumb {
                    background: #334155;
                    border-radius: 4px;
                }

            /* Brand */
            .jc-sidebar-brand {
                padding: 20px 16px 16px;
                border-bottom: 1px solid #1e293b;
                flex-shrink: 0;
            }

            /* Nav */
            .jc-sidebar-nav {
                flex: 1;
                padding: 12px 10px;
            }

                .jc-sidebar-nav ul {
                    list-style: none;
                    margin: 0;
                    padding: 0;
                    display: flex;
                    flex-direction: column;
                    gap: 2px;
                }

            .jc-sidebar-link {
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 9px 12px;
                border-radius: 10px;
                text-decoration: none;
                color: #94a3b8;
                font-size: 0.855rem;
                font-weight: 500;
                transition: background .15s, color .15s, border-color .15s;
                border-left: 3px solid transparent;
                cursor: pointer;
                /* reset button */
                width: 100%;
                background: none;
                border-top: none;
                border-right: none;
                border-bottom: none;
                text-align: left;
                font-family: inherit;
            }

                .jc-sidebar-link:hover {
                    background: rgba(255,255,255,.06);
                    color: #f1f5f9;
                    text-decoration: none;
                }

                .jc-sidebar-link.active {
                    background: rgba(59,130,246,.15);
                    color: #60a5fa;
                    border-left-color: #3b82f6;
                }

                .jc-sidebar-link .material-symbols-outlined {
                    font-size: 1.15rem;
                    flex-shrink: 0;
                }

            /* Footer */
            .jc-sidebar-footer {
                padding: 12px 10px;
                border-top: 1px solid #1e293b;
                display: flex;
                flex-direction: column;
                gap: 2px;
                flex-shrink: 0;
            }

            /* ── Main ── */
            .jc-dashboard-main {
                margin-left: 240px;
                flex: 1;
                display: flex;
                flex-direction: column;
                min-height: 100vh;
                min-width: 0;
            }

            /* ── Header ── */
            .jc-dashboard-header {
                height: 64px;
                background: #0f172a;
                border-bottom: 1px solid #1e293b;
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 0 24px;
                position: sticky;
                top: 0;
                z-index: 50;
            }

            /* ── Body padding ── */
            .jc-dashboard-main > div {
                padding: 24px;
            }

            .jc-dashboard-main > .jc-dashboard-header {
                padding: 0 24px;
            }

            /* ── Icon button ── */
            .jc-btn-icon {
                width: 36px;
                height: 36px;
                border-radius: 8px;
                border: 1px solid #334155;
                background: #1e293b;
                color: #94a3b8;
                display: flex;
                align-items: center;
                justify-content: center;
                cursor: pointer;
            }

                .jc-btn-icon:hover {
                    background: #273449;
                    color: #fff;
                }

            /* ── Token helpers (used in Dashboard.cshtml) ── */
            .text-on-surface {
                color: #1e293b !important;
            }

            .text-secondary {
                color: #64748b !important;
            }

            .text-primary {
                color: #3b82f6 !important;
            }

            .bg-surface-container {
                background: #f8fafc;
            }

            .bg-surface-container-low {
                background: #f8fafc;
            }

            .border-outline-variant {
                border-color: #e2e8f0 !important;
            }

            .divide-outline-variant > * + * {
                border-color: #e2e8f0;
            }

            /* ── Mobile ── */
            @@media (max-width: 1023px) {
                .jc-sidebar {
                    transform: translateX(-100%);
                    transition: transform .25s ease;
                }

                    .jc-sidebar.open {
                        transform: translateX(0);
                    }

                .jc-dashboard-main {
                    margin-left: 0;
                }
            }
    </style>
    @await RenderSectionAsync("Styles", required: false)
    <partial name="_ResponsiveAndSkeleton" />
</head>
<body class="antialiased">
    <div class="jc-dashboard">
        <aside class="jc-sidebar" id="adminSidebar">
            <div class="jc-sidebar-brand">
                <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-blue-400 text-3xl">admin_panel_settings</span>
                    <div>
                        <h1 class="text-lg font-bold text-white">JobConnect</h1>
                        <p class="text-xs text-slate-500">Admin Panel</p>
                    </div>
                </div>
            </div>

            <nav class="jc-sidebar-nav">
                <ul>
                    @{
                        var navItems = new[] {
                            (Icon:"dashboard",  Label:"Dashboard",      Path:"/Admin/Dashboard"),
                            (Icon:"group",      Label:"Người dùng",     Path:"/Admin/Users"),
                            (Icon:"badge",      Label:"Nhân viên",      Path:"/Staff"),
                            (Icon:"work",       Label:"Tin tuyển dụng", Path:"/Admin/Jobs"),
                            (Icon:"apartment",  Label:"Công ty",        Path:"/Admin/Companies"),
                            (Icon:"local_fire_department", Label:"Tin/Cty Hot", Path:"/Admin/Hot"),
                            (Icon:"psychology", Label:"Kỹ năng",        Path:"/Admin/Skills"),
                            (Icon:"tune",       Label:"Trạng thái",     Path:"/StatusCatalog"),
                            (Icon:"folder",     Label:"Danh mục",       Path:"/Admin/Categories"),
                            (Icon:"article",    Label:"Blog",           Path:"/Admin/Blog"),
                            (Icon:"bar_chart",  Label:"Báo cáo",        Path:"/Admin/Reports"),
                            (Icon:"chat",       Label:"Tin nhắn",       Path:"/Chat"),
                        };
                    }
                    @foreach (var item in navItems)
                    {
                        <li>
                            <a href="@item.Path"
                               class="jc-sidebar-link @(IsActive(item.Path) ? "active" : "")">
                                <span class="material-symbols-outlined">@item.Icon</span>
                                <span>@item.Label</span>
                            </a>
                        </li>
                    }
                </ul>
            </nav>

            <div class="jc-sidebar-footer">
                <a asp-controller="Home" asp-action="Index" target="_blank" class="jc-sidebar-link">
                    <span class="material-symbols-outlined">open_in_new</span>
                    <span>Xem site</span>
                </a>
                <a asp-controller="Account" asp-action="Settings" class="jc-sidebar-link">
                    <span class="material-symbols-outlined">settings</span>
                    <span>Cài đặt</span>
                </a>
                <form asp-controller="Account" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="jc-sidebar-link" style="color:#f87171;">
                        <span class="material-symbols-outlined">logout</span>
                        <span>Đăng xuất (@adminName)</span>
                    </button>
                </form>
            </div>
        </aside>

        <main class="jc-dashboard-main">
            <header class="jc-dashboard-header">
                <div class="flex items-center gap-4 min-w-0">
                    <button id="sidebarToggle" class="jc-btn-icon lg:hidden" aria-label="Menu">
                        <span class="material-symbols-outlined">menu</span>
                    </button>
                    <div>
                        <h2 class="text-xl font-bold text-white truncate">@ViewData["Title"]</h2>
                        <p class="text-slate-400 text-sm">@DateTime.Now.ToString("dddd, dd/MM/yyyy", new System.Globalization.CultureInfo("vi-VN"))</p>
                    </div>
                </div>
            </header>

            @{
                ViewData["FlashInline"] = true;
            }
            <partial name="_FlashMessages" />

            @RenderBody()
        </main>
    </div>

    <script src="~/js/site.js"></script>
    <script>
        document.getElementById('sidebarToggle')?.addEventListener('click', () => {
        document.getElementById('adminSidebar')?.classList.toggle('open');
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
