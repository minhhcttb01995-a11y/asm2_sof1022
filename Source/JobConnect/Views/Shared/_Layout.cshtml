@using System.Security.Claims
@{
    var path = Context.Request.Path.Value ?? "";
    var userName = User.FindFirst(ClaimTypes.Name)?.Value ?? "";
    var userRole = User.FindFirst(ClaimTypes.Role)?.Value ?? "";
    var userId = User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "";
    var avatarUrl = User.FindFirst("AvatarURL")?.Value ?? "";
    bool NavActive(string seg) =>
        path.StartsWith(seg, StringComparison.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="@(ViewData["Description"] ?? "JobConnect – Nền tảng tuyển dụng hàng đầu Việt Nam")" />
    <title>@ViewData["Title"] – JobConnect</title>

    <partial name="_HeadAssets" />

    @await RenderSectionAsync("Styles", required: false)
</head>

<body class="bg-black text-on-surface antialiased">

    <!-- ════════════════════════════════════════════════
     NAVBAR
     ════════════════════════════════════════════════ -->
    <header class="sticky top-0 z-50 bg-black/80 backdrop-blur-md border-b border-slate-800 shadow-sm shadow-black/50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 flex items-center h-16 gap-4">

            <!-- Logo -->
            <a asp-controller="Home" asp-action="Index"
               class="flex items-center gap-2 font-extrabold text-blue-400 text-xl shrink-0">
                <span class="material-symbols-outlined text-2xl">work</span>
                JobConnect
            </a>

            <!-- Desktop nav links -->
            <nav class="hidden md:flex items-center gap-1 ml-4">
                <a asp-controller="Job" asp-action="Index"
                   class="px-3 py-2 rounded-lg text-sm font-medium transition-colors
                    @(NavActive("/Job") ? "text-blue-400 bg-blue-500/10" : "text-slate-400 hover:text-white hover:bg-slate-800")">
                    Tìm việc làm
                </a>
                <a asp-controller="Company" asp-action="Index"
                   class="px-3 py-2 rounded-lg text-sm font-medium transition-colors
                    @(NavActive("/Company") ? "text-blue-400 bg-blue-500/10" : "text-slate-400 hover:text-white hover:bg-slate-800")">
                    Công ty
                </a>
                <a asp-controller="Blog" asp-action="Index"
                   class="px-3 py-2 rounded-lg text-sm font-medium transition-colors
                    @(NavActive("/Blog") ? "text-blue-400 bg-blue-500/10" : "text-slate-400 hover:text-white hover:bg-slate-800")">
                    Blog
                </a>
                @if (User.IsInRole("Candidate"))
                {
                    <a asp-controller="Candidate" asp-action="Applications"
                       class="px-3 py-2 rounded-lg text-sm font-medium transition-colors
                        @(NavActive("/Candidate") ? "text-blue-400 bg-blue-500/10" : "text-slate-400 hover:text-white hover:bg-slate-800")">
                        Hồ sơ & CV
                    </a>
                }
                @if (User.IsInRole("Employer"))
                {
                    <a asp-controller="Employer" asp-action="Dashboard"
                       class="px-3 py-2 rounded-lg text-sm font-medium transition-colors
                        @(NavActive("/Employer") ? "text-blue-400 bg-blue-500/10" : "text-slate-400 hover:text-white hover:bg-slate-800")">
                        Quản lý tuyển dụng
                    </a>
                }
                @if (User.IsInRole("Admin"))
                {
                    <a asp-controller="Admin" asp-action="Dashboard"
                       class="px-3 py-2 rounded-lg text-sm font-medium transition-colors
                        @(NavActive("/Admin") ? "text-blue-400 bg-blue-500/10" : "text-slate-400 hover:text-white hover:bg-slate-800")">
                        Admin
                    </a>
                }
            </nav>

            <div class="flex-1"></div>

            <!-- Auth area -->
            @if (User.Identity?.IsAuthenticated == true)
            {
                <!-- Đã đăng nhập: avatar dropdown -->
                <div class="relative hidden md:block">
                    <button id="userMenuBtn"
                            class="flex items-center gap-2 pl-2 pr-3 py-1.5 rounded-xl hover:bg-slate-800 transition-colors">
                        @if (!string.IsNullOrEmpty(avatarUrl))
                        {
                            <img src="@avatarUrl" class="w-8 h-8 rounded-full object-cover border border-slate-700" />
                        }
                        else
                        {
                            <div class="w-8 h-8 rounded-full bg-blue-600 text-white flex items-center justify-center text-sm font-bold">
                                @(userName.Length > 0 ? userName[0].ToString().ToUpper() : "U")
                            </div>
                        }
                        <span class="text-sm font-medium text-slate-200 max-w-[120px] truncate">@userName</span>
                        <span class="material-symbols-outlined text-sm text-slate-500">expand_more</span>
                    </button>

                    <!-- Dropdown -->
                    <div id="userMenuDropdown"
                         class="hidden absolute right-0 top-full mt-2 w-56 bg-slate-900 rounded-2xl shadow-xl shadow-black/60 border border-slate-700 py-1.5 z-50">
                        <!-- Role badge -->
                        <div class="px-4 py-2 border-b border-slate-700">
                            <p class="text-xs font-semibold text-slate-200 truncate">@userName</p>
                            <p class="text-xs text-slate-500">
                                @(userRole switch { "Admin" => "Quản trị viên", "Employer" => "Nhà tuyển dụng", _ => "Ứng viên" })
                            </p>
                        </div>
                        @if (userRole == "Admin")
                        {
                            <a asp-controller="Admin" asp-action="Dashboard"
                               class="flex items-center gap-2.5 px-4 py-2.5 text-sm hover:bg-slate-800 transition-colors text-slate-300">
                                <span class="material-symbols-outlined text-[1.1rem] text-slate-500">admin_panel_settings</span>
                                Admin Panel
                            </a>
                        }
                        @if (userRole == "Employer")
                        {
                            <a asp-controller="Employer" asp-action="Dashboard"
                               class="flex items-center gap-2.5 px-4 py-2.5 text-sm hover:bg-slate-800 transition-colors text-slate-300">
                                <span class="material-symbols-outlined text-[1.1rem] text-slate-500">dashboard</span>
                                Dashboard NTD
                            </a>
                            <a asp-controller="Employer" asp-action="PostJob"
                               class="flex items-center gap-2.5 px-4 py-2.5 text-sm hover:bg-slate-800 transition-colors text-slate-300">
                                <span class="material-symbols-outlined text-[1.1rem] text-slate-500">add_circle</span>
                                Đăng tin mới
                            </a>
                        }
                        @if (userRole == "Candidate")
                        {
                            <a asp-controller="Candidate" asp-action="Profile"
                               class="flex items-center gap-2.5 px-4 py-2.5 text-sm hover:bg-slate-800 transition-colors text-slate-300">
                                <span class="material-symbols-outlined text-[1.1rem] text-slate-500">person</span>
                                Hồ sơ của tôi
                            </a>
                            <a asp-controller="Candidate" asp-action="Skills"
                               class="flex items-center gap-2.5 px-4 py-2.5 text-sm hover:bg-slate-800 transition-colors text-slate-300">
                                <span class="material-symbols-outlined text-[1.1rem] text-slate-500">psychology</span>
                                Kỹ năng
                            </a>
                            <a asp-controller="Candidate" asp-action="Applications"
                               class="flex items-center gap-2.5 px-4 py-2.5 text-sm hover:bg-slate-800 transition-colors text-slate-300">
                                <span class="material-symbols-outlined text-[1.1rem] text-slate-500">send</span>
                                Đơn ứng tuyển
                            </a>
                            <a asp-controller="Candidate" asp-action="SavedJobs"
                               class="flex items-center gap-2.5 px-4 py-2.5 text-sm hover:bg-slate-800 transition-colors text-slate-300">
                                <span class="material-symbols-outlined text-[1.1rem] text-slate-500">bookmark</span>
                                Việc đã lưu
                            </a>
                            <a asp-controller="Candidate" asp-action="Notifications"
                               class="flex items-center gap-2.5 px-4 py-2.5 text-sm hover:bg-slate-800 transition-colors text-slate-300">
                                <span class="material-symbols-outlined text-[1.1rem] text-slate-500">notifications</span>
                                Thông báo
                            </a>
                            <a asp-controller="Chat" asp-action="Index"
                               class="flex items-center gap-2.5 px-4 py-2.5 text-sm hover:bg-slate-800 transition-colors text-slate-300">
                                <span class="material-symbols-outlined text-[1.1rem] text-slate-500">chat</span>
                                Tin nhắn hỗ trợ
                            </a>
                        }
                        <a asp-controller="Account" asp-action="Settings"
                           class="flex items-center gap-2.5 px-4 py-2.5 text-sm hover:bg-slate-800 transition-colors text-slate-300">
                            <span class="material-symbols-outlined text-[1.1rem] text-slate-500">settings</span>
                            Cài đặt tài khoản
                        </a>
                        <div class="border-t border-slate-700 mt-1 pt-1">
                            <form asp-controller="Account" asp-action="Logout" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit"
                                        class="w-full flex items-center gap-2.5 px-4 py-2.5 text-sm text-red-400 hover:bg-red-500/10 transition-colors">
                                    <span class="material-symbols-outlined text-[1.1rem]">logout</span>
                                    Đăng xuất
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <!-- Chưa đăng nhập -->
                <div class="hidden md:flex items-center gap-2">
                    <a asp-controller="Account" asp-action="Login"
                       class="px-4 py-2 text-sm font-semibold text-blue-400 hover:bg-blue-500/10 rounded-xl transition-colors">
                        Đăng nhập
                    </a>
                    <a asp-controller="Account" asp-action="Register"
                       class="px-4 py-2 bg-gradient-to-r from-blue-600 to-indigo-600 text-white rounded-xl text-sm font-semibold hover:from-blue-700 hover:to-indigo-700 transition-all">
                        Đăng ký
                    </a>
                    <a asp-controller="Account" asp-action="RegisterEmployer"
                       class="px-4 py-2 border border-blue-500 text-blue-400 rounded-xl text-sm font-semibold hover:bg-blue-500/10 transition-colors">
                        Đăng tin tuyển dụng
                    </a>
                </div>
            }

            <!-- Mobile hamburger -->
            <button id="mobileMenuBtn"
                    aria-expanded="false"
                    class="md:hidden p-2 rounded-xl hover:bg-slate-800 transition-colors text-slate-300">
                <span class="material-symbols-outlined text-slate-400">menu</span>
            </button>
        </div>

        <!-- Mobile menu -->
        <div id="mobileMenu"
             class="hidden md:hidden border-t border-slate-800 bg-black/90 backdrop-blur-md px-4 py-3 space-y-1">
            <a asp-controller="Job" asp-action="Index"
               class="flex items-center gap-2 px-3 py-2.5 rounded-xl text-sm font-medium text-slate-400 hover:bg-slate-800 hover:text-white">
                <span class="material-symbols-outlined text-sm">search</span> Tìm việc làm
            </a>
            <a asp-controller="Company" asp-action="Index"
               class="flex items-center gap-2 px-3 py-2.5 rounded-xl text-sm font-medium text-slate-400 hover:bg-slate-800 hover:text-white">
                <span class="material-symbols-outlined text-sm">apartment</span> Công ty
            </a>
            <a asp-controller="Blog" asp-action="Index"
               class="flex items-center gap-2 px-3 py-2.5 rounded-xl text-sm font-medium text-slate-400 hover:bg-slate-800 hover:text-white">
                <span class="material-symbols-outlined text-sm">article</span> Blog
            </a>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <hr class="border-slate-800 my-2" />
                @if (userRole == "Candidate")
                {
                    <a asp-controller="Candidate" asp-action="Profile"
                       class="flex items-center gap-2 px-3 py-2.5 rounded-xl text-sm font-medium text-slate-400 hover:bg-slate-800">
                        <span class="material-symbols-outlined text-sm">person</span> Hồ sơ của tôi
                    </a>
                    <a asp-controller="Candidate" asp-action="Applications"
                       class="flex items-center gap-2 px-3 py-2.5 rounded-xl text-sm font-medium text-slate-400 hover:bg-slate-800">
                        <span class="material-symbols-outlined text-sm">send</span> Đơn ứng tuyển
                    </a>
                    <a asp-controller="Candidate" asp-action="Notifications"
                       class="flex items-center gap-2 px-3 py-2.5 rounded-xl text-sm font-medium text-slate-400 hover:bg-slate-800">
                        <span class="material-symbols-outlined text-sm">notifications</span> Thông báo
                    </a>
                    <a asp-controller="Chat" asp-action="Index"
                       class="flex items-center gap-2 px-3 py-2.5 rounded-xl text-sm font-medium text-slate-400 hover:bg-slate-800">
                        <span class="material-symbols-outlined text-sm">chat</span> Tin nhắn hỗ trợ
                    </a>
                }
                @if (userRole == "Employer")
                {
                    <a asp-controller="Employer" asp-action="Dashboard"
                       class="flex items-center gap-2 px-3 py-2.5 rounded-xl text-sm font-medium text-slate-400 hover:bg-slate-800">
                        <span class="material-symbols-outlined text-sm">dashboard</span> Dashboard NTD
                    </a>
                }
                @if (userRole == "Admin")
                {
                    <a asp-controller="Admin" asp-action="Dashboard"
                       class="flex items-center gap-2 px-3 py-2.5 rounded-xl text-sm font-medium text-slate-400 hover:bg-slate-800">
                        <span class="material-symbols-outlined text-sm">admin_panel_settings</span> Admin Panel
                    </a>
                }
                <a asp-controller="Account" asp-action="Settings"
                   class="flex items-center gap-2 px-3 py-2.5 rounded-xl text-sm font-medium text-slate-400 hover:bg-slate-800">
                    <span class="material-symbols-outlined text-sm">settings</span> Cài đặt
                </a>
                <form asp-controller="Account" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit"
                            class="w-full flex items-center gap-2 px-3 py-2.5 rounded-xl text-sm font-medium text-red-400 hover:bg-red-500/10">
                        <span class="material-symbols-outlined text-sm">logout</span> Đăng xuất
                    </button>
                </form>
            }
            else
            {
                <hr class="border-slate-800 my-2" />
                <a asp-controller="Account" asp-action="Login"
                   class="flex items-center gap-2 px-3 py-2.5 rounded-xl text-sm font-semibold text-blue-400 hover:bg-blue-500/10">
                    <span class="material-symbols-outlined text-sm">login</span> Đăng nhập
                </a>
                <a asp-controller="Account" asp-action="Register"
                   class="flex items-center gap-2 px-3 py-2.5 rounded-xl text-sm font-semibold bg-gradient-to-r from-blue-600 to-indigo-600 text-white hover:from-blue-700 hover:to-indigo-700">
                    <span class="material-symbols-outlined text-sm">person_add</span> Đăng ký ứng viên
                </a>
                <a asp-controller="Account" asp-action="RegisterEmployer"
                   class="flex items-center gap-2 px-3 py-2.5 rounded-xl text-sm font-semibold border border-blue-500 text-blue-400 hover:bg-blue-500/10">
                    <span class="material-symbols-outlined text-sm">business</span> Đăng ký NTD
                </a>
            }
        </div>
    </header>

    <!-- ════════════════════════════════════════════════
     FLASH MESSAGES (tự ẩn sau 4s qua site.js)
     ════════════════════════════════════════════════ -->
    <partial name="_FlashMessages" />

    <!-- ════════════════════════════════════════════════
     MAIN CONTENT
     ════════════════════════════════════════════════ -->
    <main>@RenderBody()</main>

    <!-- ════════════════════════════════════════════════
     FOOTER
     ════════════════════════════════════════════════ -->
    <footer class="bg-slate-950 text-white mt-20 border-t border-slate-800">
        <div class="max-w-7xl mx-auto px-6 py-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">

            <!-- Brand -->
            <div class="lg:col-span-1">
                <div class="flex items-center gap-2 font-extrabold text-xl mb-3">
                    <span class="material-symbols-outlined">work</span> JobConnect
                </div>
                <p class="text-sm text-slate-400 leading-relaxed">
                    Nền tảng kết nối việc làm hàng đầu Việt Nam.<br />
                    Hàng nghìn cơ hội nghề nghiệp mỗi ngày.
                </p>
                <div class="flex gap-3 mt-4">
                    <a href="#" class="w-8 h-8 rounded-lg bg-white/10 hover:bg-white/20 flex items-center justify-center transition-colors" title="Facebook">
                        <span class="text-xs font-bold">f</span>
                    </a>
                    <a href="#" class="w-8 h-8 rounded-lg bg-white/10 hover:bg-white/20 flex items-center justify-center transition-colors" title="LinkedIn">
                        <span class="text-xs font-bold">in</span>
                    </a>
                </div>
            </div>

            <!-- Ứng viên -->
            <div>
                <h4 class="font-semibold text-white mb-4 text-sm uppercase tracking-wide">Ứng viên</h4>
                <ul class="space-y-2.5 text-sm text-slate-400">
                    <li><a asp-controller="Job" asp-action="Index" class="hover:text-white transition-colors">Tìm việc làm</a></li>
                    <li><a asp-controller="Candidate" asp-action="Profile" class="hover:text-white transition-colors">Hồ sơ & CV</a></li>
                    <li><a asp-controller="Candidate" asp-action="Applications" class="hover:text-white transition-colors">Đơn ứng tuyển</a></li>
                    <li><a asp-controller="Candidate" asp-action="SavedJobs" class="hover:text-white transition-colors">Việc đã lưu</a></li>
                </ul>
            </div>

            <!-- Nhà tuyển dụng -->
            <div>
                <h4 class="font-semibold text-white mb-4 text-sm uppercase tracking-wide">Nhà tuyển dụng</h4>
                <ul class="space-y-2.5 text-sm text-slate-400">
                    <li><a asp-controller="Employer" asp-action="PostJob" class="hover:text-white transition-colors">Đăng tin tuyển dụng</a></li>
                    <li><a asp-controller="Employer" asp-action="Dashboard" class="hover:text-white transition-colors">Quản lý tin đăng</a></li>
                    <li><a asp-controller="Employer" asp-action="ManageApplications" class="hover:text-white transition-colors">Xem đơn ứng tuyển</a></li>
                    <li><a asp-controller="Account" asp-action="RegisterEmployer" class="hover:text-white transition-colors">Đăng ký tài khoản NTD</a></li>
                </ul>
            </div>

            <!-- Về JobConnect -->
            <div>
                <h4 class="font-semibold text-white mb-4 text-sm uppercase tracking-wide">Về JobConnect</h4>
                <ul class="space-y-2.5 text-sm text-slate-400">
                    <li><a asp-controller="Blog" asp-action="Index" class="hover:text-white transition-colors">Blog nghề nghiệp</a></li>
                    <li><a asp-controller="Company" asp-action="Index" class="hover:text-white transition-colors">Danh sách công ty</a></li>
                    <li><a href="mailto:contact@jobconnect.vn" class="hover:text-white transition-colors">Liên hệ hỗ trợ</a></li>
                </ul>
            </div>
        </div>

        <!-- Bottom bar -->
        <div class="border-t border-white/10">
            <div class="max-w-7xl mx-auto px-6 py-4 flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-slate-500">
                <span>© 2025 JobConnect – Nhóm Star Arrow. All rights reserved.</span>
                <div class="flex gap-4">
                    <a href="#" class="hover:text-slate-300 transition-colors">Điều khoản sử dụng</a>
                    <a href="#" class="hover:text-slate-300 transition-colors">Chính sách bảo mật</a>
                </div>
            </div>
        </div>
    </footer>

    <!-- Back to top -->
    <button id="backToTop"
            class="fixed bottom-6 right-6 w-11 h-11 bg-blue-600 text-white rounded-full shadow-lg
        flex items-center justify-center opacity-0 pointer-events-none
        transition-all duration-300 hover:opacity-90 z-40">
        <span class="material-symbols-outlined text-sm">arrow_upward</span>
    </button>

    <!-- JavaScript -->
    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>