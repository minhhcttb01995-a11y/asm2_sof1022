@model List<JobConnect.Models.Employer>
@{
    ViewData["Title"] = "Quản lý Nhà tuyển dụng";
    Layout = "_StaffLayout";
}

<!-- Search & Filter -->
<form method="get" class="glass-card rounded-xl p-4 mb-6 flex gap-4">
    <input name="keyword" value="@ViewBag.Keyword" type="text" placeholder="Tìm theo tên công ty, email..."
           class="flex-1 px-4 py-2 bg-white/5 border border-white/10 rounded-lg text-sm outline-none focus:border-blue-500" />
    <select name="status" class="px-4 py-2 bg-white/5 border border-white/10 rounded-lg text-sm outline-none focus:border-blue-500">
        <option value="">Tất cả trạng thái</option>
        <option value="Verified" selected="@(ViewBag.Status == "Verified" ? "selected" : null)">Đã xác minh</option>
        <option value="Unverified" selected="@(ViewBag.Status == "Unverified" ? "selected" : null)">Chưa xác minh</option>
        <option value="Locked" selected="@(ViewBag.Status == "Locked" ? "selected" : null)">Đã khóa</option>
    </select>
    <button type="submit" class="px-6 py-2 bg-blue-500 hover:bg-blue-600 rounded-lg text-sm font-medium transition-colors">
        Tìm kiếm
    </button>
</form>

<!-- Employers Table -->
<div class="glass-card rounded-xl overflow-hidden">
    <table class="w-full text-sm">
        <thead class="bg-white/5 border-b border-white/10">
            <tr>
                <th class="text-left px-6 py-4 font-semibold">ID</th>
                <th class="text-left px-6 py-4 font-semibold">Tên công ty</th>
                <th class="text-left px-6 py-4 font-semibold">Email</th>
                <th class="text-left px-6 py-4 font-semibold">Ngành nghề</th>
                <th class="text-left px-6 py-4 font-semibold">Xác minh</th>
                <th class="text-left px-6 py-4 font-semibold">Trạng thái</th>
                <th class="text-left px-6 py-4 font-semibold">Ngày tạo</th>
                <th class="text-center px-6 py-4 font-semibold">Thao tác</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-white/10">
            @if (Model.Any())
            {
                @foreach (var employer in Model)
                {
                    var verifiedClass = employer.IsVerified ? "badge-open" : "badge-pending";
                    var verifiedLabel = employer.IsVerified ? "Đã xác minh" : "Chưa xác minh";
                    var lockedClass = employer.IsLocked ? "badge-rejected" : "badge-open";
                    var lockedLabel = employer.IsLocked ? "Đã khóa" : "Hoạt động";
                    
                    <tr class="hover:bg-white/5 transition-colors">
                        <td class="px-6 py-4">
                            <span class="font-mono text-xs text-gray-400">@employer.EmployerID</span>
                        </td>
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 bg-blue-500/20 rounded-lg flex items-center justify-center">
                                    <span class="material-icons text-blue-400">business</span>
                                </div>
                                <div>
                                    <p class="font-medium">@employer.CompanyName</p>
                                    <p class="text-xs text-gray-400">@employer.CompanySize</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4 text-gray-300">@employer.User?.Email ?? "-"</td>
                        <td class="px-6 py-4 text-gray-300">@employer.Industry ?? "-"</td>
                        <td class="px-6 py-4">
                            <span class="px-3 py-1 rounded-full text-xs font-medium @verifiedClass">@verifiedLabel</span>
                        </td>
                        <td class="px-6 py-4">
                            <span class="px-3 py-1 rounded-full text-xs font-medium @lockedClass">@lockedLabel</span>
                        </td>
                        <td class="px-6 py-4 text-gray-400">@employer.CreatedAt.ToString("dd/MM/yyyy")</td>
                        <td class="px-6 py-4 text-center">
                            <div class="flex items-center justify-center gap-2">
                                <a href="@Url.Action("UserDetail", "StaffDashboard", new { id = employer.UserID })"
                                   class="p-2 bg-blue-500/20 text-blue-400 rounded-lg hover:bg-blue-500/30 transition-colors"
                                   title="Xem chi tiết">
                                    <span class="material-icons text-sm">visibility</span>
                                </a>
                                <form asp-action="ToggleEmployerLock" method="post" class="inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="employerId" value="@employer.EmployerID" />
                                    <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                    <button type="submit" 
                                            class="p-2 @(employer.IsLocked ? "bg-green-500/20 text-green-400 hover:bg-green-500/30" : "bg-red-500/20 text-red-400 hover:bg-red-500/30") rounded-lg transition-colors"
                                            title="@(employer.IsLocked ? "Mở khóa công ty" : "Khóa công ty")">
                                        <span class="material-icons text-sm">@(employer.IsLocked ? "unlock" : "lock")</span>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8" class="px-6 py-8 text-center text-gray-400">
                        Không tìm thấy nhà tuyển dụng nào
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Pagination -->
@if (ViewBag.TotalPages > 1)
{
    <div class="flex items-center justify-center gap-2 mt-6">
        @if (ViewBag.Page > 1)
        {
            <a href="@Url.Action("Employers", new { keyword = ViewBag.Keyword, status = ViewBag.Status, page = ViewBag.Page - 1 })"
               class="px-4 py-2 bg-white/5 border border-white/10 rounded-lg hover:bg-white/10 transition-colors">
                <span class="material-icons text-sm">chevron_left</span>
            </a>
        }
        
        @for (int i = 1; i <= ViewBag.TotalPages; i++)
        {
            if (i == ViewBag.Page || i == 1 || i == ViewBag.TotalPages || (i >= ViewBag.Page - 1 && i <= ViewBag.Page + 1))
            {
                <a href="@Url.Action("Employers", new { keyword = ViewBag.Keyword, status = ViewBag.Status, page = i })"
                   class="px-4 py-2 @(i == ViewBag.Page ? "bg-blue-500" : "bg-white/5 border border-white/10 hover:bg-white/10") rounded-lg transition-colors">
                    @i
                </a>
            }
            else if (i == ViewBag.Page - 2 || i == ViewBag.Page + 2)
            {
                <span class="px-2">...</span>
            }
        }
        
        @if (ViewBag.Page < ViewBag.TotalPages)
        {
            <a href="@Url.Action("Employers", new { keyword = ViewBag.Keyword, status = ViewBag.Status, page = ViewBag.Page + 1 })"
               class="px-4 py-2 bg-white/5 border border-white/10 rounded-lg hover:bg-white/10 transition-colors">
                <span class="material-icons text-sm">chevron_right</span>
            </a>
        }
    </div>
}
