@{
    ViewData["Title"] = "Gửi Thông báo";
    Layout = "_StaffLayout";
}

<div class="glass-card rounded-xl p-6 mb-6">
    <h2 class="text-2xl font-bold mb-6">Gửi thông báo hàng loạt</h2>
    
    <form asp-action="SendNotification" method="post">
        @Html.AntiForgeryToken()
        
        <div class="grid grid-cols-1 gap-6">
            <div>
                <label class="block text-sm text-gray-400 mb-2">Tiêu đề</label>
                <input name="title" type="text" required placeholder="Nhập tiêu đề thông báo..."
                       class="w-full px-4 py-2 bg-white/5 border border-white/10 rounded-lg text-sm outline-none focus:border-blue-500" />
            </div>
            
            <div>
                <label class="block text-sm text-gray-400 mb-2">Nội dung</label>
                <textarea name="content" rows="5" required placeholder="Nhập nội dung thông báo..."
                          class="w-full px-4 py-2 bg-white/5 border border-white/10 rounded-lg text-sm outline-none focus:border-blue-500 resize-none"></textarea>
            </div>
            
            <div>
                <label class="block text-sm text-gray-400 mb-2">Đối tượng nhận</label>
                <select name="target" class="w-full px-4 py-2 bg-white/5 border border-white/10 rounded-lg text-sm outline-none focus:border-blue-500">
                    <option value="All">Tất cả người dùng</option>
                    <option value="Candidate">Ứng viên</option>
                    <option value="Employer">Nhà tuyển dụng</option>
                </select>
            </div>
            
            <div class="flex gap-4">
                <button type="submit" 
                        class="px-6 py-2 bg-blue-500 hover:bg-blue-600 rounded-lg text-sm font-medium transition-colors">
                    Gửi thông báo
                </button>
                <a href="@Url.Action("Index", "StaffDashboard")" 
                   class="px-6 py-2 bg-white/5 border border-white/10 rounded-lg text-sm font-medium hover:bg-white/10 transition-colors">
                    Huỷ
                </a>
            </div>
        </div>
    </form>
</div>

<!-- Recent Notifications -->
<div class="glass-card rounded-xl p-6">
    <h3 class="text-lg font-semibold mb-4">Thông báo gần đây</h3>
    <div class="space-y-3">
        <div class="flex items-center gap-3 p-3 bg-white/5 rounded-lg">
            <div class="w-8 h-8 bg-blue-500/20 rounded-full flex items-center justify-center">
                <span class="material-icons text-blue-400 text-sm">notifications</span>
            </div>
            <div class="flex-1">
                <p class="text-sm font-medium">Chào mừng đến với JobConnect</p>
                <p class="text-xs text-gray-400">Gửi đến: Tất cả người dùng</p>
            </div>
            <p class="text-xs text-gray-500">Hôm nay</p>
        </div>
        <div class="flex items-center gap-3 p-3 bg-white/5 rounded-lg">
            <div class="w-8 h-8 bg-green-500/20 rounded-full flex items-center justify-center">
                <span class="material-icons text-green-400 text-sm">check_circle</span>
            </div>
            <div class="flex-1">
                <p class="text-sm font-medium">Tính năng mới đã được cập nhật</p>
                <p class="text-xs text-gray-400">Gửi đến: Ứng viên</p>
            </div>
            <p class="text-xs text-gray-500">Hôm qua</p>
        </div>
    </div>
</div>
