@model List<JobConnect.Models.User>
@{
    ViewData["Title"] = "Quản lý Ứng viên";
    Layout = "_StaffLayout";
}

<!-- Search & Filter -->
<form method="get" class="glass-card rounded-xl p-4 mb-6 flex gap-4">
    <input name="keyword" value="@ViewBag.Keyword" type="text" placeholder="Tìm theo tên, email..."
           class="flex-1 px-4 py-2 bg-white/5 border border-white/10 rounded-lg text-sm outline-none focus:border-blue-500" />
    <select name="status" class="px-4 py-2 bg-white/5 border border-white/10 rounded-lg text-sm outline-none focus:border-blue-500">
        <option value="">Tất cả trạng thái</option>
        <option value="Active" selected="@(ViewBag.Status == "Active" ? "selected" : null)">Hoạt động</option>
        <option value="Banned" selected="@(ViewBag.Status == "Banned" ? "selected" : null)">Đã khóa</option>
        <option value="Pending" selected="@(ViewBag.Status == "Pending" ? "selected" : null)">Chờ duyệt</option>
    </select>
    <button type="submit" class="px-6 py-2 bg-blue-500 hover:bg-blue-600 rounded-lg text-sm font-medium transition-colors">
        Tìm kiếm
    </button>
</form>

<!-- Candidates Table -->
<div class="glass-card rounded-xl overflow-hidden">
    <table class="w-full text-sm">
        <thead class="bg-white/5 border-b border-white/10">
            <tr>
                <th class="text-left px-6 py-4 font-semibold">ID</th>
                <th class="text-left px-6 py-4 font-semibold">Họ tên</th>
                <th class="text-left px-6 py-4 font-semibold">Email</th>
                <th class="text-left px-6 py-4 font-semibold">Số điện thoại</th>
                <th class="text-left px-6 py-4 font-semibold">Trạng thái</th>
                <th class="text-left px-6 py-4 font-semibold">Ngày tạo</th>
                <th class="text-center px-6 py-4 font-semibold">Thao tác</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-white/10">
            @if (Model.Any())
            {
                @foreach (var user in Model)
                {
                    var statusClass = user.Status == "Active" ? "badge-open" : user.Status == "Banned" ? "badge-rejected" : "badge-pending";
                    var statusLabel = user.Status == "Active" ? "Hoạt động" : user.Status == "Banned" ? "Đã khóa" : "Chờ duyệt";
                    
                    <tr class="hover:bg-white/5 transition-colors">
                        <td class="px-6 py-4">
                            <span class="font-mono text-xs text-gray-400">@user.UserID</span>
                        </td>
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-3">
                                <img src="@user.AvatarURL ?? "/img/default-avatar.png"" 
                                     alt="Avatar" class="w-10 h-10 rounded-full object-cover" />
                                <div>
                                    <p class="font-medium">@user.FullName</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4 text-gray-300">@user.Email</td>
                        <td class="px-6 py-4 text-gray-300">@user.PhoneNumber ?? "-"</td>
                        <td class="px-6 py-4">
                            <span class="px-3 py-1 rounded-full text-xs font-medium @statusClass">@statusLabel</span>
                        </td>
                        <td class="px-6 py-4 text-gray-400">@user.CreatedAt.ToString("dd/MM/yyyy")</td>
                        <td class="px-6 py-4 text-center">
                            <div class="flex items-center justify-center gap-2">
                                <a href="@Url.Action("UserDetail", "StaffDashboard", new { id = user.UserID })"
                                   class="p-2 bg-blue-500/20 text-blue-400 rounded-lg hover:bg-blue-500/30 transition-colors"
                                   title="Xem chi tiết">
                                    <span class="material-icons text-sm">visibility</span>
                                </a>
                                <form asp-action="ToggleUserStatus" method="post" class="inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="userId" value="@user.UserID" />
                                    <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                    <button type="submit" 
                                            class="p-2 @(user.Status == "Active" ? "bg-red-500/20 text-red-400 hover:bg-red-500/30" : "bg-green-500/20 text-green-400 hover:bg-green-500/30") rounded-lg transition-colors"
                                            title="@(user.Status == "Active" ? "Khóa tài khoản" : "Mở khóa tài khoản")">
                                        <span class="material-icons text-sm">@(user.Status == "Active" ? "lock" : "unlock")</span>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="px-6 py-8 text-center text-gray-400">
                        Không tìm thấy ứng viên nào
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Pagination -->
@if (ViewBag.TotalPages > 1)
{
    <div class="flex items-center justify-center gap-2 mt-6">
        @if (ViewBag.Page > 1)
        {
            <a href="@Url.Action("Candidates", new { keyword = ViewBag.Keyword, status = ViewBag.Status, page = ViewBag.Page - 1 })"
               class="px-4 py-2 bg-white/5 border border-white/10 rounded-lg hover:bg-white/10 transition-colors">
                <span class="material-icons text-sm">chevron_left</span>
            </a>
        }
        
        @for (int i = 1; i <= ViewBag.TotalPages; i++)
        {
            if (i == ViewBag.Page || i == 1 || i == ViewBag.TotalPages || (i >= ViewBag.Page - 1 && i <= ViewBag.Page + 1))
            {
                <a href="@Url.Action("Candidates", new { keyword = ViewBag.Keyword, status = ViewBag.Status, page = i })"
                   class="px-4 py-2 @(i == ViewBag.Page ? "bg-blue-500" : "bg-white/5 border border-white/10 hover:bg-white/10") rounded-lg transition-colors">
                    @i
                </a>
            }
            else if (i == ViewBag.Page - 2 || i == ViewBag.Page + 2)
            {
                <span class="px-2">...</span>
            }
        }
        
        @if (ViewBag.Page < ViewBag.TotalPages)
        {
            <a href="@Url.Action("Candidates", new { keyword = ViewBag.Keyword, status = ViewBag.Status, page = ViewBag.Page + 1 })"
               class="px-4 py-2 bg-white/5 border border-white/10 rounded-lg hover:bg-white/10 transition-colors">
                <span class="material-icons text-sm">chevron_right</span>
            </a>
        }
    </div>
}
