@* [VIEW-HEADER-ADDED]
   View cho action "Profile" trong khu vực trang làm việc của Staff (StaffDashboardController).
*@
@model JobConnect.Models.Staff
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
    Layout = "_StaffLayout";
}

<!-- Profile Card -->
<div class="glass-card rounded-xl p-6 mb-6">
    <div class="flex items-start gap-6 mb-6">
        <div class="relative">
            <img src="@Model.Avatar ?? " /img/default-avatar.png""
                 alt="Avatar" class="w-24 h-24 rounded-xl object-cover" />
            <label class="absolute bottom-0 right-0 w-8 h-8 bg-blue-500 rounded-full flex items-center justify-center cursor-pointer hover:bg-blue-600 transition-colors">
                <span class="material-icons text-slate-900 text-sm">camera_alt</span>
                <input type="file" name="avatar" accept="image/*" class="hidden" onchange="document.getElementById('avatarForm').submit()" />
            </label>
        </div>
        <div class="flex-1">
            <h2 class="text-2xl font-bold mb-2">@Model.FullName</h2>
            <div class="flex items-center gap-3 text-sm text-gray-400 mb-2">
                <span class="material-icons text-sm">badge</span>
                <span>@Model.EmployeeCode</span>
                <span>•</span>
                <span>@Model.Position</span>
            </div>
            <div class="flex items-center gap-3 text-sm text-gray-400">
                <span class="material-icons text-sm">business</span>
                <span>@Model.Department</span>
                <span>•</span>
                <span class="material-icons text-sm">email</span>
                <span>@Model.Email</span>
                @if (!string.IsNullOrEmpty(Model.Gender))
                {
                    <span>•</span>
                    <span class="material-icons text-sm">wc</span>
                    <span>@Model.Gender</span>
                }
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="bg-white/5 rounded-lg p-4 text-center">
            <p class="text-xs text-gray-400 mb-1">Mã nhân viên</p>
            <p class="font-mono font-medium">@Model.EmployeeCode</p>
        </div>
        <div class="bg-white/5 rounded-lg p-4 text-center">
            <p class="text-xs text-gray-400 mb-1">Trạng thái</p>
            <span class="px-3 py-1 rounded-full text-xs font-medium @(Model.Status == "Active" ? "badge-open" : "badge-rejected")">
                @(Model.Status == "Active" ? "Hoạt động" : "Đã khóa")
            </span>
        </div>
        <div class="bg-white/5 rounded-lg p-4 text-center">
            <p class="text-xs text-gray-400 mb-1">Ngày tham gia</p>
            <p class="font-medium">@Model.CreatedAt.ToString("dd/MM/yyyy")</p>
        </div>
    </div>
</div>

<!-- Read-only info: only Admin can change these -->
<div class="glass-card rounded-xl p-6 mb-6">
    <h3 class="text-lg font-semibold mb-1">Thông tin công việc</h3>
    <p class="text-xs text-gray-400 mb-4">Các thông tin này chỉ Admin mới có quyền chỉnh sửa.</p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div>
            <label class="block text-sm text-gray-400 mb-2">CCCD</label>
            <div class="w-full px-4 py-2 bg-white/5 border border-white/10 rounded-lg text-sm text-gray-300">
                @(string.IsNullOrEmpty(Model.CCCD) ? "—" : Model.CCCD)
            </div>
        </div>
        <div>
            <label class="block text-sm text-gray-400 mb-2">Chức vụ</label>
            <div class="w-full px-4 py-2 bg-white/5 border border-white/10 rounded-lg text-sm text-gray-300">
                @Model.Position
            </div>
        </div>
        <div>
            <label class="block text-sm text-gray-400 mb-2">Phòng ban</label>
            <div class="w-full px-4 py-2 bg-white/5 border border-white/10 rounded-lg text-sm text-gray-300">
                @Model.Department
            </div>
        </div>
    </div>
</div>

<!-- Update Profile Form -->
<div class="glass-card rounded-xl p-6 mb-6">
    <h3 class="text-lg font-semibold mb-4">Cập nhật thông tin</h3>
    <form asp-action="UpdateProfile" method="post" class="grid grid-cols-1 md:grid-cols-2 gap-4">
        @Html.AntiForgeryToken()
        <div>
            <label class="block text-sm text-gray-400 mb-2">Họ tên</label>
            <input name="fullName" type="text" value="@Model.FullName" required
                   class="w-full px-4 py-2 bg-white/5 border border-white/10 rounded-lg text-sm outline-none focus:border-blue-500" />
        </div>
        <div>
            <label class="block text-sm text-gray-400 mb-2">Số điện thoại</label>
            <input name="phone" type="text" value="@Model.Phone"
                   class="w-full px-4 py-2 bg-white/5 border border-white/10 rounded-lg text-sm outline-none focus:border-blue-500" />
        </div>
        <div>
            <label class="block text-sm text-gray-400 mb-2">Giới tính</label>
            <select name="gender"
                    class="w-full px-4 py-2 bg-white/5 border border-white/10 rounded-lg text-sm outline-none focus:border-blue-500">
                <option value="" selected="@(string.IsNullOrEmpty(Model.Gender))">-- Chọn giới tính --</option>
                <option value="Nam" selected="@(Model.Gender == "Nam")">Nam</option>
                <option value="Nữ" selected="@(Model.Gender == "Nữ")">Nữ</option>
                <option value="Khác" selected="@(Model.Gender == "Khác")">Khác</option>
            </select>
        </div>
        <div class="md:col-span-2">
            <label class="block text-sm text-gray-400 mb-2">Email</label>
            <input name="email" type="email" value="@Model.Email" required
                   class="w-full px-4 py-2 bg-white/5 border border-white/10 rounded-lg text-sm outline-none focus:border-blue-500" />
        </div>
        <div class="md:col-span-2">
            <button type="submit"
                    class="px-6 py-2 bg-blue-500 hover:bg-blue-600 rounded-lg text-sm font-medium transition-colors">
                Lưu thay đổi
            </button>
        </div>
    </form>
</div>


<!-- Avatar Upload Form (hidden) -->
<form id="avatarForm" asp-action="UpdateAvatar" method="post" enctype="multipart/form-data" class="hidden">
    @Html.AntiForgeryToken()
    <input type="file" name="avatar" id="avatarInput" accept="image/*" />
</form>

<div class="flex gap-4">
    <a href="@Url.Action("Index", "StaffDashboard")"
       class="px-6 py-2 bg-white/5 border border-white/10 rounded-lg text-sm font-medium hover:bg-white/10 transition-colors">
        Quay lại Dashboard
    </a>
</div>

<script>
    // Handle avatar upload
    document.querySelector('label input[type="file"]').addEventListener('change', function(e) {
        const file = e.target.files[0];
        if (file) {
            const formData = new FormData();
            formData.append('avatar', file);
            formData.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);

            fetch('@Url.Action("UpdateAvatar", "StaffDashboard")', {
                method: 'POST',
                body: formData
            }).then(response => {
                if (response.ok) {
                    location.reload();
                }
            });
        }
    });
</script>
