@model JobConnect.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Đăng ký"; 
    Layout = "_Layout";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng ký – JobConnect</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body class="min-h-screen bg-[#f9f9ff] flex items-center justify-center font-[Inter] py-8">
    <div class="w-full max-w-md bg-white rounded-2xl shadow-lg p-8 mx-4">
        <div class="text-center mb-8">
            <a href="/" class="text-2xl font-bold text-[#003d9b]">JobConnect</a>
            <h1 class="text-xl font-semibold text-gray-900 mt-2">Tạo tài khoản ứng viên</h1>
        </div>
        <form asp-action="Register" method="post" class="space-y-4">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="text-red-600 text-sm bg-red-50 p-3 rounded-lg"></div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Họ và tên <span class="text-red-500">*</span></label>
                <input asp-for="FullName" placeholder="Nguyễn Văn A"
                       class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:border-[#003d9b] outline-none" />
                <span asp-validation-for="FullName" class="text-red-500 text-xs"></span>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Email <span class="text-red-500">*</span></label>
                <input asp-for="Email" type="email" placeholder="your@email.com"
                       class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:border-[#003d9b] outline-none" />
                <span asp-validation-for="Email" class="text-red-500 text-xs"></span>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Số điện thoại</label>
                <input asp-for="PhoneNumber" type="tel" placeholder="0901234567"
                       class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:border-[#003d9b] outline-none" />
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Mật khẩu <span class="text-red-500">*</span></label>
                <input asp-for="Password" type="password" placeholder="Ít nhất 8 ký tự"
                       class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:border-[#003d9b] outline-none" />
                <span asp-validation-for="Password" class="text-red-500 text-xs"></span>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Xác nhận mật khẩu <span class="text-red-500">*</span></label>
                <input asp-for="ConfirmPassword" type="password" placeholder="Nhập lại mật khẩu"
                       class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:border-[#003d9b] outline-none" />
                <span asp-validation-for="ConfirmPassword" class="text-red-500 text-xs"></span>
            </div>
            <label class="flex items-start gap-2 text-sm text-gray-600 cursor-pointer">
                <input asp-for="AgreeTerms" type="checkbox" class="mt-0.5 rounded border-gray-300 text-[#003d9b]" />
                <span>Tôi đồng ý với <a href="#" class="text-[#003d9b] hover:underline">Điều khoản sử dụng</a></span>
            </label>
            <button type="submit"
                    class="w-full py-3 bg-[#003d9b] text-white font-semibold rounded-xl hover:bg-[#0040a2] transition-colors">
                Tạo tài khoản
            </button>
        </form>
        <div class="mt-6 text-center text-sm text-gray-500">
            Đã có tài khoản?
            <a asp-controller="Account" asp-action="Login" class="text-[#003d9b] font-semibold hover:underline">Đăng nhập</a>
        </div>
    </div>
</body>
</html>