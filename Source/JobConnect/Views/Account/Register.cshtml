@model JobConnect.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Đăng ký";
    Layout = "_Layout";
}

<link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700&display=swap" rel="stylesheet" />
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />

<style>
    /* ... Giữ nguyên phần CSS đẹp mắt của bạn ... */
    #registerWrap * {
        font-family: 'Be Vietnam Pro', sans-serif;
    }

    #registerWrap {
        min-height: 85vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #eef2ff;
        padding: 2.5rem 1rem;
    }

    .reg-card {
        background: #fff;
        border: 1px solid #e0e7f5;
        border-radius: 16px;
        padding: 2.25rem 2rem;
        width: 100%;
        max-width: 460px;
        box-shadow: 0 4px 24px rgba(0,61,155,0.06);
    }

    .reg-brand {
        text-align: center;
        margin-bottom: 1.5rem;
    }

        .reg-brand a {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
            font-size: 1.25rem;
            font-weight: 700;
            color: #003d9b;
            letter-spacing: -0.02em;
        }

    .reg-brand-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        background: #eff6ff;
        border: 1px solid #dbeafe;
        border-radius: 9px;
    }

    .reg-title {
        font-size: 1.125rem;
        font-weight: 600;
        color: #0f172a;
        text-align: center;
        margin-bottom: 1.5rem;
    }

    .role-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin-bottom: 1.25rem;
    }

    .role-option {
        display: block;
        cursor: pointer;
    }

        .role-option input[type="radio"] {
            display: none;
        }

    .role-box {
        border: 1px solid #dde3f0;
        border-radius: 10px;
        padding: 14px 10px;
        text-align: center;
        transition: all 0.15s;
        background: #fafbff;
    }

        .role-box:hover {
            border-color: #93aee0;
            background: #f5f8ff;
        }

    .role-option input[type="radio"]:checked + .role-box {
        border-color: #003d9b;
        background: #eff6ff;
        box-shadow: inset 0 0 0 1px #003d9b;
    }

    .role-icon {
        font-size: 1.5rem;
        color: #003d9b;
        display: block;
        margin-bottom: 6px;
    }

    .role-label {
        font-size: 0.8125rem;
        font-weight: 600;
        color: #1e3a6e;
        display: block;
    }

    .role-desc {
        font-size: 0.7rem;
        color: #64748b;
        display: block;
        margin-top: 2px;
    }

    .field {
        margin-bottom: 1rem;
    }

    .field-label {
        display: block;
        font-size: 0.75rem;
        font-weight: 600;
        color: #475569;
        letter-spacing: 0.025em;
        margin-bottom: 0.4rem;
    }

        .field-label .req {
            color: #ef4444;
            margin-left: 2px;
        }

    .field-input {
        width: 100%;
        padding: 0.7rem 1rem;
        border: 1px solid #dde3f0;
        border-radius: 8px;
        font-size: 0.875rem;
        color: #0f172a;
        background: #f8fafd;
        outline: none;
        transition: border-color 0.15s, box-shadow 0.15s, background 0.15s;
        font-family: 'Be Vietnam Pro', sans-serif;
    }

        .field-input:focus {
            border-color: #003d9b;
            background: #fff;
            box-shadow: 0 0 0 3px rgba(0,61,155,0.1);
        }

    .strength-bar {
        height: 3px;
        background: #e8edf5;
        border-radius: 2px;
        margin-top: 6px;
        overflow: hidden;
    }

    .strength-fill {
        height: 100%;
        border-radius: 2px;
        width: 0;
        transition: width 0.3s, background-color 0.3s;
    }

    .strength-label {
        font-size: 0.7rem;
        margin-top: 4px;
        font-weight: 500;
        display: block;
        color: #94a3b8;
    }

    .inp-wrap {
        position: relative;
    }

        .inp-wrap .field-input {
            padding-right: 2.75rem;
        }

    .eye-toggle {
        position: absolute;
        right: 0.75rem;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        cursor: pointer;
        color: #94a3b8;
        display: flex;
        align-items: center;
    }

    .terms-row {
        display: flex;
        align-items: flex-start;
        gap: 8px;
        font-size: 0.8125rem;
        color: #475569;
        font-weight: 500;
        line-height: 1.5;
    }

        .terms-row input[type="checkbox"] {
            margin-top: 3px;
            width: 15px;
            height: 15px;
            accent-color: #003d9b;
            flex-shrink: 0;
            cursor: pointer;
        }

    .btn-primary {
        width: 100%;
        padding: 0.8rem;
        background: #003d9b;
        color: #fff;
        font-weight: 700;
        font-size: 0.875rem;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        margin-top: 1rem;
        transition: background 0.15s;
    }

    .val-summary {
        background: #fef2f2;
        border: 1px solid #fecaca;
        border-radius: 8px;
        padding: 0.75rem 1rem;
        font-size: 0.8125rem;
        color: #b91c1c;
        margin-bottom: 1.25rem;
    }

    .field-error {
        color: #ef4444;
        font-size: 0.75rem;
        margin-top: 4px;
        display: block;
        font-weight: 500;
    }
</style>

<div id="registerWrap">
    <div class="reg-card">
        <div class="reg-brand">
            <a href="/">
                <span class="reg-brand-icon">
                    <span class="material-symbols-outlined" style="color:#003d9b;font-size:20px;">work</span>
                </span>
                JobConnect
            </a>
        </div>

        <p class="reg-title">Tạo tài khoản mới</p>

        <form asp-controller="Account" asp-action="Register" method="post">
            @Html.AntiForgeryToken()

            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="ModelOnly" class="val-summary"></div>
            }

            <div class="role-grid">
                <label class="role-option">
                    <input type="radio" asp-for="Role" value="Candidate" checked />
                    <div class="role-box">
                        <span class="material-symbols-outlined role-icon">person</span>
                        <span class="role-label">Ứng viên</span>
                        <span class="role-desc">Tìm việc làm</span>
                    </div>
                </label>
                <label class="role-option">
                    <input type="radio" asp-for="Role" value="Employer" />
                    <div class="role-box">
                        <span class="material-symbols-outlined role-icon">business</span>
                        <span class="role-label">Nhà tuyển dụng</span>
                        <span class="role-desc">Đăng tuyển dụng</span>
                    </div>
                </label>
            </div>

            <div class="field">
                <label class="field-label">Họ và tên <span class="req">*</span></label>
                <input asp-for="FullName" placeholder="Nguyễn Văn A" class="field-input" required />
                <span asp-validation-for="FullName" class="field-error"></span>
            </div>

            <div class="field">
                <label class="field-label">Email <span class="req">*</span></label>
                <input asp-for="Email" type="email" placeholder="your@email.com" class="field-input" required />
                <span asp-validation-for="Email" class="field-error"></span>
            </div>

            <div class="field">
                <label class="field-label">Số điện thoại</label>
                <input asp-for="PhoneNumber" type="tel" placeholder="0901 234 567" class="field-input" />
                <span asp-validation-for="PhoneNumber" class="field-error"></span>
            </div>

            <div class="field">
                <label class="field-label">Mật khẩu <span class="req">*</span></label>
                <div class="inp-wrap">
                    <input asp-for="Password" type="password" id="pwdInput"
                           placeholder="Ít nhất 8 ký tự" class="field-input"
                           oninput="checkStrength(this.value)" required />
                    <button type="button" class="eye-toggle" onclick="togglePwd('pwdInput','eyeIcon1')">
                        <span class="material-symbols-outlined" id="eyeIcon1" style="font-size:20px;">visibility</span>
                    </button>
                </div>
                <div class="strength-bar">
                    <div class="strength-fill" id="strengthFill"></div>
                </div>
                <span class="strength-label" id="strengthLabel"></span>
                <span asp-validation-for="Password" class="field-error"></span>
            </div>

            <div class="field">
                <label class="field-label">Xác nhận mật khẩu <span class="req">*</span></label>
                <div class="inp-wrap">
                    <input asp-for="ConfirmPassword" type="password" id="pwdConfirm"
                           placeholder="Nhập lại mật khẩu" class="field-input" required />
                    <button type="button" class="eye-toggle" onclick="togglePwd('pwdConfirm','eyeIcon2')">
                        <span class="material-symbols-outlined" id="eyeIcon2" style="font-size:20px;">visibility</span>
                    </button>
                </div>
                <span asp-validation-for="ConfirmPassword" class="field-error"></span>
            </div>

            <div class="terms-row">
                <input asp-for="AgreeTerms" type="checkbox" id="agreeTerms" required />
                <label for="agreeTerms">
                    Tôi đồng ý với <a href="#">Điều khoản</a> và <a href="#">Chính sách bảo mật</a>
                </label>
            </div>
            <span asp-validation-for="AgreeTerms" class="field-error"></span>

            <button type="submit" class="btn-primary">Tạo tài khoản</button>
        </form>

        <div class="footer-link">
            Đã có tài khoản? <a asp-controller="Account" asp-action="Login">Đăng nhập</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePwd(inputId, iconId) {
            const inp = document.getElementById(inputId);
            const ico = document.getElementById(iconId);
            inp.type = inp.type === 'password' ? 'text' : 'password';
            ico.textContent = inp.type === 'text' ? 'visibility_off' : 'visibility';
        }

        function checkStrength(val) {
            const fill = document.getElementById('strengthFill');
            const label = document.getElementById('strengthLabel');
            let score = 0;
            if (val.length >= 8) score++;
            if (/[A-Z]/.test(val)) score++;
            if (/[0-9]/.test(val)) score++;
            if (/[^A-Za-z0-9]/.test(val)) score++;

            const levels = [
                { w: '0%', c: 'transparent', t: '' },
                { w: '25%', c: '#ef4444', t: 'Yếu' },
                { w: '50%', c: '#f59e0b', t: 'Trung bình' },
                { w: '75%', c: '#3b82f6', t: 'Khá mạnh' },
                { w: '100%', c: '#22c55e', t: 'Mạnh' },
            ];
            const lv = levels[score] || levels[0];
            fill.style.width = lv.w;
            fill.style.backgroundColor = lv.c;
            label.textContent = lv.t;
            label.style.color = lv.c;
        }
    </script>
}