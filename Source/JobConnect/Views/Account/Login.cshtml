@model JobConnect.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập – JobConnect</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />
    <script>
        tailwind.config = {
        theme: {
        extend: {
        colors: {
        primary: '#3b82f6',
        }
        }
        }
        }
    </script>
    <style>
        * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        }

        body {
        font-family: 'Inter', sans-serif;
        background: #000000;
        min-height: 100vh;
        position: relative;
        overflow-x: hidden;
        }

        .rain-container {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 1;
        overflow: hidden;
        }

        .drop {
        position: absolute;
        background: linear-gradient(to bottom, rgba(59, 130, 246, 0.5) 0%, rgba(59, 130, 246, 0.2) 50%, rgba(59, 130, 246, 0) 100%);
        width: 2px;
        border-radius: 0 0 3px 3px;
        animation: fall linear infinite;
        }

        .drop-small {
        position: absolute;
        background: rgba(59, 130, 246, 0.25);
        width: 1px;
        border-radius: 0 0 2px 2px;
        animation: fall linear infinite;
        }

        @@keyframes fall {
        to {
        transform: translateY(110vh);
        }
        }

        .glass-card {
        background: rgba(10, 10, 10, 0.85);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(59, 130, 246, 0.2);
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }

        .input-field {
        width: 100%;
        padding: 0.875rem 1rem;
        background: #000000;
        border: 1.5px solid #1a1a1a;
        border-radius: 0.75rem;
        font-size: 0.875rem;
        outline: none;
        transition: all 0.2s ease;
        color: #ffffff;
        }

        .input-field:focus {
        border-color: #3b82f6;
        box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.15);
        }

        .input-field::placeholder {
        color: #475569;
        }

        .label {
        display: block;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #94a3b8;
        margin-bottom: 0.5rem;
        }

        .social-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        padding: 0.75rem;
        background: #000000;
        border: 1.5px solid #1a1a1a;
        border-radius: 0.75rem;
        font-size: 0.875rem;
        font-weight: 600;
        color: #e2e8f0;
        cursor: pointer;
        transition: all 0.2s ease;
        width: 100%;
        }

        .social-btn:hover {
        border-color: #3b82f6;
        background: #0f172a;
        transform: translateY(-2px);
        }

        .orb {
        position: fixed;
        border-radius: 50%;
        filter: blur(80px);
        opacity: 0.4;
        z-index: 0;
        pointer-events: none;
        }

        .orb-1 {
        width: 400px;
        height: 400px;
        background: #3b82f6;
        top: -150px;
        right: -150px;
        }

        .orb-2 {
        width: 500px;
        height: 500px;
        background: #8b5cf6;
        bottom: -200px;
        left: -200px;
        }

        .orb-3 {
        width: 300px;
        height: 300px;
        background: #06b6d4;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        }

        ::-webkit-scrollbar {
        width: 6px;
        }

        ::-webkit-scrollbar-track {
        background: #000000;
        }

        ::-webkit-scrollbar-thumb {
        background: #1a1a1a;
        border-radius: 4px;
        }

        ::-webkit-scrollbar-thumb:hover {
        background: #3b82f6;
        }
    </style>
</head>
<body>

    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
    <div class="rain-container" id="rainContainer"></div>

    <div class="relative z-10 text-center mb-8 pt-8">
        <a href="/" class="inline-flex items-center gap-2 text-3xl font-black bg-gradient-to-r from-blue-400 to-indigo-400 bg-clip-text text-transparent">
            <span class="material-symbols-outlined text-4xl text-blue-500">bolt</span>
            JobConnect
        </a>
        <p class="text-slate-500 text-sm mt-2">Chào mừng bạn trở lại với hệ thống tuyển dụng chuyên nghiệp.</p>
    </div>

    <div class="relative z-10 w-full max-w-md mx-auto px-4">
        <div class="glass-card rounded-2xl p-8 transition-all duration-300">

            <!-- Hiển thị lỗi từ TempData -->
            @if (TempData["Error"] != null)
            {
                <div class="mb-4 p-3 bg-red-950/30 border border-red-800/50 rounded-xl text-red-400 text-sm">
                    @TempData["Error"]
                </div>
            }

            <!-- Hiển thị lỗi từ ModelState -->
            @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
            {
                <div class="mb-4 p-3 bg-red-950/30 border border-red-800/50 rounded-xl text-red-400 text-sm">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <p>@error.ErrorMessage</p>
                    }
                </div>
            }

            <form asp-action="Login" asp-controller="Account" method="post" class="space-y-5">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

                <div>
                    <label class="label">
                        <span class="material-symbols-outlined text-sm align-middle mr-1">mail</span>
                        Email hoặc tên đăng nhập
                    </label>
                    <input asp-for="Email" type="email" placeholder="example@jobconnect.com" class="input-field" required />
                    <span asp-validation-for="Email" class="text-red-400 text-xs mt-1 block"></span>
                </div>

                <div>
                    <div class="flex justify-between items-center mb-1">
                        <label class="label" style="margin-bottom:0">
                            <span class="material-symbols-outlined text-sm align-middle mr-1">lock</span>
                            Mật khẩu
                        </label>
                        <a href="#" class="text-xs text-blue-400 font-semibold hover:text-blue-300">Quên mật khẩu?</a>
                    </div>
                    <div class="relative">
                        <input asp-for="Password" type="password" id="passwordInput" placeholder="••••••••" class="input-field" style="padding-right: 2.75rem" required />
                        <button type="button" onclick="togglePwd()" class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-500 hover:text-blue-400">
                            <span class="material-symbols-outlined text-xl leading-none" id="eyeIcon">visibility_off</span>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-red-400 text-xs mt-1 block"></span>
                </div>

                <label class="flex items-center gap-2 cursor-pointer text-sm text-slate-400">
                    <input asp-for="RememberMe" type="checkbox" class="w-4 h-4 rounded border-slate-600 bg-black text-blue-500" />
                    Ghi nhớ đăng nhập
                </label>

                <button type="submit" class="w-full py-3 bg-gradient-to-r from-blue-600 to-indigo-600 text-white font-bold rounded-xl hover:from-blue-700 hover:to-indigo-700 transition-all text-sm shadow-lg shadow-blue-900/30 transform hover:scale-[1.02] active:scale-[0.98]">
                    <span class="material-symbols-outlined text-sm align-middle mr-1">login</span>
                    Đăng nhập
                </button>

                <div class="flex items-center gap-3 my-4">
                    <div class="flex-1 h-px bg-gradient-to-r from-transparent via-slate-700 to-transparent"></div>
                    <span class="text-xs text-slate-500 font-medium">HOẶC ĐĂNG NHẬP VỚI</span>
                    <div class="flex-1 h-px bg-gradient-to-r from-transparent via-slate-700 to-transparent"></div>
                </div>

                <div class="grid grid-cols-2 gap-3">
                    <button type="button" class="social-btn" onclick="alert('Tính năng đang phát triển')">
                        <svg width="20" height="20" viewBox="0 0 24 24">
                            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4" />
                            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853" />
                            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05" />
                            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335" />
                        </svg>
                        Google
                    </button>
                    <button type="button" class="social-btn" onclick="alert('Tính năng đang phát triển')">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="#0A66C2">
                            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                        </svg>
                        LinkedIn
                    </button>
                </div>
            </form>
        </div>

        <div class="text-center mt-6">
            <p class="text-sm text-slate-500">
                Bạn chưa có tài khoản?
                <a asp-controller="Account" asp-action="Register" class="text-blue-400 font-bold hover:text-blue-300">Đăng ký ngay</a>
            </p>
            <p class="text-sm text-slate-500 mt-1">
                Nhà tuyển dụng?
                <a asp-controller="Account" asp-action="RegisterEmployer" class="text-blue-400 font-bold hover:text-blue-300">Đăng ký tại đây</a>
            </p>
            <div class="flex gap-4 text-xs text-slate-600 justify-center pt-4">
                <span>© 2024 JobConnect.</span>
                <a href="#" class="hover:text-blue-400">Điều khoản</a>
                <a href="#" class="hover:text-blue-400">Bảo mật</a>
                <a href="#" class="hover:text-blue-400">Liên hệ</a>
            </div>
        </div>
    </div>

    <script>
        function togglePwd() {
        const input = document.getElementById('passwordInput');
        const eyeIcon = document.getElementById('eyeIcon');
        if (input.type === 'password') {
        input.type = 'text';
        eyeIcon.textContent = 'visibility';
        } else {
        input.type = 'password';
        eyeIcon.textContent = 'visibility_off';
        }
        }

        function initRain() {
        const container = document.getElementById('rainContainer');
        if (!container) return;
        container.innerHTML = '';
        for (let i = 0; i < 40; i++) {
        const drop = document.createElement('div');
        drop.classList.add('drop');
        drop.style.left = Math.random() * 100 + '%';
        drop.style.animationDuration = (Math.random() * 1.2 + 0.8) + 's';
        drop.style.animationDelay = (Math.random() * 8) + 's';
        drop.style.height = (Math.random() * 40 + 40) + 'px';
        drop.style.opacity = Math.random() * 0.4 + 0.15;
        container.appendChild(drop);
        }
        for (let i = 0; i < 60; i++) {
        const drop = document.createElement('div');
        drop.classList.add('drop-small');
        drop.style.left = Math.random() * 100 + '%';
        drop.style.animationDuration = (Math.random() * 1.5 + 0.6) + 's';
        drop.style.animationDelay = (Math.random() * 10) + 's';
        drop.style.height = (Math.random() * 20 + 15) + 'px';
        drop.style.opacity = Math.random() * 0.25 + 0.1;
        container.appendChild(drop);
        }
        }
        document.addEventListener('DOMContentLoaded', initRain);
    </script>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
</body>
</html>