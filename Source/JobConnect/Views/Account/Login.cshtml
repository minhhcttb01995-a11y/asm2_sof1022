@model JobConnect.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập – JobConnect</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />
    <style>
        * {
        font-family: 'Be Vietnam Pro', sans-serif;
        }

        body {
        background-color: #eef2ff;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 3rem 1rem;
        }

        .login-card {
        background: #ffffff;
        border: 1px solid #e0e7f5;
        border-radius: 16px;
        padding: 2.25rem 2rem;
        width: 100%;
        max-width: 420px;
        box-shadow: 0 4px 24px rgba(0, 61, 155, 0.06);
        }

        .field-label {
        display: block;
        font-size: 0.75rem;
        font-weight: 600;
        color: #475569;
        letter-spacing: 0.025em;
        margin-bottom: 0.4rem;
        }

        .field-input {
        width: 100%;
        padding: 0.7rem 1rem;
        border: 1px solid #dde3f0;
        border-radius: 8px;
        font-size: 0.875rem;
        color: #0f172a;
        background: #f8fafd;
        outline: none;
        transition: border-color 0.15s, box-shadow 0.15s, background 0.15s;
        }

        .field-input:focus {
        border-color: #003d9b;
        background: #fff;
        box-shadow: 0 0 0 3px rgba(0, 61, 155, 0.1);
        }

        .field-input::placeholder {
        color: #94a3b8;
        }

        .btn-primary {
        width: 100%;
        padding: 0.8rem;
        background: #003d9b;
        color: #ffffff;
        font-weight: 700;
        font-size: 0.875rem;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        letter-spacing: 0.03em;
        transition: background 0.15s, transform 0.1s;
        }

        .btn-primary:hover {
        background: #002d75;
        }

        .btn-primary:active {
        transform: scale(0.99);
        }

        .divider {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin: 1.25rem 0;
        color: #94a3b8;
        font-size: 0.75rem;
        font-weight: 500;
        }

        .divider::before, .divider::after {
        content: '';
        flex: 1;
        height: 1px;
        background: #e8edf5;
        }

        .social-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        width: 100%;
        padding: 0.65rem;
        border: 1px solid #dde3f0;
        border-radius: 8px;
        font-size: 0.8125rem;
        font-weight: 600;
        color: #334155;
        background: #fff;
        cursor: pointer;
        transition: border-color 0.15s, background 0.15s, transform 0.15s;
        }

        .social-btn:hover {
        border-color: #003d9b;
        background: #f5f8ff;
        transform: translateY(-1px);
        }

        .error-box {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        background: #fef2f2;
        border: 1px solid #fecaca;
        border-radius: 8px;
        padding: 0.75rem 1rem;
        font-size: 0.8125rem;
        color: #b91c1c;
        font-weight: 500;
        margin-bottom: 1.25rem;
        }

        .eye-toggle {
        position: absolute;
        right: 0.75rem;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        cursor: pointer;
        color: #94a3b8;
        display: flex;
        align-items: center;
        transition: color 0.15s;
        }

        .eye-toggle:hover {
        color: #475569;
        }
    </style>
</head>
<body>

    <!-- Logo -->
    <div style="text-align:center; margin-bottom:1.75rem;">
        <a href="/" style="display:inline-flex;align-items:center;gap:8px;text-decoration:none;">
            <span style="display:inline-flex;align-items:center;justify-content:center;width:40px;height:40px;background:#eff6ff;border-radius:10px;border:1px solid #dbeafe;">
                <span class="material-symbols-outlined" style="color:#003d9b;font-size:22px;">work</span>
            </span>
            <span style="font-size:1.375rem;font-weight:700;color:#003d9b;letter-spacing:-0.02em;">JobConnect</span>
        </a>
        <p style="color:#64748b;font-size:0.8125rem;margin-top:0.5rem;font-weight:500;">Hệ thống kết nối ứng viên và nhà tuyển dụng thông minh.</p>
    </div>

    <!-- Card -->
    <div class="login-card">

        <form asp-action="Login" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

            @if (TempData["Error"] != null)
            {
                <div class="error-box">
                    <span class="material-symbols-outlined" style="font-size:18px;flex-shrink:0;">error</span>
                    @TempData["Error"]
                </div>
            }

            <!-- Email -->
            <div style="margin-bottom:1rem;">
                <label class="field-label">Email hoặc tên đăng nhập</label>
                <input asp-for="Email" type="email" placeholder="name@example.com" class="field-input" />
                <span asp-validation-for="Email" style="color:#ef4444;font-size:0.75rem;margin-top:4px;display:block;font-weight:500;"></span>
            </div>

            <!-- Password -->
            <div style="margin-bottom:0.75rem;">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.4rem;">
                    <label class="field-label" style="margin-bottom:0;">Mật khẩu</label>
                    <a href="#" style="font-size:0.75rem;color:#003d9b;font-weight:600;text-decoration:none;">Quên mật khẩu?</a>
                </div>
                <div style="position:relative;">
                    <input asp-for="Password" type="password" id="passwordInput" placeholder="••••••••" class="field-input" style="padding-right:2.75rem;" />
                    <button type="button" class="eye-toggle" onclick="togglePwd()">
                        <span class="material-symbols-outlined" id="eyeIcon" style="font-size:20px;">visibility</span>
                    </button>
                </div>
                <span asp-validation-for="Password" style="color:#ef4444;font-size:0.75rem;margin-top:4px;display:block;font-weight:500;"></span>
            </div>

            <!-- Remember me -->
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:1.25rem;">
                <input asp-for="RememberMe" type="checkbox" id="rememberMe"
                       style="width:15px;height:15px;accent-color:#003d9b;border-radius:4px;cursor:pointer;" />
                <label for="rememberMe" style="font-size:0.8125rem;color:#475569;font-weight:500;cursor:pointer;">Ghi nhớ đăng nhập</label>
            </div>

            <!-- Submit -->
            <button type="submit" class="btn-primary">Đăng nhập</button>
        </form>

        <!-- Divider -->
        <div class="divider">Hoặc tiếp tục với</div>

        <!-- Social -->
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
            <a asp-controller="Account" asp-action="ExternalLogin" asp-route-returnUrl="@ViewBag.ReturnUrl" class="social-btn" style="text-decoration:none;">
                <svg width="16" height="16" viewBox="0 0 24 24">
                    <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4" />
                    <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853" />
                    <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05" />
                    <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335" />
                </svg>
                Google
            </a>
            <button type="button" class="social-btn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="#0077B5">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0h.003z" />
                </svg>
                LinkedIn
            </button>
        </div>
    </div>

    <!-- Footer links -->
    <div style="text-align:center;margin-top:1.5rem;">
        <p style="font-size:0.8125rem;color:#64748b;font-weight:500;">
            Bạn mới biết đến JobConnect?
            <a asp-controller="Account" asp-action="Register" style="color:#003d9b;font-weight:700;text-decoration:none;margin-left:4px;">Đăng ký tài khoản</a>
        </p>
        <p style="font-size:0.75rem;color:#94a3b8;margin-top:6px;">
            Bạn là nhà tuyển dụng?
            <a asp-controller="Account" asp-action="RegisterEmployer" style="color:#003d9b;font-weight:600;text-decoration:none;margin-left:2px;">Tuyển dụng tại đây</a>
        </p>
    </div>

    <!-- Copyright -->
    <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:16px;font-size:0.75rem;color:#94a3b8;margin-top:2rem;">
        <span>© @DateTime.Now.Year JobConnect.</span>
        <a href="#" style="color:#94a3b8;text-decoration:none;transition:color .15s;" onmouseover="this.style.color='#003d9b'" onmouseout="this.style.color='#94a3b8'">Điều khoản</a>
        <a href="#" style="color:#94a3b8;text-decoration:none;transition:color .15s;" onmouseover="this.style.color='#003d9b'" onmouseout="this.style.color='#94a3b8'">Bảo mật</a>
        <a href="#" style="color:#94a3b8;text-decoration:none;transition:color .15s;" onmouseover="this.style.color='#003d9b'" onmouseout="this.style.color='#94a3b8'">Trợ giúp</a>
    </div>

    <script>
        function togglePwd() {
        const i = document.getElementById('passwordInput');
        const e = document.getElementById('eyeIcon');
        i.type = i.type === 'password' ? 'text' : 'password';
        e.textContent = i.type === 'password' ? 'visibility' : 'visibility_off';
        }
    </script>
</body>
</html>
