@model JobConnect.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập – JobConnect</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />
    <script>
        tailwind.config = {
        theme: {
        extend: {
        colors: {
        primary: '#003d9b',
        }
        }
        }
        }
    </script>
    <style>
        body {
        font-family: 'Inter', sans-serif;
        }

        .input-field {
        width: 100%;
        padding: 0.75rem 1rem;
        border: 1.5px solid #e2e5f0;
        border-radius: 0.625rem;
        font-size: 0.875rem;
        outline: none;
        transition: border-color 0.15s;
        background: white;
        color: #1a1c2e;
        }

        .input-field:focus {
        border-color: #003d9b;
        box-shadow: 0 0 0 3px rgba(0,61,155,0.08);
        }

        .label {
        display: block;
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #6b7280;
        margin-bottom: 0.4rem;
        }

        .divider {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin: 1.25rem 0;
        color: #9ca3af;
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        }

        .divider::before, .divider::after {
        content: '';
        flex: 1;
        height: 1px;
        background: #e5e7eb;
        }

        .social-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        padding: 0.7rem;
        border: 1.5px solid #e5e7eb;
        border-radius: 0.625rem;
        font-size: 0.875rem;
        font-weight: 600;
        color: #1a1c2e;
        cursor: pointer;
        transition: all 0.15s;
        background: white;
        width: 100%;
        }

        .social-btn:hover {
        border-color: #003d9b;
        background: #f0f3ff;
        }
    </style>
</head>
<body class="min-h-screen flex flex-col items-center justify-center px-4 py-10"
      style="background: linear-gradient(135deg, #eef3ff 0%, #f5f7ff 50%, #dce6ff 100%)">

    <!-- Logo + tagline -->
    <div class="text-center mb-7">
        <a href="/" class="inline-flex items-center gap-2 text-2xl font-bold text-[#003d9b]">
            <span class="material-symbols-outlined text-3xl">work</span>
            JobConnect
        </a>
        <p class="text-gray-500 text-sm mt-2 max-w-xs">Chào mừng bạn trở lại với hệ thống tuyển dụng chuyên nghiệp.</p>
    </div>

    <!-- Card -->
    <div class="w-full max-w-md bg-white rounded-2xl shadow-[0_4px_24px_rgba(0,61,155,0.09)] border border-gray-100 p-8">
        <form asp-action="Login" method="post" class="space-y-4">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

            @if (TempData["Error"] != null)
            {
                <div class="text-red-600 text-sm bg-red-50 border border-red-200 p-3 rounded-lg">@TempData["Error"]</div>
            }

            <!-- Email -->
            <div>
                <label class="label">Email hoặc tên đăng nhập</label>
                <input asp-for="Email" type="email" placeholder="example@gmail.com" class="input-field" />
                <span asp-validation-for="Email" class="text-red-500 text-xs mt-1 block"></span>
            </div>

            <!-- Password -->
            <div>
                <div class="flex justify-between items-center mb-1.5">
                    <label class="label" style="margin-bottom:0">Mật khẩu</label>
                    <a href="#" class="text-xs text-[#003d9b] font-semibold hover:underline">Quên mật khẩu?</a>
                </div>
                <div class="relative">
                    <input asp-for="Password" type="password" id="passwordInput"
                           placeholder="••••••••" class="input-field" style="padding-right:2.75rem" />
                    <button type="button" onclick="togglePwd()"
                            class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600">
                        <span class="material-symbols-outlined text-xl leading-none" id="eyeIcon">visibility</span>
                    </button>
                </div>
                <span asp-validation-for="Password" class="text-red-500 text-xs mt-1 block"></span>
            </div>

            <!-- Remember me -->
            <label class="flex items-center gap-2 cursor-pointer text-sm text-gray-500 select-none">
                <input asp-for="RememberMe" type="checkbox"
                       class="w-4 h-4 rounded border-gray-300 accent-[#003d9b]" />
                Ghi nhớ đăng nhập
            </label>

            <!-- Submit -->
            <button type="submit"
                    class="w-full py-3 bg-[#003d9b] text-white font-bold rounded-xl hover:bg-[#0046b5] transition-colors text-sm tracking-wide">
                Đăng nhập
            </button>

            <!-- Divider -->
            <div class="divider">Hoặc đăng nhập với</div>

            <!-- Social -->
            <div class="grid grid-cols-2 gap-3">
                <button type="button" class="social-btn">
                    <svg width="18" height="18" viewBox="0 0 24 24">
                        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4" />
                        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853" />
                        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05" />
                        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335" />
                    </svg>
                    Google
                </button>
                <button type="button" class="social-btn">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="#0077B5">
                        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                    </svg>
                    LinkedIn
                </button>
            </div>
        </form>
    </div>

    <!-- Footer -->
    <p class="text-sm text-gray-500 mt-5">
        Bạn chưa có tài khoản?
        <a asp-controller="Account" asp-action="Register" class="text-[#003d9b] font-bold hover:underline">Đăng ký ngay</a>
    </p>
    <p class="text-sm text-gray-500 mt-2">
        Nhà tuyển dụng?
        <a asp-controller="Account" asp-action="RegisterEmployer" class="text-[#003d9b] font-bold hover:underline">Đăng ký tại đây</a>
    </p>
    <div class="flex gap-4 text-xs text-gray-400 mt-6">
        <span>© 2024 JobConnect. All rights reserved.</span>
        <a href="#" class="hover:text-[#003d9b]">Điều khoản</a>
        <a href="#" class="hover:text-[#003d9b]">Bảo mật</a>
        <a href="#" class="hover:text-[#003d9b]">Liên hệ</a>
    </div>
</body>
<script>
    function togglePwd() {
    const i = document.getElementById('passwordInput');
    const e = document.getElementById('eyeIcon');
    i.type = i.type === 'password' ? 'text' : 'password';
    e.textContent = i.type === 'password' ? 'visibility' : 'visibility_off';
    }
</script>
</html>
