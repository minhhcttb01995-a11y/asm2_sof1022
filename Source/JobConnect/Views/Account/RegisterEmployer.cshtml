@model JobConnect.ViewModels.RegisterEmployerViewModel
@{
    ViewData["Title"] = "Đăng ký Nhà tuyển dụng"; Layout = null;
    Layout = "_Layout";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng ký NTD – JobConnect</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body class="min-h-screen bg-[#f9f9ff] flex items-center justify-center font-[Inter] py-8">
    <div class="w-full max-w-lg bg-white rounded-2xl shadow-lg p-8 mx-4">
        <div class="text-center mb-8">
            <a href="/" class="text-2xl font-bold text-[#003d9b]">JobConnect</a>
            <h1 class="text-xl font-semibold text-gray-900 mt-2">Đăng ký Nhà tuyển dụng</h1>
        </div>
        <form asp-action="RegisterEmployer" method="post" class="space-y-4">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="text-red-600 text-sm bg-red-50 p-3 rounded-lg"></div>
            <h3 class="font-semibold text-gray-700 border-b pb-2">Thông tin liên hệ</h3>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Họ tên *</label>
                    <input asp-for="ContactName" class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm outline-none focus:border-[#003d9b]" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Số điện thoại</label>
                    <input asp-for="PhoneNumber" type="tel" class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm outline-none focus:border-[#003d9b]" />
                </div>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Email *</label>
                <input asp-for="Email" type="email" class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm outline-none focus:border-[#003d9b]" />
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Mật khẩu *</label>
                    <input asp-for="Password" type="password" class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm outline-none focus:border-[#003d9b]" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Xác nhận *</label>
                    <input asp-for="ConfirmPassword" type="password" class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm outline-none focus:border-[#003d9b]" />
                </div>
            </div>
            <h3 class="font-semibold text-gray-700 border-b pb-2 pt-2">Thông tin công ty</h3>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Tên công ty *</label>
                <input asp-for="CompanyName" class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm outline-none focus:border-[#003d9b]" />
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Mã số thuế</label>
                    <input asp-for="TaxCode" class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm outline-none focus:border-[#003d9b]" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Ngành nghề</label>
                    <input asp-for="Industry" class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm outline-none focus:border-[#003d9b]" />
                </div>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Địa chỉ</label>
                <input asp-for="Address" class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm outline-none focus:border-[#003d9b]" />
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Website</label>
                <input asp-for="Website" type="url" placeholder="https://..." class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm outline-none focus:border-[#003d9b]" />
            </div>
            <button type="submit" class="w-full py-3 bg-[#003d9b] text-white font-semibold rounded-xl hover:bg-[#0040a2] transition-colors">
                Đăng ký Nhà tuyển dụng
            </button>
        </form>
        <div class="mt-4 text-center text-sm text-gray-500">
            Đã có tài khoản? <a asp-controller="Account" asp-action="Login" class="text-[#003d9b] font-semibold hover:underline">Đăng nhập</a>
        </div>
    </div>
</body>
</html>