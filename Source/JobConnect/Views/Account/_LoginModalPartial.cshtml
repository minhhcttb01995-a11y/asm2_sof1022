@* [VIEW-HEADER-ADDED]
   Partial view: popup modal đăng nhập (hiển thị đè lên trang hiện tại, không chuyển trang).
*@
@model JobConnect.ViewModels.LoginViewModel
@{
    Layout = null;
}
<form id="authForm" asp-action="Login" asp-controller="Account" method="post" class="space-y-5" novalidate>
    @Html.AntiForgeryToken()
    <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

    @if (!ViewData.ModelState.IsValid && ViewData.ModelState[""] != null)
    {
        <div class="p-3 bg-rose-50 border border-rose-200 rounded-xl text-rose-600 text-sm">
            @foreach (var error in ViewData.ModelState[""]!.Errors)
            {
                <p>@error.ErrorMessage</p>
            }
        </div>
    }

    <div>
        <label class="block text-[0.7rem] font-bold tracking-wider uppercase text-slate-400 mb-2">
            <span class="material-symbols-outlined text-sm align-middle mr-1">mail</span>
            Email hoặc tên đăng nhập
        </label>
        <input asp-for="Email" type="email" placeholder="example@jobconnect.com"
               class="w-full px-4 py-3.5 bg-slate-100 border border-slate-200 rounded-xl text-sm outline-none focus:border-primary focus:ring-2 focus:ring-primary/20" />
        <span asp-validation-for="Email" class="text-rose-600 text-xs mt-1 block"></span>
    </div>

    <div>
        <div class="flex justify-between items-center mb-1">
            <label class="block text-[0.7rem] font-bold tracking-wider uppercase text-slate-400">
                <span class="material-symbols-outlined text-sm align-middle mr-1">lock</span>
                Mật khẩu
            </label>
            <a href="/Account/ForgotPassword" class="text-xs text-primary font-semibold hover:text-blue-700">Quên mật khẩu?</a>
        </div>
        <div class="relative">
            <input asp-for="Password" type="password" id="authPasswordInput" placeholder="••••••••"
                   class="w-full px-4 py-3.5 bg-slate-100 border border-slate-200 rounded-xl text-sm outline-none focus:border-primary focus:ring-2 focus:ring-primary/20" style="padding-right:2.75rem" />
            <button type="button" onclick="jcTogglePwd('authPasswordInput', 'authEyeIcon')" class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-500 hover:text-primary">
                <span class="material-symbols-outlined text-xl leading-none" id="authEyeIcon">visibility_off</span>
            </button>
        </div>
        <span asp-validation-for="Password" class="text-rose-600 text-xs mt-1 block"></span>
    </div>

    <label class="flex items-center gap-2 cursor-pointer text-sm text-slate-600">
        <input asp-for="RememberMe" type="checkbox" class="w-4 h-4 rounded border-slate-300 text-primary" />
        Ghi nhớ đăng nhập
    </label>

    <button type="submit" class="w-full py-3 bg-gradient-to-r from-blue-600 to-indigo-600 text-white font-bold rounded-xl hover:from-blue-700 hover:to-indigo-700 transition-all text-sm shadow-lg shadow-blue-900/20">
        <span class="material-symbols-outlined text-sm align-middle mr-1">login</span>
        Đăng nhập
    </button>

    <div class="flex items-center gap-3 my-2">
        <div class="flex-1 h-px bg-slate-200"></div>
        <span class="text-xs text-slate-500 font-medium">HOẶC ĐĂNG NHẬP VỚI</span>
        <div class="flex-1 h-px bg-slate-200"></div>
    </div>

    <div class="grid grid-cols-2 gap-3">
        <a asp-controller="Account" asp-action="ExternalLogin" asp-route-provider="Google" asp-route-returnUrl="@ViewBag.ReturnUrl"
           class="flex items-center justify-center gap-2 py-2.5 bg-slate-100 border border-slate-200 rounded-xl text-sm font-semibold text-slate-800 hover:border-primary hover:bg-blue-50 transition-all">
            <svg width="18" height="18" viewBox="0 0 24 24">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4" />
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853" />
                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05" />
                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335" />
            </svg>
            Google
        </a>
        <button type="button" onclick="alert('Tính năng đang phát triển')"
                class="flex items-center justify-center gap-2 py-2.5 bg-slate-100 border border-slate-200 rounded-xl text-sm font-semibold text-slate-800 hover:border-primary hover:bg-blue-50 transition-all">
            <svg width="18" height="18" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286z" fill="#0A66C2" />
                <path d="M5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452z" fill="#0A66C2" />
                <path d="M22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" fill="#0A66C2" />
            </svg>
            LinkedIn
        </button>
    </div>
</form>

<div class="text-center mt-5 text-sm text-slate-600">
    <p>Bạn chưa có tài khoản?
        <a href="#" class="text-primary font-bold hover:text-blue-700" onclick="jcOpenAuth(event, 'register')">Đăng ký ngay</a>
    </p>
    <p class="mt-1">Nhà tuyển dụng?
        <a href="#" class="text-primary font-bold hover:text-blue-700" onclick="jcOpenAuth(event, 'register-employer')">Đăng ký tại đây</a>
    </p>
</div>
