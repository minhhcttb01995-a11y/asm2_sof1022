@using System.Security.Claims
@{
    ViewData["Title"] = "Cài đặt tài khoản";
    Layout = "_Layout";
}

<div class="max-w-2xl mx-auto px-6 py-8">
    <h1 class="text-2xl font-bold text-on-surface mb-6">Cài đặt tài khoản</h1>

    @if (TempData["Success"] is string ok)
    {
        <div class="mb-4 px-4 py-3 bg-green-50 border border-green-200 text-green-800 rounded-xl text-sm flex items-center gap-2">
            <span class="material-symbols-outlined text-sm">check_circle</span> @ok
        </div>
    }
    @if (TempData["Error"] is string err)
    {
        <div class="mb-4 px-4 py-3 bg-red-50 border border-red-200 text-red-800 rounded-xl text-sm flex items-center gap-2">
            <span class="material-symbols-outlined text-sm">error</span> @err
        </div>
    }

    <!-- Tabs -->
    <div class="flex border-b border-outline-variant mb-6 gap-1">
        <button onclick="switchTab('password')" id="tab-password"
                class="tab-btn px-4 py-2.5 text-sm font-medium border-b-2 border-primary text-primary">
            Đổi mật khẩu
        </button>
        <button onclick="switchTab('email')" id="tab-email"
                class="tab-btn px-4 py-2.5 text-sm font-medium border-b-2 border-transparent text-secondary hover:text-on-surface">
            Đổi email
        </button>
        <button onclick="switchTab('danger')" id="tab-danger"
                class="tab-btn px-4 py-2.5 text-sm font-medium border-b-2 border-transparent text-secondary hover:text-on-surface">
            Xóa tài khoản
        </button>
    </div>

    <!-- Tab: Đổi mật khẩu -->
    <div id="panel-password">
        <form asp-action="ChangePassword" asp-controller="Account" method="post"
              class="bg-white rounded-2xl p-6 shadow-sm border border-outline-variant space-y-4">
            @Html.AntiForgeryToken()
            <h2 class="font-semibold text-on-surface">Đổi mật khẩu</h2>
            <div>
                <label class="block text-sm font-medium text-secondary mb-1">Mật khẩu hiện tại <span class="text-red-500">*</span></label>
                <input type="password" name="CurrentPassword" class="form-input" placeholder="Nhập mật khẩu hiện tại" />
            </div>
            <div>
                <label class="block text-sm font-medium text-secondary mb-1">Mật khẩu mới <span class="text-red-500">*</span></label>
                <input type="password" name="NewPassword" class="form-input" placeholder="Tối thiểu 8 ký tự, có chữ hoa và số" />
            </div>
            <div>
                <label class="block text-sm font-medium text-secondary mb-1">Xác nhận mật khẩu mới <span class="text-red-500">*</span></label>
                <input type="password" name="ConfirmPassword" class="form-input" placeholder="Nhập lại mật khẩu mới" />
            </div>
            <button type="submit"
                    class="w-full py-2.5 bg-primary text-white rounded-xl font-semibold text-sm hover:opacity-90">
                Cập nhật mật khẩu
            </button>
        </form>
    </div>

    <!-- Tab: Đổi email -->
    <div id="panel-email" class="hidden">
        <form asp-action="ChangeEmail" asp-controller="Account" method="post"
              class="bg-white rounded-2xl p-6 shadow-sm border border-outline-variant space-y-4">
            @Html.AntiForgeryToken()
            <h2 class="font-semibold text-on-surface">Đổi địa chỉ Email</h2>
            <div>
                <label class="block text-sm font-medium text-secondary mb-1">Email hiện tại</label>
                <input type="email" value="@User.FindFirst(ClaimTypes.Email)?.Value"
                       class="form-input bg-surface-container" readonly />
            </div>
            <div>
                <label class="block text-sm font-medium text-secondary mb-1">Email mới <span class="text-red-500">*</span></label>
                <input type="email" name="NewEmail" class="form-input" placeholder="email-moi@example.com" />
            </div>
            <div>
                <label class="block text-sm font-medium text-secondary mb-1">Xác nhận bằng mật khẩu <span class="text-red-500">*</span></label>
                <input type="password" name="Password" class="form-input" placeholder="Mật khẩu hiện tại" />
            </div>
            <button type="submit"
                    class="w-full py-2.5 bg-primary text-white rounded-xl font-semibold text-sm hover:opacity-90">
                Cập nhật email
            </button>
        </form>
    </div>

    <!-- Tab: Xóa tài khoản -->
    <div id="panel-danger" class="hidden">
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-red-200 space-y-4">
            <div class="flex items-start gap-3">
                <div class="w-10 h-10 rounded-full bg-red-50 flex items-center justify-center shrink-0">
                    <span class="material-symbols-outlined text-error">warning</span>
                </div>
                <div>
                    <h2 class="font-semibold text-red-700">Xóa tài khoản vĩnh viễn</h2>
                    <p class="text-sm text-secondary mt-1">
                        Hành động này không thể hoàn tác. Tất cả dữ liệu của bạn bao gồm hồ sơ,
                        đơn ứng tuyển và CV sẽ bị xóa hoàn toàn.
                    </p>
                </div>
            </div>
            <form asp-action="DeleteAccount" asp-controller="Account" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="block text-sm font-medium text-secondary mb-1">
                        Nhập mật khẩu để xác nhận
                    </label>
                    <input type="password" name="Password" class="form-input border-red-200 focus:border-red-400"
                           placeholder="Mật khẩu của bạn" />
                </div>
                <button type="submit"
                        data-confirm="Bạn có CHẮC CHẮN muốn xóa tài khoản? Hành động này KHÔNG THỂ hoàn tác!"
                        class="w-full py-2.5 bg-red-600 text-white rounded-xl font-semibold text-sm hover:bg-red-700 transition-colors">
                    Xóa tài khoản vĩnh viễn
                </button>
            </form>
        </div>
    </div>
</div>

<script>
    function switchTab(name) {
      ['password','email','danger'].forEach(t => {
        document.getElementById('panel-' + t).classList.toggle('hidden', t !== name);
        const btn = document.getElementById('tab-' + t);
        btn.classList.toggle('border-primary', t === name);
        btn.classList.toggle('text-primary',   t === name);
        btn.classList.toggle('border-transparent', t !== name);
        btn.classList.toggle('text-secondary', t !== name);
      });
    }
</script>