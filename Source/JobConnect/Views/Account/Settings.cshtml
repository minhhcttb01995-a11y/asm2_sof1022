@* [VIEW-HEADER-ADDED]
   View cho action "Settings" trong khu vực quản lý tài khoản (AccountController).
*@
@using System.Security.Claims
@{
    ViewData["Title"] = "Cài đặt tài khoản";
    Layout = "_Layout";
}

<style>
    body {
        background-color: #f8fafc !important;
    }

    .settings-bg {
        background: linear-gradient(135deg, #eff6ff 0%, #f8fafc 60%, #ffffff 100%);
        min-height: 100vh;
        position: relative;
        overflow: hidden;
    }

    /* Ambient glow */
    .glow-blue {
        position: absolute;
        width: 500px;
        height: 500px;
        background: radial-gradient(circle, rgba(37,99,235,0.10) 0%, transparent 70%);
        border-radius: 50%;
        pointer-events: none;
    }

    .glow-purple {
        position: absolute;
        width: 400px;
        height: 400px;
        background: radial-gradient(circle, rgba(139,92,246,0.08) 0%, transparent 70%);
        border-radius: 50%;
        pointer-events: none;
    }

    /* Glass card */
    .glass-card {
        background: rgba(255,255,255,0.85);
        border: 1px solid rgba(15,23,42,0.08);
        box-shadow: 0 8px 24px rgba(15,23,42,0.06);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
    }

    /* Tab pill */
    .tab-active {
        background: linear-gradient(135deg, #2563eb, #7c3aed);
        color: #fff;
        box-shadow: 0 4px 15px rgba(37,99,235,0.25);
    }

    .tab-inactive {
        color: rgba(15,23,42,0.55);
    }

        .tab-inactive:hover {
            color: rgba(15,23,42,0.85);
            background: rgba(15,23,42,0.04);
        }

    /* Input */
    .dark-input {
        width: 100%;
        padding: 11px 16px;
        background: #ffffff;
        border: 1px solid rgba(15,23,42,0.12);
        border-radius: 12px;
        color: #0f172a;
        font-size: 14px;
        outline: none;
        transition: all 0.2s;
    }

        .dark-input::placeholder {
            color: rgba(15,23,42,0.35);
        }

        .dark-input:focus {
            border-color: rgba(59,130,246,0.6);
            background: rgba(59,130,246,0.05);
            box-shadow: 0 0 0 3px rgba(59,130,246,0.12);
        }

        .dark-input[readonly] {
            color: rgba(15,23,42,0.45);
            background: rgba(15,23,42,0.03);
            cursor: not-allowed;
        }

    /* Button */
    .btn-primary {
        width: 100%;
        padding: 12px;
        background: linear-gradient(135deg, #2563eb 0%, #3b82f6 100%);
        border: none;
        border-radius: 12px;
        color: #fff;
        font-weight: 600;
        font-size: 14px;
        cursor: pointer;
        transition: all 0.2s;
        box-shadow: 0 4px 15px rgba(37,99,235,0.25);
    }

        .btn-primary:hover {
            opacity: 0.92;
            box-shadow: 0 6px 20px rgba(37,99,235,0.35);
            transform: translateY(-1px);
        }

    .btn-danger {
        width: 100%;
        padding: 12px;
        background: linear-gradient(135deg, #dc2626, #b91c1c);
        border: none;
        border-radius: 12px;
        color: #fff;
        font-weight: 600;
        font-size: 14px;
        cursor: pointer;
        transition: all 0.2s;
        box-shadow: 0 4px 15px rgba(220,38,38,0.25);
    }

        .btn-danger:hover {
            opacity: 0.92;
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(220,38,38,0.35);
        }

    label.field-label {
        display: block;
        font-size: 13px;
        font-weight: 500;
        color: rgba(15,23,42,0.55);
        margin-bottom: 6px;
    }
</style>

<div class="settings-bg py-14 px-4">
    <!-- Ambient glows -->
    <div class="glow-blue" style="top:-100px;left:-100px;"></div>
    <div class="glow-purple" style="bottom:0;right:-80px;"></div>

    <div class="relative z-10 max-w-lg mx-auto">

        <!-- Header -->
        <div class="text-center mb-10">
            <div class="inline-flex w-14 h-14 rounded-2xl items-center justify-center mb-4"
                 style="background:rgba(37,99,235,0.10);border:1px solid rgba(59,130,246,0.20);">
                <span class="material-symbols-outlined text-blue-600 text-2xl">settings</span>
            </div>
            <h1 class="text-3xl font-bold text-slate-900 mb-2">Cài đặt tài khoản</h1>
            <p class="text-sm" style="color:rgba(15,23,42,0.5);">Quản lý bảo mật và thông tin đăng nhập</p>
        </div>

        @if (TempData["Success"] is string ok)
        {
            <div class="mb-5 px-4 py-3 rounded-xl text-sm flex items-center gap-2 auto-hide-alert"
                 style="background:rgba(34,197,94,0.08);border:1px solid rgba(34,197,94,0.25);color:#16a34a;">
                <span class="material-symbols-outlined text-sm">check_circle</span> @ok
            </div>
        }
        @if (TempData["Error"] is string err)
        {
            <div class="mb-5 px-4 py-3 rounded-xl text-sm flex items-center gap-2"
                 style="background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.25);color:#dc2626;">
                <span class="material-symbols-outlined text-sm">error</span> @err
            </div>
        }

        <!-- Tabs -->
        <div class="flex gap-1 p-1 rounded-2xl mb-6 glass-card">
            <button onclick="switchTab('password')" id="tab-password"
                    class="tab-btn flex-1 py-2.5 px-3 text-sm font-medium rounded-xl transition-all tab-active">
                <span class="flex items-center justify-center gap-1.5">
                    <span class="material-symbols-outlined text-sm">lock</span>
                    <span class="hidden sm:inline">Đổi</span> mật khẩu
                </span>
            </button>
            <button onclick="switchTab('email')" id="tab-email"
                    class="tab-btn flex-1 py-2.5 px-3 text-sm font-medium rounded-xl transition-all tab-inactive">
                <span class="flex items-center justify-center gap-1.5">
                    <span class="material-symbols-outlined text-sm">mail</span>
                    <span class="hidden sm:inline">Đổi</span> email
                </span>
            </button>
            <button onclick="switchTab('danger')" id="tab-danger"
                    class="tab-btn flex-1 py-2.5 px-3 text-sm font-medium rounded-xl transition-all tab-inactive">
                <span class="flex items-center justify-center gap-1.5">
                    <span class="material-symbols-outlined text-sm">delete_forever</span>
                    Xóa TK
                </span>
            </button>
        </div>

        <!-- Panel: Đổi mật khẩu -->
        <div id="panel-password">
            <form asp-action="ChangePassword" asp-controller="Account" method="post"
                  class="glass-card rounded-2xl p-7 space-y-5">
                @Html.AntiForgeryToken()
                <div class="flex items-center gap-2 mb-1">
                    <span class="material-symbols-outlined text-blue-600 text-base">lock</span>
                    <h2 class="font-semibold text-slate-900">Đổi mật khẩu</h2>
                </div>
                <div>
                    <label class="field-label">Mật khẩu hiện tại <span style="color:#ef4444">*</span></label>
                    <input type="password" name="CurrentPassword" class="dark-input" placeholder="Nhập mật khẩu hiện tại" />
                </div>
                <div>
                    <label class="field-label">Mật khẩu mới <span style="color:#ef4444">*</span></label>
                    <input type="password" name="NewPassword" class="dark-input" placeholder="Tối thiểu 8 ký tự, có chữ hoa và số" />
                </div>
                <div>
                    <label class="field-label">Xác nhận mật khẩu mới <span style="color:#ef4444">*</span></label>
                    <input type="password" name="ConfirmPassword" class="dark-input" placeholder="Nhập lại mật khẩu mới" />
                </div>
                <button type="submit" class="btn-primary">Cập nhật mật khẩu</button>
                <p class="text-xs text-center" style="color:rgba(15,23,42,0.4);">
                    <span class="material-symbols-outlined text-xs align-middle">verified_user</span>
                    Yêu cầu xác thực mã OTP gửi qua email trước khi áp dụng.
                </p>
            </form>
        </div>

        <!-- Panel: Đổi email -->
        <div id="panel-email" class="hidden">
            <form asp-action="ChangeEmail" asp-controller="Account" method="post"
                  class="glass-card rounded-2xl p-7 space-y-5">
                @Html.AntiForgeryToken()
                <div class="flex items-center gap-2 mb-1">
                    <span class="material-symbols-outlined text-blue-600 text-base">mail</span>
                    <h2 class="font-semibold text-slate-900">Đổi địa chỉ Email</h2>
                </div>
                <div>
                    <label class="field-label">Email hiện tại</label>
                    <input type="email" value="@User.FindFirst(ClaimTypes.Email)?.Value" class="dark-input" readonly />
                </div>
                <div>
                    <label class="field-label">Email mới <span style="color:#ef4444">*</span></label>
                    <input type="email" name="NewEmail" class="dark-input" placeholder="email-moi@example.com" />
                </div>
                <div>
                    <label class="field-label">Xác nhận bằng mật khẩu <span style="color:#ef4444">*</span></label>
                    <input type="password" name="Password" class="dark-input" placeholder="Mật khẩu hiện tại" />
                </div>
                <button type="submit" class="btn-primary">Cập nhật email</button>
                <p class="text-xs text-center" style="color:rgba(15,23,42,0.4);">
                    <span class="material-symbols-outlined text-xs align-middle">verified_user</span>
                    Mã OTP xác thực sẽ được gửi đến email mới để xác nhận quyền sở hữu.
                </p>
            </form>
        </div>

        <!-- Panel: Xóa tài khoản -->
        <div id="panel-danger" class="hidden">
            <div class="rounded-2xl p-7 space-y-5"
                 style="background:rgba(239,68,68,0.04);border:1px solid rgba(239,68,68,0.18);backdrop-filter:blur(20px);">
                <div class="flex items-start gap-3">
                    <div class="w-10 h-10 rounded-full flex items-center justify-center shrink-0"
                         style="background:rgba(239,68,68,0.12);">
                        <span class="material-symbols-outlined text-red-500">warning</span>
                    </div>
                    <div>
                        <h2 class="font-semibold" style="color:#dc2626;">Xóa tài khoản vĩnh viễn</h2>
                        <p class="text-sm mt-1" style="color:rgba(15,23,42,0.5);">
                            Hành động này không thể hoàn tác. Tất cả dữ liệu bao gồm hồ sơ,
                            đơn ứng tuyển và CV sẽ bị xóa hoàn toàn.
                        </p>
                    </div>
                </div>
                <form asp-action="DeleteAccount" asp-controller="Account" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-4">
                        <label class="field-label">Nhập mật khẩu để xác nhận</label>
                        <input type="password" name="Password" class="dark-input"
                               style="border-color:rgba(239,68,68,0.3);"
                               placeholder="Mật khẩu của bạn" />
                    </div>
                    <button type="submit" class="btn-danger"
                            onclick="return confirm('Bạn có CHẮC CHẮN muốn xóa tài khoản? Hành động này KHÔNG THỂ hoàn tác!')">
                        Xóa tài khoản vĩnh viễn
                    </button>
                    <p class="text-xs text-center mt-3" style="color:rgba(15,23,42,0.4);">
                        <span class="material-symbols-outlined text-xs align-middle">verified_user</span>
                        Yêu cầu xác thực mã OTP gửi qua email trước khi xóa vĩnh viễn.
                    </p>
                </form>
            </div>
        </div>

    </div>
</div>

<script>
    // Tab switcher
    function switchTab(name) {
        ['password', 'email', 'danger'].forEach(t => {
            document.getElementById('panel-' + t).classList.toggle('hidden', t !== name);
            const btn = document.getElementById('tab-' + t);
            if (t === name) {
                btn.classList.add('tab-active');
                btn.classList.remove('tab-inactive');
            } else {
                btn.classList.remove('tab-active');
                btn.classList.add('tab-inactive');
            }
        });
    }
</script>
