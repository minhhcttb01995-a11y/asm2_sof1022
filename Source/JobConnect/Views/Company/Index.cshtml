@using JobConnect.Models
@model List<Employer>
@{
    ViewData["Title"] = "Danh sách công ty";
    Layout = "_Layout";
}

<style>
    /* NỀN ĐEN */
    body {
        background-color: #000000 !important;
    }

    .company-card {
        transition: all 0.22s cubic-bezier(0.4, 0, 0.2, 1);
        background: #0a0a0a;
        border: 1px solid #1a1a1a;
    }

        .company-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 24px rgba(59, 130, 246, 0.15);
            border-color: #3b82f6;
        }

    /* HIỆU ỨNG MƯA */
    .rain-container {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 9998;
        overflow: hidden;
    }

    .drop {
        position: absolute;
        background: linear-gradient(to bottom, rgba(96, 165, 250, 0.6) 0%, rgba(56, 189, 248, 0.3) 50%, rgba(96, 165, 250, 0) 100%);
        width: 2px;
        border-radius: 0 0 3px 3px;
        animation: fall linear infinite;
    }

    .drop-small {
        position: absolute;
        background: rgba(96, 165, 250, 0.3);
        width: 1px;
        border-radius: 0 0 2px 2px;
        animation: fall linear infinite;
    }

    @@keyframes fall {
        to {
            transform: translateY(110vh);
        }
    }

    /* Scrollbar */
    ::-webkit-scrollbar {
        width: 8px;
    }

    ::-webkit-scrollbar-track {
        background: #000000;
    }

    ::-webkit-scrollbar-thumb {
        background: #1a1a1a;
        border-radius: 4px;
    }

        ::-webkit-scrollbar-thumb:hover {
            background: #3b82f6;
        }

    /* Line clamp */
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>

<!-- Thêm container mưa -->
<div class="rain-container" id="rainContainer"></div>

<!-- Hero Banner -->
<div class="bg-gradient-to-br from-[#0a0a0a] to-[#050505] border-b border-[#1a1a1a] py-12 relative z-10">
    <div class="max-w-6xl mx-auto px-6 text-center">
        <h1 class="text-3xl md:text-4xl font-bold text-white mb-3">Khám phá các Công ty hàng đầu</h1>
        <p class="text-slate-400 text-base max-w-xl mx-auto mb-8">
            Tìm hiểu về môi trường làm việc, văn hóa và cơ hội nghề nghiệp tại những doanh nghiệp tốt nhất Việt Nam.
        </p>
        <form method="get" class="flex gap-2 max-w-2xl mx-auto bg-[#0a0a0a] rounded-xl shadow-sm border border-[#1a1a1a] p-2">
            <div class="flex items-center gap-2 flex-1 px-3">
                <span class="material-symbols-outlined text-slate-500">search</span>
                <input name="keyword" value="@ViewBag.Keyword" type="text"
                       placeholder="Tìm kiếm theo tên công ty..."
                       class="flex-1 border-none outline-none text-sm bg-transparent text-slate-200 placeholder:text-slate-500" />
            </div>
            <button type="submit" class="bg-blue-600 text-white px-6 py-2.5 rounded-lg text-sm font-bold hover:bg-blue-500 transition-all">
                Tìm kiếm
            </button>
        </form>
    </div>
</div>

<div class="max-w-6xl mx-auto px-6 py-8 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">

        <!-- Sidebar Filter -->
        <aside class="lg:col-span-3">
            <div class="bg-[#0a0a0a] rounded-2xl border border-[#1a1a1a] p-5 shadow-sm sticky top-4">
                <div class="flex items-center justify-between mb-5">
                    <h2 class="font-bold text-white flex items-center gap-2">
                        <span class="material-symbols-outlined text-base">tune</span>
                        Bộ lọc
                    </h2>
                    <a asp-action="Index" class="text-blue-400 text-xs font-bold hover:underline">Xóa tất cả</a>
                </div>

                <form method="get" id="filterForm">
                    <!-- Industry -->
                    <div class="mb-5">
                        <label class="block text-xs font-bold uppercase text-slate-500 tracking-wider mb-2">🏷️ Ngành nghề</label>
                        <select name="industry"
                                onchange="this.form.submit()"
                                class="w-full px-3 py-2.5 border border-[#1a1a1a] rounded-lg bg-black text-slate-200 text-sm focus:border-blue-500 outline-none">
                            <option value="">Tất cả ngành nghề</option>
                            @foreach (var cat in (ViewBag.Industries as List<Category> ?? new()))
                            {
                                <option value="@cat.Name" selected="@(ViewBag.Industry == cat.Name ? "selected" : null)">@cat.Name</option>
                            }
                        </select>
                    </div>

                    <!-- Company Size -->
                    <div class="mb-5">
                        <label class="block text-xs font-bold uppercase text-slate-500 tracking-wider mb-2">📊 Quy mô công ty</label>
                        <div class="space-y-2">
                            @foreach (var (label, val) in new[]{
                                ("1 - 50 nhân viên","1-50"),
                                ("51 - 200 nhân viên","51-200"),
                                ("201 - 500 nhân viên","201-500"),
                                ("500+ nhân viên","500+")
                            })
                            {
                                <label class="flex items-center gap-2.5 cursor-pointer group">
                                    <input type="checkbox" name="Size" value="@val"
                                           checked="@(ViewBag.Size == val ? "checked" : null)"
                                           class="w-4 h-4 rounded border-[#1a1a1a] text-blue-500 focus:ring-blue-500 bg-black" />
                                    <span class="text-sm text-slate-300 group-hover:text-blue-400 transition-colors">@label</span>
                                </label>
                            }
                        </div>
                    </div>

                    <!-- Location -->
                    <div>
                        <label class="block text-xs font-bold uppercase text-slate-500 tracking-wider mb-2">📍 Địa điểm</label>
                        <select name="location"
                                onchange="this.form.submit()"
                                class="w-full px-3 py-2.5 border border-[#1a1a1a] rounded-lg bg-black text-slate-200 text-sm focus:border-blue-500 outline-none">
                            <option value="">Toàn quốc</option>
                            <option value="Hà Nội">Hà Nội</option>
                            <option value="TP. Hồ Chí Minh">TP. Hồ Chí Minh</option>
                            <option value="Đà Nẵng">Đà Nẵng</option>
                        </select>
                    </div>
                </form>
            </div>
        </aside>

        <!-- Main Content -->
        <section class="lg:col-span-9">
            <!-- Result bar -->
            <div class="flex items-center justify-between mb-5">
                <p class="text-sm text-slate-500">
                    Hiển thị <strong class="text-white">@Model.Count</strong> kết quả
                    @if (!string.IsNullOrEmpty(ViewBag.Keyword as string))
                    {
                        <span> cho "<strong class="text-blue-400">@ViewBag.Keyword</strong>"</span>
                    }
                </p>
                <div class="flex items-center gap-2 bg-[#0a0a0a] border border-[#1a1a1a] rounded-lg px-3 py-2">
                    <span class="text-xs text-slate-500">Sắp xếp:</span>
                    <select id="sortSelect" class="border-none bg-transparent text-blue-400 text-sm font-bold outline-none cursor-pointer">
                        <option class="bg-black">Phổ biến nhất</option>
                        <option class="bg-black">Mới nhất</option>
                        <option class="bg-black">Nhiều việc nhất</option>
                    </select>
                </div>
            </div>

            @if (!Model.Any())
            {
                <div class="bg-[#0a0a0a] rounded-2xl border border-[#1a1a1a] p-16 text-center">
                    <span class="material-symbols-outlined text-5xl text-slate-600 block mb-3">domain_disabled</span>
                    <p class="text-slate-400 font-medium">Không tìm thấy công ty phù hợp.</p>
                    <a asp-action="Index" class="text-blue-400 text-sm mt-3 inline-block hover:underline">← Xóa bộ lọc</a>
                </div>
            }
            else
            {
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    @foreach (var emp in Model)
                    {
                        <a asp-controller="Company" asp-action="Detail" asp-route-id="@emp.EmployerID"
                           class="bg-[#0a0a0a] rounded-2xl border border-[#1a1a1a] p-5 company-card block group">
                            <div class="flex justify-between items-start mb-3">
                                <!-- Logo -->
                                <div class="w-14 h-14 rounded-xl border border-[#1a1a1a] bg-black flex items-center justify-center overflow-hidden shrink-0">
                                    @if (!string.IsNullOrEmpty(emp.LogoURL))
                                    {
                                        <img src="@emp.LogoURL" class="w-full h-full object-contain" />
                                    }
                                    else
                                    {
                                        <span class="material-symbols-outlined text-slate-500 text-2xl">business</span>
                                    }
                                </div>
                                <button class="text-slate-600 hover:text-rose-400 transition-colors" onclick="event.preventDefault();">
                                    <span class="material-symbols-outlined">favorite_border</span>
                                </button>
                            </div>

                            <!-- Name + verified -->
                            <div class="flex items-center gap-1.5 mb-0.5">
                                <h3 class="font-bold text-white text-base group-hover:text-blue-400 transition-colors">@emp.CompanyName</h3>
                                @if (emp.IsVerified)
                                {
                                    <span class="material-symbols-outlined text-blue-400 text-base" title="Đã xác minh">verified</span>
                                }
                            </div>

                            <!-- Industry tag -->
                            @if (!string.IsNullOrEmpty(emp.Industry))
                            {
                                <div class="flex items-center gap-1 text-xs text-slate-500 mb-2">
                                    <span class="material-symbols-outlined text-sm">category</span>
                                    @emp.Industry
                                </div>
                            }

                            <!-- Description -->
                            @if (!string.IsNullOrEmpty(emp.Description))
                            {
                                <p class="text-sm text-slate-400 line-clamp-2 mb-3">@emp.Description</p>
                            }
                            else
                            {
                                <div class="mb-3"></div>
                            }

                            <!-- Footer -->
                            <div class="flex items-center justify-between pt-3 border-t border-[#1a1a1a]">
                                <span class="bg-blue-600/20 text-blue-400 px-3 py-1.5 rounded-lg text-xs font-bold border border-blue-800/30">
                                    📋 @(emp.JobPosts?.Count(j => j.Status == "Open") ?? 0) Việc làm đang tuyển
                                </span>
                                @if (!string.IsNullOrEmpty(emp.Address))
                                {
                                    <span class="flex items-center gap-1 text-xs text-slate-500">
                                        <span class="material-symbols-outlined text-sm">location_on</span>
                                        @emp.Address
                                    </span>
                                }
                            </div>
                        </a>
                    }
                </div>

                <!-- Pagination -->
                @if ((int)(ViewBag.TotalPages ?? 1) > 1)
                {
                    int currentPage = (int)(ViewBag.Page ?? 1);
                    int totalPages = (int)ViewBag.TotalPages;
                    <div class="flex justify-center items-center gap-1.5 mt-8">
                        @if (currentPage > 1)
                        {
                            <a asp-action="Index" asp-route-page="@(currentPage - 1)" asp-route-keyword="@ViewBag.Keyword"
                               class="w-10 h-10 flex items-center justify-center rounded-lg border border-[#1a1a1a] hover:bg-[#111111] transition-colors text-slate-400">
                                <span class="material-symbols-outlined">chevron_left</span>
                            </a>
                        }
                        @for (int i = 1; i <= totalPages; i++)
                        {
                            if (i == 1 || i == totalPages || (i >= currentPage - 1 && i <= currentPage + 1))
                            {
                                <a asp-action="Index" asp-route-page="@i" asp-route-keyword="@ViewBag.Keyword"
                                   class="w-10 h-10 flex items-center justify-center rounded-lg text-sm font-bold transition-colors
                                    @(i == currentPage ? "bg-blue-600 text-white" : "border border-[#1a1a1a] text-slate-400 hover:bg-[#111111]")">
                                    @i
                                </a>
                            }
                            else if (i == currentPage - 2 || i == currentPage + 2)
                            {
                                <span class="w-10 h-10 flex items-center justify-center text-slate-600">…</span>
                            }
                        }
                        @if (currentPage < totalPages)
                        {
                            <a asp-action="Index" asp-route-page="@(currentPage + 1)" asp-route-keyword="@ViewBag.Keyword"
                               class="w-10 h-10 flex items-center justify-center rounded-lg border border-[#1a1a1a] hover:bg-[#111111] transition-colors text-slate-400">
                                <span class="material-symbols-outlined">chevron_right</span>
                            </a>
                        }
                    </div>
                }
            }
        </section>
    </div>
</div>

@section Scripts {
    <script>
        // Hiệu ứng mưa
        function initRain() {
            const container = document.getElementById('rainContainer');
            if (!container) return;
            container.innerHTML = '';

            for (let i = 0; i < 35; i++) {
                const drop = document.createElement('div');
                drop.classList.add('drop');
                drop.style.left = Math.random() * 100 + '%';
                drop.style.animationDuration = (Math.random() * 1.2 + 0.8) + 's';
                drop.style.animationDelay = (Math.random() * 8) + 's';
                drop.style.height = (Math.random() * 40 + 40) + 'px';
                drop.style.opacity = Math.random() * 0.4 + 0.15;
                container.appendChild(drop);
            }

            for (let i = 0; i < 50; i++) {
                const drop = document.createElement('div');
                drop.classList.add('drop-small');
                drop.style.left = Math.random() * 100 + '%';
                drop.style.animationDuration = (Math.random() * 1.5 + 0.6) + 's';
                drop.style.animationDelay = (Math.random() * 10) + 's';
                drop.style.height = (Math.random() * 20 + 15) + 'px';
                drop.style.opacity = Math.random() * 0.25 + 0.1;
                container.appendChild(drop);
            }
        }

        // Auto submit filter when checkbox changes
        document.querySelectorAll('#filterForm input[type="checkbox"]').forEach(el => {
            el.addEventListener('change', () => {
                document.getElementById('filterForm').submit();
            });
        });

        // Sort functionality
        document.getElementById('sortSelect')?.addEventListener('change', (e) => {
            const currentUrl = new URL(window.location.href);
            currentUrl.searchParams.set('sort', e.target.value);
            window.location.href = currentUrl.toString();
        });

        document.addEventListener('DOMContentLoaded', initRain);
    </script>
}