@using System.Linq
@using System.Security.Claims
@{
    ViewData["Title"] = "Tin nhắn";
    var role = User.FindFirst(ClaimTypes.Role)?.Value ?? "";
    Layout = (role == "Staff" || role == "Admin") ? "_StaffLayout"
             : (role == "Employer") ? "_LayoutEmployer"
             : "_Layout";

    bool hasConversations = false;
    if (ViewBag.Conversations != null)
    {
        try { hasConversations = ((System.Collections.IEnumerable)ViewBag.Conversations).Cast<object>().Any(); }
        catch { }
    }
}

<div class="max-w-4xl mx-auto px-4 py-8">
    <h1 class="text-2xl font-bold text-white mb-6">Tin nhắn</h1>

    @if (!hasConversations)
    {
        <div class="text-center py-12">
            <span class="material-symbols-outlined text-slate-600 text-6xl mb-4">chat_bubble_outline</span>
            <p class="text-slate-300 mb-1">Bạn chưa có cuộc trò chuyện nào.</p>
            @if (ViewBag.AvailableStaff != null)
            {
                <p class="text-slate-500 text-sm mb-6">Chọn nhân viên hỗ trợ để bắt đầu trò chuyện:</p>
                <div class="max-w-md mx-auto bg-slate-900 rounded-2xl border border-slate-800 overflow-hidden shadow-xl text-left">
                    @foreach (var staff in ViewBag.AvailableStaff)
                    {
                        <a asp-action="StartConversation" asp-route-staffId="@staff.UserID"
                           class="block border-b border-slate-800 last:border-0 hover:bg-white/5 transition-colors">
                            <div class="p-4 flex items-center gap-4">
                                <div class="w-12 h-12 bg-purple-500/20 rounded-full flex items-center justify-center text-purple-400 font-bold flex-shrink-0">
                                    @(staff.FullName?[0].ToString().ToUpper() ?? "S")
                                </div>
                                <div class="flex-1 min-w-0">
                                    <h3 class="font-semibold text-white truncate">@staff.FullName</h3>
                                    <p class="text-sm text-slate-400 truncate">@staff.Staff?.Position</p>
                                </div>
                                <span class="material-symbols-outlined text-slate-500">chevron_right</span>
                            </div>
                        </a>
                    }
                </div>
            }
        </div>
    }
    else
    {
        var conversations = (dynamic)ViewBag.Conversations;
        <div class="bg-slate-900 rounded-2xl border border-slate-800 overflow-hidden shadow-xl">
            @foreach (var conv in conversations)
            {
                <a asp-action="Conversation" asp-route-userId="@conv.OtherUserId" class="block border-b border-slate-800 last:border-0 hover:bg-white/5 transition-colors">
                    <div class="p-4 flex items-center gap-4">
                        <div class="w-12 h-12 bg-blue-500/20 rounded-full flex items-center justify-center text-blue-400 font-bold flex-shrink-0">
                            @(conv.OtherUser.FullName?[0].ToString().ToUpper() ?? "U")
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="flex items-center justify-between gap-2">
                                <h3 class="font-semibold text-white truncate">@conv.OtherUser.FullName</h3>
                                <span class="text-xs text-slate-500 flex-shrink-0">@conv.LastMessage.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                            <p class="text-sm text-slate-400 truncate mt-1">@conv.LastMessage.Content</p>
                        </div>
                        @if (conv.UnreadCount > 0)
                        {
                            <span class="bg-blue-600 text-white text-xs font-bold px-2 py-1 rounded-full flex-shrink-0">
                                @conv.UnreadCount
                            </span>
                        }
                    </div>
                </a>
            }
        </div>
    }
</div>
