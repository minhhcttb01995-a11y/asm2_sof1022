@using System.Linq
@using System.Security.Claims
@{
    ViewData["Title"] = "Tin nhắn";
    var role = User.FindFirst(ClaimTypes.Role)?.Value ?? "";
    Layout = (role == "Admin") ? "_LayoutAdmin"
             : (role == "Staff") ? "_StaffLayout"
             : (role == "Employer") ? "_LayoutEmployer"
             : "_Layout";

    bool hasConversations = false;
    if (ViewBag.Conversations != null)
    {
        try { hasConversations = ((System.Collections.IEnumerable)ViewBag.Conversations).Cast<object>().Any(); }
        catch { }
    }
}

<div class="jc-inbox-page">
    <div class="jc-inbox-shell">

        <div class="jc-inbox-header">
            <div>
                <h1>Tin nhắn</h1>
                <p>Tất cả cuộc trò chuyện của bạn</p>
            </div>
            @if (role == "Admin")
            {
                <a asp-action="Contacts" class="jc-inbox-new-btn">
                    <span class="material-symbols-outlined">add_comment</span>
                    Nhắn tin mới
                </a>
            }
        </div>

        @if (!hasConversations)
        {
            <div class="jc-inbox-empty">
                <span class="material-symbols-outlined">chat_bubble_outline</span>
                <p class="jc-inbox-empty-title">Bạn chưa có cuộc trò chuyện nào.</p>

                @if (ViewBag.AvailableStaff != null)
                {
                    <p class="jc-inbox-empty-sub">Chọn nhân viên hỗ trợ để bắt đầu trò chuyện:</p>
                    <div class="jc-inbox-list jc-inbox-list-narrow">
                        @foreach (var staff in ViewBag.AvailableStaff)
                        {
                            <a asp-action="StartConversation" asp-route-staffId="@staff.UserId" class="jc-inbox-item">
                                <div class="jc-inbox-avatar jc-inbox-avatar-purple">
                                    @(staff.FullName?[0].ToString().ToUpper() ?? "S")
                                </div>
                                <div class="jc-inbox-item-body">
                                    <h3>@staff.FullName</h3>
                                    <p>@staff.Staff?.Position</p>
                                </div>
                                <span class="material-symbols-outlined jc-inbox-chevron">chevron_right</span>
                            </a>
                        }
                    </div>
                }
            </div>
        }
        else
        {
            var conversations = (dynamic)ViewBag.Conversations;
            <div class="jc-inbox-list">
                @foreach (var conv in conversations)
                {
                    bool unread = conv.UnreadCount > 0;
                    <a asp-action="Conversation" asp-route-userId="@conv.OtherUserId" class="jc-inbox-item @(unread ? "jc-inbox-item-unread" : "")">
                        <div class="jc-inbox-avatar">
                            @(conv.OtherUser.FullName?[0].ToString().ToUpper() ?? "U")
                        </div>
                        <div class="jc-inbox-item-body">
                            <div class="jc-inbox-item-top">
                                <h3>@conv.OtherUser.FullName</h3>
                                <span class="jc-inbox-time">@conv.LastMessage.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                            <p class="jc-inbox-preview">@conv.LastMessage.Content</p>
                        </div>
                        @if (unread)
                        {
                            <span class="jc-inbox-badge">@conv.UnreadCount</span>
                        }
                    </a>
                }
            </div>
        }
    </div>
</div>

<style>
    .jc-inbox-page {
        display: flex;
        justify-content: center;
        padding: 24px;
    }

    .jc-inbox-shell {
        width: 100%;
        max-width: 820px;
    }

    .jc-inbox-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 24px;
    }

        .jc-inbox-header h1 {
            margin: 0;
            font-size: 28px;
            font-weight: 800;
            color: #0f172a;
        }

        .jc-inbox-header p {
            margin: 4px 0 0;
            font-size: 14px;
            color: #64748b;
        }

    .jc-inbox-new-btn {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 12px 22px;
        background: linear-gradient(135deg,#2563eb,#3b82f6);
        color: #fff;
        border-radius: 12px;
        font-size: 14px;
        font-weight: 700;
        text-decoration: none;
        box-shadow: 0 8px 20px -6px rgba(37,99,235,.5);
        transition: filter .15s, transform .1s;
        white-space: nowrap;
    }

        .jc-inbox-new-btn:hover {
            filter: brightness(1.08);
            color: #fff;
        }

        .jc-inbox-new-btn:active {
            transform: scale(0.97);
        }

    .jc-inbox-list {
        background: #0f172a;
        border: 1px solid #1e293b;
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 16px 40px -18px rgba(0,0,0,.4);
    }

    .jc-inbox-list-narrow {
        max-width: 480px;
        margin: 0 auto;
        text-align: left;
    }

    .jc-inbox-item {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 18px 22px;
        border-bottom: 1px solid #1e293b;
        text-decoration: none;
        transition: background .15s;
    }

        .jc-inbox-item:last-child {
            border-bottom: none;
        }

        .jc-inbox-item:hover {
            background: rgba(255,255,255,.04);
        }

    .jc-inbox-item-unread {
        background: rgba(59,130,246,.06);
    }

        .jc-inbox-item-unread:hover {
            background: rgba(59,130,246,.1);
        }

    .jc-inbox-avatar {
        width: 54px;
        height: 54px;
        border-radius: 50%;
        background: linear-gradient(135deg,#3b82f6,#6366f1);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 20px;
        flex-shrink: 0;
        box-shadow: 0 4px 12px rgba(59,130,246,.35);
    }

    .jc-inbox-avatar-purple {
        background: linear-gradient(135deg,#8b5cf6,#a855f7);
        box-shadow: 0 4px 12px rgba(168,85,247,.35);
    }

    .jc-inbox-item-body {
        flex: 1;
        min-width: 0;
    }

    .jc-inbox-item-top {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 10px;
    }

    .jc-inbox-item-body h3 {
        margin: 0;
        font-size: 17px;
        font-weight: 700;
        color: #f1f5f9;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .jc-inbox-item-body > p {
        margin: 2px 0 0;
        font-size: 13px;
        color: #94a3b8;
    }

    .jc-inbox-time {
        font-size: 12px;
        color: #64748b;
        flex-shrink: 0;
    }

    .jc-inbox-preview {
        margin: 6px 0 0;
        font-size: 14px;
        color: #94a3b8;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .jc-inbox-item-unread .jc-inbox-preview {
        color: #cbd5e1;
        font-weight: 500;
    }

    .jc-inbox-badge {
        flex-shrink: 0;
        background: linear-gradient(135deg,#2563eb,#3b82f6);
        color: #fff;
        font-size: 12px;
        font-weight: 800;
        min-width: 24px;
        height: 24px;
        padding: 0 7px;
        border-radius: 999px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .jc-inbox-chevron {
        color: #64748b;
    }

    .jc-inbox-empty {
        text-align: center;
        padding: 60px 20px;
        background: #0f172a;
        border: 1px solid #1e293b;
        border-radius: 18px;
    }

        .jc-inbox-empty .material-symbols-outlined {
            font-size: 64px;
            color: #334155;
            margin-bottom: 14px;
        }

    .jc-inbox-empty-title {
        color: #cbd5e1;
        font-size: 16px;
        margin: 0 0 4px;
    }

    .jc-inbox-empty-sub {
        color: #64748b;
        font-size: 14px;
        margin: 0 0 24px;
    }

    @@media (max-width: 560px) {
        .jc-inbox-page {
            padding: 14px;
        }

        .jc-inbox-header h1 {
            font-size: 22px;
        }

        .jc-inbox-new-btn span:last-child {
            display: none;
        }

        .jc-inbox-new-btn {
            padding: 12px;
        }
    }
</style>
