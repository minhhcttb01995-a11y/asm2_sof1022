@using System.Security.Claims
@using System.Linq
@{
    ViewData["Title"] = "Tin nhắn";
    var role = User.FindFirst(ClaimTypes.Role)?.Value ?? "";
    Layout = (role == "Admin") ? "_LayoutAdmin"
             : (role == "Staff") ? "_StaffLayout"
             : (role == "Employer") ? "_LayoutEmployer"
             : "_Layout";

    string otherName = ViewBag.OtherUser?.FullName ?? "Người dùng";
    string otherInitial = otherName.Trim().Length > 0 ? otherName.Trim()[0].ToString().ToUpper() : "U";
    string otherRole = ViewBag.OtherUser?.Role ?? "";
}

<div class="jc-chat-page">
    <div class="jc-chat-shell">

        <!-- Header -->
        <div class="jc-chat-header">
            <a asp-action="Index" asp-controller="Chat" class="jc-chat-back" title="Quay lại danh sách">
                <span class="material-symbols-outlined">arrow_back</span>
            </a>
            <div class="jc-chat-avatar">@otherInitial</div>
            <div class="jc-chat-header-info">
                <h1>@otherName</h1>
                <span class="jc-chat-role-badge">@otherRole</span>
            </div>
            <div class="jc-chat-header-status">
                <span class="jc-dot"></span> Đang hoạt động
            </div>
        </div>

        <!-- Messages -->
        <div id="messagesContainer" class="jc-chat-messages">
            @{
                bool hasMessages = false;
                if (ViewBag.Messages != null)
                {
                    try { hasMessages = ((System.Collections.IEnumerable)ViewBag.Messages).Cast<object>().Any(); }
                    catch { }
                }
            }
            @if (hasMessages)
            {
                DateTime? lastDate = null;
                foreach (var msg in ViewBag.Messages)
                {
                    DateTime createdAt = msg.CreatedAt;
                    bool isOwn = msg.SenderId == ViewBag.CurrentUserId;

                    if (lastDate == null || lastDate.Value.Date != createdAt.Date)
                    {
                        <div class="jc-chat-date-sep"><span>@createdAt.ToString("dd/MM/yyyy")</span></div>
                        lastDate = createdAt;
                    }

                    <div class="jc-msg-row @(isOwn ? "jc-msg-own" : "jc-msg-other")" data-msg-id="@msg.MessageId">
                        <div class="jc-msg-bubble">
                            <p class="jc-msg-text">@msg.Content</p>
                            <span class="jc-msg-time">@createdAt.ToString("HH:mm")</span>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="jc-chat-empty">
                    <span class="material-symbols-outlined">chat_bubble</span>
                    <p>Chưa có tin nhắn nào. Hãy bắt đầu trò chuyện!</p>
                </div>
            }
        </div>

        <!-- Input -->
        <div class="jc-chat-input-area">
            <form id="messageForm">
                @Html.AntiForgeryToken()
                <input type="hidden" id="receiverId" value="@ViewBag.OtherUser?.UserId" />
                <input type="text" id="messageInput"
                       placeholder="Nhập tin nhắn..." autocomplete="off" maxlength="2000" />
                <button type="submit" id="sendBtn">
                    <span class="material-symbols-outlined">send</span>
                    <span class="jc-send-label">Gửi</span>
                </button>
            </form>
        </div>

    </div>
</div>

<style>
    .jc-chat-page {
        display: flex;
        justify-content: center;
        padding: 24px;
        min-height: calc(100vh - 64px);
    }

    .jc-chat-shell {
        width: 100%;
        max-width: 980px;
        display: flex;
        flex-direction: column;
        background: #0f172a;
        border-radius: 20px;
        border: 1px solid #1e293b;
        box-shadow: 0 20px 45px -12px rgba(0,0,0,.35);
        overflow: hidden;
        height: calc(100vh - 112px);
        min-height: 640px;
    }

    .jc-chat-header {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 18px 24px;
        background: linear-gradient(90deg, #111c34, #0f172a);
        border-bottom: 1px solid #1e293b;
        flex-shrink: 0;
    }

    .jc-chat-back {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
        color: #94a3b8;
        transition: background .15s, color .15s;
        flex-shrink: 0;
    }

        .jc-chat-back:hover {
            background: rgba(255,255,255,.08);
            color: #fff;
        }

    .jc-chat-avatar {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        background: linear-gradient(135deg,#3b82f6,#6366f1);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-weight: 700;
        font-size: 20px;
        flex-shrink: 0;
        box-shadow: 0 4px 12px rgba(59,130,246,.4);
    }

    .jc-chat-header-info {
        min-width: 0;
        flex: 1;
    }

        .jc-chat-header-info h1 {
            margin: 0;
            font-size: 19px;
            font-weight: 700;
            color: #f8fafc;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

    .jc-chat-role-badge {
        display: inline-block;
        margin-top: 4px;
        font-size: 12px;
        font-weight: 600;
        color: #93c5fd;
        background: rgba(59,130,246,.15);
        padding: 2px 10px;
        border-radius: 999px;
    }

    .jc-chat-header-status {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        color: #86efac;
        white-space: nowrap;
    }

    .jc-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #22c55e;
        box-shadow: 0 0 0 3px rgba(34,197,94,.2);
    }

    @@media (max-width: 640px) {
        .jc-chat-header-status {
            display: none;
        }
    }

    .jc-chat-messages {
        flex: 1;
        overflow-y: auto;
        padding: 24px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        background: radial-gradient(circle at 20% 10%, rgba(59,130,246,.05), transparent 40%), #0b1220;
    }

        .jc-chat-messages::-webkit-scrollbar {
            width: 8px;
        }

        .jc-chat-messages::-webkit-scrollbar-thumb {
            background: #1e293b;
            border-radius: 8px;
        }

    .jc-chat-date-sep {
        display: flex;
        justify-content: center;
        margin: 10px 0;
    }

        .jc-chat-date-sep span {
            font-size: 12px;
            color: #94a3b8;
            background: #1e293b;
            padding: 4px 14px;
            border-radius: 999px;
        }

    .jc-msg-row {
        display: flex;
        width: 100%;
    }

    .jc-msg-own {
        justify-content: flex-end;
    }

    .jc-msg-other {
        justify-content: flex-start;
    }

    .jc-msg-bubble {
        max-width: 70%;
        padding: 12px 16px;
        border-radius: 18px;
        font-size: 15px;
        line-height: 1.45;
        position: relative;
    }

    .jc-msg-own .jc-msg-bubble {
        background: linear-gradient(135deg,#2563eb,#3b82f6);
        color: #fff;
        border-bottom-right-radius: 6px;
        box-shadow: 0 4px 14px rgba(37,99,235,.35);
    }

    .jc-msg-other .jc-msg-bubble {
        background: #1e293b;
        color: #e2e8f0;
        border-bottom-left-radius: 6px;
    }

    .jc-msg-text {
        margin: 0;
        white-space: pre-wrap;
        word-break: break-word;
    }

    .jc-msg-time {
        display: block;
        margin-top: 6px;
        font-size: 11px;
        opacity: .75;
        text-align: right;
    }

    .jc-chat-empty {
        margin: auto;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
        color: #64748b;
    }

        .jc-chat-empty .material-symbols-outlined {
            font-size: 46px;
        }

        .jc-chat-empty p {
            margin: 0;
            font-size: 14px;
        }

    .jc-chat-input-area {
        border-top: 1px solid #1e293b;
        background: #111c34;
        padding: 16px 20px;
        flex-shrink: 0;
    }

    #messageForm {
        display: flex;
        gap: 12px;
    }

    #messageInput {
        flex: 1;
        background: #0b1220;
        border: 1px solid #263349;
        color: #f1f5f9;
        border-radius: 14px;
        padding: 14px 18px;
        font-size: 15px;
        outline: none;
        transition: border-color .15s, box-shadow .15s;
    }

        #messageInput::placeholder {
            color: #64748b;
        }

        #messageInput:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59,130,246,.25);
        }

    #sendBtn {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 0 24px;
        background: linear-gradient(135deg,#2563eb,#3b82f6);
        color: #fff;
        border: none;
        border-radius: 14px;
        font-size: 15px;
        font-weight: 700;
        cursor: pointer;
        transition: filter .15s, transform .1s;
    }

        #sendBtn:hover {
            filter: brightness(1.08);
        }

        #sendBtn:active {
            transform: scale(0.97);
        }

        #sendBtn:disabled {
            opacity: .5;
            cursor: not-allowed;
        }

    @@media (max-width: 480px) {
        .jc-send-label {
            display: none;
        }

        #sendBtn {
            padding: 0 16px;
        }

        .jc-chat-page {
            padding: 10px;
        }

        .jc-chat-shell {
            height: calc(100vh - 40px);
            border-radius: 14px;
        }

        .jc-msg-bubble {
            max-width: 85%;
        }
    }
</style>

@section Scripts {
    <script>
        const messageForm = document.getElementById('messageForm');
        const messageInput = document.getElementById('messageInput');
        const messagesContainer = document.getElementById('messagesContainer');
        const receiverId = document.getElementById('receiverId').value;
        const sendBtn = document.getElementById('sendBtn');

        let lastMessageId = 0;
        document.querySelectorAll('[data-msg-id]').forEach(el => {
            const id = parseInt(el.dataset.msgId, 10);
            if (id > lastMessageId) lastMessageId = id;
        });

        function scrollToBottom() {
            messagesContainer.scrollTop = messagesContainer.scrollHeight;
        }
        scrollToBottom();

        function todayLabel() {
            const d = new Date();
            const dd = String(d.getDate()).padStart(2, '0');
            const mm = String(d.getMonth() + 1).padStart(2, '0');
            return `${dd}/${mm}/${d.getFullYear()}`;
        }

        function ensureDateSeparator() {
            const seps = messagesContainer.querySelectorAll('.jc-chat-date-sep span');
            const label = todayLabel();
            if (seps.length === 0 || seps[seps.length - 1].textContent !== label) {
                const sep = document.createElement('div');
                sep.className = 'jc-chat-date-sep';
                sep.innerHTML = `<span>${label}</span>`;
                messagesContainer.appendChild(sep);
            }
        }

        function appendMessage(msg) {
            const empty = messagesContainer.querySelector('.jc-chat-empty');
            if (empty) {
                messagesContainer.innerHTML = '';
            }

            ensureDateSeparator();

            const wrap = document.createElement('div');
            wrap.className = 'jc-msg-row ' + (msg.isOwn ? 'jc-msg-own' : 'jc-msg-other');
            wrap.dataset.msgId = msg.id;

            const bubble = document.createElement('div');
            bubble.className = 'jc-msg-bubble';

            const p = document.createElement('p');
            p.className = 'jc-msg-text';
            p.textContent = msg.content;

            const time = document.createElement('span');
            time.className = 'jc-msg-time';
            time.textContent = msg.createdAt;

            bubble.appendChild(p);
            bubble.appendChild(time);
            wrap.appendChild(bubble);
            messagesContainer.appendChild(wrap);

            if (msg.id > lastMessageId) lastMessageId = msg.id;
        }

        messageForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const content = messageInput.value.trim();
            if (!content) return;

            sendBtn.disabled = true;

            // Hiển thị bong bóng "đang gửi..." (skeleton) trong lúc chờ server phản hồi
            const sendingBubble = document.createElement('div');
            sendingBubble.className = 'flex justify-end mb-2';
            sendingBubble.innerHTML = '<div class="skeleton" style="width:120px;height:34px;border-radius:16px 16px 4px 16px"></div>';
            messagesContainer.appendChild(sendingBubble);
            scrollToBottom();

            const formData = new FormData();
            formData.append('receiverId', receiverId);
            formData.append('content', content);
            formData.append('__RequestVerificationToken', document.querySelector('#messageForm input[name="__RequestVerificationToken"]').value);

            try {
                const response = await fetch('/Chat/Send', { method: 'POST', body: formData });
                const result = await response.json();
                if (result.success) {
                    messageInput.value = '';
                    await pollMessages();
                    scrollToBottom();
                } else {
                    alert(result.message || 'Gửi tin nhắn thất bại');
                }
            } catch (error) {
                alert('Có lỗi xảy ra khi gửi tin nhắn');
            } finally {
                sendingBubble.remove();
                sendBtn.disabled = false;
                messageInput.focus();
            }
        });

        async function pollMessages() {
            try {
                const res = await fetch(`/Chat/GetMessagesJson?userId=${receiverId}&afterId=${lastMessageId}`);
                const data = await res.json();
                if (data.success && data.messages.length > 0) {
                    const wasAtBottom = messagesContainer.scrollHeight - messagesContainer.scrollTop - messagesContainer.clientHeight < 60;
                    data.messages.forEach(appendMessage);
                    if (wasAtBottom) scrollToBottom();
                }
            } catch (error) {
                // Silent fail — sẽ thử lại ở lần tiếp theo
            }
        }

        setInterval(pollMessages, 3000);
    </script>
}
