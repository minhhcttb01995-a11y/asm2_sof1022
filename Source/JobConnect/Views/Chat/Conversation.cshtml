@using System.Security.Claims
@using System.Linq
@{
    ViewData["Title"] = "Tin nhắn";
    var role = User.FindFirst(ClaimTypes.Role)?.Value ?? "";
    Layout = (role == "Staff" || role == "Admin") ? "_StaffLayout"
             : (role == "Employer") ? "_LayoutEmployer"
             : "_Layout";
}

<div class="max-w-4xl mx-auto px-4 py-8">
    <div class="flex items-center gap-3 mb-6">
        <a asp-action="Index" asp-controller="Chat"
           class="w-9 h-9 flex items-center justify-center rounded-lg hover:bg-white/10 text-slate-400 hover:text-white transition-colors">
            <span class="material-symbols-outlined">arrow_back</span>
        </a>
        <div class="w-11 h-11 rounded-full bg-blue-500/20 flex items-center justify-center text-blue-400 font-bold text-lg flex-shrink-0">
            @(ViewBag.OtherUser?.FullName?[0].ToString().ToUpper() ?? "U")
        </div>
        <div class="min-w-0">
            <h1 class="text-lg font-bold text-white truncate">@ViewBag.OtherUser?.FullName</h1>
            <p class="text-xs text-slate-400">@ViewBag.OtherUser?.Role</p>
        </div>
    </div>

    <div class="bg-slate-900 rounded-2xl border border-slate-800 shadow-xl overflow-hidden flex flex-col">
        <!-- Messages Container -->
        <div id="messagesContainer" class="h-[28rem] overflow-y-auto p-4 space-y-3">
            @{
                bool hasMessages = false;
                if (ViewBag.Messages != null)
                {
                    try { hasMessages = ((System.Collections.IEnumerable)ViewBag.Messages).Cast<object>().Any(); }
                    catch { }
                }
            }
            @if (hasMessages)
            {
                @foreach (var msg in ViewBag.Messages)
                {
                    bool isOwn = msg.SenderID == ViewBag.CurrentUserId;
                    <div class="flex @(isOwn ? "justify-end" : "justify-start")" data-msg-id="@msg.MessageID">
                        <div class="max-w-xs md:max-w-md px-4 py-2.5 rounded-2xl @(isOwn ? "bg-blue-600 text-white rounded-br-sm" : "bg-slate-800 text-slate-100 rounded-bl-sm")">
                            <p class="text-sm whitespace-pre-wrap break-words">@msg.Content</p>
                            <p class="text-[11px] mt-1 @(isOwn ? "text-blue-200" : "text-slate-400")">@msg.CreatedAt.ToString("HH:mm")</p>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="h-full flex flex-col items-center justify-center text-slate-500 gap-2">
                    <span class="material-symbols-outlined text-4xl">chat_bubble</span>
                    <p class="text-sm">Chưa có tin nhắn nào. Hãy bắt đầu trò chuyện!</p>
                </div>
            }
        </div>

        <!-- Input Area -->
        <div class="border-t border-slate-800 p-3 bg-slate-900/60">
            <form id="messageForm" class="flex gap-2">
                @Html.AntiForgeryToken()
                <input type="hidden" id="receiverId" value="@ViewBag.OtherUser?.UserID" />
                <input type="text" id="messageInput"
                       class="flex-1 bg-slate-800 border border-slate-700 text-white placeholder-slate-500 rounded-xl px-4 py-2.5 text-sm outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                       placeholder="Nhập tin nhắn..." autocomplete="off" maxlength="2000" />
                <button type="submit" id="sendBtn"
                        class="px-5 py-2.5 bg-blue-600 text-white rounded-xl text-sm font-semibold hover:bg-blue-700 transition-colors disabled:opacity-50 flex items-center gap-1.5">
                    <span class="material-symbols-outlined text-base">send</span>
                    <span class="hidden sm:inline">Gửi</span>
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const messageForm = document.getElementById('messageForm');
        const messageInput = document.getElementById('messageInput');
        const messagesContainer = document.getElementById('messagesContainer');
        const receiverId = document.getElementById('receiverId').value;
        const sendBtn = document.getElementById('sendBtn');

        let lastMessageId = 0;
        document.querySelectorAll('[data-msg-id]').forEach(el => {
            const id = parseInt(el.dataset.msgId, 10);
            if (id > lastMessageId) lastMessageId = id;
        });

        function scrollToBottom() {
            messagesContainer.scrollTop = messagesContainer.scrollHeight;
        }
        scrollToBottom();

        function appendMessage(msg) {
            const empty = messagesContainer.querySelector('.text-slate-500');
            if (empty && messagesContainer.children.length === 1) {
                messagesContainer.innerHTML = '';
            }

            const wrap = document.createElement('div');
            wrap.className = 'flex ' + (msg.isOwn ? 'justify-end' : 'justify-start');
            wrap.dataset.msgId = msg.id;

            const bubble = document.createElement('div');
            bubble.className = 'max-w-xs md:max-w-md px-4 py-2.5 rounded-2xl ' +
                (msg.isOwn ? 'bg-blue-600 text-white rounded-br-sm' : 'bg-slate-800 text-slate-100 rounded-bl-sm');

            const p = document.createElement('p');
            p.className = 'text-sm whitespace-pre-wrap break-words';
            p.textContent = msg.content;

            const time = document.createElement('p');
            time.className = 'text-[11px] mt-1 ' + (msg.isOwn ? 'text-blue-200' : 'text-slate-400');
            time.textContent = msg.createdAt;

            bubble.appendChild(p);
            bubble.appendChild(time);
            wrap.appendChild(bubble);
            messagesContainer.appendChild(wrap);

            if (msg.id > lastMessageId) lastMessageId = msg.id;
        }

        messageForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const content = messageInput.value.trim();
            if (!content) return;

            sendBtn.disabled = true;
            const formData = new FormData();
            formData.append('receiverId', receiverId);
            formData.append('content', content);
            formData.append('__RequestVerificationToken', document.querySelector('#messageForm input[name="__RequestVerificationToken"]').value);

            try {
                const response = await fetch('/Chat/Send', { method: 'POST', body: formData });
                const result = await response.json();
                if (result.success) {
                    messageInput.value = '';
                    await pollMessages();
                    scrollToBottom();
                } else {
                    alert(result.message || 'Gửi tin nhắn thất bại');
                }
            } catch (error) {
                alert('Có lỗi xảy ra khi gửi tin nhắn');
            } finally {
                sendBtn.disabled = false;
                messageInput.focus();
            }
        });

        async function pollMessages() {
            try {
                const res = await fetch(`/Chat/GetMessagesJson?userId=${receiverId}&afterId=${lastMessageId}`);
                const data = await res.json();
                if (data.success && data.messages.length > 0) {
                    const wasAtBottom = messagesContainer.scrollHeight - messagesContainer.scrollTop - messagesContainer.clientHeight < 60;
                    data.messages.forEach(appendMessage);
                    if (wasAtBottom) scrollToBottom();
                }
            } catch (error) {
                // Silent fail — sẽ thử lại ở lần tiếp theo
            }
        }

        setInterval(pollMessages, 3000);
    </script>
}
