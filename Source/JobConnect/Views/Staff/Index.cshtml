@* [VIEW-HEADER-ADDED]
   View cho action "Index" trong khu vực quản lý nhân viên - Admin only (StaffController).
*@
@using JobConnect.Models
@using JobConnect.ViewModels.Staff
@model StaffIndexViewModel
@{
    ViewData["Title"] = "Quản lý nhân viên hệ thống";
    Layout = "_LayoutAdmin";
    var staffStatuses = ViewBag.StaffStatuses as List<StatusCatalog>;
}

<!-- Modal Thêm nhân viên -->
<div id="modalCreateStaff" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-2xl mx-4 p-7 max-h-[90vh] overflow-y-auto">
        <div class="flex items-center justify-between mb-6">
            <h2 class="text-lg font-bold text-on-surface">Thêm nhân viên mới</h2>
            <button type="button" onclick="closeCreateStaffModal()" class="text-secondary hover:text-on-surface">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <form asp-controller="Staff" asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="grid grid-cols-1 md:grid-cols-2 gap-x-5 gap-y-4">
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-1">Email</label>
                    <input name="Email" required type="email" placeholder="email@example.com"
                           class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-1">Mật khẩu</label>
                    <input name="Password" required type="password" placeholder="Tối thiểu 6 ký tự"
                           class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-1">Họ tên</label>
                    <input name="FullName" required type="text" placeholder="Nguyễn Văn A"
                           class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-1">Số CCCD</label>
                    <input name="CCCD" required type="text" inputmode="numeric" maxlength="20" placeholder="079203001234"
                           class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-1">Số điện thoại</label>
                    <input name="Phone" type="tel" placeholder="0901234567"
                           class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-1">Giới tính</label>
                    <select name="Gender"
                            class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary bg-white">
                        <option value="">-- Chọn giới tính --</option>
                        <option value="Nam">Nam</option>
                        <option value="Nữ">Nữ</option>
                        <option value="Khác">Khác</option>
                    </select>
                </div>
                <div class="md:col-span-2">
                    <label class="block text-sm font-medium text-on-surface mb-1">Chức vụ</label>
                    <select name="Position" required
                            class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary bg-white">
                        <option value="">-- Chọn chức vụ --</option>
                        <option value="Chuyên viên tuyển dụng">Chuyên viên tuyển dụng</option>
                        <option value="Chuyên viên hỗ trợ">Chuyên viên hỗ trợ</option>
                        <option value="Chuyên viên chăm sóc khách hàng">Chuyên viên chăm sóc khách hàng</option>
                        <option value="Chuyên viên kiểm duyệt nội dung">Chuyên viên kiểm duyệt nội dung</option>
                        <option value="Kế toán">Kế toán</option>
                        <option value="Nhân viên IT">Nhân viên IT</option>
                        <option value="Quản lý">Quản lý</option>
                    </select>
                </div>
                <div class="md:col-span-2">
                    <label class="block text-sm font-medium text-on-surface mb-1">Phòng ban</label>
                    <select name="Department" required
                            class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary bg-white">
                        <option value="">-- Chọn phòng ban --</option>
                        <option value="Nhân sự">Nhân sự</option>
                        <option value="Chăm sóc KH">Chăm sóc KH</option>
                        <option value="Kiểm duyệt nội dung">Kiểm duyệt nội dung</option>
                        <option value="Kế toán">Kế toán</option>
                        <option value="Kỹ thuật - IT">Kỹ thuật - IT</option>
                        <option value="Ban giám đốc">Ban giám đốc</option>
                    </select>
                </div>
            </div>
            <div class="flex gap-3 pt-6 mt-2 border-t border-outline-variant">

                <button type="button" onclick="closeCreateStaffModal()"
                        class="flex-1 md:flex-none md:w-40 px-4 py-2.5 mt-6 border border-outline-variant rounded-xl text-sm font-medium text-secondary hover:bg-surface-container">
                    Huỷ
                </button>
                <button type="submit"
                        class="flex-1 md:flex-none md:w-48 px-4 py-2.5 mt-6 bg-primary text-white rounded-xl text-sm font-semibold hover:opacity-90">
                    Tạo tài khoản
                </button>
            </div>
        </form>
    </div>
</div>

<div class="w-full px-6 py-8">

    
    @* Header  *@
    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="text-2xl font-bold text-on-surface">Quản lý nhân viên</h1>
            <p class="text-sm text-secondary mt-1">Danh sách nhân viên hệ thống JobConnect</p>
        </div>
        <div class="flex items-center gap-2">
            <button type="button" onclick="openCreateStaffModal()"
                    class="flex items-center gap-2 px-5 py-2.5 bg-primary text-white rounded-xl text-sm font-semibold hover:opacity-90 shadow-sm transition-all">
                <span class="material-symbols-outlined text-base">person_add</span>
                Thêm nhân viên
            </button>
        </div>
    </div>

    
    @* Alerts  *@
    @if (TempData["Success"] != null)
    {
        <div class="mb-5 px-4 py-3 bg-green-50 border border-green-200 text-green-700 rounded-xl text-sm font-medium flex items-center gap-2 auto-hide-alert">
            <span class="material-symbols-outlined text-base">check_circle</span>
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="mb-5 px-4 py-3 bg-red-50 border border-red-200 text-red-700 rounded-xl text-sm font-medium flex items-center gap-2">
            <span class="material-symbols-outlined text-base">error</span>
            @TempData["Error"]
        </div>
    }

    
    @* Search & Filter Card  *@
    <div class="bg-white rounded-2xl border border-outline-variant p-4 mb-6 shadow-sm">
        <form method="get" class="flex flex-wrap gap-3 items-end">
            <div class="flex-1 min-w-[220px]">
                <label class="block text-xs font-medium text-secondary mb-1.5">Tìm kiếm</label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-secondary text-sm">search</span>
                    <input name="searchTerm" value="@Model.SearchTerm" type="text"
                           placeholder="Tên, email, mã nhân viên..."
                           class="w-full pl-9 pr-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary focus:ring-1 focus:ring-primary/20 transition-all" />
                </div>
            </div>
            <div class="min-w-[160px]">
                <label class="block text-xs font-medium text-secondary mb-1.5">Trạng thái</label>
                <select name="statusFilter" class="w-full px-3 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary bg-white">
                    <option value="">Tất cả</option>
                    @if (staffStatuses != null)
                    {
                        @foreach (var status in staffStatuses)
                        {
                            <option value="@status.Code" selected="@(Model.StatusFilter == status.Code ? "selected" : null)">@status.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="min-w-[150px]">
                <label class="block text-xs font-medium text-secondary mb-1.5">Sắp xếp</label>
                <select name="sortBy" class="w-full px-3 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary bg-white">
                    <option value="CreatedAt" selected="@(Model.SortBy == "CreatedAt" ? "selected" : null)">Ngày tạo</option>
                    <option value="EmployeeCode" selected="@(Model.SortBy == "EmployeeCode" ? "selected" : null)">Mã NV</option>
                    <option value="FullName" selected="@(Model.SortBy == "FullName" ? "selected" : null)">Họ tên</option>
                    <option value="Status" selected="@(Model.SortBy == "Status" ? "selected" : null)">Trạng thái</option>
                </select>
            </div>
            <div class="flex gap-2">
                <button type="submit"
                        class="flex items-center gap-1.5 px-5 py-2.5 bg-primary text-white rounded-xl text-sm font-semibold hover:opacity-90 transition-all">
                    <span class="material-symbols-outlined text-sm">search</span>
                    Tìm
                </button>
                <a asp-action="Index"
                   class="flex items-center gap-1.5 px-4 py-2.5 border border-outline-variant rounded-xl text-sm font-medium text-secondary hover:bg-surface-container transition-all">
                    <span class="material-symbols-outlined text-sm">refresh</span>
                    Đặt lại
                </a>
            </div>
        </form>
    </div>

    
    @* Stats row  *@
    <div class="flex items-center justify-between mb-4">
        <p class="text-sm text-secondary">
            Hiển thị <span class="font-semibold text-on-surface">@Model.StaffList.Count</span>
            / <span class="font-semibold text-on-surface">@Model.TotalCount</span> nhân viên
        </p>
    </div>

    
    @* Table  *@
    <div class="bg-white rounded-2xl border border-outline-variant overflow-hidden shadow-sm">
        @if (!Model.StaffList.Any())
        {
            <div class="flex flex-col items-center justify-center py-16 text-secondary">
                <span class="material-symbols-outlined text-5xl mb-3 opacity-30">group_off</span>
                <p class="text-sm font-medium">Không tìm thấy nhân viên nào</p>
                <p class="text-xs mt-1 opacity-70">Thử thay đổi bộ lọc hoặc từ khoá tìm kiếm</p>
            </div>
        }
        else
        {
            <table class="w-full text-sm">
                <thead>
                    <tr class="bg-surface-container-low border-b border-outline-variant">
                        <th class="text-left px-5 py-3.5 font-semibold text-xs text-secondary uppercase tracking-wide">Nhân viên</th>
                        <th class="text-left px-4 py-3.5 font-semibold text-xs text-secondary uppercase tracking-wide">Mã NV</th>
                        <th class="text-left px-4 py-3.5 font-semibold text-xs text-secondary uppercase tracking-wide">Chức vụ</th>
                        <th class="text-left px-4 py-3.5 font-semibold text-xs text-secondary uppercase tracking-wide">CCCD</th>
                        <th class="text-left px-4 py-3.5 font-semibold text-xs text-secondary uppercase tracking-wide">Trạng thái</th>
                        <th class="text-left px-4 py-3.5 font-semibold text-xs text-secondary uppercase tracking-wide">Ngày tạo</th>
                        <th class="text-center px-4 py-3.5 font-semibold text-xs text-secondary uppercase tracking-wide">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-outline-variant/60">
                    @foreach (var staff in Model.StaffList)
                    {
                        var statusInfo = staffStatuses?.FirstOrDefault(s => s.Code == staff.Status);
                        var statusLabel = statusInfo?.Name ?? staff.Status;
                        var statusClass = statusInfo?.ColorClass ?? "bg-slate-100 text-slate-500 border border-slate-200";

                        <tr class="hover:bg-surface-container-low/50 transition-colors group">

                            @* Nhân viên  *@
                            <td class="px-5 py-3.5">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-full bg-gradient-to-br from-primary/20 to-primary/5 flex items-center justify-center flex-shrink-0 overflow-hidden ring-2 ring-white">
                                        @if (!string.IsNullOrEmpty(staff.Avatar))
                                        {
                                            <img src="@staff.Avatar" class="w-10 h-10 rounded-full object-cover" alt="@staff.FullName" />
                                        }
                                        else
                                        {
                                            <span class="material-symbols-outlined text-base text-primary/50">person</span>
                                        }
                                    </div>
                                    <div>
                                        <p class="font-semibold text-on-surface text-sm">@staff.FullName</p>
                                        <p class="text-xs text-secondary">@staff.Email</p>
                                    </div>
                                </div>
                            </td>

                            @* Mã NV  *@
                            <td class="px-4 py-3.5">
                                <span class="font-mono text-xs bg-surface-container px-2.5 py-1.5 rounded-lg text-secondary select-all border border-outline-variant/50">
                                    @staff.EmployeeCode
                                </span>
                            </td>

                            @* Chức vụ  *@
                            <td class="px-4 py-3.5">
                                <span class="text-sm text-on-surface font-medium">@staff.Position</span>
                            </td>

                            @* CCCD  *@
                            <td class="px-4 py-3.5">
                                <span class="font-mono text-xs text-secondary">
                                    @(string.IsNullOrEmpty(staff.CCCD) ? "—" : staff.CCCD)
                                </span>
                            </td>

                            @* Trạng thái  *@
                            <td class="px-4 py-3.5">
                                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold @statusClass">
                                    @statusLabel
                                </span>
                            </td>

                            @* Ngày tạo  *@
                            <td class="px-4 py-3.5 text-xs text-secondary">
                                <div class="flex items-center gap-1.5">
                                    <span class="material-symbols-outlined text-xs opacity-60">calendar_today</span>
                                    @staff.CreatedAt.ToString("dd/MM/yyyy")
                                </div>
                            </td>

                            @* Thao tác  *@
                            <td class="px-4 py-3.5">
                                <div class="flex items-center justify-center gap-1.5">

                                    @* Xem  *@
                                    <a asp-action="Details" asp-route-id="@staff.Id"
                                       title="Xem chi tiết"
                                       class="w-8 h-8 flex items-center justify-center rounded-lg bg-surface-container text-secondary hover:bg-primary hover:text-white transition-all group/btn"
                                       data-tooltip="Xem">
                                        <span class="material-symbols-outlined text-sm">visibility</span>
                                    </a>

                                    @* Đổi trạng thái  *@
                                    <form asp-action="ChangeStaffStatus" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@staff.Id" />
                                        <select name="newStatus" onchange="this.form.submit()"
                                                class="px-2 py-1.5 border border-outline-variant rounded-lg text-xs outline-none focus:border-primary bg-white">
                                            @if (staffStatuses != null)
                                            {
                                                @foreach (var status in staffStatuses)
                                                {
                                                    <option value="@status.Code" selected="@(staff.Status == status.Code ? "selected" : null)">@status.Name</option>
                                                }
                                            }
                                        </select>
                                    </form>

                                    @* Xóa mềm  *@
                                    <form asp-action="Delete" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@staff.Id" />
                                        <button type="submit" title="Xóa vĩnh viễn"
                                                onclick="return confirm('Xóa VĨNH VIỄN nhân viên \" @staff.FullName\"? Hành động này KHÔNG THỂ hoàn tác.')"
                                                class="w-8 h-8 flex items-center justify-center rounded-lg bg-red-50 text-red-500 hover:bg-red-500 hover:text-white border border-red-200 hover:border-transparent transition-all">
                                            <span class="material-symbols-outlined text-sm">delete</span>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    
    @* Pagination  *@
    @if (Model.TotalPages > 1)
    {
        <div class="flex justify-center items-center gap-1.5 mt-6">
            @if (Model.CurrentPage > 1)
            {
                <a asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)"
                   asp-route-searchTerm="@Model.SearchTerm" asp-route-statusFilter="@Model.StatusFilter"
                   asp-route-departmentFilter="@Model.DepartmentFilter" asp-route-sortBy="@Model.SortBy"
                   asp-route-sortDescending="@Model.SortDescending"
                   class="w-9 h-9 flex items-center justify-center rounded-xl text-sm border border-outline-variant text-secondary hover:bg-surface-container hover:text-primary transition-all">
                    <span class="material-symbols-outlined text-sm">chevron_left</span>
                </a>
            }
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <a asp-action="Index" asp-route-page="@i"
                   asp-route-searchTerm="@Model.SearchTerm" asp-route-statusFilter="@Model.StatusFilter"
                   asp-route-departmentFilter="@Model.DepartmentFilter" asp-route-sortBy="@Model.SortBy"
                   asp-route-sortDescending="@Model.SortDescending"
                   class="w-9 h-9 flex items-center justify-center rounded-xl text-sm font-medium border @(i == Model.CurrentPage ? "bg-primary text-white border-primary shadow-sm" : "border-outline-variant text-secondary hover:bg-surface-container")">
                    @i
                </a>
            }
            @if (Model.CurrentPage < Model.TotalPages)
            {
                <a asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)"
                   asp-route-searchTerm="@Model.SearchTerm" asp-route-statusFilter="@Model.StatusFilter"
                   asp-route-departmentFilter="@Model.DepartmentFilter" asp-route-sortBy="@Model.SortBy"
                   asp-route-sortDescending="@Model.SortDescending"
                   class="w-9 h-9 flex items-center justify-center rounded-xl text-sm border border-outline-variant text-secondary hover:bg-surface-container hover:text-primary transition-all">
                    <span class="material-symbols-outlined text-sm">chevron_right</span>
                </a>
            }
        </div>
    }
</div>

<script>
    function openCreateStaffModal() {
        document.getElementById('modalCreateStaff').classList.remove('hidden');
        document.getElementById('modalCreateStaff').classList.add('flex');
    }
    function closeCreateStaffModal() {
        document.getElementById('modalCreateStaff').classList.add('hidden');
        document.getElementById('modalCreateStaff').classList.remove('flex');
    }
    document.getElementById('modalCreateStaff').addEventListener('click', function (e) {
        if (e.target === this) closeCreateStaffModal();
    });
    @if (TempData["OpenCreateModal"] != null)
    {
                    <text>openCreateStaffModal();</text>
    }
</script>
