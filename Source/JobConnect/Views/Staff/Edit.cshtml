@using JobConnect.Models
@using JobConnect.ViewModels.Staff
@model StaffEditViewModel
@{
    ViewData["Title"] = "Chỉnh sửa nhân viên";
    Layout = "_LayoutAdmin";
}

<div class="max-w-3xl mx-auto px-6 py-8">
    <div class="flex items-center gap-4 mb-6">
        <a asp-action="Index" class="text-secondary hover:text-primary">
            <span class="material-symbols-outlined">arrow_back</span>
        </a>
        <div>
            <h1 class="text-2xl font-bold text-on-surface">Chỉnh sửa nhân viên</h1>
            <p class="text-sm text-secondary mt-0.5">
                Mã nhân viên: <span class="font-mono font-medium text-on-surface">@Model.EmployeeCode</span>
            </p>
        </div>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="mb-5 px-4 py-3 bg-red-50 border border-red-200 text-red-700 rounded-xl text-sm font-medium flex items-center gap-2">
            <span class="material-symbols-outlined text-base">error</span>
            @TempData["Error"]
        </div>
    }

    <div class="bg-white rounded-2xl border border-outline-variant p-8 shadow-sm">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="ApplicationUserId" />
            <input type="hidden" asp-for="EmployeeCode" />

            <div class="grid grid-cols-1 md:grid-cols-2 gap-x-5 gap-y-5">

                <div class="md:col-span-2">
                    <label asp-for="Email" class="block text-sm font-medium text-on-surface mb-1">Email</label>
                    <input asp-for="Email" type="email"
                           class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
                    <span asp-validation-for="Email" class="text-red-600 text-xs"></span>
                </div>

                <div>
                    <label asp-for="FullName" class="block text-sm font-medium text-on-surface mb-1">Họ tên</label>
                    <input asp-for="FullName" type="text"
                           class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
                    <span asp-validation-for="FullName" class="text-red-600 text-xs"></span>
                </div>

                <div>
                    <label asp-for="CCCD" class="block text-sm font-medium text-on-surface mb-1">Số CCCD</label>
                    <input asp-for="CCCD" type="text" inputmode="numeric" maxlength="20"
                           class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
                    <span asp-validation-for="CCCD" class="text-red-600 text-xs"></span>
                </div>

                <div>
                    <label asp-for="Phone" class="block text-sm font-medium text-on-surface mb-1">Số điện thoại</label>
                    <input asp-for="Phone" type="tel"
                           class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
                    <span asp-validation-for="Phone" class="text-red-600 text-xs"></span>
                </div>

                <div>
                    <label asp-for="Gender" class="block text-sm font-medium text-on-surface mb-1">Giới tính</label>
                    <select asp-for="Gender"
                            class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary bg-white">
                        <option value="">-- Chọn giới tính --</option>
                        <option value="Nam">Nam</option>
                        <option value="Nữ">Nữ</option>
                        <option value="Khác">Khác</option>
                    </select>
                    <span asp-validation-for="Gender" class="text-red-600 text-xs"></span>
                </div>

                <div>
                    <label asp-for="Position" class="block text-sm font-medium text-on-surface mb-1">Chức vụ</label>
                    <select asp-for="Position"
                            class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary bg-white">
                        <option value="">-- Chọn chức vụ --</option>
                        <option value="Chuyên viên tuyển dụng">Chuyên viên tuyển dụng</option>
                        <option value="Chuyên viên hỗ trợ">Chuyên viên hỗ trợ</option>
                        <option value="Chuyên viên chăm sóc khách hàng">Chuyên viên chăm sóc khách hàng</option>
                        <option value="Chuyên viên kiểm duyệt nội dung">Chuyên viên kiểm duyệt nội dung</option>
                        <option value="Kế toán">Kế toán</option>
                        <option value="Nhân viên IT">Nhân viên IT</option>
                        <option value="Quản lý">Quản lý</option>
                    </select>
                    <span asp-validation-for="Position" class="text-red-600 text-xs"></span>
                </div>

                <div>
                    <label asp-for="Department" class="block text-sm font-medium text-on-surface mb-1">Phòng ban</label>
                    <select asp-for="Department"
                            class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary bg-white">
                        <option value="">-- Chọn phòng ban --</option>
                        <option value="Nhân sự">Nhân sự</option>
                        <option value="Chăm sóc KH">Chăm sóc KH</option>
                        <option value="Kiểm duyệt nội dung">Kiểm duyệt nội dung</option>
                        <option value="Kế toán">Kế toán</option>
                        <option value="Kỹ thuật - IT">Kỹ thuật - IT</option>
                        <option value="Ban giám đốc">Ban giám đốc</option>
                    </select>
                    <span asp-validation-for="Department" class="text-red-600 text-xs"></span>
                </div>

                <div class="md:col-span-2">
                    <label asp-for="Status"
                           class="block text-sm font-medium text-on-surface mb-1">Trạng thái</label>
                    <select asp-for="Status" class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary bg-white">
                        <option value="Active">Hoạt động</option>
                        <option value="Locked">Đã khóa</option>
                    </select>
                    <span asp-validation-for="Status" class="text-red-600 text-xs"></span>
                </div>
            </div>

            <div class="flex gap-3 pt-6 mt-2 border-t border-outline-variant">
                <a asp-action="Index"
                   class="flex-1 md:flex-none md:w-40 px-4 py-2.5 mt-6 border border-outline-variant rounded-xl text-sm font-medium text-secondary hover:bg-surface-container text-center whitespace-nowrap">
                    Huỷ
                </a>
                <button type="submit"
                        class="flex-1 md:flex-none md:w-48 px-4 py-2.5 mt-6 bg-primary text-slate-900 rounded-xl text-sm font-semibold hover:opacity-90 whitespace-nowrap">
                    Lưu thay đổi
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
