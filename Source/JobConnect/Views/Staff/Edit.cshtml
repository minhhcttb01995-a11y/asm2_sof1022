@using JobConnect.Models
@using JobConnect.ViewModels.Staff
@model StaffEditViewModel
@{
    ViewData["Title"] = "Chỉnh sửa nhân viên";
    Layout = "_LayoutAdmin";
}

<div class="max-w-2xl mx-auto px-6 py-8">
    <div class="flex items-center gap-4 mb-6">
        <a asp-action="Index" class="text-secondary hover:text-primary">
            <span class="material-symbols-outlined">arrow_back</span>
        </a>
        <h1 class="text-2xl font-bold text-on-surface">Chỉnh sửa nhân viên</h1>
    </div>

    <div class="bg-white rounded-xl border border-outline-variant p-6">
        <form asp-action="Edit" method="post" class="space-y-5">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="ApplicationUserId" />
            <input type="hidden" asp-for="EmployeeCode" />

            <div class="bg-surface-container-low rounded-lg p-4 mb-4">
                <p class="text-sm text-secondary">Mã nhân viên: <span class="font-mono font-medium text-on-surface">@Model.EmployeeCode</span></p>
            </div>

            <div>
                <label asp-for="Email" class="block text-sm font-medium text-on-surface mb-1">Email</label>
                <input asp-for="Email" type="email"
                       class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
                <span asp-validation-for="Email" class="text-red-600 text-xs"></span>
            </div>

            <div>
                <label asp-for="FullName" class="block text-sm font-medium text-on-surface mb-1">Họ tên</label>
                <input asp-for="FullName" type="text"
                       class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
                <span asp-validation-for="FullName" class="text-red-600 text-xs"></span>
            </div>

            <div>
                <label asp-for="Phone" class="block text-sm font-medium text-on-surface mb-1">Số điện thoại</label>
                <input asp-for="Phone" type="tel"
                       class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
                <span asp-validation-for="Phone" class="text-red-600 text-xs"></span>
            </div>

            <div>
                <label asp-for="Position" class="block text-sm font-medium text-on-surface mb-1">Chức vụ</label>
                <input asp-for="Position" type="text"
                       class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
                <span asp-validation-for="Position" class="text-red-600 text-xs"></span>
            </div>

            <div>
                <label asp-for="Department" class="block text-sm font-medium text-on-surface mb-1">Phòng ban</label>
                <input asp-for="Department" type="text"
                       class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
                <span asp-validation-for="Department" class="text-red-600 text-xs"></span>
            </div>

            <div>
                <label asp-for="Status" class="block text-sm font-medium text-on-surface mb-1">Trạng thái</label>
                <select asp-for="Status" class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary">
                    <option value="@StaffStatus.Active">Hoạt động</option>
                    <option value="@StaffStatus.Locked">Đã khóa</option>
                </select>
                <span asp-validation-for="Status" class="text-red-600 text-xs"></span>
            </div>

            <div class="flex gap-3 pt-4">
                <a asp-action="Index"
                   class="flex-1 px-4 py-2.5 border border-outline-variant rounded-xl text-sm font-medium text-secondary hover:bg-surface-container text-center whitespace-nowrap">
                    Huỷ
                </a>
                <button type="submit"
                        class="flex-1 px-4 py-2.5 bg-primary text-white rounded-xl text-sm font-semibold hover:opacity-90 whitespace-nowrap">
                    Lưu thay đổi
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
