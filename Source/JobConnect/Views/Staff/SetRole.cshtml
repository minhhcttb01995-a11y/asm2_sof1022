@* [VIEW-HEADER-ADDED]
   View cho action "SetRole" trong khu vực quản lý nhân viên - Admin only (StaffController).
*@
@{
    ViewData["Title"] = "Phân quyền nhân viên";
    Layout = "_LayoutAdmin";

    int staffId = ViewBag.StaffId;
    string staffName = ViewBag.StaffName;
    string currentRole = ViewBag.CurrentRole;
    var roles = ViewBag.AvailableRoles as List<string> ?? new();
}

<div class="max-w-lg mx-auto px-6 py-8">

    <div class="flex items-center gap-3 mb-6">
        <a asp-action="Details" asp-route-id="@staffId"
           class="text-secondary hover:text-primary transition-colors">
            <span class="material-symbols-outlined">arrow_back</span>
        </a>
        <h1 class="text-2xl font-bold text-on-surface">Phân quyền nhân viên</h1>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="mb-4 px-4 py-3 bg-red-50 text-red-700 border border-red-200 rounded-xl text-sm flex items-center gap-2">
            <span class="material-symbols-outlined text-base">error</span>
            @TempData["Error"]
        </div>
    }

    <div class="bg-white rounded-2xl border border-outline-variant p-6 space-y-6">

        @* Thông tin nhân viên*@
        <div class="flex items-center gap-3 pb-4 border-b border-outline-variant">
            <div class="w-10 h-10 rounded-full bg-blue-100 flex items-center justify-center">
                <span class="material-symbols-outlined text-blue-600">person</span>
            </div>
            <div>
                <p class="font-semibold text-on-surface">@staffName</p>
                <p class="text-xs text-secondary">
                    Vai trò hiện tại:
                    <span class="px-2 py-0.5 rounded-full text-xs font-medium
                        @(currentRole == "Admin" ? "bg-purple-100 text-purple-700" : "bg-blue-100 text-blue-700")">
                        @currentRole
                    </span>
                </p>
            </div>
        </div>

        @* Form chọn vai trò*@
        <form asp-action="SetRole" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@staffId" />

            <p class="text-sm font-medium text-on-surface mb-3">Chọn vai trò mới:</p>

            <div class="space-y-3">
                @foreach (var role in roles)
                {
                    var desc = role switch
                    {
                        "Admin" => "Toàn quyền quản trị hệ thống, quản lý nhân viên, duyệt nội dung.",
                        "Staff" => "Xem và xử lý báo cáo, duyệt tin, hỗ trợ người dùng.",
                        _ => ""
                    };
                    var icon = role switch
                    {
                        "Admin" => "admin_panel_settings",
                        _ => "badge"
                    };
                    var isSelected = role == currentRole;

                    <label class="flex items-start gap-3 p-4 border rounded-xl cursor-pointer transition-all
                        @(isSelected ? "border-primary bg-blue-50" : "border-outline-variant hover:border-primary hover:bg-surface-container-low")">
                        <input type="radio" name="role" value="@role"
                               class="mt-0.5 accent-primary"
                        @(isSelected ? "checked" : "") />
                        <div class="flex-1">
                            <div class="flex items-center gap-2">
                                <span class="material-symbols-outlined text-base
                                @(role == "Admin" ? "text-purple-600" : "text-blue-600")">@icon</span>
                                <span class="font-medium text-on-surface text-sm">@role</span>
                                @if (isSelected)
                                {
                                    <span class="px-2 py-0.5 rounded-full bg-blue-100 text-blue-700 text-xs">Hiện tại</span>
                                }
                            </div>
                            <p class="text-xs text-secondary mt-1">@desc</p>
                        </div>
                    </label>
                }
            </div>

            <div class="flex gap-3 mt-6 pt-4 border-t border-outline-variant">
                <button type="submit"
                        onclick="return confirm('Bạn có chắc muốn thay đổi vai trò của nhân viên này?')"
                        class="flex items-center gap-2 px-5 py-2.5 bg-primary text-slate-900 rounded-xl text-sm font-semibold hover:opacity-90 transition-opacity">
                    <span class="material-symbols-outlined text-base">shield_person</span>
                    Lưu phân quyền
                </button>
                <a asp-action="Details" asp-route-id="@staffId"
                   class="flex items-center gap-2 px-5 py-2.5 border border-outline-variant text-secondary rounded-xl text-sm font-medium hover:bg-surface-container transition-colors">
                    Hủy
                </a>
            </div>
        </form>
    </div>
</div>
