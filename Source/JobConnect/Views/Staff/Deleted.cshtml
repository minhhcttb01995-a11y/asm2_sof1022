@* [VIEW-HEADER-ADDED]
   View cho action "Deleted" trong khu vực quản lý nhân viên - Admin only (StaffController).
*@
@using JobConnect.Models
@using JobConnect.ViewModels.Staff
@model StaffIndexViewModel
@{
    ViewData["Title"] = "Nhân viên đã xóa";
    Layout = "_LayoutAdmin";
}

<div class="max-w-[1700px] mx-auto px-6 py-8">

    @* Header *@
    <div class="flex items-center justify-between mb-8">
        <div class="flex items-center gap-4">
            <a asp-action="Index"
               class="w-9 h-9 flex items-center justify-center rounded-xl border border-outline-variant text-secondary hover:bg-surface-container transition-all">
                <span class="material-symbols-outlined text-sm">arrow_back</span>
            </a>
            <div>
                <div class="flex items-center gap-2.5">
                    <div class="w-8 h-8 rounded-lg bg-red-100 flex items-center justify-center">
                        <span class="material-symbols-outlined text-sm text-red-600">delete</span>
                    </div>
                    <h1 class="text-2xl font-bold text-on-surface">Nhân viên đã xóa</h1>
                </div>
                <p class="text-sm text-secondary mt-1 ml-10">Danh sách nhân viên đã bị xóa khỏi hệ thống (có thể khôi phục)</p>
            </div>
        </div>
        <div class="flex items-center gap-2 px-4 py-2 bg-red-50 border border-red-200 rounded-xl">
            <span class="material-symbols-outlined text-sm text-red-500">info</span>
            <span class="text-sm text-red-600 font-medium">@Model.TotalCount nhân viên đã xóa</span>
        </div>
    </div>

    @* Alerts *@
    @if (TempData["Success"] != null)
    {
        <div class="mb-5 px-4 py-3 bg-green-50 border border-green-200 text-green-700 rounded-xl text-sm font-medium flex items-center gap-2 auto-hide-alert">
            <span class="material-symbols-outlined text-base">check_circle</span>
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="mb-5 px-4 py-3 bg-red-50 border border-red-200 text-red-700 rounded-xl text-sm font-medium flex items-center gap-2">
            <span class="material-symbols-outlined text-base">error</span>
            @TempData["Error"]
        </div>
    }

    @* Search & Filter *@
    <div class="bg-white rounded-2xl border border-outline-variant p-4 mb-6 shadow-sm">
        <form method="get" class="flex flex-wrap gap-3 items-end">
            <div class="flex-1 min-w-[220px]">
                <label class="block text-xs font-medium text-secondary mb-1.5">Tìm kiếm</label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-secondary text-sm">search</span>
                    <input name="searchTerm" value="@Model.SearchTerm" type="text"
                           placeholder="Tên, email, mã nhân viên..."
                           class="w-full pl-9 pr-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary focus:ring-1 focus:ring-primary/20 transition-all" />
                </div>
            </div>
            <div class="min-w-[160px]">
                <label class="block text-xs font-medium text-secondary mb-1.5">Phòng ban</label>
                <select name="departmentFilter" class="w-full px-3 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary bg-white">
                    <option value="">Tất cả</option>
                    @if (ViewBag.Departments != null)
                    {
                        @foreach (var dept in ViewBag.Departments)
                        {
                            <option value="@dept" selected="@(Model.DepartmentFilter == dept ? "selected" : null)">@dept</option>
                        }
                    }
                </select>
            </div>
            <div class="flex gap-2">
                <button type="submit"
                        class="flex items-center gap-1.5 px-5 py-2.5 bg-primary text-slate-900 rounded-xl text-sm font-semibold hover:opacity-90 transition-all">
                    <span class="material-symbols-outlined text-sm">search</span>
                    Tìm
                </button>
                <a asp-action="Deleted"
                   class="flex items-center gap-1.5 px-4 py-2.5 border border-outline-variant rounded-xl text-sm font-medium text-secondary hover:bg-surface-container transition-all">
                    <span class="material-symbols-outlined text-sm">refresh</span>
                    Đặt lại
                </a>
            </div>
        </form>
    </div>

    @* Table *@
    <div class="bg-white rounded-2xl border border-red-100 overflow-hidden shadow-sm">
        @* Table header accent *@
        <div class="h-1 bg-gradient-to-r from-red-400 to-rose-500"></div>

        @if (!Model.StaffList.Any())
        {
            <div class="flex flex-col items-center justify-center py-20 text-secondary">
                <div class="w-16 h-16 rounded-full bg-green-50 flex items-center justify-center mb-4">
                    <span class="material-symbols-outlined text-3xl text-green-600">check_circle</span>
                </div>
                <p class="text-sm font-semibold text-on-surface">Không có nhân viên nào đã xóa</p>
                <p class="text-xs mt-1 opacity-70">Danh sách sạch — chưa có tài khoản nào bị xóa</p>
                <a asp-action="Index" class="mt-4 text-xs text-primary font-medium hover:underline flex items-center gap-1">
                    <span class="material-symbols-outlined text-xs">arrow_back</span>
                    Quay lại danh sách nhân viên
                </a>
            </div>
        }
        else
        {
            <table class="w-full text-sm">
                <thead>
                    <tr class="bg-red-50/60 border-b border-red-100">
                        <th class="text-left px-5 py-3.5 font-semibold text-xs text-red-600 uppercase tracking-wide">Nhân viên</th>
                        <th class="text-left px-4 py-3.5 font-semibold text-xs text-red-600 uppercase tracking-wide">Mã NV</th>
                        <th class="text-left px-4 py-3.5 font-semibold text-xs text-red-600 uppercase tracking-wide">Chức vụ</th>
                        <th class="text-left px-4 py-3.5 font-semibold text-xs text-red-600 uppercase tracking-wide">Phòng ban</th>
                        <th class="text-left px-4 py-3.5 font-semibold text-xs text-red-600 uppercase tracking-wide">Ngày tạo</th>
                        <th class="text-left px-4 py-3.5 font-semibold text-xs text-red-600 uppercase tracking-wide">Ngày xóa</th>
                        <th class="text-center px-4 py-3.5 font-semibold text-xs text-red-600 uppercase tracking-wide">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-red-50">
                    @foreach (var staff in Model.StaffList)
                    {
                        <tr class="hover:bg-red-50/30 transition-colors opacity-80 hover:opacity-100">
                            @* Nhân viên *@
                            <td class="px-5 py-3.5">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center flex-shrink-0 overflow-hidden ring-2 ring-white grayscale">
                                        @if (!string.IsNullOrEmpty(staff.Avatar))
                                        {
                                            <img src="@staff.Avatar" class="w-10 h-10 rounded-full object-cover" alt="@staff.FullName" />
                                        }
                                        else
                                        {
                                            <span class="material-symbols-outlined text-base text-slate-500">person</span>
                                        }
                                    </div>
                                    <div>
                                        <p class="font-semibold text-slate-500 text-sm line-through decoration-red-300">@staff.FullName</p>
                                        <p class="text-xs text-secondary">@staff.Email</p>
                                    </div>
                                </div>
                            </td>
                            @* Mã NV *@
                            <td class="px-4 py-3.5">
                                <span class="font-mono text-xs bg-slate-100 px-2.5 py-1.5 rounded-lg text-slate-500 border border-slate-200 select-all">
                                    @staff.EmployeeCode
                                </span>
                            </td>
                            @* Chức vụ *@
                            <td class="px-4 py-3.5 text-sm text-slate-500">
                                @staff.Position
                            </td>
                            @* Phòng ban *@
                            <td class="px-4 py-3.5">
                                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 bg-slate-100 text-slate-500 border border-slate-200 rounded-lg text-xs font-medium">
                                    <span class="material-symbols-outlined text-xs">corporate_fare</span>
                                    @staff.Department
                                </span>
                            </td>
                            @* Ngày tạo *@
                            <td class="px-4 py-3.5 text-xs text-secondary">
                                <div class="flex items-center gap-1">
                                    <span class="material-symbols-outlined text-xs opacity-50">calendar_today</span>
                                    @staff.CreatedAt.ToString("dd/MM/yyyy")
                                </div>
                            </td>
                            @* Ngày xóa *@
                            <td class="px-4 py-3.5 text-xs">
                                @if (staff.UpdatedAt.HasValue)
                                {
                                    <div class="flex items-center gap-1 text-red-600">
                                        <span class="material-symbols-outlined text-xs">delete_forever</span>
                                        @staff.UpdatedAt.Value.ToString("dd/MM/yyyy HH:mm")
                                    </div>
                                }
                                else
                                {
                                    <span class="text-secondary">—</span>
                                }
                            </td>
                            @* Thao tác *@
                            <td class="px-4 py-3.5">
                                <div class="flex items-center justify-center gap-2">
                                    @* Xem chi tiết *@
                                    <a asp-action="Details" asp-route-id="@staff.Id"
                                       title="Xem chi tiết"
                                       class="w-8 h-8 flex items-center justify-center rounded-lg bg-surface-container text-secondary hover:bg-primary hover:text-slate-900 transition-all">
                                        <span class="material-symbols-outlined text-sm">visibility</span>
                                    </a>
                                    @* Khôi phục *@
                                    <form asp-action="Restore" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@staff.Id" />
                                        <button type="submit" title="Khôi phục tài khoản"
                                                onclick="return confirm('Khôi phục nhân viên \" @staff.FullName\"? Tài khoản sẽ được kích hoạt lại.')"
                                                class="flex items-center gap-1.5 px-3 py-1.5 bg-emerald-50 text-emerald-700 hover:bg-emerald-500 hover:text-slate-900 border border-emerald-200 hover:border-transparent rounded-lg text-xs font-semibold transition-all">
                                            <span class="material-symbols-outlined text-sm">restore</span>
                                            Khôi phục
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    @* Pagination *@
    @if (Model.TotalPages > 1)
    {
        <div class="flex justify-center items-center gap-1.5 mt-6">
            @if (Model.CurrentPage > 1)
            {
                <a asp-action="Deleted" asp-route-page="@(Model.CurrentPage - 1)"
                   asp-route-searchTerm="@Model.SearchTerm" asp-route-departmentFilter="@Model.DepartmentFilter"
                   class="w-9 h-9 flex items-center justify-center rounded-xl text-sm border border-outline-variant text-secondary hover:bg-surface-container transition-all">
                    <span class="material-symbols-outlined text-sm">chevron_left</span>
                </a>
            }
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <a asp-action="Deleted" asp-route-page="@i"
                   asp-route-searchTerm="@Model.SearchTerm" asp-route-departmentFilter="@Model.DepartmentFilter"
                   class="w-9 h-9 flex items-center justify-center rounded-xl text-sm font-medium border @(i == Model.CurrentPage ? "bg-red-500 text-white border-red-500 shadow-sm" : "border-outline-variant text-secondary hover:bg-surface-container")">
                    @i
                </a>
            }
            @if (Model.CurrentPage < Model.TotalPages)
            {
                <a asp-action="Deleted" asp-route-page="@(Model.CurrentPage + 1)"
                   asp-route-searchTerm="@Model.SearchTerm" asp-route-departmentFilter="@Model.DepartmentFilter"
                   class="w-9 h-9 flex items-center justify-center rounded-xl text-sm border border-outline-variant text-secondary hover:bg-surface-container transition-all">
                    <span class="material-symbols-outlined text-sm">chevron_right</span>
                </a>
            }
        </div>
    }

    @* Footer note *@
    <div class="flex items-center justify-center gap-2 mt-6 text-xs text-secondary">
        <span class="material-symbols-outlined text-xs">info</span>
        Nhân viên đã xóa không thể đăng nhập. Nhấn <strong class="mx-1 text-emerald-600">Khôi phục</strong> để kích hoạt lại tài khoản.
    </div>
</div>
