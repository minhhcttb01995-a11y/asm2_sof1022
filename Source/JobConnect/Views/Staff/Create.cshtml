@using JobConnect.ViewModels.Staff
@model StaffCreateViewModel
@{
    ViewData["Title"] = "Thêm nhân viên mới";
    Layout = "_LayoutAdmin";
}

<div class="max-w-2xl mx-auto px-6 py-8">
    <div class="flex items-center gap-4 mb-6">
        <a asp-action="Index" class="text-secondary hover:text-primary">
            <span class="material-symbols-outlined">arrow_back</span>
        </a>
        <h1 class="text-2xl font-bold text-on-surface">Thêm nhân viên mới</h1>
    </div>

    <div class="bg-white rounded-xl border border-outline-variant p-6">
        <form asp-action="Create" method="post" class="space-y-5">
            @Html.AntiForgeryToken()

            <div>
                <label asp-for="Email" class="block text-sm font-medium text-on-surface mb-1">Email</label>
                <input asp-for="Email" type="email" placeholder="email@example.com"
                       class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
                <span asp-validation-for="Email" class="text-red-600 text-xs"></span>
            </div>

            <div>
                <label asp-for="Password" class="block text-sm font-medium text-on-surface mb-1">Mật khẩu</label>
                <input asp-for="Password" type="password" placeholder="Tối thiểu 6 ký tự"
                       class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
                <span asp-validation-for="Password" class="text-red-600 text-xs"></span>
            </div>

            <div>
                <label asp-for="FullName" class="block text-sm font-medium text-on-surface mb-1">Họ tên</label>
                <input asp-for="FullName" type="text" placeholder="Nguyễn Văn A"
                       class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
                <span asp-validation-for="FullName" class="text-red-600 text-xs"></span>
            </div>

            <div>
                <label asp-for="Phone" class="block text-sm font-medium text-on-surface mb-1">Số điện thoại</label>
                <input asp-for="Phone" type="tel" placeholder="0901234567"
                       class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
                <span asp-validation-for="Phone" class="text-red-600 text-xs"></span>
            </div>

            <div>
                <label asp-for="Position" class="block text-sm font-medium text-on-surface mb-1">Chức vụ</label>
                <input asp-for="Position" type="text" placeholder="Ví dụ: Nhân viên hỗ trợ"
                       class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
                <span asp-validation-for="Position" class="text-red-600 text-xs"></span>
            </div>

            <div>
                <label asp-for="Department" class="block text-sm font-medium text-on-surface mb-1">Phòng ban</label>
                <input asp-for="Department" type="text" placeholder="Ví dụ: Hỗ trợ khách hàng"
                       class="w-full px-4 py-2.5 border border-outline-variant rounded-xl text-sm outline-none focus:border-primary" />
                <span asp-validation-for="Department" class="text-red-600 text-xs"></span>
            </div>

            <div class="flex gap-3 pt-4">
                <a asp-action="Index"
                   class="flex-1 px-4 py-2.5 border border-outline-variant rounded-xl text-sm font-medium text-secondary hover:bg-surface-container text-center whitespace-nowrap">
                    Huỷ
                </a>
                <button type="submit"
                        class="flex-1 px-4 py-2.5 bg-primary text-white rounded-xl text-sm font-semibold hover:opacity-90 whitespace-nowrap">
                    Tạo nhân viên
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
