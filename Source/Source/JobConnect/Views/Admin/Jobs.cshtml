@using JobConnect.Models
@model List<JobPost>
@{
    ViewData["Title"] = "Quản lý tin tuyển dụng";
    Layout = "_LayoutAdmin";
    var currentStatus = ViewBag.Status?.ToString() ?? "";
}

<div class="max-w-7xl mx-auto px-6 py-8">
    <h1 class="text-2xl font-bold text-on-surface mb-6">Quản lý tin tuyển dụng</h1>

    @if (TempData["Success"] != null)
    {
        <div class="mb-4 px-4 py-3 bg-green-100 text-green-700 rounded-xl text-sm font-medium flex items-center gap-2">
            <span class="material-symbols-outlined text-base">check_circle</span>
            @TempData["Success"]
        </div>
    }

    <!-- Filter tabs -->
    <div class="flex flex-wrap gap-2 mb-6">
        @foreach (var tab in new[] {
            ("Tất cả", ""), ("Chờ duyệt", "Pending"), ("Đang mở", "Open"),
            ("Đã từ chối", "Rejected"), ("Đã đóng", "Closed"), ("Nháp", "Draft")
        })
        {
            var isActive = currentStatus == tab.Item2;
            var cls = isActive
                ? "bg-primary text-white border-primary"
                : "border-outline-variant text-secondary hover:bg-surface-container";
            <a asp-action="Jobs" asp-route-status="@tab.Item2"
               class="px-4 py-2 rounded-xl text-sm font-medium border transition-colors @cls">
                @tab.Item1
            </a>
        }
    </div>

    <div class="bg-white rounded-xl border border-outline-variant overflow-hidden">
        <table class="w-full text-sm">
            <thead class="bg-surface-container-low border-b border-outline-variant">
                <tr>
                    <th class="text-left px-5 py-3 font-semibold">Tiêu đề</th>
                    <th class="text-left px-5 py-3 font-semibold">Công ty</th>
                    <th class="text-left px-5 py-3 font-semibold">Trạng thái</th>
                    <th class="text-left px-5 py-3 font-semibold">Ngày đăng</th>
                    <th class="px-5 py-3 font-semibold text-center">Hành động</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-outline-variant">
                @foreach (var job in Model)
                {
                    var statusCls = job.Status switch
                    {
                        "Open" => "bg-green-100 text-green-700",
                        "Pending" => "bg-yellow-100 text-yellow-700",
                        "Rejected" => "bg-red-100 text-red-700",
                        "Closed" => "bg-gray-100 text-gray-500",
                        "Draft" => "bg-blue-100 text-blue-700",
                        _ => "bg-gray-100 text-gray-600"
                    };
                    var statusLabel = job.Status switch
                    {
                        "Open" => "Đang mở",
                        "Pending" => "Chờ duyệt",
                        "Rejected" => "Từ chối",
                        "Closed" => "Đã đóng",
                        "Draft" => "Nháp",
                        _ => job.Status
                    };

                    <tr class="hover:bg-surface-container-low transition-colors">
                        <!-- Tiêu đề -->
                        <td class="px-5 py-3 max-w-xs">
                            <a asp-controller="Job" asp-action="Detail" asp-route-id="@job.JobID"
                               class="font-medium text-on-surface hover:text-primary line-clamp-2">@job.Title</a>
                            @if (job.IsFeatured)
                            {
                                <span class="ml-1 text-xs bg-yellow-100 text-yellow-700 px-1.5 py-0.5 rounded">Nổi bật</span>
                            }
                        </td>
                        <!-- Công ty -->
                        <td class="px-5 py-3 text-secondary">@job.Employer?.CompanyName</td>
                        <!-- Trạng thái -->
                        <td class="px-5 py-3">
                            <span class="px-2.5 py-1 rounded-full text-xs font-medium @statusCls">@statusLabel</span>
                        </td>
                        <!-- Ngày đăng -->
                        <td class="px-5 py-3 text-secondary text-xs">@job.CreatedAt.ToString("dd/MM/yyyy")</td>
                        <!-- Hành động -->
                        <td class="px-5 py-3">
                            <div class="flex items-center justify-center gap-1.5 flex-wrap">

                                @* Duyệt → chỉ khi chưa Open *@
                                @if (job.Status != "Open")
                                {
                                    <form asp-action="SetJobStatus" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="jobId" value="@job.JobID" />
                                        <input type="hidden" name="status" value="Open" />
                                        <input type="hidden" name="filterStatus" value="@currentStatus" />
                                        <button type="submit"
                                                class="flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs font-medium bg-green-50 text-green-700 hover:bg-green-100 border border-green-200 transition-colors">
                                            <span class="material-symbols-outlined text-sm">check_circle</span>
                                            Duyệt
                                        </button>
                                    </form>
                                }

                                @* Từ chối → khi đang Pending hoặc Open *@
                                @if (job.Status == "Pending" || job.Status == "Open")
                                {
                                    <form asp-action="SetJobStatus" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="jobId" value="@job.JobID" />
                                        <input type="hidden" name="status" value="Rejected" />
                                        <input type="hidden" name="filterStatus" value="@currentStatus" />
                                        <button type="submit"
                                                class="flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs font-medium bg-red-50 text-red-700 hover:bg-red-100 border border-red-200 transition-colors">
                                            <span class="material-symbols-outlined text-sm">cancel</span>
                                            Từ chối
                                        </button>
                                    </form>
                                }

                                @* Đóng tin → khi đang Open *@
                                @if (job.Status == "Open")
                                {
                                    <form asp-action="SetJobStatus" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="jobId" value="@job.JobID" />
                                        <input type="hidden" name="status" value="Closed" />
                                        <input type="hidden" name="filterStatus" value="@currentStatus" />
                                        <button type="submit"
                                                class="flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs font-medium bg-gray-100 text-gray-600 hover:bg-gray-200 border border-gray-300 transition-colors">
                                            <span class="material-symbols-outlined text-sm">block</span>
                                            Đóng
                                        </button>
                                    </form>
                                }

                                @* Chờ duyệt lại → khi đang Rejected hoặc Closed *@
                                @if (job.Status == "Rejected" || job.Status == "Closed")
                                {
                                    <form asp-action="SetJobStatus" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="jobId" value="@job.JobID" />
                                        <input type="hidden" name="status" value="Pending" />
                                        <input type="hidden" name="filterStatus" value="@currentStatus" />
                                        <button type="submit"
                                                class="flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs font-medium bg-yellow-50 text-yellow-700 hover:bg-yellow-100 border border-yellow-200 transition-colors">
                                            <span class="material-symbols-outlined text-sm">restart_alt</span>
                                            Chờ duyệt
                                        </button>
                                    </form>
                                }

                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @if (ViewBag.TotalPages > 1)
    {
        <div class="flex justify-center gap-2 mt-6">
            @for (int i = 1; i <= (int)ViewBag.TotalPages; i++)
            {
                var pgCls = i == (int)(ViewBag.Page ?? 1)
                    ? "bg-primary text-white border-primary"
                    : "border-outline-variant text-secondary hover:bg-surface-container";
                <a asp-action="Jobs" asp-route-page="@i" asp-route-status="@ViewBag.Status"
                   class="w-9 h-9 flex items-center justify-center rounded-lg text-sm border @pgCls">
                    @i
                </a>
            }
        </div>
    }
</div>
