@model JobConnect.Models.Interview
@{
    ViewData["Title"] = "Lên lịch phỏng vấn";
    Layout = "_LayoutEmployer";
    var app = ViewBag.Application as Application;
}

<div class="max-w-xl mx-auto bg-white border border-outline-variant rounded-2xl p-8 shadow-sm">
    <div class="flex items-center gap-3 mb-6">
        <a asp-action="ManageApplications" asp-route-jobId="@app?.JobID" class="text-secondary hover:text-primary">
            <span class="material-symbols-outlined text-lg">arrow_back</span>
        </a>
        <h2 class="text-xl font-bold text-on-surface">Lên lịch phỏng vấn</h2>
    </div>

    <!-- Candidate Info summary -->
    <div class="bg-surface-container rounded-xl p-4 mb-6 text-sm text-on-surface">
        <p class="font-semibold text-primary mb-1">Thông tin ứng tuyển:</p>
        <p>Ứng viên: <strong class="text-slate-800">@app?.CandidateProfile?.FullName</strong></p>
        <p>Vị trí ứng tuyển: <strong class="text-slate-800">@app?.Job?.Title</strong></p>
        <p>Email: <span class="text-slate-600">@app?.CandidateProfile?.User?.Email</span></p>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="mb-4 px-4 py-3 bg-red-50 border border-red-200 text-red-800 rounded-xl text-sm">
            <div asp-validation-summary="ModelOnly" class="text-red-600 font-medium"></div>
        </div>
    }

    <form asp-action="ScheduleInterview" method="post" class="space-y-5">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="AppID" />

        <div class="grid grid-cols-2 gap-4">
            <div class="space-y-1.5">
                <label class="text-xs font-semibold text-secondary uppercase tracking-wider">Ngày phỏng vấn (dd/MM/yyyy)</label>
                <input type="text" name="dateStr" placeholder="VD: 26/06/2026" value="@(Model.InterviewDate == default ? DateTime.Now.AddDays(1).ToString("dd/MM/yyyy") : Model.InterviewDate.ToString("dd/MM/yyyy"))" class="w-full px-4 py-2.5 bg-slate-50 border border-outline-variant rounded-xl text-sm focus:border-primary focus:outline-none" required />
            </div>
            <div class="space-y-1.5">
                <label class="text-xs font-semibold text-secondary uppercase tracking-wider">Giờ phỏng vấn (HH:mm)</label>
                <input type="text" name="timeStr" placeholder="VD: 09:00" value="@(Model.InterviewDate == default ? "09:00" : Model.InterviewDate.ToString("HH:mm"))" class="w-full px-4 py-2.5 bg-slate-50 border border-outline-variant rounded-xl text-sm focus:border-primary focus:outline-none" required />
            </div>
        </div>

        <div class="space-y-1.5">
            <label asp-for="Location" class="text-xs font-semibold text-secondary uppercase tracking-wider">Địa điểm hoặc Link phỏng vấn (Zoom/Meet)</label>
            <input asp-for="Location" type="text" placeholder="VD: Phòng họp số 2 hoặc Link Google Meet..." class="w-full px-4 py-2.5 bg-slate-50 border border-outline-variant rounded-xl text-sm focus:border-primary focus:outline-none" required />
            <span asp-validation-for="Location" class="text-red-500 text-xs"></span>
        </div>

        <div class="space-y-1.5">
            <label asp-for="Notes" class="text-xs font-semibold text-secondary uppercase tracking-wider">Ghi chú / Hướng dẫn ứng viên</label>
            <textarea asp-for="Notes" rows="4" placeholder="Nhập các chuẩn bị trước khi phỏng vấn, liên hệ phòng ban..." class="w-full px-4 py-2.5 bg-slate-50 border border-outline-variant rounded-xl text-sm focus:border-primary focus:outline-none"></textarea>
            <span asp-validation-for="Notes" class="text-red-500 text-xs"></span>
        </div>

        <div class="flex items-center gap-3 pt-4 border-t border-outline-variant">
            <button type="submit" class="flex-1 py-3 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white font-semibold rounded-xl transition-all shadow-sm">
                Xác nhận mời phỏng vấn
            </button>
            <a asp-action="ManageApplications" asp-route-jobId="@app?.JobID" class="px-6 py-3 border border-outline-variant text-secondary rounded-xl hover:bg-surface-container font-semibold transition-colors text-center">
                Hủy bỏ
            </a>
        </div>
    </form>
</div>
