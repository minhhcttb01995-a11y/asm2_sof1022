@using JobConnect.Models
@model List<JobPost>
@{
    ViewData["Title"] = "Dashboard – Nhà tuyển dụng";
    Layout = "_LayoutEmployer";
}

<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />

<div class="max-w-6xl mx-auto px-6 py-8 text-slate-100">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
        <div>
            <h1 class="text-2xl font-bold tracking-tight text-white">DASHBOARD TUYỂN DỤNG</h1>
            <p class="text-slate-400 text-sm mt-1 flex items-center gap-2">
                <span class="material-symbols-outlined text-base text-indigo-400">business</span>
                @(ViewBag.Employer as Employer)?.CompanyName
            </p>
        </div>
        <a asp-action="PostJob" 
           class="px-5 py-3 bg-indigo-600 text-white font-bold rounded-xl text-sm border-2 border-black shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] transition-all flex items-center gap-2">
            <span class="material-symbols-outlined text-lg font-bold">add</span>
            ĐĂNG TIN MỚI
        </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-10">
        <div class="bg-zinc-800 border-2 border-black p-5 rounded-2xl shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] flex items-center justify-between">
            <div>
                <p class="text-xs font-bold uppercase tracking-wider text-slate-400">Tổng tin đăng</p>
                <p class="text-4xl font-extrabold text-white mt-2">@ViewBag.JobCount</p>
            </div>
            <div class="w-12 h-12 rounded-xl bg-zinc-900 border-2 border-black flex items-center justify-center">
                <span class="material-symbols-outlined text-2xl text-slate-300">layers</span>
            </div>
        </div>

        <div class="bg-sky-950/40 border-2 border-sky-400/80 p-5 rounded-2xl shadow-[4px_4px_0px_0px_rgba(0,0,0,0.5)] flex items-center justify-between">
            <div>
                <p class="text-xs font-bold uppercase tracking-wider text-sky-400">Tin đang mở</p>
                <p class="text-4xl font-extrabold text-sky-400 mt-2">@ViewBag.OpenCount</p>
            </div>
            <div class="w-12 h-12 rounded-xl bg-sky-950 border-2 border-sky-400 flex items-center justify-center">
                <span class="material-symbols-outlined text-2xl text-sky-400">workspace_premium</span>
            </div>
        </div>

        <div class="bg-zinc-800 border-2 border-black p-5 rounded-2xl shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] flex items-center justify-between">
            <div>
                <p class="text-xs font-bold uppercase tracking-wider text-slate-400">Tổng đơn ứng tuyển</p>
                <p class="text-4xl font-extrabold text-white mt-2">@ViewBag.AppCount</p>
            </div>
            <div class="w-12 h-12 rounded-xl bg-zinc-900 border-2 border-black flex items-center justify-center">
                <span class="material-symbols-outlined text-2xl text-purple-400">group</span>
            </div>
        </div>
    </div>

    <div class="bg-zinc-900 border-2 border-black rounded-2xl shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] overflow-hidden">
        <div class="bg-zinc-850 px-6 py-4 border-b-2 border-black flex items-center gap-2">
            <span class="material-symbols-outlined text-indigo-400">history</span>
            <h2 class="font-bold uppercase tracking-wide text-sm text-white">Danh sách tin tuyển dụng gần đây</h2>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-sm border-collapse">
                <thead>
                    <tr class="border-b-2 border-black bg-zinc-950/50">
                        <th class="text-left px-6 py-4 font-bold text-slate-300 uppercase tracking-wider text-xs">Tiêu đề công việc</th>
                        <th class="text-left px-6 py-4 font-bold text-slate-300 uppercase tracking-wider text-xs">Trạng thái</th>
                        <th class="text-center px-6 py-4 font-bold text-slate-300 uppercase tracking-wider text-xs">Đơn nhận</th>
                        <th class="text-left px-6 py-4 font-bold text-slate-300 uppercase tracking-wider text-xs">Hết hạn</th>
                        <th class="px-6 py-4 w-32"></th>
                    </tr>
                </thead>
                <tbody class="divide-y-2 divide-black">
                    @foreach (var job in Model)
                    {
                        <tr class="bg-zinc-900/50 hover:bg-zinc-800/40 transition-colors">
                            <td class="px-6 py-4">
                                <a asp-controller="Job" asp-action="Detail" asp-route-id="@job.JobID"
                                   class="font-bold text-slate-100 hover:text-indigo-400 text-sm block transition-colors">@job.Title</a>
                            </td>
                            <td class="px-6 py-4">
                                <span class="inline-block px-3 py-1 border-2 border-black rounded-lg text-xs font-bold uppercase tracking-wide
                                    @(job.Status == "Open" ? "bg-emerald-500 text-black" :
                                      job.Status == "Pending" ? "bg-amber-400 text-black" :
                                      job.Status == "Rejected" ? "bg-rose-500 text-black" : "bg-zinc-700 text-white")">
                                    @job.Status
                                </span>
                            </td>
                            <td class="px-6 py-4 text-center">
                                <span class="inline-block px-2.5 py-0.5 bg-zinc-800 border border-zinc-700 rounded-md font-mono text-xs font-bold text-indigo-400">
                                    @(job.Applications?.Count ?? 0)
                                </span>
                            </td>
                            <td class="px-6 py-4 text-slate-400 font-medium font-mono text-xs">
                                @(job.Deadline?.ToString("dd/MM/yyyy") ?? "–")
                            </td>
                            <td class="px-6 py-4 text-right">
                                <a asp-action="ManageApplications" asp-route-jobId="@job.JobID"
                                   class="inline-flex items-center justify-center p-2 bg-zinc-800 hover:bg-zinc-700 text-slate-200 border-2 border-black rounded-xl hover:text-white transition-all shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] active:translate-y-0.5"
                                   title="Quản lý đơn ứng tuyển">
                                    <span class="material-symbols-outlined text-sm">visibility</span>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>