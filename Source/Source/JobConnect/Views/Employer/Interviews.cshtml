@model List<JobConnect.Models.Interview>
@{
    ViewData["Title"] = "Lịch sử phỏng vấn";
    Layout = "_LayoutEmployer";
}

<div class="max-w-6xl mx-auto px-6 py-8">
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-2xl font-bold text-on-surface">Lịch sử phỏng vấn</h1>
            <p class="text-secondary text-sm">Danh sách các lịch hẹn phỏng vấn đã xếp lịch với ứng viên</p>
        </div>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="bg-white rounded-2xl p-12 text-center border border-outline-variant shadow-sm">
            <span class="material-symbols-outlined text-6xl text-secondary mb-4">event_busy</span>
            <p class="text-lg text-secondary">Chưa có lịch phỏng vấn nào được lên lịch.</p>
            <a asp-action="Dashboard" class="mt-4 inline-block px-5 py-2.5 bg-primary text-white font-semibold rounded-xl text-sm hover:bg-primary/95 transition-colors">
                Xem danh sách tin tuyển dụng
            </a>
        </div>
    }
    else
    {
        <div class="bg-white border border-outline-variant rounded-2xl overflow-hidden shadow-sm">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50 border-b border-outline-variant text-xs font-semibold text-secondary uppercase tracking-wider">
                        <th class="px-6 py-4">Ứng viên</th>
                        <th class="px-6 py-4">Vị trí ứng tuyển</th>
                        <th class="px-6 py-4">Thời gian</th>
                        <th class="px-6 py-4">Địa điểm / Hình thức</th>
                        <th class="px-6 py-4">Ghi chú</th>
                        <th class="px-6 py-4 text-right">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-outline-variant text-sm text-on-surface">
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="px-6 py-4">
                                <div class="font-semibold text-slate-800">
                                    @(item.Application?.CandidateProfile?.FullName ?? "(Không tên)")
                                </div>
                                <div class="text-xs text-secondary">
                                    @item.Application?.CandidateProfile?.User?.Email
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                <div class="font-medium text-slate-700">@item.Application?.Job?.Title</div>
                            </td>
                            <td class="px-6 py-4">
                                <div class="font-semibold text-primary">
                                    @item.InterviewDate.ToString("dd/MM/yyyy HH:mm")
                                </div>
                            </td>
                            <td class="px-6 py-4 max-w-[200px] truncate" title="@item.Location">
                                @item.Location
                            </td>
                            <td class="px-6 py-4 max-w-[200px] truncate text-secondary" title="@item.Notes">
                                @(string.IsNullOrEmpty(item.Notes) ? "-" : item.Notes)
                            </td>
                            <td class="px-6 py-4 text-right whitespace-nowrap">
                                <div class="flex items-center justify-end gap-2">
                                    <a asp-action="EditInterview" asp-route-id="@item.InterviewID"
                                       class="flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs font-medium bg-blue-50 text-blue-700 hover:bg-blue-100 border border-blue-200 transition-colors">
                                        <span class="material-symbols-outlined text-sm">edit</span>
                                        Sửa lịch
                                    </a>
                                    <form asp-action="DeleteInterview" asp-route-id="@item.InterviewID" method="post"
                                          onsubmit="return confirm('Bạn có chắc muốn hủy lịch phỏng vấn này?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs font-medium bg-red-50 text-red-700 hover:bg-red-100 border border-red-200 transition-colors">
                                            <span class="material-symbols-outlined text-sm">delete</span>
                                            Hủy lịch
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
