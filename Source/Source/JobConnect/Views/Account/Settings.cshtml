@using System.Security.Claims
@{
    ViewData["Title"] = "Cài đặt tài khoản";
    Layout = "_Layout";
}

<style>
    body {
        background-color: #000 !important;
    }

    .settings-bg {
        background: linear-gradient(135deg, #050505 0%, #0a0a0a 60%, #0f0f0f 100%);
        min-height: 100vh;
        position: relative;
        overflow: hidden;
    }

    /* Ambient glow */
    .glow-blue {
        position: absolute;
        width: 500px;
        height: 500px;
        background: radial-gradient(circle, rgba(37,99,235,0.12) 0%, transparent 70%);
        border-radius: 50%;
        pointer-events: none;
    }

    .glow-purple {
        position: absolute;
        width: 400px;
        height: 400px;
        background: radial-gradient(circle, rgba(139,92,246,0.10) 0%, transparent 70%);
        border-radius: 50%;
        pointer-events: none;
    }

    /* Rain effect */
    .rain-container {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 1;
        overflow: hidden;
    }

    .drop {
        position: absolute;
        background: linear-gradient(to bottom, rgba(59,130,246,0.5) 0%, rgba(59,130,246,0.2) 50%, rgba(59,130,246,0) 100%);
        width: 2px;
        border-radius: 0 0 3px 3px;
        animation: fall linear infinite;
    }

    @@keyframes fall {
        to {
            transform: translateY(110vh);
        }
    }

    /* Glass card */
    .glass-card {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
    }

    /* Tab pill */
    .tab-active {
        background: linear-gradient(135deg, #1d4ed8, #7c3aed);
        color: #fff;
        box-shadow: 0 4px 15px rgba(37,99,235,0.35);
    }

    .tab-inactive {
        color: rgba(255,255,255,0.45);
    }

        .tab-inactive:hover {
            color: rgba(255,255,255,0.75);
            background: rgba(255,255,255,0.05);
        }

    /* Input */
    .dark-input {
        width: 100%;
        padding: 11px 16px;
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 12px;
        color: #fff;
        font-size: 14px;
        outline: none;
        transition: all 0.2s;
    }

        .dark-input::placeholder {
            color: rgba(255,255,255,0.3);
        }

        .dark-input:focus {
            border-color: rgba(59,130,246,0.6);
            background: rgba(59,130,246,0.07);
            box-shadow: 0 0 0 3px rgba(59,130,246,0.1);
        }

        .dark-input[readonly] {
            color: rgba(255,255,255,0.35);
            cursor: not-allowed;
        }

    /* Button */
    .btn-primary {
        width: 100%;
        padding: 12px;
        background: linear-gradient(135deg, #1d4ed8 0%, #2563eb 100%);
        border: none;
        border-radius: 12px;
        color: #fff;
        font-weight: 600;
        font-size: 14px;
        cursor: pointer;
        transition: all 0.2s;
        box-shadow: 0 4px 15px rgba(37,99,235,0.35);
    }

        .btn-primary:hover {
            opacity: 0.9;
            box-shadow: 0 6px 20px rgba(37,99,235,0.5);
            transform: translateY(-1px);
        }

    .btn-danger {
        width: 100%;
        padding: 12px;
        background: linear-gradient(135deg, #dc2626, #b91c1c);
        border: none;
        border-radius: 12px;
        color: #fff;
        font-weight: 600;
        font-size: 14px;
        cursor: pointer;
        transition: all 0.2s;
        box-shadow: 0 4px 15px rgba(220,38,38,0.3);
    }

        .btn-danger:hover {
            opacity: 0.9;
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(220,38,38,0.45);
        }

    label.field-label {
        display: block;
        font-size: 13px;
        font-weight: 500;
        color: rgba(255,255,255,0.5);
        margin-bottom: 6px;
    }
</style>

<div class="settings-bg py-14 px-4">
    <!-- Ambient glows -->
    <div class="glow-blue" style="top:-100px;left:-100px;"></div>
    <div class="glow-purple" style="bottom:0;right:-80px;"></div>

    <!-- Rain -->
    <div class="rain-container" id="rain"></div>

    <div class="relative z-10 max-w-lg mx-auto">

        <!-- Header -->
        <div class="text-center mb-10">
            <div class="inline-flex w-14 h-14 rounded-2xl items-center justify-center mb-4"
                 style="background:rgba(37,99,235,0.15);border:1px solid rgba(59,130,246,0.25);">
                <span class="material-symbols-outlined text-blue-400 text-2xl">settings</span>
            </div>
            <h1 class="text-3xl font-bold text-white mb-2">Cài đặt tài khoản</h1>
            <p class="text-sm" style="color:rgba(255,255,255,0.4);">Quản lý bảo mật và thông tin đăng nhập</p>
        </div>

        @if (TempData["Success"] is string ok)
        {
            <div class="mb-5 px-4 py-3 rounded-xl text-sm flex items-center gap-2"
                 style="background:rgba(34,197,94,0.1);border:1px solid rgba(34,197,94,0.2);color:#86efac;">
                <span class="material-symbols-outlined text-sm">check_circle</span> @ok
            </div>
        }
        @if (TempData["Error"] is string err)
        {
            <div class="mb-5 px-4 py-3 rounded-xl text-sm flex items-center gap-2"
                 style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.2);color:#fca5a5;">
                <span class="material-symbols-outlined text-sm">error</span> @err
            </div>
        }

        <!-- Tabs -->
        <div class="flex gap-1 p-1 rounded-2xl mb-6 glass-card">
            <button onclick="switchTab('password')" id="tab-password"
                    class="tab-btn flex-1 py-2.5 px-3 text-sm font-medium rounded-xl transition-all tab-active">
                <span class="flex items-center justify-center gap-1.5">
                    <span class="material-symbols-outlined text-sm">lock</span>
                    <span class="hidden sm:inline">Đổi</span> mật khẩu
                </span>
            </button>
            <button onclick="switchTab('email')" id="tab-email"
                    class="tab-btn flex-1 py-2.5 px-3 text-sm font-medium rounded-xl transition-all tab-inactive">
                <span class="flex items-center justify-center gap-1.5">
                    <span class="material-symbols-outlined text-sm">mail</span>
                    <span class="hidden sm:inline">Đổi</span> email
                </span>
            </button>
            <button onclick="switchTab('danger')" id="tab-danger"
                    class="tab-btn flex-1 py-2.5 px-3 text-sm font-medium rounded-xl transition-all tab-inactive">
                <span class="flex items-center justify-center gap-1.5">
                    <span class="material-symbols-outlined text-sm">delete_forever</span>
                    Xóa TK
                </span>
            </button>
        </div>

        <!-- Panel: Đổi mật khẩu -->
        <div id="panel-password">
            <form asp-action="ChangePassword" asp-controller="Account" method="post"
                  class="glass-card rounded-2xl p-7 space-y-5">
                @Html.AntiForgeryToken()
                <div class="flex items-center gap-2 mb-1">
                    <span class="material-symbols-outlined text-blue-400 text-base">lock</span>
                    <h2 class="font-semibold text-white">Đổi mật khẩu</h2>
                </div>
                <div>
                    <label class="field-label">Mật khẩu hiện tại <span style="color:#f87171">*</span></label>
                    <input type="password" name="CurrentPassword" class="dark-input" placeholder="Nhập mật khẩu hiện tại" />
                </div>
                <div>
                    <label class="field-label">Mật khẩu mới <span style="color:#f87171">*</span></label>
                    <input type="password" name="NewPassword" class="dark-input" placeholder="Tối thiểu 8 ký tự, có chữ hoa và số" />
                </div>
                <div>
                    <label class="field-label">Xác nhận mật khẩu mới <span style="color:#f87171">*</span></label>
                    <input type="password" name="ConfirmPassword" class="dark-input" placeholder="Nhập lại mật khẩu mới" />
                </div>
                <button type="submit" class="btn-primary">Cập nhật mật khẩu</button>
            </form>
        </div>

        <!-- Panel: Đổi email -->
        <div id="panel-email" class="hidden">
            <form asp-action="ChangeEmail" asp-controller="Account" method="post"
                  class="glass-card rounded-2xl p-7 space-y-5">
                @Html.AntiForgeryToken()
                <div class="flex items-center gap-2 mb-1">
                    <span class="material-symbols-outlined text-blue-400 text-base">mail</span>
                    <h2 class="font-semibold text-white">Đổi địa chỉ Email</h2>
                </div>
                <div>
                    <label class="field-label">Email hiện tại</label>
                    <input type="email" value="@User.FindFirst(ClaimTypes.Email)?.Value" class="dark-input" readonly />
                </div>
                <div>
                    <label class="field-label">Email mới <span style="color:#f87171">*</span></label>
                    <input type="email" name="NewEmail" class="dark-input" placeholder="email-moi@example.com" />
                </div>
                <div>
                    <label class="field-label">Xác nhận bằng mật khẩu <span style="color:#f87171">*</span></label>
                    <input type="password" name="Password" class="dark-input" placeholder="Mật khẩu hiện tại" />
                </div>
                <button type="submit" class="btn-primary">Cập nhật email</button>
            </form>
        </div>

        <!-- Panel: Xóa tài khoản -->
        <div id="panel-danger" class="hidden">
            <div class="rounded-2xl p-7 space-y-5"
                 style="background:rgba(239,68,68,0.05);border:1px solid rgba(239,68,68,0.15);backdrop-filter:blur(20px);">
                <div class="flex items-start gap-3">
                    <div class="w-10 h-10 rounded-full flex items-center justify-center shrink-0"
                         style="background:rgba(239,68,68,0.15);">
                        <span class="material-symbols-outlined text-red-400">warning</span>
                    </div>
                    <div>
                        <h2 class="font-semibold" style="color:#fca5a5;">Xóa tài khoản vĩnh viễn</h2>
                        <p class="text-sm mt-1" style="color:rgba(255,255,255,0.4);">
                            Hành động này không thể hoàn tác. Tất cả dữ liệu bao gồm hồ sơ,
                            đơn ứng tuyển và CV sẽ bị xóa hoàn toàn.
                        </p>
                    </div>
                </div>
                <form asp-action="DeleteAccount" asp-controller="Account" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-4">
                        <label class="field-label">Nhập mật khẩu để xác nhận</label>
                        <input type="password" name="Password" class="dark-input"
                               style="border-color:rgba(239,68,68,0.3);"
                               placeholder="Mật khẩu của bạn" />
                    </div>
                    <button type="submit" class="btn-danger"
                            onclick="return confirm('Bạn có CHẮC CHẮN muốn xóa tài khoản? Hành động này KHÔNG THỂ hoàn tác!')">
                        Xóa tài khoản vĩnh viễn
                    </button>
                </form>
            </div>
        </div>

    </div>
</div>

<script>
    // Rain effect
    const rain = document.getElementById('rain');
    for (let i = 0; i < 30; i++) {
        const d = document.createElement('div');
        d.className = Math.random() > 0.5 ? 'drop' : 'drop';
        const h = Math.random() * 80 + 20;
        d.style.cssText = `left:${Math.random()*100}%;top:${-h}px;height:${h}px;opacity:${Math.random()*0.4+0.1};animation-duration:${Math.random()*2+1.5}s;animation-delay:${Math.random()*3}s;`;
        rain.appendChild(d);
    }

    // Tab switcher
    function switchTab(name) {
        ['password', 'email', 'danger'].forEach(t => {
            document.getElementById('panel-' + t).classList.toggle('hidden', t !== name);
            const btn = document.getElementById('tab-' + t);
            if (t === name) {
                btn.classList.add('tab-active');
                btn.classList.remove('tab-inactive');
            } else {
                btn.classList.remove('tab-active');
                btn.classList.add('tab-inactive');
            }
        });
    }
</script>
