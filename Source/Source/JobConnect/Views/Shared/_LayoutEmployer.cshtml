@using System.Security.Claims
@{
    var userName = User.FindFirst(ClaimTypes.Name)?.Value ?? "Nhà tuyển dụng";
    var currentPath = Context.Request.Path.Value ?? "";
    bool IsActive(string path) => currentPath.StartsWith(path, StringComparison.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – JobConnect NTD</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
        theme: {
        extend: {
        colors: {
        primary: '#003d9b',
        'surface-container': '#f1f5fb',
        'on-surface': '#1e293b',
        secondary: '#64748b',
        'outline-variant': '#e2e8f0',
        }
        }
        }
        }
    </script>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        body {
        font-family: 'Be Vietnam Pro', sans-serif;
        background: #f8fafc;
        }</style>
    </head>
    <body class="text-on-surface">

        <!-- Topbar -->
        <header class="fixed top-0 left-0 right-0 z-40 h-14 bg-white border-b border-outline-variant flex items-center px-4 gap-3">
            <button id="sidebarToggle" class="p-2 rounded-lg hover:bg-surface-container lg:hidden">
                <span class="material-symbols-outlined text-xl">menu</span>
            </button>
            <a asp-controller="Home" asp-action="Index"
               class="flex items-center gap-2 font-bold text-primary text-lg">
                <span class="material-symbols-outlined">work</span> JobConnect
                <span class="text-xs font-normal text-secondary bg-blue-50 px-2 py-0.5 rounded-full ml-1">NTD</span>
            </a>
            <div class="flex-1"></div>
            <div class="relative">
                <button id="userMenuBtn"
                        class="flex items-center gap-2 px-3 py-1.5 rounded-xl hover:bg-surface-container text-sm">
                    <div class="w-7 h-7 rounded-full bg-primary text-white flex items-center justify-center text-xs font-bold">
                        @(userName.Length > 0 ? userName[0].ToString().ToUpper() : "N")
                    </div>
                    <span class="hidden sm:block max-w-[140px] truncate font-medium">@userName</span>
                    <span class="material-symbols-outlined text-sm text-secondary">expand_more</span>
                </button>
                <div id="userMenuDropdown"
                     class="hidden absolute right-0 top-full mt-1 w-52 bg-white rounded-xl shadow-lg border border-outline-variant py-1 z-50">
                    <a asp-controller="Employer" asp-action="Dashboard"
                       class="flex items-center gap-2 px-4 py-2.5 text-sm hover:bg-surface-container">
                        <span class="material-symbols-outlined text-sm">dashboard</span> Dashboard
                    </a>
                    <a asp-controller="Candidate" asp-action="Profile"
                       class="flex items-center gap-2 px-4 py-2.5 text-sm hover:bg-surface-container">
                        <span class="material-symbols-outlined text-sm">person</span> Hồ sơ
                    </a>
                    <a asp-controller="Account" asp-action="Settings"
                       class="flex items-center gap-2 px-4 py-2.5 text-sm hover:bg-surface-container">
                        <span class="material-symbols-outlined text-sm">settings</span> Cài đặt
                    </a>
                    <hr class="my-1 border-outline-variant" />
                    <form asp-controller="Account" asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit"
                                class="flex items-center gap-2 px-4 py-2.5 text-sm text-red-600 hover:bg-red-50 w-full text-left">
                            <span class="material-symbols-outlined text-sm">logout</span> Đăng xuất
                        </button>
                    </form>
                </div>
            </div>
        </header>

        <div class="flex pt-14 min-h-screen">
            <aside id="sidebar"
                   class="fixed left-0 top-14 bottom-0 w-56 bg-white border-r border-outline-variant flex flex-col
                -translate-x-full lg:translate-x-0 transition-transform z-30">
                <nav class="flex-1 p-3 space-y-0.5 overflow-y-auto">
                    @{
                        var navItems = new[] {
            (Icon:"dashboard",    Label:"Dashboard",         Path:"/Employer/Dashboard"),
            (Icon:"add_circle",   Label:"Đăng tin mới",      Path:"/Employer/PostJob"),
            (Icon:"manage_search",Label:"Quản lý đơn ứng tuyển",       Path:"/Employer/ManageApplications"),
            (Icon:"event",        Label:"Lịch sử phỏng vấn",  Path:"/Employer/Interviews"),
            (Icon:"apartment",    Label:"Thông tin công ty", Path:"/Employer/CompanyProfile"),
          };
                    }
                    @foreach (var item in navItems)
                    {
                        <a href="@item.Path"
                           class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm transition-colors
                            @(IsActive(item.Path) ? "bg-blue-50 text-primary font-semibold" : "text-secondary hover:bg-surface-container hover:text-on-surface")">
                            <span class="material-symbols-outlined text-[1.1rem]">@item.Icon</span>
                            @item.Label
                        </a>
                    }
                </nav>
                <div class="p-3 border-t border-outline-variant">
                    <a asp-controller="Home" asp-action="Index"
                       class="flex items-center gap-2 px-3 py-2 text-xs text-secondary hover:text-primary">
                        <span class="material-symbols-outlined text-sm">open_in_new</span>
                        Xem trang công khai
                    </a>
                </div>
            </aside>

            <main class="flex-1 lg:ml-56 p-6">
                @if (TempData["Success"] is string ok)
                {
                    <div class="mb-4 px-4 py-3 bg-green-50 border border-green-200 text-green-800 rounded-xl text-sm">@ok</div>
                }
                @if (TempData["Error"] is string err)
                {
                    <div class="mb-4 px-4 py-3 bg-red-50 border border-red-200 text-red-800 rounded-xl text-sm">@err</div>
                }
                @RenderBody()
            </main>
        </div>

        <script src="~/js/site.js"></script>
        <script>
            document.getElementById('sidebarToggle')?.addEventListener('click', () => {
            document.getElementById('sidebar')?.classList.toggle('-translate-x-full');
            });
        </script>
        @await RenderSectionAsync("Scripts", required: false)
    </body>
</html>