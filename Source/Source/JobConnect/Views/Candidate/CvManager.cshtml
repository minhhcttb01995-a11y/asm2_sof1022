@using JobConnect.Models
@using JobConnect.Extensions
@model CandidateProfile
@{
    ViewData["Title"] = "Quản lý CV";
    Layout = "_Layout";
}

<div class="max-w-4xl mx-auto px-6 py-8 text-slate-200">
    <!-- Header -->
    <div class="flex items-center gap-3 mb-6">
        <a asp-action="Profile" class="text-slate-400 hover:text-indigo-400 transition-colors">
            <span class="material-symbols-outlined align-middle">arrow_back</span>
        </a>
        <h1 class="text-2xl font-bold text-white">Quản lý CV</h1>
    </div>

    <!-- Thông báo dạng Dark Mode -->
    @if (TempData["Success"] != null)
    {
        <div class="bg-emerald-950/40 border border-emerald-500/30 text-emerald-400 px-4 py-3 rounded-xl mb-6 flex items-center gap-2">
            <span class="material-symbols-outlined text-emerald-400">check_circle</span>
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="bg-rose-950/40 border border-rose-500/30 text-rose-400 px-4 py-3 rounded-xl mb-6 flex items-center gap-2">
            <span class="material-symbols-outlined text-rose-400">error</span>
            @TempData["Error"]
        </div>
    }

    <!-- Upload form -->
    <div class="bg-zinc-900/50 backdrop-blur-sm rounded-2xl border border-zinc-800 p-6 mb-8">
        <h2 class="font-semibold text-white mb-4 flex items-center gap-2">
            <span class="material-symbols-outlined text-indigo-400">upload_file</span>
            Tải lên CV mới
        </h2>
        <form asp-action="UploadCv" method="post" enctype="multipart/form-data" class="flex flex-col sm:flex-row gap-4">
            @Html.AntiForgeryToken()
            <div class="flex-1">
                <label class="block text-sm font-medium text-slate-300 mb-2">
                    Chọn file CV
                    <span class="text-slate-400 text-xs ml-1">(PDF hoặc DOCX, tối đa 5MB)</span>
                </label>
                <input type="file" name="cvFile" accept=".pdf,.docx" required
                       class="w-full text-sm text-slate-300 border border-zinc-700 bg-zinc-950/60 rounded-xl px-4 py-2.5
                file:mr-4 file:py-1.5 file:px-4 file:rounded-lg file:border-0
                file:bg-indigo-600 file:text-white file:font-medium hover:file:bg-indigo-500 file:transition-colors cursor-pointer" />
            </div>
            <button type="submit"
                    class="px-8 py-3 bg-indigo-600 text-white font-semibold rounded-xl hover:bg-indigo-500 shadow-lg shadow-indigo-600/20 transition-all whitespace-nowrap self-end h-[46px] flex items-center justify-center">
                Tải lên CV
            </button>
        </form>
    </div>

    <!-- Danh sách CV -->
    @if (Model?.CvFiles?.Any() == true)
    {
        <div class="space-y-4">
            @foreach (var cv in Model.CvFiles.OrderByDescending(c => c.IsDefault).ThenByDescending(c => c.UploadedAt))
            {
                <div class="bg-zinc-900/40 border border-zinc-800 p-5 rounded-2xl flex flex-col sm:flex-row sm:items-center gap-4 hover:border-zinc-700 transition-colors">
                    <!-- Icon file -->
                    <div class="w-12 h-12 rounded-xl bg-rose-950/30 border border-rose-900/40 flex items-center justify-center flex-shrink-0">
                        <span class="material-symbols-outlined text-2xl text-rose-400">
                            @(System.IO.Path.GetExtension(cv.FileName ?? "").ToLower() == ".pdf" ? "picture_as_pdf" : "description")
                        </span>
                    </div>

                    <!-- Thông tin file -->
                    <div class="flex-1 min-w-0">
                        <p class="font-medium text-slate-100 truncate">@cv.FileName</p>
                        <p class="text-xs text-slate-400 mt-1 flex items-center gap-2">
                            @if (cv.FileSize.HasValue)
                            {
                                <span>@(((double)cv.FileSize.Value / 1024).ToString("N0")) KB</span>
                            }
                            <span class="text-zinc-700">·</span>
                            <span>@cv.UploadedAt.ToString("dd/MM/yyyy HH:mm")</span>
                        </p>
                    </div>

                    <!-- Hành động -->
                    <div class="flex items-center gap-2 flex-wrap">
                        @if (cv.IsDefault)
                        {
                            <span class="inline-flex items-center px-3 py-1.5 bg-emerald-950/60 border border-emerald-500/30 text-emerald-400 rounded-xl text-xs font-medium">
                                <span class="material-symbols-outlined text-sm mr-1">check</span>
                                Mặc định
                            </span>
                        }
                        else
                        {
                            <form asp-action="SetDefaultCv" method="post" class="inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="cvId" value="@cv.CvID" />
                                <button type="submit"
                                        class="text-sm px-4 py-2 text-indigo-400 border border-indigo-500/30 rounded-xl hover:bg-indigo-600 hover:text-white transition-all">
                                    Đặt mặc định
                                </button>
                            </form>
                        }

                        <a href="@cv.FilePath" target="_blank"
                           class="flex items-center gap-1.5 text-sm text-slate-300 border border-zinc-700 bg-zinc-800/40 px-4 py-2 rounded-xl hover:bg-zinc-800 hover:text-white transition-all">
                            <span class="material-symbols-outlined text-base">download</span>
                            Tải xuống
                        </a>

                        <form asp-action="DeleteCv" method="post" class="inline"
                              onsubmit="return confirm('Bạn có chắc muốn xóa CV này?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="cvId" value="@cv.CvID" />
                            <button type="submit"
                                    class="flex items-center gap-1.5 text-sm text-rose-400 border border-rose-950 px-4 py-2 rounded-xl hover:bg-rose-950/60 transition-all">
                                <span class="material-symbols-outlined text-base">delete</span>
                                Xóa
                            </button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <!-- Giao diện trống -->
        <div class="bg-zinc-900/30 border border-zinc-800/80 rounded-2xl p-16 text-center">
            <span class="material-symbols-outlined text-6xl text-zinc-600 block mb-4">folder_open</span>
            <p class="text-lg text-slate-300 font-medium">Bạn chưa có CV nào</p>
            <p class="text-slate-500 mt-1 text-sm">Hãy tải lên CV đầu tiên của bạn để bắt đầu ứng tuyển</p>
        </div>
    }
</div>