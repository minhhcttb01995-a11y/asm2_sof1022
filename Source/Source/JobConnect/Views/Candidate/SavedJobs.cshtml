@using JobConnect.Models
@model List<SavedJob>
@{
    ViewData["Title"] = "Việc làm đã lưu";
    Layout = "_Layout";
}

<div class="max-w-4xl mx-auto px-6 py-8 text-slate-200">
    <!-- Header -->
    <div class="flex items-center gap-3 mb-6">
        <a asp-action="Profile" class="text-slate-400 hover:text-indigo-400 transition-colors">
            <span class="material-symbols-outlined align-middle">arrow_back</span>
        </a>
        <h1 class="text-2xl font-bold text-white">Việc làm đã lưu</h1>
        <span class="ml-2 bg-zinc-800 border border-zinc-700/50 text-slate-300 text-sm px-3 py-0.5 rounded-full">@Model.Count tin</span>
    </div>

    @if (!Model.Any())
    {
        <!-- Giao diện trống -->
        <div class="bg-zinc-900/30 border border-zinc-800/80 rounded-2xl p-16 text-center">
            <span class="material-symbols-outlined text-5xl text-zinc-600 block mb-3">bookmark</span>
            <p class="text-slate-400 mb-4">Bạn chưa lưu tin tuyển dụng nào.</p>
            <a asp-controller="Job" asp-action="Index"
               class="inline-block px-5 py-2.5 bg-indigo-600 text-white rounded-xl text-sm font-semibold hover:bg-indigo-500 shadow-lg shadow-indigo-600/10 transition-all">
                Khám phá việc làm
            </a>
        </div>
    }
    else
    {
        <!-- Danh sách việc làm -->
        <div class="space-y-3">
            @foreach (var saved in Model)
            {
                var job = saved.JobPost;
                <div class="bg-zinc-900/40 border border-zinc-800 p-5 rounded-xl hover:border-zinc-700 transition-all">
                    <div class="flex items-start gap-4">
                        <!-- Logo Công ty -->
                        <div class="w-12 h-12 rounded-xl border border-zinc-800 bg-zinc-950/80 flex items-center justify-center flex-shrink-0 overflow-hidden">
                            @if (!string.IsNullOrEmpty(job?.Employer?.LogoURL))
                            {
                                <img src="@job.Employer.LogoURL" class="w-full h-full object-contain" />
                            }
                            else
                            {
                                <span class="material-symbols-outlined text-slate-500">business</span>
                            }
                        </div>
                        
                        <!-- Thông tin Job -->
                        <div class="flex-1 min-w-0">
                            <div class="flex items-start justify-between gap-3">
                                <div class="min-w-0">
                                    <a asp-controller="Job" asp-action="Detail" asp-route-id="@job?.JobID"
                                       class="font-semibold text-slate-100 hover:text-indigo-400 text-sm block truncate transition-colors">@job?.Title</a>
                                    <p class="text-slate-400 text-xs mt-0.5 truncate">@job?.Employer?.CompanyName</p>
                                </div>
                                <!-- Lương (Xanh dương sáng theo phong cách các số liệu ở trang chủ) -->
                                <p class="text-sm font-bold text-sky-400 whitespace-nowrap flex-shrink-0">@job?.SalaryDisplay</p>
                            </div>
                            
                            <!-- Tags mô tả -->
                            <div class="flex flex-wrap items-center gap-2 mt-2.5">
                                @if (job?.JobType != null)
                                {
                                    <span class="text-xs bg-zinc-800 border border-zinc-700/40 px-2 py-0.5 rounded-md text-slate-300">@job.JobType</span>
                                }
                                @if (job?.Location != null)
                                {
                                    <span class="text-xs bg-zinc-800 border border-zinc-700/40 px-2 py-0.5 rounded-md text-slate-300 flex items-center gap-0.5">
                                        <span class="material-symbols-outlined text-xs">location_on</span> @job.Location
                                    </span>
                                }
                                <span class="text-xs text-slate-500 ml-auto">
                                    Đã lưu: @saved.SavedAt.ToString("dd/MM/yyyy")
                                </span>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Nút hành động -->
                    <div class="mt-4 pt-3 border-t border-zinc-800/80 flex gap-3">
                        <a asp-controller="Job" asp-action="Detail" asp-route-id="@job?.JobID"
                           class="px-4 py-1.5 bg-indigo-600 text-white text-xs font-semibold rounded-lg hover:bg-indigo-500 transition-colors">
                            Xem chi tiết
                        </a>
                        <form asp-controller="Job" asp-action="ToggleSave" method="post" class="inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="jobId" value="@job?.JobID" />
                            <button type="submit"
                                    class="px-4 py-1.5 border border-zinc-700 text-slate-300 text-xs rounded-lg bg-zinc-800/20 hover:bg-zinc-800 hover:text-white transition-all">
                                Bỏ lưu
                            </button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }
</div>